(ns mmllm.core
  "Minimal LLM playground in basilisp. PyTorch CPU/GPU.

  Hand-rolled modern decoder block with HARD-SPLIT TIERED attention
  across THREE memory tiers:

    - RMSNorm (pre-norm) + SwiGLU FFN
    - Weight-tied LM head (head reuses tok-emb.weight)
    - Q heads split by index: short heads + long heads
    - SHORT tier: RoPE'd, causal SDPA, KV grows in-RAM (recent
      working memory, single-conversation).
    - LONG tier has TWO sources, summed inside attention:
        (a) Set-style SDPA over a per-conversation long-tier KV
            cache (k-proj-l, v-proj-l). Mutable, episodic, paged
            via mmllm.longcache mmap at inference; per-instance
            (or shared per-team) for many-parallel-inference setups.
        (b) Product-key memory bank: sqrt-n² learned (key,value)
            entries retrieved by product-key search — sub-linear
            lookup regardless of N. Immutable at inference, shared
            via mmap across many parallel inference instances.

  (a) is episodic memory; (b) is semantic memory. Together with
  the short cache, you get the three classical memory tiers in one
  attention block — without a single cross-attention or RAG seam."
  (:import sys
           math
           os
           random
           time
           contextlib
           torch
           [torch.amp :as amp]
           [torch.cuda :as cuda]
           [torch.nn :as nn]
           [torch.nn.utils :as nn-utils]
           [torch.nn.functional :as F]
           [torch.optim :as optim]
           [mmllm.memory :as mem]
           [mmllm.netbank :as netb]
           [mmllm.corpus :as corp]
           [mmllm.artifacts :as art]
           [mmllm.gating :as gate]
           [mmllm.bank_query :as bq]
           [mmllm.bank_feedback :as bfb]
           [mmllm.router_smarts :as rs]
           [mmllm.sparse_per_row :as spr]
           [mmllm.fim :as fim]
           [mmllm.fim.generator :as fim-gen]
           [mmllm.metrics :as metrics]
           [mmllm.runtime :as rt]
           [mmllm.attention_kernel :as kernel]
           [mmllm.spec_decode :as spec]
           [mmllm.optim :as vbopt]
           [mmllm.evals :as ev]
           [mmllm.datasets :as ds]))

(defn- mps-available? []
  (try
    (and (hasattr torch/backends "mps")
         (.is_available (.- torch/backends mps)))
    (catch python/Exception _ false)))

(defn- sync-device!
  "Block until pending GPU work finishes — needed before timing on
   accelerator backends (cuda, mps) since their submissions are
   asynchronous. No-op on cpu."
  [device]
  (cond
    (= device "cuda") (cuda/synchronize)
    (= device "mps")  (try (.synchronize (.- torch mps))
                           (catch python/Exception _ nil))
    :else             nil))

(defn pick-device
  "Resolve the active torch device. Reads MMLLM_DEVICE — one of
   cpu / cuda / mps / auto (default auto).

     'auto' prefers cuda → mps → cpu in that order
     'mps'  is Apple Silicon's Metal Performance Shaders backend
            (M-series SoC GPU); requires torch with MPS support and
            macOS. Bank V stays on CPU mmap (Int8/PKM cross-device
            gather pattern handles the MPS↔CPU hop per query).
     'cuda' is NVIDIA GPU
     'cpu'  is the always-available fallback"
  []
  (let [req (.get (.- os environ) "MMLLM_DEVICE" "auto")]
    (cond
      (= req "cpu")  "cpu"
      (= req "cuda") (if (cuda/is_available) "cuda"
                         (do (println "WARN: MMLLM_DEVICE=cuda but cuda not available — falling back to cpu")
                             "cpu"))
      (= req "mps")  (if (mps-available?) "mps"
                         (do (println "WARN: MMLLM_DEVICE=mps but MPS not available — falling back to cpu")
                             "cpu"))
      :else          (cond
                       (cuda/is_available) "cuda"
                       (mps-available?)    "mps"
                       :else               "cpu"))))

(defn setup-threads!
  "Tune intra-op + inter-op CPU thread counts for the active process.
   Reads MMLLM_NUM_THREADS (default = os.cpu_count()). Sets:
     - torch.set_num_threads        (matmul / SDPA workers)
     - torch.set_num_interop_threads (graph-level parallelism, max 1/4 of intra)
     - OMP_NUM_THREADS, MKL_NUM_THREADS, MKL_DYNAMIC=FALSE, OMP_DYNAMIC=FALSE
       (so BLAS / OpenMP backends honor the choice)
   Idempotent. No-op effect on CUDA hot path; meaningful win on CPU
   inference where intra-op threads drive matmul throughput.

   Phase-1b of the inference optimization plan."
  []
  (let [n      (python/int (.get (.- os environ) "MMLLM_NUM_THREADS"
                                 (str (or (os/cpu_count) 4))))
        interop (max 1 (quot n 4))]
    (torch/set_num_threads n)
    (torch/set_num_interop_threads interop)
    (.__setitem__ (.- os environ) "OMP_NUM_THREADS"  (str n))
    (.__setitem__ (.- os environ) "MKL_NUM_THREADS"  (str n))
    (.__setitem__ (.- os environ) "OMP_DYNAMIC"      "FALSE")
    (.__setitem__ (.- os environ) "MKL_DYNAMIC"      "FALSE")
    {:n-threads n :n-interop interop}))

(defn pick-lr
  "Resolve learning rate. Reads MMLLM_LR (float string,
   default 3e-3). The unified peak lr; per-component multipliers
   (`pick-lr-dense-mult` / `pick-lr-bank-mult`) decouple dense
   (router) and bank (semantic content) update intensities."
  []
  (python/float (.get (.- os environ) "MMLLM_LR" "3e-3")))

(defn- mult-cosine-interp
  "Cosine-interpolate between `start` and `end` over (warmup, total]
   training. Inside the warmup window, return `start`. After total,
   return `end`. Used by the *_mult-at-step schedule resolvers below
   to ramp/cool LR multipliers across a run."
  [start end step total warmup]
  (cond
    (= start end)  start
    (zero? total)  start
    (< step warmup) start
    (>= step total) end
    :else (let [progress (/ (python/float (- step warmup))
                            (python/float (- total warmup)))
                cos-half (* 0.5 (+ 1.0 (math/cos (* (.- math pi) progress))))]
            (+ end (* (- start end) cos-half)))))

(defn pick-lr-dense-mult
  "Multiplier on the dense-side (AdamW) lr. Reads
   MMLLM_LR_DENSE_MULT (float, default 1.0). Combined with
   `pick-lr` to produce the AdamW peak lr. See
   `docs/router-bank-lr-decoupling.md` for the differential-decay
   schedule (cool the dense / router lr after ~9-12B tokens while
   the bank / expert lr stays at 1.0×).

   Arity 2 — `(step total)` — returns the cosine-scheduled value
   between MMLLM_LR_DENSE_MULT and MMLLM_LR_DENSE_MULT_END (defaults
   to start if unset, i.e. constant). Warmup re-uses MMLLM_LR_WARMUP."
  ([] (python/float (.get (.- os environ) "MMLLM_LR_DENSE_MULT" "1.0")))
  ([step total]
   (let [start  (pick-lr-dense-mult)
         end    (python/float (.get (.- os environ) "MMLLM_LR_DENSE_MULT_END" (str start)))
         ;; pick-lr-warmup defined later in this file; inline the env
         ;; read to keep forward references out of the analyzer's path.
         warmup (python/int (.get (.- os environ) "MMLLM_LR_WARMUP" "0"))]
     (mult-cosine-interp start end step total warmup))))

(defn pick-lr-bank-mult
  "Multiplier on the bank-side (SparseAdam) lr. Reads
   MMLLM_LR_BANK_MULT (float, default 1.0). Combined with
   `pick-lr` to produce the SparseAdam peak lr. Cooled only at the
   very end of training (15B+ in the v3 plan; near 100B in an
   extended run).

   Arity 2 — `(step total)` — returns the cosine-scheduled value
   between MMLLM_LR_BANK_MULT and MMLLM_LR_BANK_MULT_END. T1
   consolidation: set END < START (e.g. 10 → 1) so Local Bank's lr
   cools as training progresses, freeing NetBank to keep absorbing
   while Local stops chasing new patterns."
  ([] (python/float (.get (.- os environ) "MMLLM_LR_BANK_MULT" "1.0")))
  ([step total]
   (let [start  (pick-lr-bank-mult)
         end    (python/float (.get (.- os environ) "MMLLM_LR_BANK_MULT_END" (str start)))
         ;; pick-lr-warmup defined later in this file; inline the env
         ;; read to keep forward references out of the analyzer's path.
         warmup (python/int (.get (.- os environ) "MMLLM_LR_WARMUP" "0"))]
     (mult-cosine-interp start end step total warmup))))

(defn pick-lr-dense
  "Effective dense (AdamW) peak lr = pick-lr × pick-lr-dense-mult."
  []
  (* (pick-lr) (pick-lr-dense-mult)))

(defn pick-lr-bank
  "Effective bank (SparseAdam) peak lr = pick-lr × pick-lr-bank-mult."
  []
  (* (pick-lr) (pick-lr-bank-mult)))

;;; ─────────────────────── NetBank (off-machine long-term memory tier) ───────────────────────

(defn pick-netbank-enabled?
  "Whether the NetBank tier is active for this run. Reads
   MMLLM_NETBANK_ENABLED (default 'false'). When false the model is
   strictly two-tier (SDPA + Local Bank) and existing ckpts load
   identically to pre-NetBank code."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_NETBANK_ENABLED" "false"))]
    (.__contains__ #{"1" "true" "yes"} v)))

(defn pick-netbank-sqrt-n
  "Side length of NetBank (entries = sqrt_n²). Reads MMLLM_NET_SQRT_N
   (default 8192 → 67M entries). Independent of Local Bank's sqrt_n."
  []
  (python/int (.get (.- os environ) "MMLLM_NET_SQRT_N" "8192")))

(defn pick-netbank-c-net
  "Bottleneck dim of NetBank V (rows stored as c_net latents, expanded
   to q_dim by a learned Linear). Reads MMLLM_NET_C_NET (default 64)."
  []
  (python/int (.get (.- os environ) "MMLLM_NET_C_NET" "64")))

(defn pick-netbank-top-k
  "Rows retrieved per NetBank query (larger payload amortizes the
   simulated round-trip). Reads MMLLM_NET_TOP_K (default 64)."
  []
  (python/int (.get (.- os environ) "MMLLM_NET_TOP_K" "64")))

(defn pick-netbank-sub-top-k
  "Sub-keys retained per K_a/K_b half before re-rank. Reads
   MMLLM_NET_SUB_TOP_K (default 64). Capped to sqrt_n inside NetBank."
  []
  (python/int (.get (.- os environ) "MMLLM_NET_SUB_TOP_K" "64")))

(defn pick-local-bank-layers
  "Set of transformer-layer indices that get a Local Bank attached.
   Other layers run with `:memory = None` and the long-tier mix degrades
   to 2-way (sdpa + Net) at those layers.

   Reads MMLLM_LOCAL_BANK_LAYERS as a comma-separated int list. If unset,
   falls back to the config's :local-bank-layers. If neither is provided,
   defaults to ALL layers (preserves pre-asymmetric behavior).

   Usage examples:
     MMLLM_LOCAL_BANK_LAYERS=\"0,1,2,12,20,29,30,31\"   ; 8 of 32 layers
     MMLLM_LOCAL_BANK_LAYERS=\"\"                       ; no Local anywhere"
  [config]
  (let [raw     (.get (.- os environ) "MMLLM_LOCAL_BANK_LAYERS")
        ;; Treat empty string / whitespace-only the same as unset.
        ;; GitHub Actions' workflow env passthrough sets the var to ""
        ;; when the corresponding input is blank, so without this guard
        ;; an empty input → empty layer set → no Local Bank anywhere →
        ;; sparse-parameters returns [] → optimizer construction errors
        ;; with "got an empty parameter list".
        env-val (when (and raw (not (zero? (count (.strip raw))))) raw)]
    (cond
      env-val
      (python/set (filter #(not (nil? %))
                          (map (fn [s] (try (python/int (.strip s))
                                            (catch python/Exception _ nil)))
                               (.split env-val ","))))
      (:local-bank-layers config)
      (python/set (:local-bank-layers config))
      :else
      ;; Default: all n-layers (backward-compatible with pre-asymmetric).
      (python/set (range (:n-layers config))))))

(defn pick-memory-top-k
  "Final retrieved entries per query from the Local bank. Reads
   MMLLM_MEMORY_TOP_K if set; otherwise falls back to the value
   passed in (typically the config's :memory-top-k).

   At larger sqrt_n the default top_k under-samples V — at sqrt_n=720
   with top_k=16, each query touches only 0.003% of V rows; the bank
   can't populate. Scale top_k with sqrt_n to keep per-row touch rate
   comparable across bank sizes."
  [config-default]
  (let [env-val (.get (.- os environ) "MMLLM_MEMORY_TOP_K")]
    (if env-val (python/int env-val) config-default)))

(defn pick-n-trunks
  "Number of Local Bank trunks for shared-trunk multi-stream training.
   Reads MMLLM_N_TRUNKS (default 1 = single trunk, legacy behavior).

   When > 1, every block's Local Bank V_local is sized (N*sqrt_n², q_dim)
   and per-batch-row trunk_ids route each row to its own V_local slice.
   Dense weights, K_a/K_b, and NetBank stay shared across trunks — the
   bank values are the only thing that specializes per trunk. The training
   batch is built as N×B_per_trunk content-sharded windows, with trunk_ids
   = [0]*B_per_trunk ++ [1]*B_per_trunk ++ … so each trunk hill-climbs on
   a disjoint slice of the corpus while the shared trunk averages dense
   gradients across all N sources."
  []
  (python/int (.get (.- os environ) "MMLLM_N_TRUNKS" "1")))

(defn pick-memory-sub-top-k
  "Sub-keys retained per K_a/K_b half in product-key search of the Local
   bank. Reads MMLLM_MEMORY_SUB_TOP_K if set; otherwise the config default."
  [config-default]
  (let [env-val (.get (.- os environ) "MMLLM_MEMORY_SUB_TOP_K")]
    (if env-val (python/int env-val) config-default)))

(defn pick-netbank-delay-min
  "Minimum simulated WAN delay per NetBank forward, in milliseconds.
   Reads MMLLM_NET_DELAY_MS_MIN (default 1.0). Set both min and max
   to 0 to disable the delay."
  []
  (python/float (.get (.- os environ) "MMLLM_NET_DELAY_MS_MIN" "1.0")))

(defn pick-netbank-delay-max
  "Maximum simulated WAN delay per NetBank forward, in milliseconds.
   Reads MMLLM_NET_DELAY_MS_MAX (default 10.0)."
  []
  (python/float (.get (.- os environ) "MMLLM_NET_DELAY_MS_MAX" "10.0")))

(defn pick-netbank-dtype
  "NetBank V dtype. Reads MMLLM_NET_DTYPE (default 'fp32'). fp16
   available but causes SparseAdam underflow/overflow on small models;
   use fp32 until we ship a mixed-precision optimizer."
  []
  (.lower (.get (.- os environ) "MMLLM_NET_DTYPE" "fp32")))

(defn pick-netbank-on-gpu?
  "Whether NetBank V lives in GPU VRAM (training-fast) vs host-RAM mmap
   (production-realism). Reads MMLLM_NET_BANK_ON_GPU (default 'false').
   On GPU: no FUSE / mmap latency, just the simulated 1-10ms delay.
   At sqrt_n=4096 + c_net=64 + fp32 = 21.5 GB on top of Local's 18.8 GB,
   fits H100 80GB with ~40GB headroom for activations."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_NET_BANK_ON_GPU" "false"))]
    (.__contains__ #{"1" "true" "yes"} v)))

(defn pick-netbank-path
  "Per-layer mmap path prefix for NetBank V. Reads MMLLM_NET_BANK_PATH;
   if unset, derive from <bank>+'-net' so a `--bank /data/foo` flow
   gets `/data/foo-net.<i>.bin`. Empty string or nil bank-path → returns
   nil (NetBank V uses an in-RAM nn.Embedding, not mmap)."
  [bank-path]
  (or (.get (.- os environ) "MMLLM_NET_BANK_PATH")
      (when (and bank-path (not (zero? (count bank-path))))
        (str bank-path "-net"))))

(defn pick-netbank-shared?
  "SPIKE 3 — MMLLM_NETBANK_SHARED — when 'true', all 32 blocks share a
   single NetBank V tensor (and expander) via weight-tying after
   construction. Each block keeps its own K_a / K_b (so per-layer
   queries each have their own retrieval geometry) but reads/writes
   the SAME V table.

   Rationale: the current per-layer NetBank has 32 separate V tensors
   each receiving gradient only from its own layer's queries. With
   8 of 32 layers having a Local target, 24 V tensors get no
   distillation signal and only train from main loss. Sharing V means
   gradients accumulate from all 32 layers per step — a 32× boost in
   gradient signal per row — and the 'single NB' framing of the
   triune-brain doc maps cleanly to the implementation.

   Reads MMLLM_NETBANK_SHARED (default 'false')."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_NETBANK_SHARED" "false"))]
    (.__contains__ #{"1" "true" "yes"} v)))

(defn pick-lr-kab-mult
  "Multiplier on K_a/K_b's lr (the bank's 'addressing' weights). Reads
   MMLLM_LR_KAB_MULT (default = MMLLM_LR_DENSE_MULT, i.e. K_a/K_b live
   in the same group as core dense and use lr_dense_mult). When set
   to a different value, build-time `make-opt-dense` puts K_a/K_b in a
   separate AdamW param group with its own lr × kab-mult.

   Rationale (#3 spike): K_a/K_b learn the bank's structural addressing
   (when to retrieve which slot). V learns content. Decoupling the two
   lets K-side hill-climb structure faster than V's slower content
   updates. Standard PKM tip.

   Arity 2 — `(step total)` — cosine-scheduled to MMLLM_LR_KAB_MULT_END."
  ([] (python/float (.get (.- os environ) "MMLLM_LR_KAB_MULT"
                          (str (pick-lr-dense-mult)))))
  ([step total]
   (let [start  (pick-lr-kab-mult)
         end    (python/float (.get (.- os environ) "MMLLM_LR_KAB_MULT_END" (str start)))
         warmup (python/int (.get (.- os environ) "MMLLM_LR_WARMUP" "0"))]
     (mult-cosine-interp start end step total warmup))))

(defn pick-lr-kab
  "Effective K_a/K_b lr = pick-lr × pick-lr-kab-mult."
  []
  (* (pick-lr) (pick-lr-kab-mult)))

(defn pick-lr-net-mult
  "Multiplier on NetBank's SparseAdam lr. Reads MMLLM_LR_NET_MULT
   (default 1.0). Default Phase-4 schedule: 5.0 (half of Local Bank's
   10.0). Cooled later in the curriculum like Local but on a separate
   schedule.

   Arity 2 — `(step total)` — returns the cosine-scheduled value
   between MMLLM_LR_NET_MULT and MMLLM_LR_NET_MULT_END. T1 plan: set
   END > START (e.g. 5 → 10) so NetBank's lr ramps UP as Local cools,
   absorbing the relative training pressure as Local consolidates."
  ([] (python/float (.get (.- os environ) "MMLLM_LR_NET_MULT" "1.0")))
  ([step total]
   (let [start  (pick-lr-net-mult)
         end    (python/float (.get (.- os environ) "MMLLM_LR_NET_MULT_END" (str start)))
         ;; pick-lr-warmup defined later in this file; inline the env
         ;; read to keep forward references out of the analyzer's path.
         warmup (python/int (.get (.- os environ) "MMLLM_LR_WARMUP" "0"))]
     (mult-cosine-interp start end step total warmup))))

(defn pick-lr-net
  "Effective NetBank (SparseAdam) peak lr = pick-lr × pick-lr-net-mult."
  []
  (* (pick-lr) (pick-lr-net-mult)))

(defn pick-batch
  "Resolve training batch size. Reads MMLLM_BATCH (int string,
   default 4). Bigger batch = smoother gradients + better GPU
   utilization, but linear scaling on cross-device bank gather."
  []
  (python/int (.get (.- os environ) "MMLLM_BATCH" "4")))

(defn pick-sqrt-n
  "Resolve memory bank's sqrt_n (i.e. side length of the bank;
   total entries = sqrt_n²). Reads MMLLM_SQRT_N if set,
   otherwise falls back to (:memory-sqrt-n config). Used to
   override bank size at runtime without editing config."
  [config]
  (let [env-val (.get (.- os environ) "MMLLM_SQRT_N")]
    (if env-val
      (python/int env-val)
      (:memory-sqrt-n config))))

(defn pick-sparse-optimizer
  "Return the class to use for the bank's optimizer.

   MMLLM_SPARSE_OPT (preferred — explicit choice):
     'adam'     → torch.optim.SparseAdam (default)
     'adam-cpu' → mmllm.optim.CPUOffloadSparseAdam
                  (touched-row-sparse m/v on host RAM; required at N>1
                  to avoid the dense state allocation)
     'sgd'      → mmllm.optim.CPUSparseSGD
                  (no m/v state at all; smallest possible — useful when
                  even the touched-row-sparse Adam state hits the
                  per-trunk ceiling on a small box. Noisier dynamics.)

   MMLLM_CPU_OFFLOAD=true is the legacy knob for 'adam-cpu'; respected
   when MMLLM_SPARSE_OPT is unset, so the previous behavior is preserved."
  []
  (let [explicit (.lower (.get (.- os environ) "MMLLM_SPARSE_OPT" ""))]
    (cond
      (= explicit "sgd")      vbopt/CPUSparseSGD
      (= explicit "adam-cpu") vbopt/CPUOffloadSparseAdam
      (= explicit "adam")     optim/SparseAdam
      :else
      ;; Legacy: MMLLM_CPU_OFFLOAD=true → CPUOffloadSparseAdam.
      (if (= "true" (.lower (.get (.- os environ) "MMLLM_CPU_OFFLOAD" "false")))
        vbopt/CPUOffloadSparseAdam
        optim/SparseAdam))))

(defn pick-lr-warmup
  "Resolve linear warmup steps. Reads MMLLM_LR_WARMUP (default 0
   = no schedule; constant lr throughout). Standard 1000 for our
   305k-step 5B run is ~0.3% of training, plenty for warm bring-up."
  []
  (python/int (.get (.- os environ) "MMLLM_LR_WARMUP" "0")))

(defn pick-lr-min
  "Resolve cosine-decay floor lr. Reads MMLLM_LR_MIN (default
   = MMLLM_LR / 10, i.e. 10% of peak). Only used when warmup > 0."
  []
  (let [env-val (.get (.- os environ) "MMLLM_LR_MIN")]
    (if env-val
      (python/float env-val)
      (* 0.1 (pick-lr)))))

(defn lr-at-step
  "Linear warmup + cosine decay. Returns the lr to use at step s.
   When warmup == 0 returns max-lr (constant — backward compat).

   Schedule shape (relative to MMLLM_LR_ROUND_BASE, default 0):
     round_base ≤ s < warmup : linearly ramp floor → max-lr
     warmup     ≤ s < total  : cosine decay max-lr → min-lr
     s ≥ total               : min-lr (defensive; loop should have exited)

   MMLLM_LR_ROUND_BASE: absolute step at which the current chain round
   started. Subtracted from `s` and `warmup` before the ramp math so
   each round gets a fresh linear warmup over its first
   (warmup - round_base) steps. Without this, resuming from step N ≫ 0
   makes `s/warmup` ≈ 1.0 on every step and the ramp is degenerate.
   Default 0 = legacy behavior (ramp uses absolute step).

   MMLLM_LR_RAMP_FLOOR: fraction of max-lr to use as the minimum of
   the linear-warmup ramp (default 0.0 = ramp from zero, the textbook
   transformer warmup). 0.1 means step 0 of a round starts at 10% of
   peak — useful for very short chain rounds where a from-zero ramp
   wastes the first step entirely."
  [s total max-lr warmup min-lr]
  (let [round-base (python/int
                     (.get (.- os environ) "MMLLM_LR_ROUND_BASE" "0"))
        floor      (try (python/float
                          (.get (.- os environ) "MMLLM_LR_RAMP_FLOOR" "0.0"))
                        (catch python/ValueError _ 0.0))
        s-eff      (max 0 (- s round-base))
        warmup-eff (max 0 (- warmup round-base))]
    (cond
      (zero? warmup-eff) max-lr
      (< s-eff warmup-eff) (let [progress (/ (python/float s-eff)
                                             (python/float warmup-eff))]
                             (* max-lr (max floor progress)))
      (>= s total) min-lr
      :else (let [progress (/ (python/float (- s warmup))
                              (python/float (- total warmup)))
                  cos-half (* 0.5 (+ 1.0 (math/cos (* (.- math pi) progress))))]
              (+ min-lr (* (- max-lr min-lr) cos-half))))))

(defn set-opt-lr!
  "Mutate every param group of `opt` to have lr=`lr`. Used inside
   the train loop to apply lr-at-step results.

   torch.optim.Optimizer.param_groups is a list of plain Python
   dicts (not attribute-objects), so we use __setitem__ rather than
   setattr."
  [opt lr]
  (doseq [pg (.- opt param_groups)]
    (.__setitem__ pg "lr" lr)))

(defn set-opt-lrs!
  "Set lr per param group. `lrs` is a list of floats, one per group
   (in declaration order). Used when the optimizer has multiple groups
   with independent schedules (e.g. core dense + K_a/K_b)."
  [opt lrs]
  (let [pgs (python/list (.- opt param_groups))]
    (doseq [i (range (count pgs))]
      (when (< i (count lrs))
        (.__setitem__ (.__getitem__ pgs i) "lr" (nth lrs i))))))

(defn pick-sync-every
  "Resolve cross-worker bank sync interval, in training steps.
   Reads MMLLM_SYNC_EVERY (int, default 0 = sync disabled).

   When > 0 and a Modal Volume is reachable, every N steps the
   training loop calls (mem/sync_banks layers volume), which:
     1. commits dirty bank pages to the volume,
     2. reloads to pull other workers' commits,
     3. remaps each layer's mmap so V.weight sees the fresh content.

   Recommended values: 50-500 for multi-trainer Hogwild on Modal
   Volumes. Lower → tighter cross-worker coupling but more
   commit/reload overhead. 0 → single-worker training, no sync."
  []
  (python/int (.get (.- os environ) "MMLLM_SYNC_EVERY" "0")))

(defn pick-volume-name
  "Modal volume name for cross-worker bank sync.
   Reads MMLLM_VOLUME_NAME (default 'mmllm-data')."
  []
  (.get (.- os environ) "MMLLM_VOLUME_NAME" "mmllm-data"))

(defn pick-ablate-every
  "Resolve interval (in training steps) between intermediate ablation
   evals — temporarily zero V across all blocks, eval bpc, restore V.
   Reads MMLLM_ABLATE_EVERY (default 0 = disabled).

   Each ablation eval costs one extra eval-bpc pass (~30-60s wall on
   prod hardware) plus a transient ~bank-size CPU/GPU clone for the
   restore. Bank V is mutated in-place during the eval and restored
   in a try/finally — safe across crashes only at process boundary.

   Useful values: equal to ckpt-every (one Δ datapoint per ckpt) so
   the trajectory aligns with the checkpoint history. 0 disables."
  []
  (python/int (.get (.- os environ) "MMLLM_ABLATE_EVERY" "0")))

(defn pick-slot-log-every
  "Resolve interval (in training steps) between PKM slot-utilization
   logs + optional dead-slot reinit. Reads MMLLM_SLOT_LOG_EVERY
   (default 0 = disabled).

   Each event reads each PKM layer's hit counters, logs entropy /
   dead-count to log.jsonl, then resets counters. If
   MMLLM_DEAD_SLOT_REINIT=true is also set, dead rows (hits=0 over
   the window) are re-initialized with small Gaussian noise.

   Recommended: equal to ckpt-every (one slot snapshot per ckpt).
   0 disables."
  []
  (python/int (.get (.- os environ) "MMLLM_SLOT_LOG_EVERY" "0")))

(defn pick-dead-slot-reinit?
  "Reads MMLLM_DEAD_SLOT_REINIT (default 'false'). When true, the
   slot-log event also calls reinit_dead_slots() on each PKM layer
   to redistribute capacity to never-selected rows."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_DEAD_SLOT_REINIT" "false"))]
    (.__contains__ #{"1" "true" "yes"} v)))

(defn pick-max-hours
  "Resolve session wall-time cap, in hours. Reads MMLLM_MAX_HOURS
   (float, default 0 = no cap). When > 0, train-long checkpoints
   and exits cleanly after this many hours, even if total-steps
   isn't reached.

   Use case: budget-bounded slow-walk training. Each Modal session
   costs $/hr × hours; setting MMLLM_MAX_HOURS=8 makes a session
   self-terminate at the budget boundary instead of running out mid-
   step. train-long auto-resumes from the latest ckpt next session,
   so this is purely a clean-shutdown convenience."
  []
  (python/float (.get (.- os environ) "MMLLM_MAX_HOURS" "0")))

(defn pick-max-steps
  "Resolve hard step cap. Reads MMLLM_MAX_STEPS (int, default 0 = no cap).
   When > 0, train-long checkpoints and exits cleanly at step == max-steps,
   even if total-steps is higher.

   Use case: build a base ckpt at a known step (e.g. step 70 of a 100-step
   recipe) for sweep iteration on later-stage knobs. Total-steps remains
   the schedule's reference point (so LR/distill cosines evaluate as if
   the full run will continue), but execution halts at max-steps and saves
   a resumable ckpt. Subsequent runs resume from that ckpt with overrides
   on the back-half knobs only."
  []
  (python/int (.get (.- os environ) "MMLLM_MAX_STEPS" "0")))

(defn pick-ablation-quick?
  "Bundle env for fast ablation. Reads MMLLM_ABLATION_QUICK
   (default 'false'). When true, implies:
     - MMLLM_ABLATION_SKIP_LOCAL=true  (skip the Δ_local pass; report ~0)
     - MMLLM_ABLATION_SKIP_BOTH=true   (synthesize Δ_both from parts)
     - MMLLM_ABLATION_EVAL_CAP=2500    (10× smaller token budget)
   Net effect: 1 ctrl pass + 1 Δ_net pass at 2500 tokens each ≈ 5%
   of the default eval-phase wall. Trade-off: Δ_net noise floor goes
   from ~0.002 bpc → ~0.02 bpc. Use for bite-size dev rounds where
   recognizing the recipe works is the goal; keep false for the
   final production round of a chain extension where the published
   Δ_net trend across rounds needs precision."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_ABLATION_QUICK" "false"))]
    (.__contains__ #{"1" "true" "yes"} v)))

(defn pick-ablation-eval-cap
  "Token-cap used by ablation-step! / -net! / -both! eval-bpc passes.
   Reads MMLLM_ABLATION_EVAL_CAP (int, default arg). Used to trade
   off ablation precision for wall time — at cpu-mini scale where
   Δ_net is +0.17 (well above noise), a 25k cap measures the Δ
   accurately in ~25% the time of the 100k default. When
   MMLLM_ABLATION_QUICK=true, the cap drops to 2500 (one batch of
   2-3 windows) — Δ_net noise rises from ~0.002 bpc to ~0.02 bpc,
   acceptable for bite-size dev iterations."
  ([] (pick-ablation-eval-cap 100000))
  ([default-cap]
   (let [env-cap (.get (.- os environ) "MMLLM_ABLATION_EVAL_CAP" nil)
         quick?  (pick-ablation-quick?)]
     (cond
       (some? env-cap) (python/int env-cap)
       quick?          2500
       :else           (python/int default-cap)))))

(defn pick-ablation-skip-local?
  "Whether to skip the Δ_local ablation pass and report Δ_local ≈ 0
   without measuring. Reads MMLLM_ABLATION_SKIP_LOCAL (default
   'false'); also implied by MMLLM_ABLATION_QUICK=true.

   Right after a chain-extension round starts, V_local is reset to
   fresh Gaussian (extend_chain.sh re-initializes it). The 20- to
   100-step training schedule in a chain round doesn't move V_local
   enough to register a meaningful Δ_local — measured 0.0000 at
   round-11. Skipping the pass saves 25% of eval wall."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_ABLATION_SKIP_LOCAL" "false"))]
    (or (pick-ablation-quick?)
        (.__contains__ #{"1" "true" "yes"} v))))

(defn pick-ablation-skip-both?
  "Whether to skip the Δ_both ablation pass (zeroing BOTH banks) and
   synthesize Δ_both from Δ_local + Δ_net by assuming zero synergy.
   Reads MMLLM_ABLATION_SKIP_BOTH (default 'false');
   also implied by MMLLM_ABLATION_QUICK=true.

   The fourth ablation pass at end-of-training costs ~25% of total
   eval wall (each pass is one full eval-bpc over the ablation token
   cap, 4 passes = ctrl + Δ_local + Δ_net + Δ_both). Skipping it
   saves that quarter at the cost of losing the synergy measurement
   — which on cpu-mini × wave-2 has been near zero across measured
   rounds (round-11 verified: Δ_both=Δ_local+Δ_net, synergy=+0.0000).

   When true, the printed Δ_both line shows '(synthesized)' so
   operators know it's a sum, not a direct measurement. Use for
   bite-size dev iterations; keep false for the final round of a
   chain extension if synergy is being tracked."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_ABLATION_SKIP_BOTH" "false"))]
    (or (pick-ablation-quick?)
        (.__contains__ #{"1" "true" "yes"} v))))

(defn pick-long-tier-mix
  "Resolve how the long-tier KV-cache SDPA path and the bank-V
   retrieval path get combined inside attention. Reads
   MMLLM_LONG_TIER_MIX (default 'sum'). One of:
     'sum'    — attn_l = sdpa + mem (no learned gate; baseline)
     'scalar' — α[h], β[h] trainable per long head; init 1, 1
     'switch' — sigmoid(Q · w_h) gates a convex mix; init 0.5/0.5
   See `mmllm.gating` for the implementation."
  []
  (.get (.- os environ) "MMLLM_LONG_TIER_MIX" "sum"))

(defn pick-bank-query-mode
  "Resolve how the bank query is shaped before the product-key search.
   Reads MMLLM_BANK_QUERY_MODE (default 'plain'). One of:
     'plain'   — bank_query = q_long_flat (no context modulation)
     'ctx-add' — bank_query = q_long_flat + W_ctx · x  (learned dense
                 weights influence the query; W_ctx zero-init at step 0
                 → identical to plain, then grows useful modulation)
   See `mmllm.bank_query` for the implementation."
  []
  (.get (.- os environ) "MMLLM_BANK_QUERY_MODE" "plain"))

(defn pick-bank-feedback-mode
  "Resolve whether the bank's output is fed back into x before q-proj.
   Reads MMLLM_BANK_FEEDBACK_MODE (default 'plain'). One of:
     'plain'    — no feedback (q = q_proj(x))
     'feedback' — q = q_proj(x + W_back · bank(W_probe · x)); W_back is
                  zero-init so step-0 behavior is identical to plain.
                  Adds one extra PKM lookup per layer per forward.
   See `mmllm.bank_feedback` for the implementation."
  []
  (.get (.- os environ) "MMLLM_BANK_FEEDBACK_MODE" "plain"))

(defn pick-max-t
  "Resolve the pre-allocated KV cache buffer length (max sequence
   length the cache will hold). Reads MMLLM_MAX_T (default 4096).

   Phase-1c of the inference optimization plan: rather than
   rebuilding the cache via torch.cat on every token (O(T²) memory
   traffic across a generation), pre-allocate a (B, n_kv, MAX_T,
   head_dim) buffer once and write each token into its slot.

   Bound on generation length per conversation. Larger = higher
   one-time RAM cost for the buffer; smaller = sooner we hit the
   ceiling on long generations."
  []
  (python/int (.get (.- os environ) "MMLLM_MAX_T" "4096")))

(defn- pick-window
  "Resolve a sliding-window size from env. Returns int or nil."
  [env-key]
  (let [val (.get (.- os environ) env-key)]
    (when val
      (let [n (python/int val)]
        (when (pos? n) n)))))

(defn pick-short-window
  "Resolve short-tier sliding-window size. Reads MMLLM_SHORT_WINDOW
   (int, default unset = unbounded)."
  []
  (pick-window "MMLLM_SHORT_WINDOW"))

(defn pick-long-window
  "Resolve long-tier in-RAM sliding-window size. Reads MMLLM_LONG_WINDOW
   (int, default unset = unbounded)."
  []
  (pick-window "MMLLM_LONG_WINDOW"))

(defn- get-modal-volume
  "Return a modal.Volume reference for the named volume, or nil
   if modal isn't installed or the lookup fails. Lazily imported
   so non-Modal users (local dev, tests) don't need modal in their
   environment."
  [name]
  (try
    (let [modal (python/__import__ "modal")]
      (.from_name (.- modal Volume) name))
    (catch python/ImportError _
      (println (format "  WARN: modal not installed; volume features (bank sync + ckpt commits) disabled."))
      nil)
    (catch python/Exception e
      (println (format "  WARN: modal.Volume.from_name(\"%s\") failed: %s — volume features (bank sync + ckpt commits) disabled."
                       name e))
      nil)))

(def ^:private LN2 0.6931471805599453)

;;; ─────────────────────── byte tokenizer ───────────────────────

(def vocab-size 256)

(defn encode
  "string → 1-D LongTensor of UTF-8 byte codepoints."
  [s]
  (torch/tensor (python/list (.encode s "utf-8"))
                ** :dtype torch/long))

(defn decode
  "1-D int tensor → string. Replaces invalid UTF-8 sequences."
  [t]
  (.decode (python/bytes (.tolist t))
           "utf-8" ** :errors "replace"))

;;; ─────────────────────── configs ───────────────────────

(def default-config
  "Short-leaning (5/7) — ~10 M dense params + ~1 GB mmap bank.

   Dense: d-model=384 across 5 layers. Per block ≈ 1.97 M
   (q/k/v/o + SwiGLU(384→1408→384) + 2 RMSNorm + K_a/K_b);
   tok-emb 256×384 + final RMSNorm. 5 × 1.97 M + 0.1 M ≈ 10.0 M.

   Bank: GQA 5:1 in the short tier (5 short Q-heads → 1 short
   KV-head), leaving 7 long heads. q-dim into the bank is
   7 × 32 = 224 fp32 per slot. Per-layer V is sqrt-n² × q-dim × 4
   = 512² × 224 × 4 ≈ 234 MB; 5 layers ≈ 1.17 GB. Pass
   :memory-mmap-path (or use the train-mmap CLI verb) to back V
   on disk — sparse-grad means only touched rows page in/out."
  {:d-model            384
   :n-heads            12        ; total Q heads = n-short-heads + n-long-heads
   :n-short-heads      5
   :n-long-heads       7
   :n-short-kv-heads   1         ; GQA 5:1 within short tier
   :n-long-kv-heads    1         ; MQA 7:1 within long tier — minimal K/V proj cost
   :n-layers           5
   :seq-len            128       ; training window
   :max-pos            1024      ; RoPE cache size
   :d-ff               1408
   :rope-theta         10000.0
   ;; Long heads have TWO sources at attention time, summed:
   ;;  (1) SDPA over the per-conversation long-tier K/V cache
   ;;      (set-style attention; populated from k-proj-l/v-proj-l;
   ;;      grows unbounded — paged via mmllm.longcache mmap at inference).
   ;;  (2) Product-key retrieval from the learned bank V (below).
   ;; (1) handles per-conversation episodic context. (2) handles
   ;; cross-corpus learned semantic memory. Two independent pathways.
   ;; Product-key memory bank (per-block, learned semantic memory)
   :memory-sqrt-n      512       ; sqrt of bank entries; bank holds sqrt-n^2 = 262 144
   :memory-top-k       16        ; final retrieved entries per query
   :memory-sub-top-k   32        ; sub-keys per half kept before re-rank
   :memory-mmap-path   nil       ; if set, V.weight is mmap-backed at <path>.<i>.bin
   :bank-query-mode    nil       ; nil → fall back to MMLLM_BANK_QUERY_MODE env (default 'plain');
                                  ; 'plain' / 'ctx-add' — see mmllm.bank_query
   :bank-feedback-mode nil       ; nil → fall back to MMLLM_BANK_FEEDBACK_MODE env (default 'plain');
                                  ; 'plain' / 'feedback' — see mmllm.bank_feedback
   :long-tier-mix      nil       ; nil → fall back to MMLLM_LONG_TIER_MIX env (default 'sum');
                                  ; 'sum' / 'scalar' / 'switch' — see mmllm.gating
   ;; Sliding-window eviction. nil = unbounded (cache grows linearly with
   ;; conversation length — fine for training where T is fixed, a memory
   ;; leak at inference). Set to an integer to keep only the last W tokens
   ;; in each respective KV cache. Training is a no-op when T < window.
   ;;   short-window: hard cutoff on the RoPE'd short cache.
   ;;     RoPE preserves relative position under eviction (q·k depends on
   ;;     i - j, both still rotated correctly), so eviction is safe.
   ;;   long-window:  cutoff on the in-RAM long cache. The longcache.py
   ;;     paged-LRU mmap layer (not yet wired into forward) is a separate
   ;;     larger working set behind this — long-window is the IN-RAM
   ;;     ceiling, longcache is the on-disk extension.
   :short-window       nil
   :long-window        nil})

(def long-leaning-config
  "Long-leaning (2/10): 10 of 12 heads route through the memory bank.
   q-dim = 10 × 32 = 320 → bank ≈ 1.68 GB across 5 layers."
  (assoc default-config
         :n-short-heads     2
         :n-long-heads      10
         :n-short-kv-heads  1))

(def default-config-cpu-tiny
  "CPU-trainable tiny config for community fan-out training.

   Targets a ~16 GB RAM box with a few GB of disk: Local Bank fits in
   RAM (~200 MB V + 200 MB optimizer state); NetBank is mmap'd to disk
   so only touched rows page in. Dense trunk is ~5-8 M params.

   Sizing math (per-layer):
     q-dim       = 4 long heads × 32 head-dim = 128
     Local V     = 256² × 128 × 4 ≈ 33.5 MB / layer × 4 = 134 MB
     Local opt   = same shape    ≈ 134 MB
     NetBank V   = 1024² × 32 × 4 ≈ 128 MB / layer × 4 = 512 MB on disk
     dense       = ~6 M params × 4 × 3 (Adam state) = ~72 MB

   Total RAM: ~500-700 MB steady state.
   Total disk: ~600 MB (NetBank V mmap files).

   Use with the `train-cpu` CLI verb (preserves all 9 spike knobs;
   defaults conservative)."
  {:d-model            192
   :n-heads            6
   :n-short-heads      2
   :n-long-heads       4
   :n-short-kv-heads   1
   :n-long-kv-heads    1
   :n-layers           32
   ;; Asymmetric bank distribution: NetBank at every layer (32 total),
   ;; Local Bank only at a subset for capability/cost balance. Positions
   ;; chosen: first-3 (raw signal in, fastest plastic), last-3 (output
   ;; refinement, where wide context resolves), and 2 spaced through
   ;; the middle (cross-domain handoff). Override via env:
   ;;   MMLLM_LOCAL_BANK_LAYERS="0,1,2,12,20,29,30,31"
   :local-bank-layers  [0 1 2 12 20 29 30 31]
   :seq-len            128
   :max-pos            512
   :d-ff               768
   :rope-theta         10000.0
   :memory-sqrt-n      256
   :memory-top-k       16
   :memory-sub-top-k   16
   :memory-mmap-path   nil
   :bank-query-mode    nil
   :bank-feedback-mode nil
   :long-tier-mix      nil
   :short-window       nil
   :long-window        nil})

(def default-config-cpu-mini
  "Mini-trunk variant of cpu-tiny: same 32-layer asymmetric Local/Net
   architecture, but with the dense backbone shrunk ~10× to test
   whether a smaller trunk forces the bank tier to actually get adopted.

   Sizing math:
     d-model = 32, d-ff = 128, head-dim = 8
     n-heads = 4 = 2 short + 2 long
     q-dim   = 2 long heads × 8 head-dim = 16 (vs cpu-tiny's 128 — 8× smaller)

   Per-block dense:
     Q + O proj          : 32² × 2 = 2,048
     K_s + V_s + K_l + V_l (head_dim=8 each): 32 × 8 × 4 = 1,024
     FFN (gate + up + down at d_ff=128)     : 32 × 128 × 3 = 12,288
     norms + small heads                    : ~200
                                              ─────────
     per-block                                ≈ 15.5 k
   × 32 blocks                               ≈ 500 k dense params
   = ~2 MB at fp32 (vs cpu-tiny's ~17.5 M ≈ 70 MB — 35× reduction)

   The asymmetric Local-Bank layer set is unchanged so existing trunks
   and the chain runner still slot in cleanly. The bank-side shape (V
   per row × q-dim) shrinks proportionally with q-dim: V_local per
   layer × trunk at sqrt_n=226 is 226² × 16 × 4 = 3.3 MB (vs 26 MB at
   cpu-tiny's q-dim=128)."
  {:d-model            32
   ;; n-heads = 4 (split 2 short + 2 long) at head-dim=8. The original
   ;; cpu-mini layout (commit 0530af6). DON'T reshuffle this without
   ;; resetting the chain — head_dim governs K/V proj shape via
   ;; (d_model × n_kv_heads × head_dim), and saved dense.pt checkpoints
   ;; have head_dim=8-shaped K/V tensors. Reshuffling to head_dim=4 or 2
   ;; broke 240/618 dense params on resume in commits 414ea97 / 7e45963
   ;; (caught 2026-05-15; reverted here). The "wider routing" argument
   ;; for reshuffling was wrong — bandwidth lives in TOP_K env vars,
   ;; not in n_heads geometry. q-dim = n-long-heads × head-dim = 2 × 8 = 16.
   :n-heads            4
   :n-short-heads      2
   :n-long-heads       2
   :n-short-kv-heads   1
   :n-long-kv-heads    1
   :n-layers           32
   :local-bank-layers  [0 1 2 12 20 29 30 31]
   ;; seq-len 1024 = 8× original 128, supports realistic conversation /
   ;; document training contexts. max-pos 8192 = 16× original 512, giving
   ;; ample RoPE cache for inference prompts up to 8K tokens. Compute is
   ;; O(seq-len²) in attention so per-step wall scales 64× from the
   ;; original 128 — counterbalanced by batch=16 increasing tokens/step.
   :seq-len            1024
   :max-pos            8192
   :d-ff               128
   ;; rope-theta = 500000 (was 10000). Llama 3's base-training choice.
   ;; Larger theta makes the high-freq RoPE dims have longer periods,
   ;; so the model trained at this base can later extend to long
   ;; context (128K-1M) via continued pretraining without YARN-style
   ;; rescaling. Short-context performance is unchanged at this value
   ;; (Llama 3 demonstrated). One-line prep for the 1M-context goal.
   :rope-theta         500000.0
   :memory-sqrt-n      256
   ;; Retrieval bandwidth defaults (extend_chain.sh env vars override
   ;; these to 128/128/512/64 for production chain training). Widened
   ;; so per-query info pulled from each tier matches bank capacity at
   ;; design size. Local: 128 × q_dim(16) = 2048 fp32 per query. Net
   ;; defaults stay smaller here since the config-only path uses smaller
   ;; banks; production chain uses MMLLM_NET_TOP_K=512.
   :memory-top-k       128
   :memory-sub-top-k   128
   :memory-mmap-path   nil
   :bank-query-mode    nil
   :bank-feedback-mode nil
   :long-tier-mix      nil
   :short-window       nil
   :long-window        nil})

;;; ─────────────────────── RoPE (used only on the short tier) ───────────────────────

(defn build-rope-cache
  "Precompute (cos, sin) tensors for max-seq-len positions.
   Returns [cos sin] each of shape (max-seq-len, head-dim)."
  [max-seq-len head-dim theta]
  (let [idx        (torch/arange 0 head-dim 2 ** :dtype torch/float32)
        log-theta  (.log (torch/tensor (python/float theta)))
        inv-freq   (.exp (.mul (.div (.neg idx) (python/float head-dim))
                               log-theta))
        positions  (torch/arange max-seq-len ** :dtype torch/float32)
        freqs      (.outer positions inv-freq)
        cos-half   (.cos freqs)
        sin-half   (.sin freqs)
        cos        (torch/cat (python/list [cos-half cos-half]) ** :dim -1)
        sin        (torch/cat (python/list [sin-half sin-half]) ** :dim -1)]
    [cos sin]))

(defn- rotate-half [x]
  (let [last-dim (- (.dim x) 1)
        half     (quot (.size x last-dim) 2)
        x1       (.narrow x last-dim 0 half)
        x2       (.narrow x last-dim half half)]
    (torch/cat (python/list [(.neg x2) x1]) ** :dim -1)))

(defn apply-rope
  "Rotate x by RoPE. x: (..., T, head-dim); cos, sin: (T, head-dim)."
  [x cos sin]
  (torch/add (torch/mul x cos)
             (torch/mul (rotate-half x) sin)))

;;; ─────────────────────── attention (delegates to Python kernel) ───────────────────────
;;;
;;; Phase-1a fix: the hot per-token tensor flow lives in
;;; `mmllm.attention_kernel` (pure Python, native tuples for caches)
;;; so torch.compile / Dynamo can trace it cleanly. basilisp here just
;;; destructures the block once per call and forwards positionally.
;;;
;;; Cache representation: Python tuple `(k-buf, v-buf, pos)`. basilisp
;;; `nth` works on tuples, so callers (`forward`, `sample`, tests)
;;; still read elements via `(nth cache 2)` etc. without changes.

(defn attention
  "Thin shim — destructure the block dict once and call the Python
   `attention_kernel.attention`. See `mmllm.attention_kernel` for the
   per-token tensor flow.

     short-cache, long-cache: None or (k-buf, v-buf, pos) Python tuple
   Returns (out, new-short-cache, new-long-cache) Python tuple."
  [block x cos sin short-cache long-cache]
  (let [{:keys [q-proj k-proj-s v-proj-s k-proj-l v-proj-l o-proj memory
                long-gate bank-query bank-feedback
                n-heads n-short-heads n-long-heads
                n-short-kv-heads n-long-kv-heads head-dim max-t
                short-window long-window]} block]
    (kernel/attention
      q-proj k-proj-s v-proj-s k-proj-l v-proj-l o-proj
      memory long-gate bank-query bank-feedback
      n-heads n-short-heads n-long-heads
      n-short-kv-heads n-long-kv-heads head-dim max-t
      short-window long-window
      x cos sin short-cache long-cache)))

;;; ─────────────────────── router smarts (focal CE + importance head + carry) ───────────────────────

(defn pick-focal-gamma
  "Focal-loss gamma exponent. Reads MMLLM_FOCAL_GAMMA (default 0.0 =
   plain CE). 2.0 is the standard focal default (Lin et al 2017): hard
   bytes get up-weighted via (1-p)^2, easy bytes get down-weighted.
   Cheap (~+1% per-step compute). 0 disables → reduces to flat CE."
  []
  (python/float (.get (.- os environ) "MMLLM_FOCAL_GAMMA" "0.0")))

(defn pick-importance-head?
  "Whether to construct & use the LearnedImportanceHead. Reads
   MMLLM_IMPORTANCE_HEAD (default 'false'). When true, a Linear(d_model,
   1) head produces a per-position multiplier on top of focal CE.
   Self-supervised. Adds 1 dense param tensor per model."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_IMPORTANCE_HEAD" "false"))]
    (.__contains__ #{"1" "true" "yes"} v)))

(defn pick-nan-guard?
  "Whether forward should NaN-check at every block boundary +
   logits. Reads MMLLM_NAN_GUARD (default 'false'). Opt-in because
   the .isnan().any() call adds a sync per layer (~1% throughput
   hit). On detection: raises RuntimeError with the specific layer
   index that first produced NaN, instead of the unhelpful
   `loss=nan` abort that says nothing about WHERE the NaN started."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_NAN_GUARD" "false"))]
    (.__contains__ #{"1" "true" "yes"} v)))

(defn pick-grad-checkpoint?
  "Whether `forward` should wrap each block in
   torch.utils.checkpoint.checkpoint. Reads MMLLM_GRAD_CHECKPOINT
   (default 'false').

   When true and grad is enabled, each block's intermediates
   (NetBank latent, Local-PKM combined_scores, SDPA scratch, …)
   are dropped after the block returns and recomputed during
   backward. Trades ~30% wall time for ~16-32× lower peak RAM:
   the 32 layers' activation snapshot is replaced by 32 small
   per-block input tensors plus one block's intermediates live
   at a time during backward.

   Required for wave-2's NET_TOP_K=512 / MEMORY_SUB_TOP_K=128
   recipe to fit on common containers — without checkpointing
   the activation snapshot is ~36 GB at effective batch 16 and
   ~576 GB at the wave-2 default effective batch of 256.

   Skipped at eval (no grad → no backward → nothing to save)."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_GRAD_CHECKPOINT" "false"))]
    (.__contains__ #{"1" "true" "yes"} v)))

(defn nan-guard!
  "Check tensor for NaN/Inf and raise with `tag` on detection. No-op
   when t is None (e.g., aux-logits in non-MTP mode). Caller decides
   whether to call (gated by `pick-nan-guard?`).

   On detection: also prints a tensor stats summary (NaN count, Inf
   count, finite-min/max, mean of finite entries) so the caller has
   localized info about how bad the corruption is. This is purely
   diagnostic; total tensor scan adds <1ms even for the largest
   tensor in the model."
  [tag t]
  (when t
    (let [has-nan (.item (.any (.isnan t)))
          has-inf (.item (.any (.isinf t)))]
      (when (or has-nan has-inf)
        (let [n-nan    (.item (.sum (.isnan t)))
              n-inf    (.item (.sum (.isinf t)))
              numel    (.numel t)
              finite-mask (torch/isfinite t)
              n-finite (.item (.sum finite-mask))
              finite-stats (if (pos? n-finite)
                             (let [t-finite (.masked_select t finite-mask)]
                               (format "finite[min=%.3e max=%.3e mean=%.3e]"
                                       (.item (.amin t-finite))
                                       (.item (.amax t-finite))
                                       (.item (.mean t-finite))))
                             "no finite entries")]
          (println (format "  ⚠ nan-guard FIRED: tag=%s numel=%d nan=%d inf=%d %s"
                           tag numel n-nan n-inf finite-stats))
          (throw (python/RuntimeError
                   (format "nan-guard: tensor %s has NaN/Inf — forward path corrupted" tag))))))))

(defn pick-log-param-norms?
  "Whether to log per-param L∞/L2 norms at slot-log events. Reads
   MMLLM_LOG_PARAM_NORMS (default 'false'). Opt-in because the walk
   over all named tensors adds a sync at log-time. Useful for
   identifying slow drift in any specific param tensor."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_LOG_PARAM_NORMS" "false"))]
    (.__contains__ #{"1" "true" "yes"} v)))

(defn pick-replay-every
  "Run a frozen-Local replay step every N training steps. Reads
   MMLLM_REPLAY_EVERY (default 0 = disabled). When > 0, train-long
   maintains a CPU-side circular buffer of (x, y) batches whose
   plain-CE was below MMLLM_REPLAY_THRESHOLD (mastered positions),
   and every N main steps samples one batch and runs an extra
   train-step with Local Bank's gradients zeroed before the
   optimizer step. Goal: Net trains directly on patterns Local
   already mastered, accelerating consolidation."
  []
  (python/int (.get (.- os environ) "MMLLM_REPLAY_EVERY" "0")))

(defn pick-replay-buffer-size
  "Maximum number of (x, y) batches kept in the replay buffer.
   Reads MMLLM_REPLAY_BUFFER_SIZE (default 256). Each batch is on
   CPU; at B=128 T=128 int64 that's ~2 MB per batch, ~512 MB total
   for 256 — fits comfortably in CPU host RAM."
  []
  (python/int (.get (.- os environ) "MMLLM_REPLAY_BUFFER_SIZE" "256")))

(defn pick-replay-threshold
  "Plain-CE threshold below which a training batch is considered
   'mastered' and pushed to the replay buffer. Reads
   MMLLM_REPLAY_THRESHOLD (default 0.5). Lower = more selective; the
   buffer fills with only the most-confidently-predicted batches."
  []
  (python/float (.get (.- os environ) "MMLLM_REPLAY_THRESHOLD" "0.5")))

(defn freeze-local-grads!
  "Zero out the gradient on every Local Bank parameter (K_a, K_b,
   q_norm, V) across all blocks. Used during a replay step to keep
   Local Bank frozen while NetBank, dense projections, and the carry
   update from the replay batch's gradient. Safe to call after
   .backward() and before opt.step() — zeroed gradients become no-ops
   in the optimizer step."
  [m]
  (doseq [b (:blocks m)]
    (when-let [mem (:memory b)]
      (doseq [p (python/list (.parameters mem))]
        (when-let [g (.- p grad)]
          (.zero_ g))))))

(defn pick-distill-coef
  "Coefficient on the Net→Local distillation aux loss.

   Arity 0 — returns the start (or constant) value. Reads
   MMLLM_DISTILL_COEF (default 0.0 = disabled).

   Arity 2 — `(step total)` — returns the cosine-scheduled value
   between MMLLM_DISTILL_COEF and MMLLM_DISTILL_COEF_END.

   Why schedule: with target=residual at init Local≈0, so target ≈
   −sdpa. Plastic Net + constant coef=1.0 from step 1 drives Net
   into an anti-sdpa basin (round-9 redo: ctrl_bpc spiked 0.30→1.06
   at step 500 from destructive interference). Distill should only
   fire once Local has actually accumulated content — set
   MMLLM_DISTILL_COEF=0 and MMLLM_DISTILL_COEF_END=1.0 so distill
   ramps up over the run, mirroring the LR_NET cosine.

   When > 0, train-step walks every 3-way SwitchGate, pulls
   last_net_out and the residual/local target, and adds
   `coef · MSE(net_out, target.detach())` averaged across blocks
   to the backward loss."
  ([] (python/float (.get (.- os environ) "MMLLM_DISTILL_COEF" "0.0")))
  ([step total]
   (let [start  (pick-distill-coef)
         end    (python/float (.get (.- os environ) "MMLLM_DISTILL_COEF_END" (str start)))
         warmup (python/int (.get (.- os environ) "MMLLM_LR_WARMUP" "0"))]
     (mult-cosine-interp start end step total warmup))))

(defn pick-alpha-net-enabled?
  "Whether to attach a per-layer learnable alpha_net scalar (per long
   head) on each SwitchGate's Net-output path. Compensates for the
   c_net=64 bottleneck + expander-init magnitude loss that leaves Net's
   contribution small in absolute terms despite high gate weight. Init
   = 1.0 (identity); learns to amplify Net's effective contribution.
   Reads MMLLM_ALPHA_NET (default 'false' for back-compat). Stored as
   block.long-gate.alpha_net so position-aligned ckpt-load doesn't
   shift; included in (parameters m) at the END for the same reason."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_ALPHA_NET" "false"))]
    (.__contains__ #{"1" "true" "yes"} v)))

(defn pick-gate-net-default?
  "Whether SwitchGate uses Net-default + straight-through Bernoulli-gated
   Local. Reads MMLLM_GATE_NET_DEFAULT (default 'false').

   When true, the block builder attaches two params to each SwitchGate
   after construction (same alignment-safe pattern as alpha_net):

     local_active_proj: (n_long_heads, head_dim)  — zero init
     local_active_bias: (n_long_heads,)           — init -2.0

   At each forward, the gate computes per-(B,H,T) Bernoulli decisions
   on whether Local fires for that query. Net and sdpa always run.
   Local only contributes when the Bernoulli sample is 1 (training:
   stochastic; inference: deterministic threshold at 0.5). The surviving
   gate weights are renormalized so they sum to 1.

   Initial firing rate sigmoid(-2.0) ≈ 12% — Net is the default; Local
   is on-demand. Gradient flows through the straight-through trick
   (forward = hard 0/1, backward = sigmoid grad).

   Position-aligned ckpt-load: the new params surface at the END of
   (parameters m) via local-gate-params, so old ckpts (round-2..7)
   load cleanly into a Net-default-enabled model."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_GATE_NET_DEFAULT" "false"))]
    (.__contains__ #{"1" "true" "yes"} v)))

(defn pick-distill-direction-only?
  "When true, distillation MSE is computed on UNIT-NORMALIZED Net &
   Local outputs — Net learns Local's direction, not magnitude. Avoids
   the failure mode where Net minimizes MSE by shrinking its output to
   match Local's, leaving the gate routing to a tiny-magnitude tier
   that contributes little. Reads MMLLM_DISTILL_DIRECTION_ONLY (default
   'false' — preserves existing magnitude-aware MSE)."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_DISTILL_DIRECTION_ONLY" "false"))]
    (.__contains__ #{"1" "true" "yes"} v)))

(defn pick-distill-target
  "What Net's distill MSE targets. Reads MMLLM_DISTILL_TARGET — one of
   'local' or 'residual' (default 'residual').

   'local'    — target = local_out.detach(). Net mimics Local's full
                output. Round-5/8/9 pathology: when Local's output is
                mostly sdpa+ε, Net learns sdpa, becomes Local's twin,
                Δ_net collapses to noise.

   'residual' — target = (local_out - sdpa_out).detach(). Net learns
                Local's UNIQUE contribution beyond sdpa, not Local's
                full output. The shared sdpa floor is subtracted out
                so Net can't twin Local by replicating sdpa. This is
                Worker 2's diagnosis from the round-9 reports — the
                round-10 architectural fix."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_DISTILL_TARGET" "residual"))]
    (if (.__contains__ #{"residual" "local"} v) v "residual")))

(defn pick-distill-mode
  "MMLLM_DISTILL_MODE — distillation aggregation mode.

   'per-layer' (default): per-block 1:1 distill. Each block's Net output
                          is distilled toward that block's own Local
                          output. Only fires at the 8 Local-bank layers;
                          the 24 Net-only layers receive zero distill
                          pressure.

   'aggregate-local' (SPIKE 1): collect the 8 Local outputs (across the
                          layers where Local Bank exists), aggregate via
                          element-wise mean into one (B, H, T, head_dim)
                          target tensor, and distill ALL 32 Net layers
                          against that aggregate. Gives the 24 Net-only
                          layers a target instead of zero pressure.
                          Mutually exclusive with gate-weights /
                          gate-indices (those are per-layer concepts).

   Why aggregate exists: at 32 layers the per-layer 1:1 distill leaves
   24/32 Net banks with no consolidation target, which Agent 2's analysis
   correlates with Δ_net stuck near 0 across the post-LR=1e-1 chain. The
   aggregate variant is the spike for 'one shared NetBank tier sees the
   Local tier as a unified signal.'"
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_DISTILL_MODE" "per-layer"))]
    (if (.__contains__ #{"per-layer" "aggregate-local"} v) v "per-layer")))

(defn pick-distill-magnitude-coef
  "Weight on the magnitude component of distill (default 0.0).

   When MMLLM_DISTILL_DIRECTION_ONLY=true and this coef is 0, the loss
   is pure direction-match (round-9 v3 behavior): Net rotates its V to
   point in the target's direction but ||V|| barely moves. That's the
   stability fix but it broke the consolidation transfer — Net can be
   perfectly direction-aligned with Local's residual and still
   contribute essentially zero to the gate-mixed output because its
   magnitude is too small.

   Setting magnitude-coef > 0 adds a parallel MSE term on the raw
   magnitudes (per-position L2 norm), so Net's V grows toward the
   target's magnitude *as well as* its direction. Use with
   MMLLM_DISTILL_MAGNITUDE_CLAMP to bound the target magnitude — that
   prevents the round-9 v2 explosion mode where unbounded residual
   pulled Net's V into instability.

   Composite loss when direction-only + magnitude-coef > 0:
     loss = (1-mag_coef) * MSE(net/||net||, tgt/||tgt||)
          +    mag_coef  * MSE(||net||, clamp(||tgt||, max=clamp))

   Arity 0 — returns the start (or constant) value. Reads
   MMLLM_DISTILL_MAGNITUDE_COEF (default 0.0).

   Arity 2 — `(step total)` — cosine-scheduled between
   MMLLM_DISTILL_MAGNITUDE_COEF and MMLLM_DISTILL_MAGNITUDE_COEF_END.
   Lets the loss shape itself transition smoothly from pure-direction
   (early) to magnitude-aware (late), mirroring the wake/sleep LR
   schedule: during wake direction-only keeps Net's V bounded while
   Local accumulates, during sleep the magnitude term opens up so
   Net's V can grow to carry Local's contribution scale."
  ([] (python/float (.get (.- os environ) "MMLLM_DISTILL_MAGNITUDE_COEF" "0.0")))
  ([step total]
   (let [start  (pick-distill-magnitude-coef)
         end    (python/float (.get (.- os environ)
                                     "MMLLM_DISTILL_MAGNITUDE_COEF_END"
                                     (str start)))
         warmup (python/int (.get (.- os environ) "MMLLM_LR_WARMUP" "0"))]
     (mult-cosine-interp start end step total warmup))))

(defn pick-distill-magnitude-clamp
  "Upper bound on per-position target L2 norm used by the magnitude
   term of the distill loss. Prevents Net's V from being pulled toward
   an unbounded residual magnitude (the round-9 v2 explosion mode).

   Reads MMLLM_DISTILL_MAGNITUDE_CLAMP (default 0.0 = no clamp)."
  []
  (python/float (.get (.- os environ) "MMLLM_DISTILL_MAGNITUDE_CLAMP" "0.0")))

(defn collect-distill-loss
  "Walk every 3-way SwitchGate in the model, pull last_local_out,
   last_net_out, (and last_sdpa_out when target='residual'), compute
   mean(MSE(net, target.detach())) across blocks, scaled by coef.
   Returns 0.0 when coef=0 OR when no SwitchGate has stashed outputs
   yet (e.g. NetBank disabled, 2-way mode, or first forward not done).

   Target is set by MMLLM_DISTILL_TARGET ∈ {'local', 'residual'}.
   See pick-distill-target for the per-mode behavior.

   When MMLLM_DISTILL_DIRECTION_ONLY=true, both target and net are
   RMS-normalized before MSE — Net learns the target's direction only.
   Stacks with target-mode (direction of the residual is still the
   direction Local adds beyond sdpa).

   Coefficient is cosine-scheduled when train-long has stashed
   current_step + total_steps in (:metrics m). Otherwise falls back
   to the constant MMLLM_DISTILL_COEF. Schedule reason: at init Local≈0
   so target ≈ −sdpa; with a flat coef Net is driven into an anti-sdpa
   basin within hundreds of steps. The ramp lets distill stay near-off
   while Local accumulates, then engage in the back half."
  [m]
  (let [metrics (:metrics m)
        step    (when metrics (.get metrics "current_step" nil))
        total   (when metrics (.get metrics "total_steps"  nil))
        coef    (if (and step total (pos? total))
                  (pick-distill-coef (python/int step) (python/int total))
                  (pick-distill-coef))
        dir-only (pick-distill-direction-only?)
        target-kind (pick-distill-target)
        mag-coef    (pick-distill-magnitude-coef)
        mag-clamp   (pick-distill-magnitude-clamp)
        ;; Per-layer distill gating (set by probe-distill-gate! at the
        ;; Local→Net handoff). Two forms:
        ;;   gate-weights : {block_idx → float}  continuous weighting.
        ;;     Each block's distill MSE is multiplied by its weight before
        ;;     averaging. Weights normalized so mean=1 — preserves the
        ;;     global MMLLM_DISTILL_COEF magnitude.
        ;;   gate-indices : set of block indices  binary include/exclude.
        ;;     Used as fallback when weights aren't set.
        ;; Both nil = no gating (default).
        gate-weights (when metrics (.get metrics "distill_gate_weights" nil))
        gate         (when (and metrics (nil? gate-weights))
                       (.get metrics "distill_gate_indices" nil))
        eps      1e-6
        mode     (pick-distill-mode)]
    (cond
      (zero? coef) 0.0

      ;; SPIKE 1 — aggregate-local mode.
      ;;
      ;; Collect last_local_out from every block that has a Local Bank
      ;; (typically 8 of 32 in cpu-tiny / cpu-mini asymmetric layout).
      ;; Stack to (n_local, B, H, T, D), mean over n_local to get a single
      ;; (B, H, T, D) target. In residual mode, do the same aggregation on
      ;; the matched last_sdpa_out so the residual subtracts mean(sdpa) at
      ;; the SAME 8 layers (mean(lo - so) = mean(lo) - mean(so) by
      ;; linearity). Then walk ALL blocks and distill each block's
      ;; last_net_out against the aggregate target. Net-only layers (24 of
      ;; 32) get a target instead of being filtered out.
      ;;
      ;; gate-weights / gate-indices are per-layer concepts; aggregate mode
      ;; ignores them (documented in pick-distill-mode docstring).
      (= mode "aggregate-local")
      (let [local-blocks (filter (fn [b] (some? (:memory b))) (:blocks m))
            los (->> local-blocks
                     (map (fn [b]
                            (let [g (:long-gate b)]
                              (python/getattr g "last_local_out" nil))))
                     (filter some?))
            sos-at-local (->> local-blocks
                              (map (fn [b]
                                     (let [g (:long-gate b)]
                                       (python/getattr g "last_sdpa_out" nil))))
                              (filter some?))]
        (if (empty? los)
          0.0
          (let [mean-lo (-> (torch/stack (vec los) ** :dim 0)
                            (.mean ** :dim 0)
                            (.detach))
                mean-so (when (and (= target-kind "residual") (seq sos-at-local))
                          (-> (torch/stack (vec sos-at-local) ** :dim 0)
                              (.mean ** :dim 0)
                              (.detach)))
                tgt (if mean-so (.sub mean-lo mean-so) mean-lo)
                ;; ALL 32 blocks contribute one MSE term against the aggregate.
                losses (->> (:blocks m)
                            (map (fn [b]
                                   (let [g  (:long-gate b)
                                         no (python/getattr g "last_net_out" nil)]
                                     (when no
                                       (if dir-only
                                         (let [tgt-n   (.add (.norm tgt ** :dim -1 :keepdim true) eps)
                                               no-n    (.add (.norm no  ** :dim -1 :keepdim true) eps)
                                               dir-mse (F/mse_loss (.div no no-n)
                                                                   (.div tgt tgt-n))]
                                           (if (pos? mag-coef)
                                             (let [tgt-mag (if (pos? mag-clamp)
                                                             (.clamp tgt-n ** :max mag-clamp)
                                                             tgt-n)
                                                   mag-mse (F/mse_loss no-n (.detach tgt-mag))]
                                               (+ (* (- 1.0 mag-coef) dir-mse)
                                                  (* mag-coef         mag-mse)))
                                             dir-mse))
                                         (F/mse_loss no tgt))))))
                            (filter some?))]
            (if (empty? losses)
              0.0
              (let [raw-mse (/ (reduce + losses) (python/float (count losses)))]
                (when metrics
                  (.__setitem__ metrics "distill_loss_raw"
                                (if (number? raw-mse)
                                  (python/float raw-mse)
                                  (.item (.detach raw-mse))))
                  (.__setitem__ metrics "distill_n_blocks" (python/int (count losses)))
                  (.__setitem__ metrics "distill_mode" "aggregate-local"))
                (* coef raw-mse))))))

      :else
      ;; Three paths:
      ;;   gate-weights set: continuous per-layer weighting (each block's
      ;;     MSE multiplied by its weight before averaging).
      ;;   gate set: binary include/exclude.
      ;;   neither set: original hot path (all blocks contribute equally).
      (let [losses
            (cond
              ;; Weighted path: per-layer continuous multiplier.
              (some? gate-weights)
              (->> (map-indexed vector (:blocks m))
                   (map (fn [[i b]]
                          (let [w (.get gate-weights i 0.0)]
                            (when (> w 0.0)
                              (let [g  (:long-gate b)
                                    lo (python/getattr g "last_local_out" nil)
                                    no (python/getattr g "last_net_out" nil)
                                    so (python/getattr g "last_sdpa_out" nil)]
                                (when (and lo no)
                                  (let [tgt (if (and (= target-kind "residual") so)
                                              (.sub (.detach lo) (.detach so))
                                              (.detach lo))
                                        base-mse
                                        (if dir-only
                                          (let [tgt-n   (.add (.norm tgt ** :dim -1 :keepdim true) eps)
                                                no-n    (.add (.norm no  ** :dim -1 :keepdim true) eps)
                                                dir-mse (F/mse_loss (.div no no-n)
                                                                    (.div tgt tgt-n))]
                                            (if (pos? mag-coef)
                                              (let [tgt-mag (if (pos? mag-clamp)
                                                              (.clamp tgt-n ** :max mag-clamp)
                                                              tgt-n)
                                                    mag-mse (F/mse_loss no-n (.detach tgt-mag))]
                                                (+ (* (- 1.0 mag-coef) dir-mse)
                                                   (* mag-coef         mag-mse)))
                                              dir-mse))
                                          (F/mse_loss no tgt))]
                                    (* w base-mse))))))))
                   (filter some?))
              ;; Binary gate path.
              (some? gate)
              (->> (map-indexed vector (:blocks m))
                   (filter (fn [[i _]] (.__contains__ gate i)))
                   (map (fn [[_ b]]
                          (let [g  (:long-gate b)
                                lo (python/getattr g "last_local_out" nil)
                                no (python/getattr g "last_net_out" nil)
                                so (python/getattr g "last_sdpa_out" nil)]
                            (when (and lo no)
                              (let [tgt (if (and (= target-kind "residual") so)
                                          (.sub (.detach lo) (.detach so))
                                          (.detach lo))]
                                (if dir-only
                                  (let [tgt-n   (.add (.norm tgt ** :dim -1 :keepdim true) eps)
                                        no-n    (.add (.norm no  ** :dim -1 :keepdim true) eps)
                                        dir-mse (F/mse_loss (.div no no-n)
                                                            (.div tgt tgt-n))]
                                    (if (pos? mag-coef)
                                      (let [tgt-mag (if (pos? mag-clamp)
                                                      (.clamp tgt-n ** :max mag-clamp)
                                                      tgt-n)
                                            mag-mse (F/mse_loss no-n (.detach tgt-mag))]
                                        (+ (* (- 1.0 mag-coef) dir-mse)
                                           (* mag-coef         mag-mse)))
                                      dir-mse))
                                  (F/mse_loss no tgt)))))))
                   (filter some?))
              ;; Fast path: no gating.
              :else
              (->> (:blocks m)
                   (map (fn [b]
                          (let [g  (:long-gate b)
                                lo (python/getattr g "last_local_out" nil)
                                no (python/getattr g "last_net_out" nil)
                                so (python/getattr g "last_sdpa_out" nil)]
                            (when (and lo no)
                              (let [tgt (if (and (= target-kind "residual") so)
                                          (.sub (.detach lo) (.detach so))
                                          (.detach lo))]
                                (if dir-only
                                  (let [tgt-n   (.add (.norm tgt ** :dim -1 :keepdim true) eps)
                                        no-n    (.add (.norm no  ** :dim -1 :keepdim true) eps)
                                        dir-mse (F/mse_loss (.div no no-n)
                                                            (.div tgt tgt-n))]
                                    (if (pos? mag-coef)
                                      (let [tgt-mag (if (pos? mag-clamp)
                                                      (.clamp tgt-n ** :max mag-clamp)
                                                      tgt-n)
                                            mag-mse (F/mse_loss no-n (.detach tgt-mag))]
                                        (+ (* (- 1.0 mag-coef) dir-mse)
                                           (* mag-coef         mag-mse)))
                                      dir-mse))
                                  (F/mse_loss no tgt)))))))
                   (filter some?)))]
        (if (empty? losses)
          0.0
          (let [raw-mse (/ (reduce + losses) (python/float (count losses)))]
            ;; Stash the pre-coef raw MSE on metrics so we can see the
            ;; mechanism-side convergence (Net catching up to Local's
            ;; residual direction) independently of the cosine coef ramp.
            ;; Without this, the only reported distill_loss is coef×raw_mse,
            ;; which rises naturally with the coef schedule even when raw
            ;; MSE is flat or falling.
            (when metrics
              (.__setitem__ metrics "distill_loss_raw"
                            (if (number? raw-mse)
                              (python/float raw-mse)
                              (.item (.detach raw-mse)))))
            (* coef raw-mse)))))))

(defn pick-k-align-coef
  "MMLLM_K_ALIGN_COEF — coefficient for the ongoing K_a/K_b alignment
   MSE between Net and Local. Default 0.0 = disabled (no extra loss
   term, no extra compute).

   Set to a small positive value (~1e-3 to 1e-2) to keep Net's K_a/K_b
   bootstrap rows gently pulled toward Local's after a one-shot
   MMLLM_REWARM_NETBANK_KEYS=true. Breaks the cyclic random-K_a/K_b →
   gate-suppresses-Net → no-gradient-to-K_a/K_b trap flagged in
   CLAUDE.md."
  []
  (python/float (.get (.- os environ) "MMLLM_K_ALIGN_COEF" "0.0")))

(defn collect-k-align-loss
  "MSE alignment loss between Net's first min(local.sqrt_n, net.sqrt_n)
   rows of K_a/K_b and Local's K_a/K_b (detached). Pulls Net's
   bootstrap rows toward Local's retrieval geometry every step.

   Returns 0.0 when MMLLM_K_ALIGN_COEF=0 (the default) or when no
   block has both a Local and a Net bank.

   Scope: layers in :local-bank-layers (8 of 32 in cpu-mini's
   asymmetric architecture). Net's K_a/K_b beyond row sqrt_local
   stays free to learn independent addressing — alignment only
   anchors the bootstrap rows.

   Loss formula, per block with both Local+Net:
     n = min(local.sqrt_n, net.sqrt_n)
     mse_a = mse(net.K_a[:n], local.K_a[:n].detach())
     mse_b = mse(net.K_b[:n], local.K_b[:n].detach())
   Returned as coef × mean_over_blocks(mse_a + mse_b)."
  [m]
  (let [coef (pick-k-align-coef)]
    (if (zero? coef)
      0.0
      (let [losses (->> (:blocks m)
                        (keep (fn [b]
                                (let [nb  (:netbank b)
                                      mem (:memory b)]
                                  (when (and nb mem)
                                    (let [n-copy (python/min (.- mem sqrt_n) (.- nb sqrt_n))
                                          local-K_a (.detach (.- mem K_a))
                                          local-K_b (.detach (.- mem K_b))
                                          mse_a (F/mse_loss
                                                  (.narrow (.- nb K_a) 0 0 n-copy)
                                                  (.narrow local-K_a 0 0 n-copy))
                                          mse_b (F/mse_loss
                                                  (.narrow (.- nb K_b) 0 0 n-copy)
                                                  (.narrow local-K_b 0 0 n-copy))]
                                      (+ mse_a mse_b))))))
                        (into []))]
        (if (empty? losses)
          0.0
          (* coef (/ (reduce + losses) (python/float (count losses)))))))))

(defn pick-grad-clip-max-norm
  "Max global norm for dense-parameter gradient clipping (AdamW only;
   SparseAdam's per-row updates are localized and don't suffer the
   same single-step blow-up mode). Reads MMLLM_GRAD_CLIP (default 0.0
   = disabled). Standard ML hygiene; 1.0 is a reasonable default
   when enabling. Prevents the 'one bad batch → huge grad → optimizer
   step explodes a param to inf → next forward NaNs' failure mode."
  []
  (python/float (.get (.- os environ) "MMLLM_GRAD_CLIP" "0.0")))

(defn pick-importance-aux-coef
  "Coefficient on the IH self-supervised aux loss (MSE between IH
   output and detached per_pos_ce). Reads MMLLM_IMPORTANCE_AUX
   (default 1.0). 0 disables aux training (IH stays at init bias).
   This is the v2 IH knob — replaces the old MMLLM_IMPORTANCE_REG
   regularizer which never worked (v1 IH had a sign bug)."
  []
  (python/float (.get (.- os environ) "MMLLM_IMPORTANCE_AUX" "1.0")))

(defn pick-carry-enabled?
  "Whether to insert MultiTimescaleCarry per block. Reads
   MMLLM_CARRY_ENABLED (default 'false'). 4 EMAs per block at log-spaced
   decay rates. ~10-15% throughput hit. Init: gate zero → identity at
   step 0; gradient differentiates over training."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_CARRY_ENABLED" "false"))]
    (.__contains__ #{"1" "true" "yes"} v)))

(defn pick-carry-n-clocks
  "Number of EMAs per MultiTimescaleCarry block. Reads
   MMLLM_CARRY_N_CLOCKS (default 4). Decay rates are hardcoded at
   [0.5, 0.875, 0.96875, 0.992] when n_clocks=4."
  []
  (python/int (.get (.- os environ) "MMLLM_CARRY_N_CLOCKS" "4")))

(defn pick-bwd-skip-frac-net-only
  "Probability that any given net-only block (no Local Memory; just
   NetBank) will run inside torch.no_grad on a training step, so its
   internal compute receives no gradient.

   Stochastic-depth-in-backward: skips the block's entire backward
   graph (attention + FFN + NetBank gather all elided for that step).
   The residual addition happens OUTSIDE the no_grad context so the
   upstream x's gradient chain stays alive and earlier blocks still
   backward normally.

   MMLLM_BWD_SKIP_FRAC_NET_ONLY: float in [0, 1]. Default 0.0 = off.
   1.0 means every net-only block (24 of 32 at the default layer
   assignment) skips its backward each step."
  []
  (try
    (max 0.0 (min 1.0 (python/float
                        (.get (.- os environ)
                              "MMLLM_BWD_SKIP_FRAC_NET_ONLY" "0.0"))))
    (catch python/ValueError _
      0.0)))

(defn pick-bwd-skip-frac-local
  "Probability that any given Local layer (one of the 8 carrying
   V_local + SwitchGate + distill) will run inside torch.no_grad on
   a training step. Default 0.0 = always backward, never skip — these
   layers carry the distillation pathway whose training we don't want
   to randomly drop. Set MMLLM_BWD_SKIP_FRAC_LOCAL>0 to extend the
   bwd-skip lever to local layers (faster steps, more aggressive
   risk to training signal)."
  []
  (try
    (max 0.0 (min 1.0 (python/float
                        (.get (.- os environ)
                              "MMLLM_BWD_SKIP_FRAC_LOCAL" "0.0"))))
    (catch python/ValueError _
      0.0)))

;;; ─────────────────────── decoder block ───────────────────────

(defn block-forward
  "Thin shim — destructure block fields and call the Python
   `attention_kernel.block_forward`, which runs pre-norm + attention
   + SwiGLU FFN with native Python data structures (torch.compile-
   traceable). Returns (x_out, new-short-cache, new-long-cache).

   `skip-bank?` (Phase-5 draft mode) — pass true to bypass the PKM
   bank lookup at the long-tier. ~17% lower FLOPs per layer.

   `trunk-ids` (optional, (B,) long torch tensor): per-batch-row
   routing into Local Bank's per-trunk V slices. nil at n-trunks=1."
  ([block x cos sin short-cache long-cache]
   (block-forward block x cos sin short-cache long-cache false nil))
  ([block x cos sin short-cache long-cache skip-bank?]
   (block-forward block x cos sin short-cache long-cache skip-bank? nil))
  ([block x cos sin short-cache long-cache skip-bank? trunk-ids]
   (let [{:keys [norm1 norm2
                 q-proj k-proj-s v-proj-s k-proj-l v-proj-l o-proj
                 memory netbank long-gate bank-query bank-feedback
                 gate-proj up-proj down-proj carry
                 n-heads n-short-heads n-long-heads
                 n-short-kv-heads n-long-kv-heads head-dim max-t
                 short-window long-window]} block
         ;; Gradient checkpointing branch: when MMLLM_GRAD_CHECKPOINT
         ;; is true AND grad is enabled (training, not eval), route
         ;; through kernel/checkpointed_block_forward. That helper is
         ;; a top-level Python function — taking the destructured
         ;; block fields as arguments — so each call's inner closure
         ;; gets a FRESH Python local for `block`, avoiding the
         ;; late-binding bug that would happen if we tried to close
         ;; over `block` from a basilisp `loop` (Clojure's `loop`
         ;; compiles to a Python while-loop with shared cells; every
         ;; per-iter closure ends up pointing at the LAST block by
         ;; the time backward runs the recompute).
         ;;
         ;; Returns only x_out (no KV-cache outputs). Train-step
         ;; discards short/long caches anyway, so this is fine and
         ;; lets checkpoint's saved-tensor tracker see a single
         ;; tensor return — no false-positive non-determinism trips
         ;; on the original mixed tensor+tuple return.
         ckpt?      (and (pick-grad-checkpoint?) (torch/is_grad_enabled))
         ;; Stochastic-depth-in-backward gate. Skipped blocks run their
         ;; forward inside torch.no_grad — output is still computed
         ;; (residual unchanged) but no autograd graph is built, so
         ;; backward through the block's internals is elided entirely.
         ;; Block's params don't update this step; over many steps every
         ;; block trains in expectation.
         ;;
         ;; Net-only layers (memory == nil) and Local layers consult
         ;; separate fractions, so the operator can keep V_local +
         ;; SwitchGate + distill always-on while skipping the cheaper
         ;; net-only blocks.
         skip-bwd?  (and (torch/is_grad_enabled)
                         (if (nil? memory)
                           (< (random/random) (pick-bwd-skip-frac-net-only))
                           (< (random/random) (pick-bwd-skip-frac-local))))]
     (if ckpt?
       (let [[x-ckpt distill-term z-term]
                    (kernel/checkpointed_block_forward
                      norm1 norm2
                      q-proj k-proj-s v-proj-s k-proj-l v-proj-l o-proj
                      memory long-gate bank-query bank-feedback
                      gate-proj up-proj down-proj
                      n-heads n-short-heads n-long-heads
                      n-short-kv-heads n-long-kv-heads head-dim max-t
                      short-window long-window
                      x cos sin short-cache long-cache
                      ** :skip_bank skip-bank?
                      :netbank netbank
                      :trunk_ids trunk-ids
                      :skip_bwd skip-bwd?)
             ;; Carry applied OUTSIDE checkpoint — it's cheap and we
             ;; don't need its tiny intermediates re-materialized.
             x'     (if carry (carry x-ckpt) x-ckpt)]
         [x' nil nil distill-term z-term])
       (let [[x' s' l' distill-term z-term]
                          (kernel/block_forward
                          norm1 norm2
                          q-proj k-proj-s v-proj-s k-proj-l v-proj-l o-proj
                          memory long-gate bank-query bank-feedback
                          gate-proj up-proj down-proj
                          n-heads n-short-heads n-long-heads
                          n-short-kv-heads n-long-kv-heads head-dim max-t
                          short-window long-window
                          x cos sin short-cache long-cache
                          ** :skip_bank skip-bank?
                          :netbank netbank
                          :trunk_ids trunk-ids
                          :skip_bwd skip-bwd?)]
         ;; Multi-timescale carry as a post-block residual delta.
         ;; Carry's gate is zero-init so at step 0 this is identity
         ;; (no behavior change vs no-carry); training pushes the
         ;; gate to mix EMAs at ~1/5/22/86-token half-lives back
         ;; into the stream.
         (if carry
           [(carry x') s' l' distill-term z-term]
           [x' s' l' distill-term z-term]))))))

(defn build-block
  [{:keys [d-model n-heads n-short-heads n-long-heads
           n-short-kv-heads n-long-kv-heads d-ff
           memory-top-k memory-sub-top-k
           memory-mmap-path long-tier-mix bank-query-mode bank-feedback-mode
           short-window long-window] :as config}
   block-idx]
  (let [head-dim  (quot d-model n-heads)
        q-dim     (* n-long-heads head-dim)
        sqrt-n    (pick-sqrt-n config)
        ;; Phase-3: bank V can be loaded as fp32 (training + inference)
        ;; or int8 (inference-only, ~4× smaller on disk). Selected by
        ;; MMLLM_BANK_DTYPE env var; defaults to fp32. The int8 path
        ;; expects files with a different suffix and a header-prefixed
        ;; layout — see mmllm.memory for the format.
        bank-dtype (.lower (.get (.- os environ) "MMLLM_BANK_DTYPE" "fp32"))
        int8?      (= bank-dtype "int8")
        path       (when memory-mmap-path
                     (if int8?
                       (str memory-mmap-path "." block-idx ".int8.bin")
                       (str memory-mmap-path "." block-idx ".bin")))
        memory-cls (if int8? mem/Int8ProductKeyMemory mem/ProductKeyMemory)
        gate-kind (or long-tier-mix       (pick-long-tier-mix))
        bq-kind   (or bank-query-mode     (pick-bank-query-mode))
        fb-kind   (or bank-feedback-mode  (pick-bank-feedback-mode))
        sw        (or short-window        (pick-short-window))
        lw        (or long-window         (pick-long-window))
        ;; Phase-1c: pre-allocated KV cache buffer length. Bound on
        ;; max generation per conversation; bigger buffers cost RAM
        ;; once at first call but eliminate per-token reallocation.
        mt        (pick-max-t)]
    {:d-model           d-model
     :head-dim          head-dim
     :max-t             mt
     :n-heads           n-heads
     :n-short-heads     n-short-heads
     :n-long-heads      n-long-heads
     :n-short-kv-heads  n-short-kv-heads
     :n-long-kv-heads   n-long-kv-heads
     :norm1     (nn/RMSNorm d-model)
     :norm2     (nn/RMSNorm d-model)
     :q-proj    (nn/Linear d-model (* n-heads          head-dim) ** :bias false)
     :k-proj-s  (nn/Linear d-model (* n-short-kv-heads head-dim) ** :bias false)
     :v-proj-s  (nn/Linear d-model (* n-short-kv-heads head-dim) ** :bias false)
     :k-proj-l  (nn/Linear d-model (* n-long-kv-heads  head-dim) ** :bias false)
     :v-proj-l  (nn/Linear d-model (* n-long-kv-heads  head-dim) ** :bias false)
     :o-proj    (nn/Linear (* n-heads head-dim) d-model ** :bias false)
     :gate-proj (nn/Linear d-model d-ff ** :bias false)
     :up-proj   (nn/Linear d-model d-ff ** :bias false)
     :down-proj (nn/Linear d-ff    d-model ** :bias false)
     :short-window      sw
     :long-window       lw
     :long-gate     (let [g (gate/build_gate gate-kind n-long-heads head-dim)]
                      ;; Optional per-head learnable scale on Net's path.
                      ;; Attached to the gate AFTER construction (so it's
                      ;; not part of SwitchGate's declaration-order params,
                      ;; which would shift positional ckpt-load alignment).
                      ;; Surfaces as a fresh tensor in (parameters m) at
                      ;; the END of the param list — see `alpha-net-params`.
                      (when (and (= gate-kind "switch") (pick-alpha-net-enabled?))
                        (.__setattr__ g "alpha_net"
                                      (nn/Parameter (torch/ones n-long-heads))))
                      ;; Net-default Bernoulli routing — same alignment-safe
                      ;; pattern as alpha_net. proj zero-init, bias init -2.0
                      ;; so sigmoid(-2.0) ≈ 12% initial Local firing rate.
                      ;; Skip on layers without a Local Bank (no routing decision
                      ;; to make at those layers — the gate runs in 2-way
                      ;; sdpa+net mode there).
                      (when (and (= gate-kind "switch")
                                 (pick-gate-net-default?)
                                 (.__contains__ (pick-local-bank-layers config) block-idx))
                        (.__setattr__ g "local_active_proj"
                                      (nn/Parameter (torch/zeros n-long-heads head-dim)))
                        (.__setattr__ g "local_active_bias"
                                      (nn/Parameter (.fill_ (torch/empty n-long-heads) -2.0))))
                      g)
     :bank-query    (bq/build_bank_query     bq-kind   d-model      q-dim)
     :bank-feedback (bfb/build_bank_feedback fb-kind   d-model      q-dim)
     ;; Local Bank only at the layers selected by pick-local-bank-layers.
     ;; At other layers `:memory` is nil and the long-tier mix uses just
     ;; sdpa + Net (handled in attention_kernel and SwitchGate).
     :memory    (when (.__contains__ (pick-local-bank-layers config) block-idx)
                  (memory-cls q-dim sqrt-n
                              ** :top_k     (pick-memory-top-k memory-top-k)
                              :sub_top_k (pick-memory-sub-top-k memory-sub-top-k)
                              :mmap_path path
                              :n_trunks  (pick-n-trunks)))
     :netbank   (when (pick-netbank-enabled?)
                  (netb/NetBank q-dim
                                ** :sqrt_n       (pick-netbank-sqrt-n)
                                :c_net           (pick-netbank-c-net)
                                :top_k           (pick-netbank-top-k)
                                :sub_top_k       (pick-netbank-sub-top-k)
                                :mmap_path       (when-let [base (pick-netbank-path memory-mmap-path)]
                                                   (str base "." block-idx ".bin"))
                                :delay_ms_min    (pick-netbank-delay-min)
                                :delay_ms_max    (pick-netbank-delay-max)
                                :dtype           (pick-netbank-dtype)
                                :bank_on_gpu     (pick-netbank-on-gpu?)))
     ;; Optional MultiTimescaleCarry — per-block "brain-stem clocks"
     ;; residual at log-uniform decay rates. Zero-init gate → identity at
     ;; step 0 so adding to an existing ckpt is behavior-preserving;
     ;; gradient differentiates over training. nil when disabled.
     :carry     (when (pick-carry-enabled?)
                  (rs/MultiTimescaleCarry d-model (pick-carry-n-clocks)))}))

;;; ─────────────────────── model ───────────────────────

(defn- block-to-device!
  "Move every nn.Module child of a block to `device`. ProductKeyMemory and
   NetBank both wrap their V tensors in CPUPinnedEmbedding-style modules
   whose `_apply` no-ops; the parent module's recursive .to() walks into
   K_a/K_b/q_norm/expander but skips V, leaving the mmap on CPU."
  [block device]
  (doseq [k [:norm1 :norm2 :q-proj :k-proj-s :v-proj-s :k-proj-l :v-proj-l
             :o-proj :gate-proj :up-proj :down-proj
             :long-gate :bank-query :bank-feedback]]
    (.to (get block k) device))
  ;; :memory is conditional under the asymmetric :local-bank-layers config.
  (when-let [mem (:memory block)] (.to mem device))
  (when-let [nb (:netbank block)]
    (.to nb device))
  (when-let [c (:carry block)]
    (.to c device))
  block)

(def ^:private DELIM_BYTES
  "JSON structural delimiter byte values. Intentionally excludes whitespace
   (space, tab) since JSON allows arbitrary whitespace and including it
   would dilute the structural signal. Defined here (above first user)
   so basilisp's analyzer doesn't hit a forward reference."
  #{(python/int 0x7B)   ;; {
    (python/int 0x7D)   ;; }
    (python/int 0x5B)   ;; [
    (python/int 0x5D)   ;; ]
    (python/int 0x3A)   ;; :
    (python/int 0x2C)   ;; ,
    (python/int 0x22)   ;; "
    (python/int 0x0A)}) ;; newline

(defn pick-fim-loss-mask-middle-only?
  "When true, train-step zeroes per-position CE outside the
   `<|fim_mid|>...<|fim_eom|>` span on each example. Examples without
   FIM markers (raw causal docs in a mixed corpus) keep full CE
   everywhere. Reads MMLLM_FIM_LOSS_MASK_MIDDLE_ONLY (default 'false').
   Forces the model to focus its gradient on middle-fill prediction;
   prefix and suffix become conditioning context only."
  []
  (let [v (.lower (.get (.- os environ) "MMLLM_FIM_LOSS_MASK_MIDDLE_ONLY" "false"))]
    (.__contains__ #{"1" "true" "yes"} v)))

(defn pick-schema-mask-weight
  "Per-position CE weight multiplier for 'commit' positions — positions
   where the PREVIOUS byte was a structural JSON delimiter. Reads
   MMLLM_SCHEMA_MASK_WEIGHT (default 1.0 = disabled). Values > 1.0
   up-weight the loss on bytes immediately after `{`, `:`, `,`, etc.
   Approximates schema-masked teacher forcing without a real grammar
   parser. Tier-3 spike #5."
  []
  (python/float (.get (.- os environ) "MMLLM_SCHEMA_MASK_WEIGHT" "1.0")))

(defn ^:private schema-mask-of
  "x: (B, T) int64 → (B, T) float weight tensor. Position t gets weight
   w (= MMLLM_SCHEMA_MASK_WEIGHT) if x[t-1] is in DELIM_BYTES, else 1.0.
   Position 0 always weight 1.0 (no preceding byte). Used to multiply
   per-position CE."
  [x w]
  (let [delim-shifted (torch/zeros_like x ** :dtype torch/bool)
        prev          (.narrow x 1 0 (- (.size x 1) 1))]   ;; x[:, :-1]
    ;; Build a mask: prev is in DELIM_BYTES → True
    (let [prev-mask (torch/zeros_like prev ** :dtype torch/bool)]
      (doseq [b DELIM_BYTES] (.logical_or_ prev-mask (.eq prev b)))
      ;; Shift by one so that position t (in result) flags x[t-1]
      (.copy_ (.narrow delim-shifted 1 1 (- (.size x 1) 1)) prev-mask))
    (-> (.float delim-shifted)
        (.mul (- w 1.0))
        (.add 1.0))))

(defn pick-pause-bytes
  "Number of pause-byte 'thinking' positions to prepend to training
   batches with probability MMLLM_PAUSE_PROB. Reads MMLLM_PAUSE_BYTES
   (default 0 = disabled). When > 0, with probability pause-prob the
   first N bytes of each input sequence are replaced with the pause
   byte (default value 0x00). Targets give the model extra 'forward
   passes' before predicting real content — at inference, prepend N
   pause bytes to the prompt to give Local Bank time to deliberate
   before committing to structural output. Tier-3 spike #9."
  []
  (python/int (.get (.- os environ) "MMLLM_PAUSE_BYTES" "0")))

(defn pick-pause-prob
  "Probability per training batch of injecting pause-byte prefix.
   Reads MMLLM_PAUSE_PROB (default 0.5). 0 = always insert; 1 = never
   skip; 0.5 = half of batches get pauses, half don't."
  []
  (python/float (.get (.- os environ) "MMLLM_PAUSE_PROB" "0.5")))

(defn pick-pause-byte-val
  "Byte value used for pause filling. Reads MMLLM_PAUSE_BYTE_VAL
   (default 0 = NUL). Pick a byte that's rare in actual training data
   so model learns to treat it as a pause marker, not as content."
  []
  (python/int (.get (.- os environ) "MMLLM_PAUSE_BYTE_VAL" "0")))

(defn ^:private maybe-inject-pause-prefix!
  "Mutate x in-place: with probability `prob`, replace the first
   `n` bytes of every sequence in x with `pause-val`. y is left
   untouched — model still predicts the original next-byte sequence,
   just with pause bytes as input prefix instead of real content."
  [x n prob pause-val]
  (when (and (pos? n) (< (.item (torch/rand 1)) prob))
    (let [pause-tensor (torch/full (python/tuple [(.size x 0) n])
                                    pause-val
                                    ** :dtype (.- x dtype)
                                    :device (.- x device))]
      (.copy_ (.narrow x 1 0 n) pause-tensor)))
  x)

(defn pick-delim-aux-coef
  "Coefficient on the JSON-delimiter auxiliary head's BCE loss. Reads
   MMLLM_DELIM_AUX_COEF (default 0.0 = disabled). When > 0, a Linear
   (d_model, 1) head over the final hidden state predicts whether the
   NEXT byte is a JSON structural delimiter ({ } [ ] : , \" \\n).
   Auxiliary loss = BCEWithLogits(head(x), is_delim(y)). Forces the
   trunk's hidden state to encode JSON parse state — which Local Bank
   can then leverage when retrieving structural patterns. 0.05-0.1 is
   a reasonable initial cap. Tier-2 spike #4 from the upgrade plan."
  []
  (python/float (.get (.- os environ) "MMLLM_DELIM_AUX_COEF" "0.0")))

(defn pick-mtp-coef
  "Coefficient on the multi-token-prediction (t+2) auxiliary loss.
   Reads MMLLM_MTP_COEF (default 0.0 = disabled). When > 0, an
   independent linear head predicts the byte two positions ahead;
   its CE loss is added to the main t+1 loss with this coefficient.
   Meta MTP 2024 + recent byte-LM work suggest 0.25-0.5 for byte
   models; start small (0.25) and tune up if it helps."
  []
  (python/float (.get (.- os environ) "MMLLM_MTP_COEF" "0.0")))

(defn build-model
  [{:keys [d-model n-heads n-short-heads n-long-heads
           n-short-kv-heads
           n-layers seq-len max-pos rope-theta] :as config}]
  (assert (= n-heads (+ n-short-heads n-long-heads))
          "n-heads must equal n-short-heads + n-long-heads")
  (assert (zero? (mod n-short-heads n-short-kv-heads))
          "n-short-heads must be divisible by n-short-kv-heads")
  (let [head-dim   (quot d-model n-heads)
        [cos sin]  (build-rope-cache (or max-pos seq-len) head-dim rope-theta)
        device     (pick-device)
        ;; Aux MTP head — only constructed when MMLLM_MTP_COEF > 0 so
        ;; default models stay parameter-identical to pre-MTP code and
        ;; old ckpts load cleanly. Goes AT THE END of (parameters m)
        ;; for positional-ckpt-load compatibility.
        mtp-head   (when (pos? (pick-mtp-coef))
                     (.to (nn/Linear d-model vocab-size ** :bias false) device))
        ;; Optional LearnedImportanceHead — Linear(d_model, 1) over the
        ;; final hidden state, softplus-transformed → per-position loss
        ;; multiplier. Self-supervised by the loss itself (regularized to
        ;; mean=1). Zero-init weights → softplus(0) ≈ 0.69 ≈ const at
        ;; step 0; differentiates over training. Goes at END of
        ;; (parameters m) for ckpt back-compat.
        importance-head (when (pick-importance-head?)
                          (.to (rs/LearnedImportanceHead d-model) device))
        ;; JSON-delimiter aux head — Linear(d_model, 1) over final hidden
        ;; state. Predicts whether the NEXT byte is a structural JSON
        ;; delimiter. Zero-init so adds no signal at step 0 (back-compat).
        ;; Goes at END of (parameters m) for positional ckpt-load.
        delim-head (when (pos? (pick-delim-aux-coef))
                     (let [h (nn/Linear d-model 1 ** :bias true)]
                       (with [_ (torch/no_grad)]
                         (.zero_ (.- (.- h weight) data))
                         (.zero_ (.- (.- h bias)   data)))
                       (.to h device)))
        blocks     (vec (map #(block-to-device! (build-block config %) device)
                             (range n-layers)))]
    ;; SPIKE 3 — MMLLM_NETBANK_SHARED=true weight-ties NetBank's V and
    ;; expander across all blocks. K_a / K_b stay per-layer so each
    ;; layer learns its own retrieval geometry, but every layer reads /
    ;; writes the SAME V table. Gradient accumulates from all n_layers
    ;; forwards per step — the 'one shared NetBank tier' interpretation
    ;; of the triune-brain doc made literal.
    ;;
    ;; Mechanism: each block's NetBank module was constructed by
    ;; build-block with its own V (mmap) and expander (Linear). After
    ;; building, we point every block.netbank.V and .expander at the
    ;; first block's instance. PyTorch parameter-tying handles the
    ;; gradient accumulation across forward call sites. The K_a / K_b
    ;; stay per-block so per-layer queries each learn their own routing.
    ;;
    ;; Caveat: this leaves the other (n_layers-1) mmap files allocated
    ;; but unused. That's ~1 GB of orphaned disk at default sizes.
    ;; Spike-only; production sharing would skip allocation entirely.
    (when (pick-netbank-shared?)
      (let [first-nb (:netbank (first blocks))]
        (when first-nb
          (doseq [b (rest blocks)]
            (when-let [nb (:netbank b)]
              (.__setattr__ nb "V"        (.- first-nb V))
              (.__setattr__ nb "expander" (.- first-nb expander))))
          (println (format "  SPIKE-3: NetBank shared — V + expander tied across %d blocks"
                           (count blocks))))))
    {:config          config
     :device          device
     :tok-emb         (.to (nn/Embedding vocab-size d-model) device)
     :blocks          blocks
     :norm-final      (.to (nn/RMSNorm d-model) device)
     :rope-cos        (.to cos device)
     :rope-sin        (.to sin device)
     :mtp-head        mtp-head
     :importance-head importance-head
     :delim-head      delim-head
     ;; Mutable metrics stash for visibility into router-smarts /
     ;; consolidation aux losses. train-step writes the most recent
     ;; distill_loss; train-long writes replay_loss after the periodic
     ;; replay step. Read at print and slot-log time.
     :metrics         (python/dict {"distill_loss" 0.0
                                    "replay_loss"  0.0
                                    "replay_buf_n" 0
                                    "delim_loss"   0.0})}))

(defn- dedupe-by-py-id
  "Filter a seq of Python objects to remove duplicates by id().
   No-op when no duplicates exist (the default cron path). Needed
   when weight-tying (MMLLM_NETBANK_SHARED=true, spike-3) causes the
   same nn.Parameter to appear in multiple per-block param lists —
   without dedupe, optimizers receive the same Parameter N times and
   apply each update N times per step (effective LR × N, fast NaN)."
  [xs]
  (let [seen-id (python/set)]
    (filter (fn [x]
              (let [pid (python/id x)]
                (if (.__contains__ seen-id pid)
                  false
                  (do (.add seen-id pid) true))))
            xs)))

(defn parameters
  "DENSE learnable parameters — these route to AdamW. Excludes the
   memory bank V.weight per block (sparse — see sparse-parameters).
   The LM head is weight-tied to tok-emb so doesn't appear separately.

   Backward-compat ordering: anything that may have ZERO params in a
   prior ckpt's gate config (e.g. SumGate had 0, SwitchGate has 2)
   is appended at the END of the list. That way switching to a gate
   with MORE params doesn't shift the positional map of all the
   tensors that come after it — old ckpt's K_a/K_b/q_norm don't get
   misaligned onto the new gate's gate_proj.

   Order:
     1. tok-emb
     2. per-block CORE (norm1, norm2, q/k/s/v/l-projs, FFN, bank-query,
        bank-feedback, memory's dense params)
     3. norm-final
     4. mtp-head (optional, at END so pre-MTP ckpts load cleanly)
     5. per-block long-gate (at END for the same reason — SumGate→
        SwitchGate transition would otherwise misalign)
     6. per-block netbank dense (at END so a pre-NetBank ckpt loads
        cleanly into a NetBank-enabled model)
     7. importance-head (at END — added in router-smarts work)
     8. per-block carry gate (at END — added in router-smarts work)"
  [m]
  (let [{:keys [tok-emb blocks norm-final mtp-head importance-head delim-head]} m
        ;; CORE block params (K_a/K_b only from memory — q_norm goes at end)
        core-params (fn [b]
                      (concat
                       (mapcat #(python/list (.parameters (get b %)))
                               [:norm1 :norm2 :q-proj
                                :k-proj-s :v-proj-s
                                :k-proj-l :v-proj-l
                                :o-proj :gate-proj :up-proj :down-proj
                                :bank-query :bank-feedback])
                       ;; memory's K_a, K_b only; q_norm at END below.
                       ;; Skip when this block has no Local Bank attached
                       ;; (asymmetric :local-bank-layers config).
                       (when-let [mem (:memory b)] (.dense_parameters mem))))
        memory-q-norm (fn [b]
                        (when-let [mem (:memory b)]
                          (.q_norm_parameters mem)))
        gate-params (fn [b]
                      ;; Exclude alpha_net, local_active_proj, local_active_bias
                      ;; (all added later as SwitchGate attributes) from this
                      ;; position so position-aligned ckpt-load doesn't shift.
                      ;; They surface at the END of (parameters m) via the
                      ;; corresponding "added later" collectors below.
                      (->> (.named_parameters (:long-gate b))
                           python/list
                           (filter (fn [t]
                                     (not (.__contains__
                                            #{"alpha_net"
                                              "local_active_proj"
                                              "local_active_bias"}
                                            (.__getitem__ t 0)))))
                           (map (fn [t] (.__getitem__ t 1)))
                           python/list))
        netbank-params (fn [b]
                         (when-let [nb (:netbank b)]
                           (.dense_parameters nb)))
        carry-params (fn [b]
                       (when-let [c (:carry b)]
                         (python/list (.parameters c))))
        alpha-net-params (fn [b]
                           ;; SwitchGate.alpha_net (per-block, optional).
                           ;; nil/None when not enabled or not a SwitchGate.
                           (let [g (:long-gate b)
                                 a (python/getattr g "alpha_net" nil)]
                             (when (and a (python/isinstance a nn/Parameter))
                               [a])))
        local-gate-params (fn [b]
                            ;; SwitchGate.local_active_proj + local_active_bias
                            ;; (per-block, optional — present when
                            ;; MMLLM_GATE_NET_DEFAULT=true). Appended at the
                            ;; very end so pre-Net-default ckpts load cleanly.
                            (let [g  (:long-gate b)
                                  lp (python/getattr g "local_active_proj" nil)
                                  lb (python/getattr g "local_active_bias" nil)]
                              (concat
                                (when (and lp (python/isinstance lp nn/Parameter)) [lp])
                                (when (and lb (python/isinstance lb nn/Parameter)) [lb]))))]
    (concat (python/list (.parameters tok-emb))
            (mapcat core-params blocks)
            (python/list (.parameters norm-final))
            (when mtp-head (python/list (.parameters mtp-head)))
            ;; everything below is "added later" — appended at end so
            ;; positional ckpt-load from a ckpt without these stays aligned
            (mapcat memory-q-norm blocks)
            (mapcat gate-params blocks)
            ;; Dedupe by Python id: when MMLLM_NETBANK_SHARED=true,
            ;; each block's nb.expander.weight refers to the same
            ;; Parameter, so the per-block walk would emit it 32×.
            ;; No-op in the default (un-shared) path.
            (dedupe-by-py-id (mapcat netbank-params blocks))
            ;; router-smarts additions go at the very end so a ckpt
            ;; saved before these features can still load positionally.
            (when importance-head
              (python/list (.parameters importance-head)))
            (mapcat carry-params blocks)
            ;; alpha_net (per-SwitchGate per-head) — last so even
            ;; ckpts from before this feature exists load cleanly.
            (mapcat alpha-net-params blocks)
            ;; SwitchGate.local_active_proj + local_active_bias (Net-default
            ;; Bernoulli routing) — appended after alpha-net so pre-Net-
            ;; default ckpts (round-2..7) still load cleanly.
            (mapcat local-gate-params blocks)
            ;; JSON-delimiter aux head — at END for back-compat.
            (when delim-head (python/list (.parameters delim-head))))))

(defn- kab-parameters
  "Per-block K_a / K_b parameters. Returned as a flat Python list for
   the AdamW K_a/K_b sub-group when MMLLM_LR_KAB_MULT differs from
   MMLLM_LR_DENSE_MULT. Each block's :memory has K_a, K_b directly.
   Skips blocks without a Local Bank (asymmetric :local-bank-layers)."
  [m]
  (python/list
    (mapcat (fn [b]
              (when-let [mem (:memory b)]
                [(.- mem K_a) (.- mem K_b)]))
            (:blocks m))))

(defn make-opt-dense
  "Build the AdamW optimizer for dense (router) params. When
   MMLLM_LR_KAB_MULT == MMLLM_LR_DENSE_MULT: single-group (back-compat).
   When different: K_a/K_b move to a separate group (index 1) with
   their own lr; everything else stays in group 0. Train loop uses
   `set-opt-lrs!` to update both groups per-step. Returns the AdamW.

   Identifying K_a/K_b in `(parameters m)` — they're tensors with the
   same `id()` as the ones returned by `kab-parameters`. Using a Python
   set of object ids dedupes across the parameters list."
  [m]
  (let [d-mult (pick-lr-dense-mult)
        k-mult (pick-lr-kab-mult)]
    (if (= d-mult k-mult)
      (optim/AdamW (python/list (parameters m)) ** :lr (pick-lr-dense))
      (let [kab-list   (kab-parameters m)
            kab-id-set (python/set (python/list (map python/id kab-list)))
            all-list   (python/list (parameters m))
            core-list  (python/list (filter (fn [p] (not (.__contains__ kab-id-set
                                                                          (python/id p))))
                                            all-list))]
        (optim/AdamW
          (python/list [(python/dict {"params" core-list "lr" (pick-lr-dense)})
                        (python/dict {"params" kab-list  "lr" (pick-lr-kab)})])
          ** :lr (pick-lr-dense))))))

(defn sparse-parameters
  "Local Bank sparse params — route to opt-sparse (SparseAdam).
   See `netbank-sparse-parameters` for the third-tier route.
   Skips blocks without a Local Bank (asymmetric :local-bank-layers)."
  [m]
  (mapcat (fn [b]
            (when-let [mem (:memory b)] (.sparse_parameters mem)))
          (:blocks m)))

(defn netbank-sparse-parameters
  "NetBank V.weight per block — route to opt-sparse-net (third
   SparseAdam) with its own lr (pick-lr-net). Empty list when NetBank
   is disabled, so the caller can skip optimizer construction without
   special-casing.

   When MMLLM_NETBANK_SHARED=true (spike-3), all blocks' nb.V point at
   the same nn.Embedding. We dedupe by Python id so the optimizer
   doesn't see duplicate Parameters — SparseAdam would apply the same
   update once per duplicate, multiplying the effective LR by N and
   driving V to NaN within a few steps. No-op in the default path."
  [m]
  (dedupe-by-py-id
    (mapcat (fn [b] (when-let [nb (:netbank b)] (.sparse_parameters nb)))
            (:blocks m))))

(defn warm-start-netbanks-from-local!
  "Per-block, copy Local Bank's K_a/K_b into the corresponding NetBank's
   first `local.sqrt_n` rows. Bootstraps NetBank's retrieval geometry
   from Local's so queries that score highly against Local also score
   highly against the corresponding NetBank rows from step 0.

   When MMLLM_NET_V_WARMSTART_FROM_LOCAL=true, also project Local's V
   tensor through the NetBank expander's pseudo-inverse and copy into
   NetBank's V[:n_copy]. Gives NetBank trained CONTENT at step 0, not
   just trained addressing — addresses round-2's finding that Δ_net
   stays at the noise floor because V starts random.

   No-op when NetBank is disabled. Called by train-long when the resume
   path detects a missing opt-sparse-net.pt (i.e. NetBank just turned on
   for an existing dense-only run)."
  [m]
  (let [warm-V? (= "true" (.lower (.get (.- os environ)
                                        "MMLLM_NET_V_WARMSTART_FROM_LOCAL"
                                        "false")))]
    (doseq [[i b] (map-indexed vector (:blocks m))]
      (when-let [nb (:netbank b)]
        ;; Warm-start needs a Local Bank to copy K_a/K_b from. Layers
        ;; without one skip warm-start (Net-only layers in the
        ;; asymmetric architecture).
        (when-let [mem (:memory b)]
          (if warm-V?
            (.warm_start_from nb
                              (.- mem K_a)
                              (.- mem K_b)
                              ** :local_V (.- (.- mem V) weight))
            (.warm_start_from nb
                              (.- mem K_a)
                              (.- mem K_b))))
        (println (format "  NetBank[layer %d] warm-started from Local K_a/K_b%s"
                         i (if warm-V? " + V (projected)" "")))))))

(defn rewarm-netbank-keys-only!
  "Like warm-start-netbanks-from-local! but ALWAYS with local_V=None —
   refresh only Net's K_a/K_b retrieval geometry, leave V_net's
   harvested content untouched.

   Used for one-shot K_a/K_b realignment on a chain whose Net's keys
   have drifted from Local's (random-init at chain genesis + cyclic
   gate-suppression keeping them misaligned, per CLAUDE.md
   'MMLLM_SKIP_NETBANK_WARMSTART=true keeps Net's K_a/K_b random').
   Triggered via MMLLM_REWARM_NETBANK_KEYS=true in train-long.

   Pairs with MMLLM_K_ALIGN_COEF (ongoing distill-style pressure) so
   that after the one-shot kick, Net's K_a/K_b doesn't drift back."
  [m]
  (doseq [[i b] (map-indexed vector (:blocks m))]
    (when-let [nb (:netbank b)]
      (when-let [mem (:memory b)]
        (.warm_start_from nb
                          (.- mem K_a)
                          (.- mem K_b))
        (println (format "  NetBank[layer %d] K_a/K_b realigned from Local (V untouched)" i))))))

(defn forward
  "Run the model.
     tokens:       (B, T) int64
     short-caches: nil OR vector of n-layers per-layer [k v]
     long-caches:  nil OR vector of n-layers per-layer [k v]
     skip-bank?:   Phase-5 draft mode — bypass PKM lookup
     trunk-ids:    (B,) long torch tensor or nil — per-batch-row Local
                   Bank V_local trunk routing. nil at n-trunks=1.
   Returns [logits new-short-caches new-long-caches]."
  ([m tokens] (forward m tokens nil nil false nil))
  ([m tokens short-caches] (forward m tokens short-caches nil false nil))
  ([m tokens short-caches long-caches] (forward m tokens short-caches long-caches false nil))
  ([m tokens short-caches long-caches skip-bank?] (forward m tokens short-caches long-caches skip-bank? nil))
  ([m tokens short-caches long-caches skip-bank? trunk-ids]
   (let [{:keys [tok-emb blocks norm-final rope-cos rope-sin mtp-head]} m
         n-layers     (count blocks)
         short-caches (or short-caches (vec (repeat n-layers nil)))
         long-caches  (or long-caches  (vec (repeat n-layers nil)))
         guard?       (pick-nan-guard?)
         x0           (tok-emb tokens)]
     (when guard? (nan-guard! "tok-emb" x0))
     (loop [i         0
            x         x0
            out-short []
            out-long  []
            ;; Aux-loss accumulators: distill MSE and Local-PKM z-loss
            ;; flow through the block_forward return chain instead of
            ;; module-side .last_X stashes — see attention_kernel's
            ;; `attention` body for the collect-and-clear logic. We
            ;; accumulate them here as we walk the blocks so the totals
            ;; ride forward's return and train-step doesn't need a
            ;; second pass via collect-z-loss / collect-distill-loss.
            ;; Start at 0 (python int); the first non-nil block term
            ;; promotes the accumulator to a scalar tensor, after which
            ;; subsequent + ops are tensor-scalar adds.
            distill-acc 0
            z-acc       0]
       (if (= i n-layers)
         (let [x'         (norm-final x)
               _          (when guard? (nan-guard! "norm-final" x'))
               logits     (torch/matmul x' (.t (.- tok-emb weight)))
               _          (when guard? (nan-guard! "logits" logits))
               ;; Multi-token-prediction aux logits: independent linear
               ;; head from the same final hidden state. Used by
               ;; train-step to compute t+2 CE loss when MMLLM_MTP_COEF
               ;; > 0; nil and skipped otherwise.
               aux-logits (when mtp-head (mtp-head x'))
               _          (when (and guard? aux-logits) (nan-guard! "aux-logits" aux-logits))]
           ;; Return slots:
           ;;   0 logits          5 distill_total (scalar tensor or 0)
           ;;   1 short_caches    6 z_total       (scalar tensor or 0)
           ;;   2 long_caches
           ;;   3 aux_logits
           ;;   4 final_x         — only train-step's importance-head
           ;;                       path consumes >=5th element; older
           ;;                       callers destructure 3-4 and ignore.
           [logits out-short out-long aux-logits x' distill-acc z-acc])
         (let [block      (nth blocks i)
               sc         (nth short-caches i)
               lc         (nth long-caches  i)
               [x' s' l' distill-term z-term]
                          (block-forward block x rope-cos rope-sin sc lc skip-bank? trunk-ids)]
           (when guard? (nan-guard! (format "block-%d-out" i) x'))
           (recur (inc i) x' (conj out-short s') (conj out-long l')
                  (if distill-term (+ distill-acc distill-term) distill-acc)
                  (if z-term       (+ z-acc       z-term)       z-acc))))))))

;;; ─────────────────────── training ───────────────────────

(def ^:private toy-text
  (str "she sells seashells by the seashore. "
       "the shells she sells are surely seashells. "
       "so if she sells shells on the seashore, "
       "i'm sure she sells seashore shells. "))

(defn batch
  "Sample B random (T+1)-windows from `data`; split into x, y.

   `data` may be uint8 (mmap-backed; multi-GB corpora) or int64
   (preloaded; small corpora). We .long()-cast the sampled batch
   so the model always sees int64 token IDs — for B=128, T=128
   that's 132 KB per batch, trivial regardless of corpus size."
  [data B T]
  (let [N    (.size data 0)
        idx  (torch/randint 0 (- N T 1) (python/tuple [B])
                            ** :dtype torch/long)
        rows (python/list)]
    (doseq [i (.tolist idx)]
      (.append rows (.narrow data 0 i (+ T 1))))
    (let [win (.long (torch/stack rows))]
      [(.narrow win 1 0 T)
       (.narrow win 1 1 T)])))

(defn batch-multi-trunk
  "Content-sharded multi-trunk batch sampler. Splits `data` into
   `n-trunks` contiguous byte ranges (trunk t gets bytes
   [t*N/n_trunks, (t+1)*N/n_trunks)) and samples `B-per-trunk` windows
   from each range. Returns [x, y, trunk-ids] where:

     x, y       : (n-trunks * B-per-trunk, T) int64 token windows
     trunk-ids  : (n-trunks * B-per-trunk,) long, value = which trunk

   Row layout: [trunk0×B_per_trunk, trunk1×B_per_trunk, …]. The model's
   Local Bank uses trunk-ids to route each row's bank gather into its
   trunk's V slice; the shared trunk (dense weights, K_a, K_b, NetBank)
   sees gradients summed across all rows.

   At n-trunks=1, equivalent to `(batch data B-per-trunk T)` with a
   zero trunk-ids vector — kept as a separate function so the legacy
   path stays free of multi-trunk overhead."
  [data n-trunks B-per-trunk T]
  (let [N             (.size data 0)
        per-trunk-N   (quot N n-trunks)
        rows          (python/list)
        ids           (python/list)]
    (doseq [t (range n-trunks)]
      (let [t-start  (* t per-trunk-N)
            t-end    (- (+ t-start per-trunk-N) T 1)
            t-len    (- t-end t-start)
            offs     (.add (torch/randint 0 t-len (python/tuple [B-per-trunk])
                                          ** :dtype torch/long)
                           t-start)]
        (doseq [i (.tolist offs)]
          (.append rows (.narrow data 0 i (+ T 1)))
          (.append ids  t))))
    (let [win        (.long (torch/stack rows))
          trunk-ids  (torch/tensor ids ** :dtype torch/long)]
      [(.narrow win 1 0 T)
       (.narrow win 1 1 T)
       trunk-ids])))

(defn pick-z-loss-coef
  "Coefficient on the PKM query z-loss term. Reads MMLLM_Z_LOSS_COEF
   (default 1e-5). 0 disables. ST-MoE uses 1e-3 for whole-model
   router z; PKM has more sub-key matmuls per query so a smaller
   coefficient is appropriate."
  []
  (python/float (.get (.- os environ) "MMLLM_Z_LOSS_COEF" "1e-5")))

(defn collect-z-loss
  "Sum the per-layer z-loss terms accumulated by ProductKeyMemory.forward
   on the most recent forward pass. Returns a scalar tensor on the
   model device, or 0.0 when disabled / no PKM forward in this pass."
  [m]
  (let [coef (pick-z-loss-coef)]
    (if (zero? coef)
      0.0
      (let [terms (->> (:blocks m)
                       (map (fn [b]
                              (when-let [mem (:memory b)]
                                (.- mem last_z_loss))))
                       (filter some?))]
        (if (empty? terms)
          0.0
          (* coef (reduce + terms)))))))

(defn collect-mtp-loss
  "Compute the multi-token-prediction (t+2) auxiliary CE loss when
   `aux-logits` is non-nil, scaled by MMLLM_MTP_COEF. The aux head
   at position p predicts byte at p+2; we score the inner T-1
   positions (positions [0..T-2] of aux logits paired with y[1..T-1])
   since the t+2 target for position T-1 is outside the window.

   Returns a scalar tensor when active, 0.0 otherwise."
  [aux-logits y T]
  (if (nil? aux-logits)
    0.0
    (let [coef            (pick-mtp-coef)
          aux-logits-trim (.narrow aux-logits 1 0 (- T 1))
          y-trim          (.narrow y 1 1 (- T 1))]
      (* coef (F/cross_entropy
               (.reshape aux-logits-trim -1 vocab-size)
               (.reshape y-trim -1))))))

(defn ^:private delim-mask-for
  "y: (B, T) int64 byte tokens → (B, T) float bool mask: 1.0 where the
   byte is in DELIM_BYTES, 0.0 otherwise. Used as BCE target for the
   delimiter aux head."
  [y]
  ;; Build OR over the delimiter set: y == 0x7B | y == 0x7D | …
  (let [mask (torch/zeros_like y ** :dtype torch/bool)]
    (doseq [b DELIM_BYTES]
      (.logical_or_ mask (.eq y b)))
    (.float mask)))

(defn collect-delim-loss
  "Compute the JSON-delimiter aux head's BCE loss when the head is
   present and MMLLM_DELIM_AUX_COEF > 0.

   delim-head produces (B, T, 1) logit per position over the trunk's
   final hidden state. Target: 1.0 where y[t] is a structural delim,
   0.0 otherwise. BCEWithLogits handles sigmoid internally for stability.

   Returns scaled scalar tensor (active) or 0.0 (disabled / nil head)."
  [m final-x y]
  (let [coef (pick-delim-aux-coef)
        head (:delim-head m)]
    (if (or (zero? coef) (nil? head))
      0.0
      (let [logits (.squeeze (head final-x) -1)   ;; (B, T)
            target (delim-mask-for y)             ;; (B, T)
            loss   (F/binary_cross_entropy_with_logits logits target)]
        (* coef loss)))))

(defn train-step
  ([m opt-dense opt-sparse x y]
   (train-step m opt-dense opt-sparse nil x y false nil))
  ([m opt-dense opt-sparse opt-sparse-net x y]
   (train-step m opt-dense opt-sparse opt-sparse-net x y false nil))
  ([m opt-dense opt-sparse opt-sparse-net x y freeze-local?]
   (train-step m opt-dense opt-sparse opt-sparse-net x y freeze-local? nil))
  ([m opt-dense opt-sparse opt-sparse-net x y freeze-local? trunk-ids]
   (let [device       (:device m)
         x            (.to x device)
         y            (.to y device)
         trunk-ids    (when trunk-ids (.to trunk-ids device))
         [logits _ _ aux-logits final-x distill-total z-total]
                      (forward m x nil nil false trunk-ids)
         T            (.size y 1)
         ;; Router-smarts loss path. focal_ce with gamma=0 reduces to
         ;; plain CE, so this is behavior-preserving when no env vars
         ;; are set. When MMLLM_FOCAL_GAMMA > 0, hard bytes get up-
         ;; weighted via (1-p)^gamma. When MMLLM_IMPORTANCE_HEAD=true,
         ;; an additional self-supervised per-position multiplier kicks
         ;; in (regularized to mean=1).
         gamma        (pick-focal-gamma)
         logits-flat  (.reshape logits -1 vocab-size)
         y-flat       (.reshape y -1)
         per-pos-ce   (rs/focal_ce logits-flat y-flat
                                   ** :gamma gamma :reduction "none")
         ;; #5 spike: schema-mask weight on positions immediately after
         ;; a JSON delimiter byte. Default w=1.0 (no-op). When > 1.0,
         ;; up-weights CE on "commit" positions where the byte right
         ;; before was `{` `:` `,` `"` `]` `}` `[` or newline.
         schema-w     (pick-schema-mask-weight)
         per-pos-ce   (if (= schema-w 1.0)
                        per-pos-ce
                        (let [w-mask (.reshape (schema-mask-of x schema-w) -1)]
                          (.mul per-pos-ce w-mask)))
         ;; FIM loss mask: when MMLLM_FIM_LOSS_MASK_MIDDLE_ONLY=true,
         ;; zero per-position CE outside <|fim_mid|>...<|fim_eom|>. Examples
         ;; without those markers (non-FIM batches) get all-1 mask, no-op.
         per-pos-ce   (if (pick-fim-loss-mask-middle-only?)
                        (let [fim-mask (.to (fim/fim_loss_mask x) (.- per-pos-ce device))]
                          (.mul per-pos-ce (.reshape fim-mask -1)))
                        per-pos-ce)
         ih           (:importance-head m)
         ce-loss      (if ih
                        (let [imp-raw  (ih final-x)
                              imp-flat (.reshape imp-raw -1)]
                          ;; v2: IH is a detached, mean-1-normalized
                          ;; multiplier on per_pos_ce (no grad from main
                          ;; loss into IH) PLUS a separate aux MSE that
                          ;; trains IH to predict per_pos_ce. See
                          ;; rs/importance_weighted_loss for path
                          ;; semantics. Replaces the v1 design which had
                          ;; a sign bug — gradient pushed IH down on
                          ;; hard bytes, collapsing training signal to 0.
                          (rs/importance_weighted_loss
                            per-pos-ce imp-flat
                            ** :aux_coef (pick-importance-aux-coef)))
                        (.mean per-pos-ce))
         ;; Plain CE for operator-facing prints + per-corpus tracker.
         ;; The focal+IH-weighted ce-loss is what backward sees, but it
         ;; isn't directly comparable to historical (pre-router-smarts)
         ;; train-loss / val_bpc numbers because (a) IH's softplus(0) ≈
         ;; 0.69 multiplier and (b) focal's (1-p)^γ down-weighting of
         ;; easy bytes both shrink the printed scalar in misleading
         ;; ways. plain-ce is computed cheaply from the same logits we
         ;; already have and reflects "what would CE have been without
         ;; router-smarts" — directly comparable to phases 0-N.
         plain-ce     (F/cross_entropy logits-flat y-flat)
         ;; Aux losses now flow through `forward`'s return chain
         ;; (distill-total, z-total) instead of module-side .last_X
         ;; stashes. This is what makes gradient checkpointing actually
         ;; reduce backward RAM — the stashes used to keep autograd
         ;; alive on each block's intermediates past the block's
         ;; checkpoint scope. See attention_kernel's `attention` body
         ;; for how each block contributes its per-layer term.
         ;;
         ;; Apply coefficients here. z-total is the sum across local
         ;; banks (collect-z-loss used mean; we keep sum since the
         ;; coef is operator-tuned and the count is fixed at 8).
         ;; distill-total is the sum across 3-way gate layers (8 of
         ;; the 32 in the asymmetric architecture); divide by 8 to
         ;; match the mean semantics that collect-distill-loss had.
         z-coef       (pick-z-loss-coef)
         z-loss       (if (and (zero? z-coef)
                               (or (number? z-total) (= 0 z-total)))
                        0.0
                        (* z-coef z-total))
         d-coef       (let [metrics (:metrics m)
                            step    (when metrics (.get metrics "current_step" nil))
                            total   (when metrics (.get metrics "total_steps"  nil))]
                        (if (and step total (pos? (python/int total)))
                          (pick-distill-coef (python/int step) (python/int total))
                          (pick-distill-coef)))
         n-distill-layers 8 ;; number of 3-way gate (= local-bank) layers
         distill-loss (if (or (zero? d-coef)
                              (number? distill-total)
                              (= 0 distill-total))
                        0.0
                        (* d-coef (/ distill-total (python/float n-distill-layers))))
         mtp-loss     (collect-mtp-loss aux-logits y T)
         delim-loss   (collect-delim-loss m final-x y)
         ;; K_a/K_b alignment between Net and Local — no-op when
         ;; MMLLM_K_ALIGN_COEF=0 (the default). When enabled, pulls
         ;; Net's first sqrt_local rows of K_a/K_b toward Local's
         ;; (detached) every step. Pairs with one-shot
         ;; MMLLM_REWARM_NETBANK_KEYS=true at run start.
         k-align-loss (collect-k-align-loss m)
         ;; Stash distill / delim / k-align losses on :metrics for printer / JSONL.
         _            (when-let [metrics (:metrics m)]
                        (.__setitem__ metrics "distill_loss"
                                      (if (number? distill-loss)
                                        (python/float distill-loss)
                                        (.item distill-loss)))
                        (.__setitem__ metrics "delim_loss"
                                      (if (number? delim-loss)
                                        (python/float delim-loss)
                                        (.item delim-loss)))
                        (.__setitem__ metrics "k_align_loss"
                                      (if (number? k-align-loss)
                                        (python/float k-align-loss)
                                        (.item k-align-loss))))
         ;; Sum non-zero terms; numerics matter — adding a Python 0.0 to
         ;; a tensor would coerce to a fp tensor scalar of value 0, fine.
         loss         (cond-> ce-loss
                        (not (number? z-loss))         (+ z-loss)
                        (not (number? mtp-loss))       (+ mtp-loss)
                        (not (number? distill-loss))   (+ distill-loss)
                        (not (number? delim-loss))     (+ delim-loss)
                        (not (number? k-align-loss))   (+ k-align-loss))]
     ;; Hard-abort on NaN/Inf loss before backward — a degenerate step
     ;; would propagate NaN into all params, opt state, and bank V; the
     ;; ckpt-save next event would then persist a poisoned model. Raising
     ;; here gives `train-long`'s try/finally a chance to checkpoint
     ;; pre-poisoning and exit non-zero so the operator notices.
     (when (or (.item (.isnan loss)) (.item (.isinf loss)))
       (throw (python/RuntimeError
                (format "train-step aborted: loss=%s (ce=%s plain=%s) is NaN or Inf — model may be poisoned"
                        (.item loss) (.item ce-loss) (.item plain-ce)))))
     (.zero_grad opt-dense)
     (.zero_grad opt-sparse)
     (when opt-sparse-net (.zero_grad opt-sparse-net))
     (.backward loss)
     ;; #1 spike: cold-row gradient boost on Local Bank V. No-op when
     ;; MMLLM_BANK_COLD_BOOST=0. Applied after backward, before opt step,
     ;; so SparseAdam's update sees the rescaled gradient.
     (doseq [b (:blocks m)]
       (when-let [mem (:memory b)]
         (spr/boost_cold_row_grads_ mem)))
     ;; P3 replay path: zero Local Bank's grads after backward but
     ;; before optimizer.step() so the replay update flows only into
     ;; NetBank, dense projections, and carry — Local stays frozen on
     ;; mastered patterns it's already learned.
     (when freeze-local? (freeze-local-grads! m))
     ;; Gradient clipping on the AdamW (dense / router) param group.
     ;; SparseAdam's per-row updates on bank V are robust to single
     ;; large grads (the update is localized per touched row) so we
     ;; skip clipping there. We pull the dense params from opt-dense
     ;; itself: param_groups[0]["params"] is the canonical handle
     ;; already grouped for the optimizer, so we don't re-derive
     ;; from the model on every step.
     (let [max-norm (pick-grad-clip-max-norm)]
       (when (pos? max-norm)
         (nn-utils/clip_grad_norm_
           (.__getitem__ (nth (.- opt-dense param_groups) 0) "params")
           max-norm)))
     (.step opt-dense)
     (.step opt-sparse)
     (when opt-sparse-net (.step opt-sparse-net))
     ;; Return plain CE — comparable to historical numbers. The
     ;; focal+IH-weighted loss is internal to backward.
     (.item plain-ce))))

(defn train
  "Train on the toy corpus. Returns the trained model.

   Uses TWO optimizers: AdamW for dense params (K_a, K_b, model
   weights) and SparseAdam for the memory bank's V.weight per
   block (sparse-grad via nn.Embedding(sparse=True))."
  ([] (train default-config 200))
  ([config steps]
   (let [m          (build-model config)
         data       (encode toy-text)
         opt-dense  (optim/AdamW    (python/list (parameters m))        ** :lr (pick-lr-dense))
         opt-sparse ((pick-sparse-optimizer) (python/list (sparse-parameters m)) ** :lr (pick-lr-bank))
         T          (:seq-len config)
         sqrt-n     (pick-sqrt-n config)
         bank-n     (* sqrt-n sqrt-n)
         mmap-note  (if (:memory-mmap-path config)
                      (str " mmap=" (:memory-mmap-path config))
                      " in-RAM")]
     (println (format "training %d steps; T=%d, d=%d, layers=%d"
                      steps T (:d-model config) (:n-layers config)))
     (println (format "   short: %dQ / %dKV    long: %dQ → memory(%d entries × %d layers,%s)"
                      (:n-short-heads config) (:n-short-kv-heads config)
                      (:n-long-heads  config) bank-n (:n-layers config) mmap-note))
     (doseq [step (range steps)]
       (let [[x y] (batch data (pick-batch) T)
             l     (train-step m opt-dense opt-sparse x y)]
         (when (zero? (mod step 20))
           (println (format "  step %4d  loss %.3f" step l)))))
     m)))

;;; ─────────────────────── sampling ───────────────────────

(defn- set-eval-mode! [m]
  (.eval (:tok-emb m))
  (.eval (:norm-final m))
  (doseq [b (:blocks m)]
    (doseq [k [:norm1 :norm2 :q-proj
               :k-proj-s :v-proj-s
               :k-proj-l :v-proj-l
               :o-proj :gate-proj :up-proj :down-proj
               :long-gate :bank-query :bank-feedback]]
      (.eval (get b k)))
    (when-let [mem (:memory b)] (.eval mem))
    (when-let [nb (:netbank b)] (.eval nb))
    (when-let [c (:carry b)] (.eval c)))
  (when-let [mh (:mtp-head m)] (.eval mh))
  (when-let [ih (:importance-head m)] (.eval ih)))

(defn- set-train-mode! [m]
  "Inverse of set-eval-mode!. Call before every train step so the
   model's training-mode flags get restored after any intermediate
   eval-bpc / ablation / sample call. Without this, Local Bank's
   `if self.training:` guards (slot tracking, z-loss accumulator)
   silently disable themselves after the first eval and the bank
   trains with no regularizer + zero diagnostics."
  (.train (:tok-emb m))
  (.train (:norm-final m))
  (doseq [b (:blocks m)]
    (doseq [k [:norm1 :norm2 :q-proj
               :k-proj-s :v-proj-s
               :k-proj-l :v-proj-l
               :o-proj :gate-proj :up-proj :down-proj
               :long-gate :bank-query :bank-feedback]]
      (.train (get b k)))
    (when-let [mem (:memory b)] (.train mem))
    (when-let [nb (:netbank b)] (.train nb))
    (when-let [c (:carry b)] (.train c)))
  (when-let [mh (:mtp-head m)] (.train mh))
  (when-let [ih (:importance-head m)] (.train ih)))

(defn sample
  "Generate `n` characters after `prompt`. Threads BOTH short cache
   (RoPE'd, recent) and long cache (set-style, episodic). Long heads
   ALSO query the bank V (semantic memory) — those two long-tier
   sources are summed inside attention.

   `forward-fn` (optional) overrides the forward callable — used by
   bench-inference to swap in a torch.compile-wrapped forward
   (Phase-1a). Defaults to the eager `forward` defn.

   `temperature` (optional, default 1.0):
     0.0  — greedy / argmax over vocab (deterministic). Use for
            format-critical evals where you want to measure the model's
            mode rather than its full output distribution. mmllm is
            byte-level (256-token vocab), so each generated byte is one
            independent sampling decision; at temp=1.0 a 30-byte JSON
            envelope needs ~30 sequentially-correct samples, which
            compounds against format-validity even when the model has
            high per-position confidence.
     1.0  — standard multinomial over softmax(logits) (legacy).
     >0   — multinomial over softmax(logits / temperature). Lower
            sharpens the distribution; higher flattens it."
  ([m prompt n] (sample m prompt n forward 1.0))
  ([m prompt n forward-fn] (sample m prompt n forward-fn 1.0))
  ([m prompt n forward-fn temperature]
   (set-eval-mode! m)
   (let [device                 (:device m)
         prompt-toks            (-> prompt encode (.unsqueeze 0) (.to device))
         [logits short long]    (forward-fn m prompt-toks nil nil)
         greedy?                (= (float temperature) 0.0)]
     (loop [step    0
            short-c short
            long-c  long
            prev    logits
            toks    prompt-toks]
       (if (= step n)
         (decode (.to (.squeeze toks 0) "cpu"))
         (let [last-log              (.select prev 1 -1)
               next-tok              (if greedy?
                                       (.unsqueeze
                                         (torch/argmax last-log ** :dim -1)
                                         -1)
                                       (let [scaled (if (= (float temperature) 1.0)
                                                      last-log
                                                      (.div last-log temperature))
                                             probs  (F/softmax scaled ** :dim -1)]
                                         (torch/multinomial probs 1)))
               [new-log new-s new-l] (forward-fn m next-tok short-c long-c)]
           (recur (inc step) new-s new-l new-log
                  (torch/cat (python/list [toks next-tok]) ** :dim 1))))))))

(defn sample-batch
  "Phase-2 continuous-batching decoder. Decodes `n` tokens in
   parallel for B independent sequences, all kicked off from the
   same prompt (synchronized batching: every forward processes a
   (B, 1) batch). Measures pure batched-matmul throughput without
   ragged-batch padding/masking complications.

   Dense Linear matmuls become (B, in)·(in, out) GEMMs with
   substantially better throughput per FLOP than B independent
   (1, in)·(in, out) calls. Bank K_a/K_b matmuls batch the same
   way; bank V row gather is per-batch-row (each sequence has its
   own top-K).

   Per-sequence KV cache: ~21 MB at MAX_T=4096 + 5 layers + (k+v)
   for both short and long tiers. At B=64 → ~1.3 GB cache RAM.
   Bank itself is shared (one mmap regardless of B).

   Returns nil — this is a throughput bench, not a real generator.
   A production server would interleave per-user prompts with an
   attention mask + per-sequence positions; deferred."
  [m prompt n B]
  (set-eval-mode! m)
  (let [device                 (:device m)
        prompt-1               (-> prompt encode (.unsqueeze 0) (.to device))
        T-prompt               (.size prompt-1 1)
        prompt-toks            (.contiguous (.expand prompt-1 B T-prompt))
        [logits short long]    (forward m prompt-toks)]
    (loop [step    0
           short-c short
           long-c  long
           prev    logits]
      (if (= step n)
        nil
        (let [last-log              (.select prev 1 -1)
              probs                 (F/softmax last-log ** :dim -1)
              next-tok              (torch/multinomial probs 1)
              [new-log new-s new-l] (forward m next-tok short-c long-c)]
          (recur (inc step) new-s new-l new-log))))))

;;; ─────────────────────── inference benchmark ───────────────────────

(defn bench-inference
  "Time the per-token inference path. Builds the model, loads dense
   ckpt + bank mmap, runs `n-warm` warmup tokens (kernel JIT, page
   cache priming), then times `n-time` tokens generated via `sample`.
   Prints tok/sec and ms/tok.

   Bank placement controlled by MMLLM_BANK_ON_GPU env var:
     true  → bank V lives in cuda VRAM (fastest single-instance path)
     false → bank V is mmap'd from disk; per-token cross-device top-K
             gather (the multi-tenant-friendly path)."
  [config base-path ckpt-step bank-path n-warm n-time]
  (let [cfg    (assoc config :memory-mmap-path bank-path)
        m      (build-model cfg)
        device (:device m)]
    (when ckpt-step
      (let [path  (str base-path ".ckpts/step-" ckpt-step)
            ;; Ckpt may have been saved on cuda; map to current device so
            ;; CPU benches don't fail with "deserialize object on a CUDA
            ;; device but cuda not available".
            saved (python/list (torch/load (str path "/dense.pt")
                                           ** :map_location device))]
        (println (format "  loaded ckpt: %s (%d dense param tensors)" path (count saved)))
        (doseq [[p s] (map vector (parameters m) saved)]
          (.copy_ (.- p data) s))))
    (set-eval-mode! m)
    (torch/set_grad_enabled false)
    ;; Phase-1 step C1: optional bf16 cast of dense weights. Engages
    ;; AMX matmul on Intel Sapphire Rapids+ / AVX-512 BF16 on Zen4+ /
    ;; Apple M-series neon BF16. Bank V (the trained content) and the
    ;; bank's K_a/K_b sub-keys stay at their native dtype; the
    ;; surrounding torch.amp.autocast (below) handles dtype mixing at
    ;; the bank-query boundary so the bf16/fp32 hop costs one cast per
    ;; bank lookup, not per-token-everywhere.
    (let [bf16? (= "bf16" (.lower (.get (.- os environ) "MMLLM_DENSE_DTYPE" "")))]
      (when bf16?
        (.to (:tok-emb m) torch/bfloat16)
        (.to (:norm-final m) torch/bfloat16)
        (doseq [b (:blocks m)]
          (doseq [k [:norm1 :norm2 :q-proj :k-proj-s :v-proj-s :k-proj-l :v-proj-l
                     :o-proj :gate-proj :up-proj :down-proj
                     :long-gate :bank-query :bank-feedback]]
            (.to (get b k) torch/bfloat16)))
        (println "  dense weights cast to bfloat16 (bank stays at native dtype; autocast bridges)"))
      (let [forward-fn (rt/maybe_compile_forward forward)
            ;; When bf16 is enabled, wrap the inference loop in CPU
            ;; bf16 autocast so matmuls between bf16 weights and any
            ;; lingering fp32 tensors (notably K_a/K_b inside the
            ;; bank) get cast at-op, hitting the AMX matmul path on
            ;; Intel SPR+. Otherwise use a no-op nullcontext so the
            ;; control flow stays the same.
            autocast-ctx (if bf16?
                           (amp/autocast ** :device_type "cpu" :dtype torch/bfloat16)
                           (contextlib/nullcontext))]
        (println (format "  device=%s  bank_on_gpu=%s  sqrt_n=%d  bank=%s"
                         device
                         (.lower (.get (.- os environ) "MMLLM_BANK_ON_GPU" "false"))
                         (pick-sqrt-n config)
                         bank-path))
        (try
          (with [_ autocast-ctx]
            (let [prompt "the quick brown fox jumps over the lazy dog. "]
              (println (format "  warmup: %d tokens …" n-warm))
              (sample m prompt n-warm forward-fn)
              (sync-device! device)
              (println (format "  timed:  %d tokens …" n-time))
              (let [t0  (time/time)
                    _   (sample m prompt n-time forward-fn)
                    _   (sync-device! device)
                    dt  (- (time/time) t0)
                    tps (/ (python/float n-time) dt)
                    ms  (* 1000.0 (/ dt (python/float n-time)))]
                (println)
                (println (format "  RESULT: %d tokens in %.3fs → %.2f tok/sec  (%.3f ms/tok)"
                                 n-time dt tps ms)))))
          (finally
            (torch/set_grad_enabled true)))))))

(defn bench-inference-spec
  "Phase-5 speculative-decoding bench. Same setup as bench-inference,
   but generation goes through `mmllm.spec_decode.speculative_sample`
   with the bank-zeroed forward as the cheap draft.

   Reports tok/sec (wall-clock generation rate) plus speculative
   stats: total drafted, accepted, acceptance rate, outer iterations.
   Compare to bench-inference to see whether spec dec wins on this
   ckpt + this hardware."
  [config base-path ckpt-step bank-path n-warm n-time K]
  (let [cfg    (assoc config :memory-mmap-path bank-path)
        m      (build-model cfg)
        device (:device m)]
    (when ckpt-step
      (let [path  (str base-path ".ckpts/step-" ckpt-step)
            saved (python/list (torch/load (str path "/dense.pt")
                                           ** :map_location device))]
        (println (format "  loaded ckpt: %s (%d dense param tensors)" path (count saved)))
        (doseq [[p s] (map vector (parameters m) saved)]
          (.copy_ (.- p data) s))))
    (set-eval-mode! m)
    (torch/set_grad_enabled false)
    (println (format "  device=%s  bank_on_gpu=%s  sqrt_n=%d  bank=%s  K=%d"
                     device
                     (.lower (.get (.- os environ) "MMLLM_BANK_ON_GPU" "false"))
                     (pick-sqrt-n config)
                     bank-path K))
    (try
      (let [prompt-toks (-> "the quick brown fox jumps over the lazy dog. "
                            encode (.unsqueeze 0) (.to device))]
        (println (format "  warmup: %d tokens (spec K=%d) …" n-warm K))
        (spec/speculative_sample forward m prompt-toks n-warm ** :K K)
        (println (format "  timed:  %d tokens (spec K=%d) …" n-time K))
        (let [t0    (time/time)
              [_ stats] (spec/speculative_sample forward m prompt-toks n-time ** :K K)
              dt    (- (time/time) t0)
              tps   (/ (python/float n-time) dt)
              ms    (* 1000.0 (/ dt (python/float n-time)))]
          (println)
          (println (format "  RESULT spec K=%d: %d tokens in %.3fs → %.2f tok/sec  (%.3f ms/tok)"
                           K n-time dt tps ms))
          (println (format "    drafted=%d  accepted=%d  rate=%.1f%%  iters=%d  resampled=%d  toks/iter=%.2f"
                           (.get stats "n_drafted")
                           (.get stats "n_accepted")
                           (* 100.0 (.get stats "acceptance_rate"))
                           (.get stats "n_outer_iters")
                           (.get stats "n_resampled")
                           (.get stats "avg_tokens_per_iter")))))
      (finally
        (torch/set_grad_enabled true)))))

(defn bench-inference-batch
  "Phase-2 continuous-batching bench. Decodes n_time tokens for B
   parallel sequences via `sample-batch`. Reports per-sequence
   tok/sec and aggregate (B × per-sequence) tok/sec.

   At B=1 should match `bench-inference`. At B=4-64 the aggregate
   should grow with batched-matmul throughput up to a saturation
   point (typically B ≈ 32-64 on a few-core CPU)."
  [config base-path ckpt-step bank-path n-warm n-time B]
  (let [cfg    (assoc config :memory-mmap-path bank-path)
        m      (build-model cfg)
        device (:device m)]
    (when ckpt-step
      (let [path  (str base-path ".ckpts/step-" ckpt-step)
            saved (python/list (torch/load (str path "/dense.pt")
                                           ** :map_location device))]
        (println (format "  loaded ckpt: %s (%d dense param tensors)" path (count saved)))
        (doseq [[p s] (map vector (parameters m) saved)]
          (.copy_ (.- p data) s))))
    (set-eval-mode! m)
    (torch/set_grad_enabled false)
    (println (format "  device=%s  bank_on_gpu=%s  sqrt_n=%d  bank=%s  B=%d"
                     device
                     (.lower (.get (.- os environ) "MMLLM_BANK_ON_GPU" "false"))
                     (pick-sqrt-n config)
                     bank-path B))
    (try
      (let [prompt "the quick brown fox jumps over the lazy dog. "]
        (println (format "  warmup: %d tokens × B=%d …" n-warm B))
        (sample-batch m prompt n-warm B)
        (sync-device! device)
        (println (format "  timed:  %d tokens × B=%d …" n-time B))
        (let [t0  (time/time)
              _   (sample-batch m prompt n-time B)
              _   (sync-device! device)
              dt  (- (time/time) t0)
              per-seq-tps (/ (python/float n-time) dt)
              agg-tps     (* B per-seq-tps)
              ms          (* 1000.0 (/ dt (python/float n-time)))]
          (println)
          (println (format "  RESULT batch B=%d: %d tokens/seq in %.3fs"
                           B n-time dt))
          (println (format "    per-sequence: %.2f tok/sec  (%.3f ms/tok)"
                           per-seq-tps ms))
          (println (format "    aggregate:    %.2f tok/sec  (%d × per-seq)"
                           agg-tps B))))
      (finally
        (torch/set_grad_enabled true)))))

;;; ─────────────────────── agentic eval against a ckpt ───────────────────────

(defn eval-agent
  "Run agentic evals against a ckpt: load model + bank, then for each
   held-out SFT transcript feed the prompt prefix, generate `gen-len`
   chars, score the produced assistant turn against gold via
   `mmllm.evals.score_predictions`.

   Writes one JSONL row to log-path per call (same shape as the
   training-loop eval events so the timelines plot together).

   `eval-test-path` is a `.test.bin` produced by
   `mmllm.datasets.prepare_hf_dataset` against an SFT-style dataset
   (commitpackft, xlam, ...). Uses the default chat template — if you
   re-prep with different delimiters, the prompt/gold split here will
   be wrong (silently mis-scored). Lock the template before running."
  [config base-path ckpt-step bank-path eval-test-path eval-name
   n-samples gen-len log-path]
  (let [cfg      (assoc config :memory-mmap-path bank-path)
        m        (build-model cfg)
        device   (:device m)
        ckpt-dir (str base-path ".ckpts")]
    (when ckpt-step
      (let [path  (str ckpt-dir "/step-" ckpt-step)
            saved (python/list (torch/load (str path "/dense.pt")
                                           ** :map_location device))]
        (println (format "  loaded ckpt: %s (%d dense param tensors)"
                         path (count saved)))
        (doseq [[p s] (map vector (parameters m) saved)]
          (.copy_ (.- p data) s))
        ;; Restore bank V from <ckpt-dir>/bank-latest.<i>.bin — same
        ;; fix as eval-bpc-on-path. Without this the model generates
        ;; with random bank V (when MMLLM_BANK_ON_GPU=true) which
        ;; trashes the agent eval entirely. See eval-bpc-on-path
        ;; comment for full diagnosis.
        (doseq [[i b] (map-indexed vector (:blocks m))]
          (when-let [mem (:memory b)]
            (try
              (.load_from_mmap mem
                               (str ckpt-dir "/bank-latest." i ".bin"))
              (catch python/Exception e
                (println (format "  WARN: bank V layer %d load failed (%s) — using random init"
                                 i e))))))
        (println (format "  bank V load attempted from %s/bank-latest.{0..%d}.bin"
                         ckpt-dir (dec (count (:blocks m)))))))
    (set-eval-mode! m)
    (torch/set_grad_enabled false)
    (println (format "  eval-agent[%s]: ckpt=%s test=%s n=%d gen=%d"
                     eval-name (or ckpt-step "init") eval-test-path
                     n-samples gen-len))
    (let [;; Cap prompt bytes at model's max-pos minus gen-len so we
          ;; don't blow past the RoPE cache. cpu-tiny's max-pos=512
          ;; while default-config's is 1024 — both must work.
          max-pos       (:max-pos config)
          max-prompt    (max 64 (- max-pos gen-len 8))
          samples (python/list (ev/iter_eval_samples eval-test-path
                                                     ** :max_samples n-samples
                                                     :max_prompt_bytes max-prompt))
          verbose?      (= (.get (.- os environ) "MMLLM_AGENT_EVAL_VERBOSE" "false") "true")]
      (println (format "  iter_eval_samples returned %d samples (max_prompt_bytes=%d)"
                       (count samples) max-prompt))
      (if (zero? (count samples))
        (println "  no samples in eval set — skipping")
        (let [t0          (time/time)
              predictions (python/list)
              golds       (python/list)
              end-mark    (.- ds/DEFAULT_TEMPLATE end)]
          (doseq [[idx s] (map-indexed vector samples)]
            (let [prompt    (.- s prompt)
                  gold      (.- s gold)
                  ;; Greedy decode for format-critical evals — at byte
                  ;; level a 30-byte JSON envelope needs 30 sequentially
                  ;; correct samples, and multinomial-at-temp-1 sabotages
                  ;; format-validity even when the model is well-trained.
                  raw       (sample m prompt gen-len forward 0.0)
                  ;; sample decodes prompt+generation; strip prefix.
                  gen-only  (if (.startswith raw prompt)
                              (subs raw (count prompt))
                              raw)
                  ;; Cut at first <|end|> if model emitted it.
                  end-idx   (.find gen-only end-mark)
                  pred      (if (>= end-idx 0)
                              (subs gen-only 0 end-idx)
                              gen-only)]
              (when verbose?
                (println (format "  [sample %d/%d] gold-len=%d pred-len=%d"
                                 idx (count samples) (count gold) (count pred)))
                (println (format "    PRED: %s" (python/repr pred)))
                (println (format "    GOLD: %s" (python/repr gold))))
              (.append predictions pred)
              (.append golds gold)))
          (let [results (ev/score_predictions predictions golds)
                dt      (- (time/time) t0)]
            (println (format "  → format=%.3f  name=%.3f  args=%.3f  exact=%.3f  (%.1fs)"
                             (.get results "format_validity")
                             (.get results "tool_name_match")
                             (.get results "tool_args_match")
                             (.get results "exact_match")
                             dt))
            (ev/append_eval_log log-path
                                (or ckpt-step 0) eval-name results)))))))

;;; ─────────────────────── multi-corpus mix sampler ───────────────────────

(defn pick-mix
  "Parse MMLLM_MIX env var into [[tensor weight] ...] or nil.

   Format: 'path1:w1,path2:w2,…' — weights don't need to sum to 1
   (we normalize at sample time via torch/multinomial). Each path
   is loaded mmap'd (uint8), so the working-set memory is bounded
   by sampled batches not corpus size, no matter how many sources
   you mix. Empty / unset env var → nil (caller falls back to the
   single train-path mode)."
  []
  (let [v (.strip (.get (.- os environ) "MMLLM_MIX" ""))]
    (when (pos? (count v))
      (python/list
        (for [entry (.split v ",")
              :let  [entry (.strip entry)]
              :when (pos? (count entry))]
          (let [colon (.rfind entry ":")
                path  (.strip (subs entry 0 colon))
                w-str (.strip (subs entry (inc colon)))
                ten   (corp/load-as-tensor path ** :use_mmap true)]
            [ten (python/float w-str)]))))))


(defn make-corpus-tracker
  "Per-corpus rolling loss tracker. Returns a Python dict whose values
   are deque-style ring buffers of recent losses per corpus index.

   `n-corpora`: how many corpora the mix has (sets up that many slots).
   `window`: rolling window size (default 50 — matches step-print cadence)."
  [n-corpora & {:keys [window] :or {window 50}}]
  (let [from-collections (python/__import__ "collections")
        deque-cls        (.- from-collections deque)
        d (python/dict)]
    (doseq [i (range n-corpora)]
      (.__setitem__ d i (deque-cls ** :maxlen window)))
    {:dq d :n n-corpora :window window}))

(defn record-corpus-loss!
  "Append a loss value to corpus `idx`'s rolling buffer."
  [tracker idx loss]
  (when (and tracker (>= idx 0) (< idx (:n tracker)))
    (.append (.__getitem__ (:dq tracker) idx) loss)))

(defn corpus-loss-summary
  "Snapshot per-corpus mean loss over the rolling window. Returns
   a Python list of [idx, n_seen, mean_loss] tuples for every corpus
   that has at least one loss recorded. Skips empty buckets."
  [tracker]
  (let [out (python/list)]
    (doseq [i (range (:n tracker))]
      (let [dq (.__getitem__ (:dq tracker) i)
            n  (count dq)]
        (when (pos? n)
          (.append out (python/tuple [i n (/ (sum dq) (python/float n))])))))
    out))

(defn mix-batch
  "One (x y) batch drawn from the weighted mix. Picks ONE corpus per
   batch (chunky mixing — proportions hold across many batches).

   `mix-tensors`: list of 1-D byte tensors (mmap'd).
   `mix-weights-t`: 1-D fp32 tensor of weights, same length as
   mix-tensors. Pre-built once at train-long startup so the hot
   loop only does the multinomial draw.

   Returns [x y idx] — `idx` is the corpus index this batch came from,
   used by the trainer to attribute loss back to a specific corpus
   (rolling per-corpus loss window in step prints)."
  [mix-tensors mix-weights-t B T]
  (let [idx     (.item (torch/multinomial mix-weights-t 1))
        ten     (nth mix-tensors idx)
        [x y]   (batch ten B T)]
    [x y idx]))

(defn mix-batch-multi-trunk
  "Multi-trunk variant of `mix-batch`. Picks ONE corpus per batch
   (preserves chunky-mix semantics + per-corpus loss attribution), then
   content-shards that corpus into N contiguous byte ranges and samples
   B-per-trunk windows from each.

   Returns [x y idx trunk-ids] where:
     x, y       : (N * B-per-trunk, T)
     idx        : single corpus index for the whole batch
     trunk-ids  : (N * B-per-trunk,) long, with value = trunk row owner.

   The compound semantic: each step's batch contains rows from one corpus
   (so per-corpus loss tracking still works) AND the N trunks specialize
   on disjoint slices of that corpus (so hill-climbing diversity is
   preserved). Across many batches, each trunk sees the full mix weighted
   the same way as the single-trunk path."
  [mix-tensors mix-weights-t n-trunks B-per-trunk T]
  (let [idx           (.item (torch/multinomial mix-weights-t 1))
        ten           (nth mix-tensors idx)
        [x y tids]    (batch-multi-trunk ten n-trunks B-per-trunk T)]
    [x y idx tids]))

;;; ─────────────────────── train on a real corpus ───────────────────────

(defn train-corpus
  "Train on a binary corpus file. The file is byte tokens (each
   octet is one token in our 256-vocab byte tokenizer). Random
   T+1-byte windows are sampled per step, same loop as `train`
   but the data source is the corpus rather than the toy text.

   If config has :memory-mmap-path set, each block's bank V is
   backed by <path>.<i>.bin — the V tensor is a zero-copy view
   over the file, sparse-grad updates only touched rows, so the
   bank can grow past RAM (the whole point of the architecture)."
  [config steps corpus-path]
  (let [m          (build-model config)
        data       (corp/load-as-tensor corpus-path)
        opt-dense  (optim/AdamW    (python/list (parameters m))         ** :lr (pick-lr-dense))
        opt-sparse ((pick-sparse-optimizer) (python/list (sparse-parameters m)) ** :lr (pick-lr-bank))
        T          (:seq-len config)
        sqrt-n     (pick-sqrt-n config)
        bank-n     (* sqrt-n sqrt-n)
        N          (.size data 0)
        mmap-note  (if (:memory-mmap-path config)
                     (str " mmap=" (:memory-mmap-path config))
                     " in-RAM")]
    (println (format "train-corpus: corpus=%d bytes (%d MB); %d steps; T=%d, B=%d, d=%d, layers=%d  lr=%g"
                     N (quot N 1048576) steps T (pick-batch) (:d-model config) (:n-layers config) (pick-lr)))
    (println (format "   short: %dQ / %dKV    long: %dQ → memory(%d entries × %d layers,%s)"
                     (:n-short-heads config) (:n-short-kv-heads config)
                     (:n-long-heads  config) bank-n (:n-layers config) mmap-note))
    (doseq [step (range steps)]
      (let [[x y] (batch data (pick-batch) T)
            l     (train-step m opt-dense opt-sparse x y)]
        (when (zero? (mod step 50))
          (println (format "  step %4d  loss %.3f" step l)))))
    m))

;;; ─────────────────────── BPC eval ───────────────────────
;;;
;;; Standard byte-level LM metric. Splits held-out data into
;;; non-overlapping (B, T) windows, runs forward, sums NLL in
;;; nats over predicted tokens, divides by token count, divides
;;; by ln(2). The first byte of each window has no left context
;;; from the previous window — this is the standard "non-
;;; overlapping" convention used by text8/enwik8/wikitext papers.

(defn eval-bpc
  "Compute bytes-per-character on a held-out byte tensor. Returns
   {:bpc :ppl :n-tokens :n-windows}. `max-tokens` caps total
   tokens predicted so eval stays bounded on big held-out splits
   — pass nil for the whole tensor.

   At N_TRUNKS > 1, every eval batch row is assigned a trunk_id
   round-robin (row i → trunk i mod N). This means each trunk's
   V_local slice is exercised in proportion to its share of the
   batch, so the ablation Δ measures pooled trunk performance
   rather than just trunk-0's contribution. trunk_ids is built
   deterministically from row index, so control and ablated eval
   passes see the SAME routing — the Δ between them is the actual
   bank-tier signal, not trunk-assignment noise."
  ([m data T] (eval-bpc m data T 16 100000))
  ([m data T B max-tokens]
   (set-eval-mode! m)
   (torch/set_grad_enabled false)
   (let [n-trunks (pick-n-trunks)]
     (try
       (let [N        (.size data 0)
             cap-toks (or max-tokens N)
             wins-cap (quot cap-toks T)
             n-wins   (min (quot (- N 1) T) wins-cap)
             usable   (* n-wins T)
             x-flat   (.narrow data 0 0 usable)
             y-flat   (.narrow data 0 1 usable)
             x-wins   (.reshape x-flat n-wins T)
             y-wins   (.reshape y-flat n-wins T)]
         (println (format "  eval-bpc: %d windows × T=%d, B=%d (cap=%d toks)%s"
                          n-wins T B (* n-wins T)
                          (if (> n-trunks 1)
                            (format " trunk-round-robin N=%d" n-trunks)
                            "")))
         (loop [i      0
                total  0.0
                n-toks 0
                logged 0]
           (if (>= i n-wins)
             (let [nll (/ total n-toks)
                   bpc (/ nll LN2)
                   ppl (math/exp nll)]
               (println (format "    bpc=%.4f  ppl=%.2f  over %d tokens"
                                bpc ppl n-toks))
               {:bpc bpc :ppl ppl :n-tokens n-toks :n-windows n-wins})
             (let [device    (:device m)
                   end       (min (+ i B) n-wins)
                   bsz       (- end i)
                   xb        (.to (.narrow x-wins 0 i bsz) device)
                   yb        (.to (.narrow y-wins 0 i bsz) device)
                   ;; Per-batch-row trunk routing for N>1. Window i in
                   ;; the eval split → trunk (i mod N_TRUNKS). Deterministic
                   ;; so control and ablated eval passes are aligned.
                   trunk-ids (when (> n-trunks 1)
                               (.to (.remainder
                                      (torch/arange i end ** :dtype torch/long)
                                      n-trunks)
                                    device))
                   [logits _ _] (forward m xb nil nil false trunk-ids)
                   loss      (F/cross_entropy
                              (.reshape logits -1 vocab-size)
                              (.reshape yb -1)
                              ** :reduction "sum")
                   bsz-toks  (* bsz T)
                   total'    (+ total (.item loss))
                   n-toks'   (+ n-toks bsz-toks)
                   logged'   (+ logged bsz)]
               (when (>= logged' 256)
                 (println (format "      %d/%d windows  running bpc=%.4f"
                                  end n-wins (/ (/ total' n-toks') LN2))))
               (recur end total' n-toks' (mod logged' 256))))))
       (finally
         (torch/set_grad_enabled true))))))

(defn eval-bpc-on-path
  "Run eval-bpc against an arbitrary held-out byte tensor at <test-path>,
   log result via `mmllm.evals.append_eval_log` so it lives in the same
   JSONL as the agentic-eval rows.

   Cheap (no generation), so the eval-watcher can run BPC across all
   the pretraining-style splits (cosmopedia.test.bin, fineweb-edu.test.bin,
   the-stack-v2-py.test.bin, etc.) in seconds-to-minutes per ckpt."
  [config base-path ckpt-step bank-path test-path eval-name log-path]
  (let [cfg      (assoc config :memory-mmap-path bank-path)
        m        (build-model cfg)
        device   (:device m)
        ckpt-dir (str base-path ".ckpts")]
    (when ckpt-step
      (let [path  (str ckpt-dir "/step-" ckpt-step)
            saved (python/list (torch/load (str path "/dense.pt")
                                           ** :map_location device))]
        (println (format "  loaded ckpt: %s (%d dense param tensors)"
                         path (count saved)))
        (doseq [[p s] (map vector (parameters m) saved)]
          (.copy_ (.- p data) s))
        ;; Restore bank V from the ckpt-dir's bank-latest.<i>.bin files.
        ;; Without this, when MMLLM_BANK_ON_GPU=true the bank V stays
        ;; at random init (the mmap_path arg is ignored) and we silently
        ;; measure dense-only quality (== ablated bpc), not the full
        ;; model. Caught by comparing watcher's bpc to train-long's
        ;; in-session val_bpc + ablation Δ on session 2 — they matched
        ;; the gap exactly. bank-latest is overwrite-in-place per
        ;; save-checkpoint!, so it reflects the LATEST training state,
        ;; not necessarily ckpt-step's state — for ckpts published at
        ;; session-end this is exact; for in-flight intermediate ckpts
        ;; it's the closest available bank state.
        (doseq [[i b] (map-indexed vector (:blocks m))]
          (when-let [mem (:memory b)]
            (try
              (.load_from_mmap mem
                               (str ckpt-dir "/bank-latest." i ".bin"))
              (catch python/Exception e
                (println (format "  WARN: bank V layer %d load failed (%s) — using random init"
                                 i e))))))
        (println (format "  bank V load attempted from %s/bank-latest.{0..%d}.bin"
                         ckpt-dir (dec (count (:blocks m)))))))
    (set-eval-mode! m)
    (torch/set_grad_enabled false)
    (println (format "  eval-bpc-on-path[%s]: ckpt=%s test=%s"
                     eval-name (or ckpt-step "init") test-path))
    (let [data     (corp/load-as-tensor test-path)
          T-seq    (:seq-len cfg)
          results  (eval-bpc m data T-seq 16 100000)
          bpc      (:bpc results)
          ppl      (:ppl results)
          n-toks   (:n-tokens results)
          row      (python/dict)]
      (.update row {"bpc"      bpc
                    "ppl"      ppl
                    "n_tokens" n-toks
                    "kind"     "bpc"})
      (println (format "  bpc[%s]=%.4f ppl=%.2f n_tokens=%d"
                       eval-name bpc ppl n-toks))
      (ev/append_eval_log log-path (or ckpt-step 0) eval-name row))))

(defn- run-bpc-on-loaded
  "Helper: run eval-bpc against test-path on an already-loaded model.
   Used by eval-battery-on-ckpt to avoid re-loading the model + bank V
   per eval target. Logs a kind='bpc' row to log-path."
  [m cfg ckpt-step test-path eval-name log-path]
  (let [data    (corp/load-as-tensor test-path)
        T-seq   (:seq-len cfg)
        results (eval-bpc m data T-seq 16 100000)
        bpc     (:bpc results)
        ppl     (:ppl results)
        n-toks  (:n-tokens results)
        row     (python/dict)]
    (.update row {"bpc"      bpc
                  "ppl"      ppl
                  "n_tokens" n-toks
                  "kind"     "bpc"})
    (println (format "  bpc[%s]=%.4f ppl=%.2f n_tokens=%d"
                     eval-name bpc ppl n-toks))
    (ev/append_eval_log log-path (or ckpt-step 0) eval-name row)))

(defn- run-agent-on-loaded
  "Helper: run agentic eval against test-path on an already-loaded model.
   Used by eval-battery-on-ckpt. Logs format_validity / tool_name_match /
   tool_args_match / exact_match to log-path."
  [m ckpt-step test-path eval-name n-samples gen-len log-path]
  (println (format "  eval-agent[%s]: ckpt=%s test=%s n=%d gen=%d"
                   eval-name (or ckpt-step "init") test-path
                   n-samples gen-len))
  (let [samples (python/list (ev/iter_eval_samples test-path
                                                   ** :max_samples n-samples))]
    (if (zero? (count samples))
      (println "  no samples in eval set — skipping")
      (let [t0          (time/time)
            predictions (python/list)
            golds       (python/list)
            end-mark    (.- ds/DEFAULT_TEMPLATE end)]
        (doseq [[idx s] (map-indexed vector samples)]
          (let [prompt   (.- s prompt)
                gold     (.- s gold)
                ;; Greedy decode (temp=0). See sample's docstring: at
                ;; byte-level multinomial-at-temp-1 sabotages format-
                ;; validity measurement even on a well-trained model.
                raw      (sample m prompt gen-len forward 0.0)
                gen-only (if (.startswith raw prompt)
                           (subs raw (count prompt))
                           raw)
                end-idx  (.find gen-only end-mark)
                pred     (if (>= end-idx 0)
                           (subs gen-only 0 end-idx)
                           gen-only)]
            ;; Observability: dump the first 2 predictions per dataset so
            ;; we can see what the model is actually emitting greedily.
            ;; Cheap (2 short prints per agent eval) and lets us tell the
            ;; difference between "model emits garbage" vs "model emits
            ;; almost-JSON" vs "model emits valid JSON with wrong content".
            (when (< idx 2)
              (let [prompt-tail (subs prompt (max 0 (- (count prompt) 80)))
                    pred-head   (subs pred 0 (min 200 (count pred)))
                    gold-head   (subs gold 0 (min 120 (count gold)))]
                (println (format "    [%s sample %d]" eval-name idx))
                (println (format "      prompt-tail: ...%s" (.replace prompt-tail "\n" "\\n")))
                (println (format "      pred:        %s" (.replace pred-head "\n" "\\n")))
                (println (format "      gold:        %s" (.replace gold-head "\n" "\\n")))))
            (.append predictions pred)
            (.append golds gold)))
        (let [results (ev/score_predictions predictions golds)
              dt      (- (time/time) t0)]
          (println (format "  → format=%.3f  name=%.3f  args=%.3f  exact=%.3f  (%.1fs)"
                           (.get results "format_validity")
                           (.get results "tool_name_match")
                           (.get results "tool_args_match")
                           (.get results "exact_match")
                           dt))
          (ev/append_eval_log log-path
                              (or ckpt-step 0) eval-name results))))))

(defn eval-battery-on-ckpt
  "Run BPC + agent evals against multiple test sets in ONE process.

   Replaces the prior watcher pattern of N+M independent subprocess
   invocations of `mmllm eval-bpc-on-path` / `mmllm eval-agent` per
   ckpt — each of which redundantly built the model and reloaded the
   17.5 GB bank V from disk. With sqrt_n=2048 fp32 that bank-V load
   was ~35-90s per eval × 15 evals = ~10-20 min wasted per ckpt before
   any actual eval work. This batched verb loads model + dense + bank V
   ONCE, then iterates through every test set against the already-
   loaded state. ~5-10× speedup on the eval-watcher loop.

   `bpc-evals-str` and `agent-evals-str` are comma-separated
   'name:test_path' specs (same shape as the watcher's CLI args).
   Each eval's failure is caught + warned so a single bad eval
   doesn't abort the whole battery."
  [config base-path ckpt-step bank-path
   bpc-evals-str agent-evals-str n-samples gen-len log-path]
  (let [parse-spec (fn [s]
                     (vec
                       (for [entry (.split (or s "") ",")
                             :let  [entry (.strip entry)]
                             :when (pos? (count entry))]
                         (let [parts (.split entry ":" 1)]
                           [(aget parts 0) (aget parts 1)]))))
        bpc-specs   (parse-spec bpc-evals-str)
        agent-specs (parse-spec agent-evals-str)
        cfg         (assoc config :memory-mmap-path bank-path)
        m           (build-model cfg)
        device      (:device m)
        ckpt-dir    (str base-path ".ckpts")]
    (when ckpt-step
      (let [path  (str ckpt-dir "/step-" ckpt-step)
            saved (python/list (torch/load (str path "/dense.pt")
                                           ** :map_location device))
            ;; Tolerant load: skip+warn on shape mismatch (mirrors
            ;; load-checkpoint!). Eval's model topology may differ from
            ;; the trainer's (e.g. MTP head only present if MMLLM_MTP_COEF
            ;; > 0; switch gate / NetBank only if respective env flags
            ;; on). Skipping aligns with "use whatever's compatible,
            ;; leave the rest at fresh init for components that aren't
            ;; relevant to eval anyway".
            n-skipped (python/list [0])]
        (println (format "  loaded ckpt: %s (%d dense param tensors)"
                         path (count saved)))
        (doseq [[i [p s]] (map-indexed vector (map vector (parameters m) saved))]
          (try
            (.copy_ (.- p data) s)
            (catch python/Exception e
              (.__setitem__ n-skipped 0 (inc (.__getitem__ n-skipped 0)))
              (when (< (.__getitem__ n-skipped 0) 5)
                (println (format "  WARN eval-load: skip param %d (model %s vs saved %s) — %s"
                                 i
                                 (str (python/list (.- p shape)))
                                 (str (python/list (.- s shape)))
                                 (str e)))))))
        (when (pos? (.__getitem__ n-skipped 0))
          (println (format "  WARN eval-load: %d/%d param tensors skipped due to shape mismatch"
                           (.__getitem__ n-skipped 0)
                           (count saved))))
        (doseq [[i b] (map-indexed vector (:blocks m))]
          (when-let [mem (:memory b)]
            (try
              (.load_from_mmap mem
                               (str ckpt-dir "/bank-latest." i ".bin"))
              (catch python/Exception e
                (println (format "  WARN: bank V layer %d load failed (%s) — using random init"
                                 i e))))))
        (println (format "  bank V load attempted from %s/bank-latest.{0..%d}.bin"
                         ckpt-dir (dec (count (:blocks m)))))))
    (set-eval-mode! m)
    (torch/set_grad_enabled false)
    (println (format "  battery: %d bpc + %d agent evals on ckpt %s"
                     (count bpc-specs) (count agent-specs)
                     (or ckpt-step "init")))
    (let [t0           (time/time)
          empty-cache! (fn []
                         (try
                           (when (.is_available torch/cuda)
                             (.empty_cache torch/cuda))
                           (catch python/Exception _ nil)))]
      (doseq [[name path] bpc-specs]
        (try
          (run-bpc-on-loaded m cfg ckpt-step path name log-path)
          (catch python/Exception e
            (println (format "  WARN: bpc[%s] failed: %s" name e))))
        (empty-cache!))
      (doseq [[name path] agent-specs]
        (try
          (run-agent-on-loaded m ckpt-step path name n-samples gen-len log-path)
          (catch python/Exception e
            (println (format "  WARN: agent[%s] failed: %s" name e))))
        (empty-cache!))
      (println (format "  battery done in %.1fs" (- (time/time) t0))))))

;;; ─────────────────────── intermediate ablation eval ───────────────────────
;;;
;;; Periodic 'zero V → eval bpc → restore V' cycle, used by train-long
;;; to plot the trajectory of Δ across training. Mutates the bank
;;; in-place transiently; restored under try/finally.
;;;
;;; Note on safety with mmap-backed banks: `.zero_()` modifies the
;;; mmap pages in place; if the process crashes between zero and
;;; restore, the on-disk bank is corrupted. The restore copies the
;;; saved tensor back via `.copy_`, which writes the same pages back.
;;; No volume.commit() runs during the ablation block, so a crash
;;; mid-ablation only damages the in-memory mmap (next run sees the
;;; pre-ablation state from disk via fresh mmap).

;;; Disk-backed ablation backup. The original code cloned every block's V
;;; to host RAM via .to("cpu", copy=true), which at sqrt_n=2500 puts 3-4 GB
;;; of clones in memory simultaneously while ALSO holding the original
;;; mmap'd V. On a 15 GiB sandbox that aggregates to OOM.
;;;
;;; Disk-streamed variant: torch.save each block to /tmp BEFORE zeroing
;;; (so the save reads from the still-valid mmap'd V), then zero in-place.
;;; At restore, torch.load one block at a time, copy_ into V's mmap,
;;; immediately drop the loaded tensor. Peak extra RAM = 1 block's V.
;;;
;;; Memory: V_local block = sqrt_n² × q_dim × 4 = ~256 MB at sqrt_n=720.
;;; V_net block = sqrt_n² × c_net × 4 = ~768 MB at sqrt_n=2500.
;;; Cleanup is in `finally` so a crash mid-ablation still removes
;;; the temp files.

(defn- save-v-to-disk
  "Serialize a bank's V.weight to a temp file path. Returns the path.
   Caller is responsible for unlinking on cleanup."
  [bank tag]
  (let [uuid-mod (python/__import__ "uuid")
        path (str "/tmp/mmllm-cpu/abl-" tag "-" (.- (.uuid4 uuid-mod) hex) ".pt")
        w (.- (.- bank V) weight)]
    (torch/save (.detach w) path)
    path))

(defn- restore-v-from-disk!
  "Load a backup .pt file and copy_ its contents into bank.V.weight.
   The loaded tensor goes out of scope immediately so RAM is freed."
  [bank path]
  (let [backup (torch/load path)]
    (with [_ (torch/no_grad)]
      (.copy_ (.- (.- bank V) weight) backup))))

(defn- unlink-paths! [paths]
  (let [os-mod (python/__import__ "os")]
    (doseq [p paths]
      (try (.unlink os-mod p) (catch python/Exception _ nil)))))

(defn ablation-step!
  "Save Local V across all blocks to disk, zero them in-place, run
   eval-bpc, restore V from the disk backups. Returns ablated bpc.

   Disk-streamed backup (vs. the original in-RAM clone) keeps the
   ablation's extra-memory peak at 1 block's V (~256 MB at sqrt_n=720),
   not N_blocks × V (which OOMs on the 15 GiB sandbox at production
   bank sizes)."
  [m val-data T B max-toks]
  ;; Asymmetric :local-bank-layers — only blocks with a Local Bank
  ;; participate. Zip backup-paths with the SAME filtered block list.
  (let [blocks-with-local (filter :memory (:blocks m))
        backup-paths (mapv (fn [b]
                             (let [p (save-v-to-disk (:memory b) "local")]
                               (.zero_bank (:memory b))
                               p))
                           blocks-with-local)]
    (try
      (let [r (eval-bpc m val-data T B max-toks)]
        (:bpc r))
      (finally
        (doseq [[b p] (map vector blocks-with-local backup-paths)]
          (restore-v-from-disk! (:memory b) p))
        (unlink-paths! backup-paths)))))

(defn ablation-step-net!
  "Same pattern as ablation-step! but zeros NetBank V (not Local Bank).
   No-op (returns nil) when NetBank is disabled. Returns ablated bpc.

   Together with ablation-step! this gives Δ_local and Δ_net as separate
   metrics — answers 'how much is short-term memory carrying' vs 'how
   much is long-term memory carrying' independently."
  [m val-data T B max-toks]
  (let [blocks-with-net (filter :netbank (:blocks m))]
    (when (seq blocks-with-net)
      (let [backup-paths (mapv (fn [b]
                                 (let [p (save-v-to-disk (:netbank b) "net")]
                                   (.zero_bank (:netbank b))
                                   p))
                               blocks-with-net)]
        (try
          (let [r (eval-bpc m val-data T B max-toks)]
            (:bpc r))
          (finally
            (doseq [[b p] (map vector blocks-with-net backup-paths)]
              (restore-v-from-disk! (:netbank b) p))
            (unlink-paths! backup-paths)))))))

(defn ablation-step-both!
  "Zero BOTH Local V and NetBank V across all blocks, run eval-bpc,
   restore both. Returns ablated bpc when at least one tier is present.

   Δ_both vs Δ_local + Δ_net tells us about interaction between the two
   tiers — superadditive Δ means the tiers carry overlapping signal
   (one can compensate for the other); subadditive means complementary
   (each carries unique signal that the other can't replace)."
  [m val-data T B max-toks]
  (let [blocks (:blocks m)
        blocks-with-local (filter :memory blocks)
        blocks-with-net   (filter :netbank blocks)
        local-paths (mapv (fn [b]
                            (let [p (save-v-to-disk (:memory b) "both-local")]
                              (.zero_bank (:memory b))
                              p))
                          blocks-with-local)
        net-paths (mapv (fn [b]
                          (let [p (save-v-to-disk (:netbank b) "both-net")]
                            (.zero_bank (:netbank b))
                            p))
                        blocks-with-net)]
    (try
      (let [r (eval-bpc m val-data T B max-toks)]
        (:bpc r))
      (finally
        (doseq [[b p] (map vector blocks-with-local local-paths)]
          (restore-v-from-disk! (:memory b) p))
        (doseq [[b p] (map vector blocks-with-net net-paths)]
          (restore-v-from-disk! (:netbank b) p))
        (unlink-paths! (concat local-paths net-paths))))))

(defn quick-ablate-on-path
  "Standalone QUICK ablation against a trained round: ctrl + Δ_net + synthesized
   Δ_both (Δ_local skipped). Loads dense.pt from <ckpt-dir>/step-<step>/, leaves
   Memory + NetBank V on their existing mmap-backed files (so the on-disk state
   from the just-trained round is what gets ablated).

   Used by extend_chain.sh / interactive smoke runs that want the ablation
   signal on an already-trained round without paying the cost of another
   training pass through train-long. Eval cap is taken from
   MMLLM_ABLATION_EVAL_CAP (default 2500 under MMLLM_ABLATION_QUICK)."
  [config base-path ckpt-step bank-path test-path]
  (let [cfg      (assoc config :memory-mmap-path bank-path)
        m        (build-model cfg)
        device   (:device m)
        ckpt-dir (str base-path ".ckpts")]
    (when ckpt-step
      (let [path      (str ckpt-dir "/step-" ckpt-step)
            saved     (python/list (torch/load (str path "/dense.pt")
                                               ** :map_location device))
            n-skipped (python/list [0])]
        (println (format "  loaded ckpt: %s (%d dense param tensors)"
                         path (count saved)))
        (doseq [[i [p s]] (map-indexed vector (map vector (parameters m) saved))]
          (try
            (.copy_ (.- p data) s)
            (catch python/Exception e
              (.__setitem__ n-skipped 0 (inc (.__getitem__ n-skipped 0)))
              (when (< (.__getitem__ n-skipped 0) 3)
                (println (format "  WARN load-ckpt: skip param %d (model %s vs saved %s)"
                                 i
                                 (str (python/list (.- p shape)))
                                 (str (python/list (.- s shape)))))))))
        (when (pos? (.__getitem__ n-skipped 0))
          (println (format "  WARN load-ckpt: %d/%d param tensors skipped (kept at fresh init)"
                           (.__getitem__ n-skipped 0) (count saved))))))
    (set-eval-mode! m)
    (torch/set_grad_enabled false)
    (let [data     (corp/load-as-tensor test-path)
          T-seq    (:seq-len cfg)
          eval-cap (pick-ablation-eval-cap)
          t0       (time/time)
          ctrl-r   (eval-bpc m data T-seq 16 eval-cap)
          ctrl-bpc (:bpc ctrl-r)
          ctrl-ppl (:ppl ctrl-r)
          abl-n    (ablation-step-net! m data T-seq 16 eval-cap)
          delta-n  (when abl-n (- abl-n ctrl-bpc))
          delta-b  delta-n
          wall     (- (time/time) t0)]
      (println (format "  quick-ablate: cap=%d wall=%.1fs" eval-cap wall))
      (println (format "    ctrl bpc=%.4f ppl=%.2f n_tokens=%d"
                       ctrl-bpc ctrl-ppl (:n-tokens ctrl-r)))
      (when abl-n
        (println (format "    Δ_net:    %.4f → %+.4f (ablated bpc=%.4f)"
                         ctrl-bpc delta-n abl-n)))
      (when delta-b
        (println (format "    Δ_both:   %.4f → %+.4f (synthesized = Δ_local + Δ_net, Δ_local skipped)"
                         ctrl-bpc delta-b))))))

(defn- probe-loss
  "Lightweight single-batch forward + plain CE on (x, y). No backward,
   no optimizer. Returns a Python float. Used by the ablation-mode
   variant of probe-distill-gate! to measure per-layer Δ via CE delta.

   Caller must put the model in eval mode + set torch.no_grad — this
   function does NEITHER (hoist out of the inner loop for speed).
   probe-distill-gate! manages that bracketing."
  [m x y]
  (let [device  (:device m)
        x       (.to x device)
        y       (.to y device)
        [logits _ _ _ _] (forward m x nil nil false nil)
        logits-flat (.reshape logits -1 vocab-size)
        y-flat      (.reshape y -1)]
    (.item (F/cross_entropy logits-flat y-flat))))

(defn- v-local-movement
  "Per-layer V_local 'how much did it move from Gaussian init?' signal.

   V_local is initialized with std=0.02 Gaussian (see ProductKeyMemory's
   init at memory.py:571). For a Gaussian, E[|X|] = σ·sqrt(2/π) ≈ 0.01596.
   After training, rows that received gradient updates grow beyond this;
   untouched rows stay at the Gaussian baseline. mean(|V_local|) over the
   whole layer is therefore a direct signal of how much that layer's
   V_local actually moved.

   Returns per-layer mean-abs-V, indexed by block position. ~1ms total.

   Layers with high mean-abs → rows moved → distillable content.
   Layers near the Gaussian baseline (0.016) → barely trained → noise."
  [m]
  (vec
    (for [[i b] (map-indexed vector (:blocks m))
          :when (:memory b)]
      (let [w (.- (.- (:memory b) V) weight)
            mean-abs (.item (.mean (.abs w)))]
        [i (python/float mean-abs)]))))

(defn probe-distill-gate!
  "Per-Local-layer gate for the distill loss. Two signal modes:

   MMLLM_DISTILL_GATE_SIGNAL=movement (default — fast, robust):
     Per-layer signal = mean(|V_local|). Compares actual V to Gaussian
     init baseline (E[|N(0, 0.02)|] ≈ 0.016). Layers whose mean-abs
     significantly exceeds the baseline have rows that moved; rank by
     this. ~1ms total. Does NOT use the `batches` argument.

   MMLLM_DISTILL_GATE_SIGNAL=ablation:
     Original mode. Backup V_local, zero it, forward+CE on probe
     batches, restore. Per-layer Δ = ablated_loss − baseline_loss.
     Found empirically to be at the noise floor at step 70 — V_local
     hasn't accumulated enough mass for ablation-on-loss to discriminate.
     Kept available for comparison. Requires the eval-mode + no_grad
     bracketing managed by the caller.

   Selection rule (both modes):
     MMLLM_DISTILL_GATE_TOP_K (default 0) > 0:
       sort layers by signal descending; keep top K.
     Otherwise:
       keep layers with signal > MMLLM_DISTILL_GATE_THRESHOLD.
       For movement: threshold defaults to 0.016 (the Gaussian-init
         baseline) — anything above this means rows moved.
       For ablation: threshold defaults to 0.0.

   MMLLM_DISTILL_GATE_INVERT=true takes the complement of the primary
   selection — gate IN everyone EXCEPT the primary set.

   Stashed on (:metrics m):
     distill_gate_deltas   {block_idx → signal value}
     distill_gate_indices  set of gate-in block indices"
  [m batches]
  (let [signal-mode (.lower (.get (.- os environ) "MMLLM_DISTILL_GATE_SIGNAL" "movement"))
        ;; Threshold default depends on signal:
        ;;   movement: 0.016 (Gaussian baseline)
        ;;   ablation: 0.0   (positive ablation cost)
        default-thresh (if (= signal-mode "movement") "0.016" "0.0")
        thresh    (python/float (.get (.- os environ) "MMLLM_DISTILL_GATE_THRESHOLD" default-thresh))
        top-k     (python/int  (.get (.- os environ) "MMLLM_DISTILL_GATE_TOP_K" "0"))
        ;; Baseline value used for logging. movement: Gaussian E[|X|]
        ;; threshold. ablation: averaged probe-loss across batches.
        baseline  (if (= signal-mode "movement")
                    (python/float 0.016)
                    (let [losses (mapv (fn [[x y]] (probe-loss m x y)) batches)]
                      (/ (reduce + losses) (python/float (count losses)))))
        ;; Per-layer signal. movement: V-state, no forward passes.
        ;; ablation: per-layer CE-loss delta on the probe batches.
        results
        (if (= signal-mode "movement")
          (v-local-movement m)
          (vec
            (for [[i b] (map-indexed vector (:blocks m))
                  :when (:memory b)]
              (let [bp (save-v-to-disk (:memory b) (str "gate-" i))]
                (.zero_bank (:memory b))
                (try
                  (let [losses    (mapv (fn [[x y]] (probe-loss m x y)) batches)
                        abl-mean  (/ (reduce + losses) (python/float (count losses)))
                        delta     (- abl-mean baseline)]
                    [i delta])
                  (finally
                    (restore-v-from-disk! (:memory b) bp)
                    (unlink-paths! [bp])))))))
        invert?   (= (.lower (.get (.- os environ) "MMLLM_DISTILL_GATE_INVERT" "false")) "true")
        ;; Compute the "primary" gate set first per the original rule:
        ;;   top-K>0:   layers with largest Δ (most helpful)
        ;;   threshold: layers with Δ > thresh
        primary   (if (pos? top-k)
                    (->> results
                         (sort-by (fn [[_ d]] (- d)))
                         (take top-k)
                         (mapv first))
                    (->> results
                         (filter (fn [[_ d]] (> d thresh)))
                         (mapv first)))
        ;; If MMLLM_DISTILL_GATE_INVERT=true, take the COMPLEMENT — gate
        ;; in every Local layer EXCEPT the primary set. Useful when the
        ;; gate's discrimination is signed correctly but the "helpers"
        ;; the probe finds are actually the noise (and the layers with
        ;; near-zero Δ are the ones we should be distilling from).
        ;; Discovered empirically: at step 70, V_local hasn't accumulated
        ;; enough for ablation-on-loss to register a clear "helps" signal;
        ;; layers with tiny positive Δ tend to be flukes, while layers
        ;; with near-zero Δ are doing fine.
        gate-in   (if invert?
                    (->> results
                         (mapv first)
                         (remove (set primary))
                         vec)
                    primary)
        ;; MMLLM_DISTILL_GATE_WEIGHTED=true → continuous per-layer weights
        ;; instead of binary include/exclude. Weight ∝ max(0, signal - thresh).
        ;; Normalized so that mean(weights over Local layers) = 1.0, which
        ;; preserves the global MMLLM_DISTILL_COEF schedule's magnitude.
        ;; Layers near the threshold (e.g. Gaussian baseline for movement
        ;; signal) get weight ≈ 0; most-active layers get weight > 1.
        weighted? (= (.lower (.get (.- os environ) "MMLLM_DISTILL_GATE_WEIGHTED" "false")) "true")
        per-layer-weight
        (when weighted?
          (let [raw   (mapv (fn [[i d]] [i (max 0.0 (- d thresh))]) results)
                total (reduce + (mapv second raw))
                ;; Normalize to mean=1 over the Local layers (raw mean × N / sum).
                ;; If all weights are 0 (no layer above thresh), keep zeros.
                n-loc (python/float (count raw))
                scale (if (> total 0.0) (/ n-loc total) 0.0)]
            (mapv (fn [[i w]] [i (python/float (* w scale))]) raw)))]
    (when-let [metrics (:metrics m)]
      (let [py-deltas (python/dict)
            py-gate   (python/set)
            py-weights (python/dict)]
        (doseq [[i d] results]
          (.__setitem__ py-deltas i (python/float d)))
        (doseq [i gate-in]
          (.add py-gate i))
        (when per-layer-weight
          (doseq [[i w] per-layer-weight]
            (.__setitem__ py-weights i w)))
        (.__setitem__ metrics "distill_gate_deltas"  py-deltas)
        (.__setitem__ metrics "distill_gate_indices" py-gate)
        (when per-layer-weight
          (.__setitem__ metrics "distill_gate_weights" py-weights))))
    {:baseline baseline :deltas results :gate-in gate-in
     :weights per-layer-weight}))

;;; ─────────────────────── train + eval text8 / enwik8 ───────────────────────

(defn train-text8
  "Train on <base>.train.bin then eval BPC on <base>.{val,test}.bin.
   Standard 90M/5M/5M Mikolov split. Returns the trained model.

   `base` is the path WITHOUT the .train.bin/.val.bin/.test.bin
   suffix — e.g. /tmp/text8 expects /tmp/text8.{train,val,test}.bin
   produced by `split-text8`."
  [config steps base-path]
  (let [train-path (str base-path ".train.bin")
        val-path   (str base-path ".val.bin")
        test-path  (str base-path ".test.bin")
        T          (:seq-len config)
        B-eval     16
        eval-toks  100000]
    (println (format "train-text8: base=%s steps=%d" base-path steps))
    (let [m         (train-corpus config steps train-path)
          val-data  (corp/load-as-tensor val-path)
          test-data (corp/load-as-tensor test-path)]
      (println)
      (println (format "═══ eval on val (first %d tokens) ═══" eval-toks))
      (eval-bpc m val-data T B-eval eval-toks)
      (println)
      (println (format "═══ eval on test (first %d tokens) ═══" eval-toks))
      (eval-bpc m test-data T B-eval eval-toks)
      m)))

;;; ─────────────────────── checkpointing + long-running training ───────────────────────
;;;
;;; Bank V is mmap-backed and lives at <:memory-mmap-path>.<i>.bin —
;;; persistent by construction. What's NOT persistent across process
;;; restarts: dense parameter values (q/k/v/o/FFN/RMSNorm/embeddings)
;;; and optimizer moments (AdamW for dense, SparseAdam for the bank's
;;; touched-row state). Checkpointing here saves exactly those, into
;;; <ckpt-dir>/step-<N>/{dense.pt, opt-dense.pt, opt-sparse.pt}, so a
;;; crashed N-day run resumes within a few minutes.

(defn save-checkpoint!
  "Persist dense params + optimizer state + bank V to disk.

   Per-step ckpt dir holds dense + opt state (small, can accumulate):
     <ckpt-dir>/step-<step>/dense.pt
     <ckpt-dir>/step-<step>/opt-dense.pt
     <ckpt-dir>/step-<step>/opt-sparse.pt
     <ckpt-dir>/step-<step>/step.txt

   Bank V is large (~18.8 GB at sqrt_n=2048) so we save only the
   LATEST copy, overwriting in place at:
     <ckpt-dir>/bank-latest.<i>.bin   (one per layer)

   Without this V save, a crash + resume that reads dense.pt and
   the opt-state but rebuilds V via build-model would get a fresh
   N(0, 0.02) random V — collapsing the bank's training to zero.
   The opt-state's m, v moments would then push on a random V,
   forcing a partial relearn. (We hit this on the 5B+fb run and it
   cost us ~80k steps of effective bank progress.)

   For mmap-backed V (bank_on_gpu=False), the V save still runs but
   produces the same content the in-flight mmap already has; it's
   redundant but harmless.

   `volume` (optional) is a Modal Volume (or any object with a
   .commit() method). When provided, called after the writes so the
   ckpt is durably persisted before training continues. Without
   this, Modal Volumes only auto-commit at clean function exit; a
   crash mid-run loses any writes since the last commit. If `volume`
   is nil (non-Modal env or local dev), the commit step is skipped."
  ([m opt-dense opt-sparse ckpt-dir step]
   (save-checkpoint! m opt-dense opt-sparse nil ckpt-dir step nil))
  ([m opt-dense opt-sparse ckpt-dir step volume]
   (save-checkpoint! m opt-dense opt-sparse nil ckpt-dir step volume))
  ([m opt-dense opt-sparse opt-sparse-net ckpt-dir step volume]
   (let [path (str ckpt-dir "/step-" step)
         ;; MMLLM_LITE_CKPT=true skips the big optimizer state files
         ;; (opt-sparse-net at sqrt_n=2500 is ~5 GB; opt-sparse for
         ;; V_local at sqrt_n=720 is ~2 GB) AND the bank-latest copies
         ;; (mmap'd V is already on disk via its own path). Useful for
         ;; disk-constrained sandboxes when each round is a fresh
         ;; schedule replay that doesn't need Adam moments to resume.
         lite-ckpt? (= "true" (.lower (.get (.- os environ) "MMLLM_LITE_CKPT" "false")))]
     (os/makedirs path ** :exist_ok true)
     (torch/save (python/list (for [p (parameters m)]
                                (.detach (.clone (.- p data)))))
                 (str path "/dense.pt"))
     (when (not lite-ckpt?)
       (torch/save (.state_dict opt-dense)  (str path "/opt-dense.pt"))
       (torch/save (.state_dict opt-sparse) (str path "/opt-sparse.pt"))
       ;; NetBank's third optimizer state, only when NetBank is enabled.
       ;; NetBank V doesn't need a separate save — it's mmap-backed at
       ;; <base>-net.<i>.bin and every sparse-grad update writes through.
       (when opt-sparse-net
         (torch/save (.state_dict opt-sparse-net)
                     (str path "/opt-sparse-net.pt"))))
     ;; Save bank V to a fixed per-layer path (overwrite in place).
     ;; Skip on errors so a bank-save hiccup doesn't lose the dense
     ;; ckpt — but log loudly because the resume will be bad.
     (when (not lite-ckpt?)
       (try
         (doseq [[i b] (map-indexed vector (:blocks m))]
           (when-let [mem (:memory b)]
             (.save_to_mmap mem
                            (str ckpt-dir "/bank-latest." i ".bin"))))
         (catch python/Exception e
           (println (format "  WARN: bank V save failed at step %d: %s — "
                            step e))
           (println (format "        resume from this ckpt will get random V.")))))
     (let [f (python/open (str path "/step.txt") "w")]
       (.write f (str step))
       (.close f))
     ;; Modal Volume durable commit. Pushes all dirty bytes since
     ;; the last commit (≈ bank-latest size on the V-rewrite path).
     ;; Wrapped because some Volume backends raise if there are open
     ;; file handles; we don't want to lose the local ckpt over a
     ;; commit hiccup, just warn.
     (when volume
       (try
         (.commit volume)
         (catch python/Exception e
           (println (format "  WARN: volume.commit at step %d failed: %s"
                            step e))
           (println (format "        ckpt files exist on container but may not survive a crash."))))))))

(defn load-checkpoint!
  "Restore dense params + optimizer state + bank V state.

   Reads dense.pt / opt-dense.pt / opt-sparse.pt from the per-step
   ckpt dir, and bank-latest.<i>.bin (one per layer) from the
   parent ckpt-dir.

   If bank-latest files are missing (older ckpts pre-this-fix, or
   first-ever save aborted), V stays at whatever build-model
   initialized it to and emits a loud warning — this is the failure
   mode that cost us 80k steps of bank training on the 5B+fb run."
  ([m opt-dense opt-sparse ckpt-dir step]
   (load-checkpoint! m opt-dense opt-sparse nil ckpt-dir step))
  ([m opt-dense opt-sparse opt-sparse-net ckpt-dir step]
  (let [path  (str ckpt-dir "/step-" step)
        saved (python/list (torch/load (str path "/dense.pt")))
        ;; Tolerant load: zip param-list with saved tensors, skip
        ;; mismatches (warn loudly) instead of crashing. This is the
        ;; recovery path for "old ckpt has fewer / differently-ordered
        ;; tensors than the new model"; affected new params stay at
        ;; their build-time fresh init (typically zero-init or
        ;; small-Gaussian, both safe).
        n-skipped (python/list [0])]
    (doseq [[i [p s]] (map-indexed vector (map vector (parameters m) saved))]
      (try
        (.copy_ (.- p data) s)
        (catch python/Exception e
          (.__setitem__ n-skipped 0 (inc (.__getitem__ n-skipped 0)))
          (when (< (.__getitem__ n-skipped 0) 5)
            (println (format "  WARN load-checkpoint: skip param %d (model %s vs saved %s) — %s"
                             i
                             (str (python/list (.- p shape)))
                             (str (python/list (.- s shape)))
                             (str e)))))))
    (when (pos? (.__getitem__ n-skipped 0))
      (println (format "  WARN load-checkpoint: %d/%d param tensors skipped due to shape mismatch (kept at fresh init)"
                       (.__getitem__ n-skipped 0)
                       (count saved))))
    ;; Optimizer state load is also tolerant — when the param topology
    ;; changed (new gate / NetBank added), the saved state has fewer
    ;; param groups than the live optimizer. PyTorch's load_state_dict
    ;; raises ValueError in that case; we catch it and continue with
    ;; fresh-init optimizer state. The first few thousand steps will
    ;; have stronger gradients (no Adam momentum smoothing on new
    ;; params), but training restabilizes quickly.
    (try
      (.load_state_dict opt-dense  (torch/load (str path "/opt-dense.pt")))
      (catch python/Exception e
        (println (format "  WARN load-checkpoint: opt-dense state skipped (topology change?) — %s" (str e)))))
    (try
      (.load_state_dict opt-sparse (torch/load (str path "/opt-sparse.pt")))
      (catch python/Exception e
        (println (format "  WARN load-checkpoint: opt-sparse state skipped — %s" (str e)))))
    ;; NetBank's third-tier optimizer state. Optional on load — when an
    ;; old (pre-NetBank) ckpt is being resumed and NetBank is now enabled,
    ;; the file won't exist; opt-sparse-net stays at fresh init and
    ;; SparseAdam adapts from there.
    (when (and opt-sparse-net (os.path/exists (str path "/opt-sparse-net.pt")))
      (try
        (.load_state_dict opt-sparse-net (torch/load (str path "/opt-sparse-net.pt")))
        (catch python/Exception e
          (println (format "  WARN load-checkpoint: opt-sparse-net state skipped — %s" (str e))))))
    ;; Restore bank V if the bank-latest files exist. If they don't,
    ;; warn loudly — this is silent-data-loss territory otherwise.
    (let [bank-files (vec
                       (for [i (range (count (:blocks m)))]
                         (str ckpt-dir "/bank-latest." i ".bin")))
          all-present? (every? #(os.path/exists %) bank-files)]
      (if all-present?
        (do
          (doseq [[i b] (map-indexed vector (:blocks m))]
            (when-let [mem (:memory b)]
              (.load_from_mmap mem
                             (str ckpt-dir "/bank-latest." i ".bin"))))
          (println (format "  bank V restored from %s/bank-latest.{0..%d}.bin"
                           ckpt-dir (dec (count (:blocks m))))))
        (println (format "  WARN: bank V files missing in %s — V stays at random init.\n        Bank will need to retrain from scratch (the opt-state's m, v will\n        push it forward, but dense will see a useless bank for thousands of steps)."
                         ckpt-dir)))))))

(defn latest-checkpoint-step
  "Largest N for which <ckpt-dir>/step-N/ exists, or nil. Used on
   train-long startup to decide whether to resume."
  [ckpt-dir]
  (try
    (let [items     (vec (os/listdir ckpt-dir))
          step-dirs (filter #(.startswith % "step-") items)
          steps     (map #(python/int (subs % 5)) step-dirs)]
      (when (seq steps) (apply max steps)))
    (catch Exception _ nil)))

(defn- append-jsonl! [path line]
  (let [f (python/open path "a")]
    (.write f (str line "\n"))
    (.close f)))

(defn- git-rev []
  "Capture current git HEAD SHA. Empty string on failure."
  (try
    (let [subp (python/__import__ "subprocess")
          res  (.run subp (python/list ["git" "rev-parse" "HEAD"])
                     ** :capture_output true :text true :timeout 2)]
      (if (zero? (.- res returncode))
        (.strip (.- res stdout))
        ""))
    (catch python/Exception _ "")))

(defn- preflight!
  "Sanity-check the run's preconditions BEFORE the training loop starts.
   Catches missing corpus paths, OOM-likely VRAM forecasts, and cost
   forecasts > $50 (operator should set MMLLM_CONFIRM_COST=1 to opt in).
   Throws on hard failures, prints WARN on soft."
  [config train-path val-path mix total-steps]
  (let [torch-mod (python/__import__ "torch")
        ;; 1. Validate training-required paths exist. Mix paths are
        ;; already checked by pick-mix's load-as-tensor call (would
        ;; have raised before reaching here), so we only verify the
        ;; val-path + the train-path used in no-mix mode.
        paths   (concat
                  (when val-path [val-path])
                  (when (and (nil? mix) train-path) [train-path]))
        missing (vec (filter #(not (os.path/exists %)) paths))]
    (when (seq missing)
      (throw (python/RuntimeError
               (format "preflight: missing corpus paths:\n  %s"
                       (.join "\n  " (python/list missing))))))
    ;; 2. VRAM forecast (rough: model + activations + opt state)
    (try
      (when (.is_available (.- torch-mod cuda))
        (let [free-bytes  (first (.mem_get_info (.- torch-mod cuda)))
              free-gb     (/ free-bytes 1.073741824e9)]
          (println (format "  preflight: free VRAM = %.1f GB" free-gb))
          (when (< free-gb 5.0)
            (println (format "  WARN preflight: only %.1f GB VRAM free; may OOM during training"
                             free-gb)))))
      (catch python/Exception _ nil))
    ;; 3. Cost forecast — H100 ~$5.50/hr; estimate from total-steps × est-step-time
    (let [max-hours-env (python/float (.get (.- (python/__import__ "os") environ)
                                            "MMLLM_MAX_HOURS" "0"))
          est-cost      (* (max max-hours-env 0.0) 5.50)
          confirm       (.lower (.get (.- (python/__import__ "os") environ)
                                      "MMLLM_CONFIRM_COST" "0"))]
      (if (zero? max-hours-env)
        (println "  preflight: no MMLLM_MAX_HOURS cap — train-long will run until total-steps")
        (println (format "  preflight: budget cap = %.1f h × $5.50/h = $%.2f"
                         max-hours-env est-cost)))
      (when (and (> est-cost 50.0)
                 (not (.__contains__ #{"1" "true" "yes"} confirm)))
        (println (format "  WARN preflight: forecast $%.2f exceeds $50; set MMLLM_CONFIRM_COST=1 to silence"
                         est-cost))))
    ;; 4. Mix summary if applicable
    (when mix
      (println (format "  preflight: mix has %d corpora" (count mix)))
      (doseq [[i [path w]] (map-indexed vector mix)]
        (println (format "    [%2d] %5.1fpp  %s" i (* 100.0 w) path))))
    (println "  preflight: OK")))

(defn- print-session-summary
  "Final banner at clean session end (max_hours or step-cap). Reads
   recent ckpt info + cost + token count + recent eval and prints a
   condensed report card."
  [m start-step end-step base-path log-path t0 tracker]
  (try
    (let [wall-s    (- (time/time) t0)
          hours     (/ wall-s 3600.0)
          n-tokens  (try (.- tracker n_tokens) (catch python/Exception _ 0))
          tps       (if (pos? wall-s) (/ n-tokens wall-s) 0.0)
          cost-usd  (* hours 5.50)
          steps     (- end-step start-step)
          per-tok-c (if (pos? n-tokens) (* (/ cost-usd n-tokens) 1e6) 0.0)]
      (println "")
      (println "  ═══════════════ session summary ═══════════════")
      (println (format "    base:       %s" base-path))
      (println (format "    steps:      %d → %d (+%d)"
                       start-step end-step steps))
      (println (format "    tokens:     %.1f M  (%.1fk tok/s avg)"
                       (/ n-tokens 1e6) (/ tps 1000.0)))
      (println (format "    wall:       %.2f h" hours))
      (println (format "    cost:       $%.2f  ($%.3f/M tokens)"
                       cost-usd per-tok-c))
      (println "  ═══════════════════════════════════════════════"))
    (catch python/Exception e
      (println (format "  WARN print-session-summary failed: %s" e)))))

(defn- write-run-manifest!
  "At train-long startup, write base.manifest.json with the resolved
   config + git SHA + relevant MMLLM_* env vars + launch timestamp.
   Also append a `manifest` event to log.jsonl. This is the run's
   reproducibility record — without it, resume from a ckpt + new env
   var would be a silent config change."
  [base-path config log-path total-steps eval-every ckpt-every]
  (try
    (let [json   (python/__import__ "json")
          time-m (python/__import__ "time")
          path   (str base-path ".manifest.json")
          env-snap (python/dict)
          _       (doseq [k (python/list (.- (python/__import__ "os") environ))]
                    (when (.startswith k "MMLLM_")
                      (.__setitem__ env-snap k
                                    (.get (.- (python/__import__ "os") environ) k))))
          ts-str  (.strftime time-m "%Y-%m-%dT%H:%M:%SZ" (.gmtime time-m))
          sha     (git-rev)
          payload (python/dict)]
      (.__setitem__ payload "ts"           ts-str)
      (.__setitem__ payload "git_sha"      sha)
      (.__setitem__ payload "base_path"    base-path)
      (.__setitem__ payload "total_steps"  total-steps)
      (.__setitem__ payload "eval_every"   eval-every)
      (.__setitem__ payload "ckpt_every"   ckpt-every)
      (.__setitem__ payload "env"          env-snap)
      (let [cfg-d (python/dict)]
        (doseq [[k v] (seq config)]
          (.__setitem__ cfg-d (str k) (str v)))
        (.__setitem__ payload "config" cfg-d))
      (let [f (python/open path "w")]
        (.write f (.dumps json payload ** :indent 2))
        (.close f))
      (let [sha-short (if (>= (count sha) 8) (subs sha 0 8) sha)]
        (println (format "  manifest: %s (git=%s)" path sha-short)))
      (when log-path
        (append-jsonl! log-path
                       (format "{\"event\":\"manifest\",\"ts\":\"%s\",\"git_sha\":\"%s\",\"total_steps\":%d}"
                               ts-str sha total-steps))
        ;; Also emit a 'config' event with the key recipe knobs so the
        ;; published log.jsonl proves what env vars the bird ran with.
        ;; Without this, the rewarm/k_align/etc println output lives only
        ;; in stdout (GH Actions runner log), inaccessible from the bird's
        ;; published payload.
        (let [recipe-keys ["MMLLM_REWARM_NETBANK_KEYS"
                           "MMLLM_K_ALIGN_COEF"
                           "MMLLM_SKIP_NETBANK_WARMSTART"
                           "MMLLM_STEPS_PER_ROUND"
                           "MMLLM_N_ROUNDS"
                           "MMLLM_LR"
                           "MMLLM_LR_NET_MULT_END"
                           "MMLLM_DISTILL_COEF_END"
                           "MMLLM_DISTILL_MAGNITUDE_COEF"
                           "MMLLM_NETBANK_ENABLED"]
              env-pairs (->> recipe-keys
                             (map (fn [k]
                                    (let [v (.get (.- (python/__import__ "os") environ) k)]
                                      (if v
                                        (format "\"%s\":\"%s\"" k v)
                                        (format "\"%s\":null" k)))))
                             (interpose ",")
                             (apply str))]
          (append-jsonl! log-path
                         (format "{\"event\":\"config\",\"ts\":\"%s\",\"recipe\":{%s}}"
                                 ts-str env-pairs)))))
    (catch python/Exception e
      (println (format "  WARN: write-run-manifest! failed: %s" e)))))

(defn train-long
  "Long-running training with periodic eval + checkpoint + resume.

   Trains on <train-path> from current step (or resumed) up to
   total-steps. Every eval-every steps: BPC eval on val-data, append
   {step, loss, val_bpc, val_ppl, time} to <log-path>. Every
   ckpt-every steps: save dense+optimizer state to <ckpt-dir>.
   On startup: scans <ckpt-dir>; if any step-<N>/ exists, restores
   from the latest. Bank V picks up via mmap.

   Designed to run for hours-days under Modal/tmux/nohup. Returns
   the trained model (mostly useful for in-process callers)."
  [config train-path val-path ckpt-dir log-path total-steps eval-every ckpt-every]
  (let [;; Derive base-path from ckpt-dir (drop trailing .ckpts) so
        ;; manifest / summary / publish-after can write sibling files.
        base-path  (if (.endswith ckpt-dir ".ckpts")
                     (subs ckpt-dir 0 (- (count ckpt-dir) (count ".ckpts")))
                     ckpt-dir)
        m          (build-model config)
        ;; MMLLM_MIX (optional) → multi-corpus weighted sampler.
        ;; Format: 'path1:w1,path2:w2,…'.  When set, `train-path` is
        ;; ignored for sampling — only val-path drives eval-bpc.
        mix          (pick-mix)
        mix-tensors  (when mix (python/list (map first  mix)))
        mix-weights-t (when mix
                         (torch/tensor (python/list (map second mix))
                                       ** :dtype torch/float))
        ;; Short label per corpus for the per-corpus loss line in step
        ;; prints. pick-mix has already loaded the tensors so we can't
        ;; extract paths from `mix` (the [tensor weight] pairs); re-parse
        ;; MMLLM_MIX from env to get the path strings, then derive a
        ;; short label by basename. E.g. /data/agent-corpus-v2/xlam.bin
        ;; .train.bin → "xlam".
        mix-labels   (when mix
                       (let [raw (.strip (.get (.- os environ) "MMLLM_MIX" ""))]
                         (python/list
                           (for [entry (.split raw ",")
                                 :let  [entry (.strip entry)]
                                 :when (pos? (count entry))]
                             (let [colon (.rfind entry ":")
                                   path  (.strip (subs entry 0 colon))
                                   base  (.replace
                                           (.replace path ".train.bin" "")
                                           ".bin" "")
                                   parts (.split base "/")]
                               (.__getitem__ parts (- (count parts) 1)))))))
        corpus-tracker (when mix (make-corpus-tracker (count mix)))
        ;; Mutable cell for "wall-s at last 50-step print" — used to
        ;; compute rolling tokens/sec. Python list = 1-element ref.
        prev-print-s-ref (python/list [0.0])
        ;; Mutable cell for Δ_local baseline (captured at first ablation
        ;; event of the run). consolidation_index = (baseline - current)
        ;; / baseline tells us if Local's importance is dropping (Net
        ;; consolidating) or growing (routing-absorption warning).
        delta-local-baseline-ref (python/list [nil])
        ;; P3 replay buffer state. Mutable Python list of (x_cpu, y_cpu)
        ;; tuples representing batches whose plain-CE was below the
        ;; replay threshold (i.e. positions Local has already mastered).
        ;; Replay step every `replay-every` main steps with frozen Local.
        replay-every     (pick-replay-every)
        replay-cap       (pick-replay-buffer-size)
        replay-thresh    (pick-replay-threshold)
        replay-buf       (python/list [])
        ;; Train file may be many GB — use_mmap=True keeps it on disk
        ;; (uint8 view, .long()-cast per batch). Pre-load val (typically
        ;; ≤500 MB) directly as int64 so eval-bpc's repeated narrow()
        ;; over fixed windows doesn't repeatedly cast.
        train-data (when (nil? mix)
                     (corp/load-as-tensor train-path ** :use_mmap true))
        val-data   (corp/load-as-tensor val-path)
        ;; opt-dense: single-group AdamW unless MMLLM_LR_KAB_MULT differs
        ;; from MMLLM_LR_DENSE_MULT, in which case K_a/K_b move to a
        ;; separate group with its own lr (#3 spike). See make-opt-dense.
        opt-dense  (make-opt-dense m)
        opt-sparse ((pick-sparse-optimizer) (python/list (sparse-parameters m)) ** :lr (pick-lr-bank))
        ;; Third optimizer: NetBank's V_net. Constructed only when
        ;; NetBank is enabled AND has sparse params (otherwise SparseAdam
        ;; on an empty list errors). Tracks pick-lr-net for its peak lr,
        ;; cooled independently from opt-sparse on the same cosine
        ;; schedule with its own multiplier.
        net-sparse-params (python/list (netbank-sparse-parameters m))
        ;; MMLLM_SKIP_OPT_NET=true skips initializing opt-sparse-net.
        ;; SparseAdam (and CPUOffloadSparseAdam) allocate dense state
        ;; (m, v moments) at V.weight's shape on first step — for
        ;; V_net at sqrt_n=5600/c_net=32 that's 16 GB × 2 = 32 GB anon
        ;; RAM, OOMs a 15 GiB sandbox. Useful when running train-fim
        ;; ONLY to materialize a fresh-shape dense.pt for bench/eval —
        ;; V_net just stays where it is (mmap'd to disk) and won't
        ;; receive gradients during the materialization run.
        skip-opt-net? (= "true" (.lower (.get (.- os environ)
                                              "MMLLM_SKIP_OPT_NET"
                                              "false")))
        opt-sparse-net (when (and (not skip-opt-net?)
                                  (pos? (count net-sparse-params)))
                         ((pick-sparse-optimizer) net-sparse-params
                          ** :lr (pick-lr-net)))
        T          (:seq-len config)
        sqrt-n     (pick-sqrt-n config)
        bank-n     (* sqrt-n sqrt-n)
        start-step   (or (latest-checkpoint-step ckpt-dir) 0)
        sync-every   (pick-sync-every)
        ablate-every (pick-ablate-every)
        slot-every   (pick-slot-log-every)
        slot-reinit? (pick-dead-slot-reinit?)
        ;; Grab the Modal Volume reference unconditionally — used
        ;; for both (a) Hogwild bank sync (gated by sync-every and
        ;; mmap-backed bank) AND (b) durable ckpt commits (always-
        ;; on, so bank-V writes survive a crash). On non-Modal
        ;; envs, get-modal-volume returns nil and both features
        ;; gracefully no-op.
        volume     (get-modal-volume (pick-volume-name))
        do-sync?   (and volume (pos? sync-every) (:memory-mmap-path config))]
    (os/makedirs ckpt-dir ** :exist_ok true)
    ;; Pre-flight: validate paths, forecast cost, fail fast on missing data.
    (preflight! config train-path val-path mix total-steps)
    ;; Reproducibility: write manifest with config + git SHA + env vars
    ;; before any training happens. No-op if write fails (warn only).
    (write-run-manifest! base-path config log-path total-steps eval-every ckpt-every)
    (when (pos? start-step)
      (println (format "  resuming from checkpoint at step %d" start-step))
      (load-checkpoint! m opt-dense opt-sparse opt-sparse-net ckpt-dir start-step))
    ;; NetBank warm-start trigger: if NetBank is enabled but the resume
    ;; ckpt didn't contain opt-sparse-net.pt (i.e., NetBank is being
    ;; turned on for the first time on an existing dense-only run), copy
    ;; Local Bank's K_a/K_b into NetBank's first 2048 rows so retrieval
    ;; geometry is bootstrapped instead of cold.
    ;;
    ;; Round-7 override: when the resume seed carries a harvested NetBank V
    ;; (loaded via fp16 expansion to the runtime mmap before train-long
    ;; starts), the warm-start would OVERWRITE that harvested content with
    ;; a fresh projection of Local V — destroying the cross-worker
    ;; consolidation the harvester just produced. Set
    ;; MMLLM_SKIP_NETBANK_WARMSTART=true to suppress the warm-start when
    ;; NetBank V was pre-populated externally.
    (when (and opt-sparse-net
               (not (= "true" (.lower (.get (.- os environ)
                                            "MMLLM_SKIP_NETBANK_WARMSTART" "false"))))
               (or (zero? start-step)
                   (not (os.path/exists
                          (str ckpt-dir "/step-" start-step "/opt-sparse-net.pt")))))
      (println "  NetBank: opt-sparse-net.pt missing — warm-starting from Local Bank")
      (warm-start-netbanks-from-local! m))
    (when (and opt-sparse-net
               (= "true" (.lower (.get (.- os environ)
                                       "MMLLM_SKIP_NETBANK_WARMSTART" "false"))))
      (println "  NetBank: MMLLM_SKIP_NETBANK_WARMSTART=true — using NetBank V as already mmap'd (likely from harvester)"))
    ;; One-shot K_a/K_b realignment, V untouched.
    ;; Bypasses the SKIP_NETBANK_WARMSTART guard AND the opt-sparse-net.pt
    ;; existence check — fires UNCONDITIONALLY when MMLLM_REWARM_NETBANK_KEYS=true.
    ;; Use this for ONE worker run to break the random-K_a/K_b ↔
    ;; gate-suppresses-Net feedback loop. Pair with MMLLM_K_ALIGN_COEF
    ;; (>0) to keep the realignment from drifting back.
    (when (and opt-sparse-net
               (= "true" (.lower (.get (.- os environ)
                                       "MMLLM_REWARM_NETBANK_KEYS" "false"))))
      (println "  NetBank: MMLLM_REWARM_NETBANK_KEYS=true — K_a/K_b realignment from Local (V untouched)")
      (rewarm-netbank-keys-only! m))
    (when (>= start-step total-steps)
      ;; Silent skip is the bug we hit on the first sync smoke: a stale
      ;; ckpt from a prior longer run made start-step exceed the new
      ;; total-steps; the step loop never executed and we got the end-
      ;; of-training ablation against the *initial* (untrained) bank.
      ;; Warn loudly so the operator sees it before chasing ghost results.
      (println (format "  WARN: start-step (%d) >= total-steps (%d) — step loop will not run."
                       start-step total-steps))
      (println (format "        Either bump --total-steps above %d, or clear the ckpt dir: %s"
                       start-step ckpt-dir)))
    (let [mmap-note (if (:memory-mmap-path config)
                      (str " mmap=" (:memory-mmap-path config))
                      " in-RAM")]
      (println (format "train-long: %s  steps=%d→%d  B=%d  eval-every=%d  ckpt-every=%d  lr=%g  device=%s"
                       train-path start-step total-steps (pick-batch) eval-every ckpt-every
                       (pick-lr) (:device m)))
      (println (format "  bank: %d entries × %d layers,%s"
                       bank-n (:n-layers config) mmap-note))
      (when mix
        (println (format "  mix: %d corpora (MMLLM_MIX) — train-path arg ignored" (count mix)))
        (let [total-w (.item (.sum mix-weights-t))]
          (doseq [[i [_ w]] (map-indexed vector mix)]
            (println (format "    [%d] weight=%.3f (%.1f%%)"
                             i w (* 100.0 (/ w total-w)))))))
      (println (format "  log: %s    ckpt: %s" log-path ckpt-dir))
      (if do-sync?
        (println (format "  sync: every %d steps via modal.Volume(\"%s\")  (Hogwild)"
                         sync-every (pick-volume-name)))
        (when (pos? sync-every)
          (println (format "  sync: requested every %d steps but volume unavailable — disabled"
                           sync-every))))
      (when (pos? ablate-every)
        (println (format "  ablate: intermediate Δ eval every %d steps (zero V → eval → restore V)"
                         ablate-every))
        (when (pos? (mod ablate-every eval-every))
          (println (format "    WARN: ablate-every (%d) is not a multiple of eval-every (%d); ablation steps that don't align with eval steps will be skipped."
                           ablate-every eval-every)))))
    (let [t0          (time/time)
          en-label    (str "train-long:" train-path)
          tracker     (metrics/EnergyTracker ** :label en-label :device (:device m))
          max-hours   (pick-max-hours)
          max-seconds (when (pos? max-hours) (* max-hours 3600.0))
          max-steps   (pick-max-steps)
          ;; Distill gate config — resolved ONCE at training start so the
          ;; per-step loop sees a pre-computed boolean / int instead of
          ;; repeating env-var lookups + .lower + string compares (~30s
          ;; over 100 steps at cpu-mini if inlined in the loop body).
          gate-enabled?   (= (.lower (.get (.- os environ) "MMLLM_DISTILL_GATE_BY_ABLATION" "false")) "true")
          gate-probe-step (when gate-enabled?
                            (python/int (.get (.- os environ) "MMLLM_DISTILL_GATE_STEP"
                                              (str (python/int (.get (.- os environ) "MMLLM_LR_WARMUP" "0"))))))
          gate-n-batches  (when gate-enabled?
                            (python/int (.get (.- os environ) "MMLLM_DISTILL_GATE_PROBE_BATCHES" "1")))
          ;; Probe batch size override. Training runs at B=1 at cpu-mini,
          ;; which gives the probe only 128 tokens per batch — far too few
          ;; to exercise the ~2% of V_local rows that 70 sparse-gradient
          ;; steps actually touched. Default 16 → 16× more probe coverage.
          gate-probe-B    (when gate-enabled?
                            (python/int (.get (.- os environ) "MMLLM_DISTILL_GATE_PROBE_B" "16")))]
      (when (pos? max-hours)
        (println (format "  session cap: %.2f h (MMLLM_MAX_HOURS) — will checkpoint and exit cleanly when reached"
                         max-hours)))
      (when (pos? max-steps)
        (println (format "  step cap: max-steps=%d (MMLLM_MAX_STEPS) — will checkpoint and exit cleanly at this step"
                         max-steps)))
      (.start tracker)
      (try
        (loop [step start-step]
        (cond
          (>= step total-steps)
          (do
            (save-checkpoint! m opt-dense opt-sparse opt-sparse-net ckpt-dir step volume)
            (println (format "training complete at step %d" step))
            ;; Inline bank ablation: eval (control), zero V across all blocks,
            ;; eval (ablation), report Δ. The Δ tells us how much of the
            ;; model's BPC depends on the trained memory bank.
            (println "  ── eval at end (control: bank trained) ──")
            (let [r-ctrl (eval-bpc m val-data T 16 (pick-ablation-eval-cap))]
              (append-jsonl! log-path
                             (format "{\"step\":%d,\"event\":\"final\",\"val_bpc\":%.4f,\"val_ppl\":%.4f,\"wall_s\":%.1f}"
                                     step (:bpc r-ctrl) (:ppl r-ctrl) (- (time/time) t0)))
              ;; Persist V to disk BEFORE ablation zeroes it. Inference can
              ;; later re-mount via CPUPinnedEmbedding + mmap (set
              ;; MMLLM_BANK_ON_GPU=false at inf time + same memory-mmap-path).
              (when-let [bank-path (:memory-mmap-path config)]
                (println (format "  ── saving trained bank to %s.<i>.bin ──" bank-path))
                (let [t-save (time/time)]
                  (doseq [[i b] (map-indexed vector (:blocks m))]
                    (when-let [mem (:memory b)]
                      (let [path (str bank-path "." i ".bin")
                            n    (.save_to_mmap mem path)]
                        (println (format "    block %d → %s (%.2f GB)"
                                         i path (/ n 1.073741824e9))))))
                  (println (format "    bank saved in %.1fs" (- (time/time) t-save)))
                  (append-jsonl! log-path
                                 (format "{\"step\":%d,\"event\":\"bank_saved\",\"bank_path\":\"%s\",\"wall_s\":%.1f}"
                                         step bank-path (- (time/time) t0)))))
              (println "  ── ablation: zeroing Local Bank V (NetBank kept active) ──")
              ;; Use ablation-step! (save → zero → eval → restore) so V_local
              ;; ends up back in memory AND on its mmap-backed file at the
              ;; trained-content state. The previous inline (zero_bank → eval)
              ;; left V_local at exactly zero on disk because the mmap-backed
              ;; V.weight was wiped in-place. ablation-step! backs V up to a
              ;; temp .pt before zeroing and copy_'s it back after eval, so
              ;; the post-run on-disk bank reflects training.
              ;;
              ;; Also run ablation-step-net! and ablation-step-both! so the
              ;; end-of-train summary reports Δ_local, Δ_net, and Δ_both —
              ;; matching the intermediate-ablation event format. This is
              ;; what answers "did distillation work" (Δ_net) and "do the
              ;; two banks combine constructively" (Δ_both vs sum of pieces).
              (let [eval-cap   (pick-ablation-eval-cap)
                    skip-local? (pick-ablation-skip-local?)
                    skip-both?  (pick-ablation-skip-both?)
                    ctrl     (:bpc r-ctrl)
                    ;; Δ_local: V_local was reset to fresh Gaussian at the
                    ;; start of this chain-extension round. A 20- to 100-step
                    ;; training schedule barely moves V_local; the measured
                    ;; Δ_local is near zero on every measured wave-2 round
                    ;; (round-11 verified: 0.0000). With SKIP_LOCAL set we
                    ;; skip the pass and report a placeholder; saves 25% of
                    ;; eval wall.
                    abl-l    (when (not skip-local?)
                               (ablation-step! m val-data T 16 eval-cap))
                    d-l      (if abl-l (- abl-l ctrl) 0.0)
                    abl-n    (ablation-step-net! m val-data T 16 eval-cap)
                    d-n      (when abl-n (- abl-n ctrl))
                    ;; Δ_both: by default we measure it directly (zero both
                    ;; banks, run eval-bpc). When MMLLM_ABLATION_SKIP_BOTH
                    ;; is set we skip that fourth eval pass and SYNTHESIZE
                    ;; Δ_both = Δ_local + Δ_net (i.e. assume synergy = 0).
                    ;; Empirically synergy has been ≈ 0 on cpu-mini wave-2
                    ;; recipes; the synthesized number is good enough for
                    ;; bite-size dev iterations where the 25% eval-wall
                    ;; savings matter more than the synergy measurement.
                    abl-b    (cond
                               (nil? abl-n)  nil
                               skip-both?    (when (some? d-n)
                                               (+ ctrl d-l d-n))
                               :else         (ablation-step-both! m val-data T 16 eval-cap))
                    d-b      (when abl-b (- abl-b ctrl))]
                (println (format "  ════ ablation summary ════"))
                (println (format "    control  bpc=%.4f ppl=%.2f" ctrl (:ppl r-ctrl)))
                (if skip-local?
                  (println (format "    Δ_local: (skipped — V_local fresh-init, assumed ≈0)"))
                  (println (format "    Δ_local: %.4f → %+.4f" abl-l d-l)))
                (when abl-n
                  (println (format "    Δ_net:   %.4f → %+.4f" abl-n d-n)))
                (when abl-b
                  (if skip-both?
                    (println (format "    Δ_both:  %.4f → %+.4f  (synthesized: synergy assumed 0)"
                                     abl-b d-b))
                    (let [synergy (- d-b (+ d-l (or d-n 0.0)))]
                      (println (format "    Δ_both:  %.4f → %+.4f  (synergy: %+.4f)"
                                       abl-b d-b synergy)))))
                (append-jsonl! log-path
                               (format "{\"step\":%d,\"event\":\"ablation\",\"control_bpc\":%.4f,\"ablated_local_bpc\":%s,\"delta_local\":%.4f,\"ablated_net_bpc\":%s,\"delta_net\":%s,\"ablated_both_bpc\":%s,\"delta_both\":%s,\"wall_s\":%.1f}"
                                       step ctrl
                                       (if abl-l (format "%.4f" abl-l) "null")
                                       d-l
                                       (if abl-n (format "%.4f" abl-n) "null")
                                       (if d-n   (format "%.4f" d-n)   "null")
                                       (if abl-b (format "%.4f" abl-b) "null")
                                       (if d-b   (format "%.4f" d-b)   "null")
                                       (- (time/time) t0)))))
            m)
          ;; Session-timeout branch: budget-bounded slow-walk training.
          ;; Save ckpt and exit cleanly so the next session resumes from
          ;; here. Skip the end-of-training ablation (we're not done, just
          ;; out of time).
          (and max-seconds (>= (- (time/time) t0) max-seconds))
          (do
            (save-checkpoint! m opt-dense opt-sparse opt-sparse-net ckpt-dir step volume)
            (let [hrs (/ (- (time/time) t0) 3600.0)]
              (println (format "  ── session timeout at %.2f h / step %d — checkpointed and exiting ──"
                               hrs step))
              (append-jsonl! log-path
                             (format "{\"step\":%d,\"event\":\"session_end\",\"reason\":\"max_hours\",\"hours\":%.3f,\"wall_s\":%.1f}"
                                     step hrs (- (time/time) t0))))
            (print-session-summary m start-step step base-path log-path t0 tracker)
            m)
          ;; Step-cap branch: hit MMLLM_MAX_STEPS. Save ckpt + run a Δ
          ;; ablation snapshot (control / Δ_local / Δ_net / Δ_both) then
          ;; exit clean. Used to build a "step-N base ckpt" for sweep
          ;; iteration AND to measure front-half (Local-phase) signal
          ;; accumulation: a step-70 ablation tells us how much V_local
          ;; has actually pulled in (the upper bound on what can distill
          ;; into V_net in the back half).
          (and (pos? max-steps) (>= step max-steps))
          (do
            (save-checkpoint! m opt-dense opt-sparse opt-sparse-net ckpt-dir step volume)
            (println (format "  ── step cap reached at step %d (MMLLM_MAX_STEPS=%d) — checkpointed and exiting ──"
                             step max-steps))
            (append-jsonl! log-path
                           (format "{\"step\":%d,\"event\":\"session_end\",\"reason\":\"max_steps\",\"wall_s\":%.1f}"
                                   step (- (time/time) t0)))
            ;; Inline ablation at the cap step. Mirrors the end-of-train
            ;; ablation block (save-V → zero → eval → restore for each tier,
            ;; collective Δ across all bank layers) so step-N base ckpts
            ;; are comparable to the end-of-train ablations.
            (println "  ── ablation Δ at step cap ──")
            (let [eval-cap (pick-ablation-eval-cap)
                  r-ctrl (eval-bpc m val-data T 16 eval-cap)
                  ctrl   (:bpc r-ctrl)
                  abl-l  (ablation-step!     m val-data T 16 eval-cap)
                  d-l    (- abl-l ctrl)
                  abl-n  (ablation-step-net! m val-data T 16 eval-cap)
                  d-n    (when abl-n (- abl-n ctrl))
                  abl-b  (when abl-n (ablation-step-both! m val-data T 16 eval-cap))
                  d-b    (when abl-b (- abl-b ctrl))]
              (println (format "    control  bpc=%.4f ppl=%.2f" ctrl (:ppl r-ctrl)))
              (println (format "    Δ_local: %.4f → %+.4f" abl-l d-l))
              (when abl-n
                (println (format "    Δ_net:   %.4f → %+.4f" abl-n d-n)))
              (when abl-b
                (let [synergy (- d-b (+ d-l (or d-n 0.0)))]
                  (println (format "    Δ_both:  %.4f → %+.4f  (synergy: %+.4f)"
                                   abl-b d-b synergy))))
              (append-jsonl! log-path
                             (format "{\"step\":%d,\"event\":\"ablation_at_cap\",\"control_bpc\":%.4f,\"delta_local\":%.4f,\"delta_net\":%s,\"delta_both\":%s,\"wall_s\":%.1f}"
                                     step ctrl d-l
                                     (if d-n (format "%.4f" d-n) "null")
                                     (if d-b (format "%.4f" d-b) "null")
                                     (- (time/time) t0))))
            (print-session-summary m start-step step base-path log-path t0 tracker)
            m)
          :else
          (let [warmup     (pick-lr-warmup)
                ;; Apply lr schedule unconditionally. lr-at-step returns
                ;; max-lr when warmup=0, and mult-cosine-interp returns
                ;; start when start==end, so this is safe at warmup=0.
                ;;
                ;; Bug (round-1..4): the previous `(when (pos? warmup)
                ;; ...)` wrapper silently silenced every round's LR
                ;; schedule because MMLLM_LR_WARMUP defaults to 0 and
                ;; run_round2.sh didn't set it. The schedule values
                ;; were COMPUTED for the per-step print line but never
                ;; APPLIED to the optimizer — log showed lr_b=3e-2 while
                ;; opt-sparse.param_groups[0].lr stayed at base 3e-3.
                ;; Sleep-cycle LR rotation was a ghost across 4 rounds.
                _          (let [cur-lr (lr-at-step step total-steps
                                                    (pick-lr) warmup
                                                    (pick-lr-min))
                                  d-mult (pick-lr-dense-mult step total-steps)
                                  k-mult (pick-lr-kab-mult   step total-steps)
                                  b-mult (pick-lr-bank-mult  step total-steps)
                                  n-mult (pick-lr-net-mult   step total-steps)]
                              ;; If opt-dense has 2 groups (K_a/K_b separated
                              ;; via make-opt-dense), use the grouped setter;
                              ;; otherwise the single-lr setter (back-compat).
                              (if (= 2 (count (.- opt-dense param_groups)))
                                (set-opt-lrs! opt-dense
                                              [(* cur-lr d-mult) (* cur-lr k-mult)])
                                (set-opt-lr!  opt-dense (* cur-lr d-mult)))
                              (set-opt-lr! opt-sparse (* cur-lr b-mult))
                              (when opt-sparse-net
                                (set-opt-lr! opt-sparse-net (* cur-lr n-mult))))
                ;; Restore training-mode flags. eval-bpc and ablation-step!
                ;; flip submodules to eval mode but never flip them back —
                ;; without this call, Local Bank's `if self.training:`
                ;; guards (slot tracking, z-loss) silently disable after
                ;; the first eval. Cheap (~5µs).
                _      (set-train-mode! m)
                B-cur (pick-batch)
                n-trunks (pick-n-trunks)
                ;; Multi-trunk content-sharded batch sampling. When N>1,
                ;; B-cur is interpreted as B-per-trunk and the final batch
                ;; is (N*B-per-trunk, T) with trunk-ids: (N*B-per-trunk,).
                ;; mix-batch-multi-trunk preserves chunky-mix semantics
                ;; (one corpus per batch) while content-sharding that
                ;; corpus across the N trunks.
                [x y corpus-idx trunk-ids]
                    (cond
                      (and mix (> n-trunks 1))
                        (mix-batch-multi-trunk mix-tensors mix-weights-t
                                               n-trunks B-cur T)
                      mix
                        (let [[x y idx] (mix-batch mix-tensors mix-weights-t B-cur T)]
                          [x y idx nil])
                      (> n-trunks 1)
                        (let [[x y tids] (batch-multi-trunk train-data n-trunks B-cur T)]
                          [x y nil tids])
                      :else
                        (let [[x y] (batch train-data B-cur T)]
                          [x y nil nil]))
                ;; #9 spike: with probability `pause-prob`, replace
                ;; the first `pause-n` bytes of x with the pause byte.
                ;; In-place mutation; y untouched.
                _     (when (pos? (pick-pause-bytes))
                        (maybe-inject-pause-prefix!
                          x (pick-pause-bytes) (pick-pause-prob) (pick-pause-byte-val)))
                ;; Stash current step + total on metrics so collect-distill-loss
                ;; can read the cosine-scheduled coefficient. Avoids threading
                ;; step/total through train-step's signature. `step'` (inc step)
                ;; is bound later in this let; use `step` (loop var) which is
                ;; in scope here.
                _     (when-let [metrics (:metrics m)]
                        (.__setitem__ metrics "current_step" step)
                        (.__setitem__ metrics "total_steps"  total-steps))
                ;; One-shot per-layer ablation gate probe at the
                ;; Local→Net handoff. Config resolved once at train-long
                ;; entry (gate-enabled?, gate-probe-step, gate-n-batches);
                ;; the per-step check here is a single boolean AND a single
                ;; integer comparison. See defs at the (let [t0 ...]) above.
                _     (when (and gate-enabled? (= step gate-probe-step))
                        ;; Probe uses gate-probe-B (default 16, vs training B-cur=1)
                        ;; so each probe batch exercises 16× more tokens and queries
                        ;; more V_local rows. With B=16 × T=128 × n_batches the
                        ;; probe touches enough rows that the trained ~2% have a
                        ;; chance of being hit.
                        (let [pB (max 1 gate-probe-B)
                              batches (vec
                                        (for [_ (range gate-n-batches)]
                                          (cond
                                            (and mix (> n-trunks 1))
                                              (let [[x2 y2 _ _] (mix-batch-multi-trunk
                                                                   mix-tensors mix-weights-t
                                                                   n-trunks pB T)]
                                                [x2 y2])
                                            mix
                                              (let [[x2 y2 _] (mix-batch mix-tensors mix-weights-t pB T)]
                                                [x2 y2])
                                            :else
                                              (let [[x2 y2] (batch train-data pB T)]
                                                [x2 y2]))))]
                          (println (format "  [step %d] running distill-gate ablation probe (n_batches=%d, B=%d) …"
                                           step gate-n-batches pB))
                          (let [tp0  (.time (python/__import__ "time"))
                                _    (set-eval-mode! m)
                                res  (with [_ (torch/no_grad)]
                                       (probe-distill-gate! m batches))
                                _    (set-train-mode! m)
                                dt   (- (.time (python/__import__ "time")) tp0)]
                            (println (format "    baseline_loss=%.4f  Δ per layer: %s"
                                             (:baseline res)
                                             (.join " "
                                                    (mapv (fn [[i d]]
                                                            (format "L%d=%+.4f" i d))
                                                          (:deltas res)))))
                            (println (format "    gate-in: %d/%d layers — indices %s  (probe wall %.2fs)"
                                             (count (:gate-in res))
                                             (count (:deltas res))
                                             (str (:gate-in res))
                                             dt)))))
                loss  (train-step m opt-dense opt-sparse opt-sparse-net x y false trunk-ids)
                ;; n-trunks > 1 multiplies the effective batch by N: each
                ;; trunk contributes B-cur rows. Token count for the energy
                ;; tracker scales the same way.
                _     (.add_tokens tracker (* B-cur T (max 1 n-trunks)))
                ;; Per-corpus loss tracker — running window of last 50
                ;; losses per corpus index. Used by the 50-step print to
                ;; show which corpora are easy / hard. nil idx = no-mix
                ;; mode (single corpus from `train-data`); skip update.
                _     (when corpus-idx
                        (record-corpus-loss! corpus-tracker corpus-idx loss))
                ;; P3 replay-buffer push: any step whose plain CE landed
                ;; below replay-thresh is considered "mastered" and saved
                ;; to the buffer for later replay. Both x and y are
                ;; cloned to CPU to avoid GPU memory growth.
                ;;
                ;; At n-trunks > 1 we also stash trunk-ids so the replay
                ;; routes each row back to the trunk that mastered it;
                ;; otherwise replay items would all collapse into trunk-0.
                _     (when (and (pos? replay-every) (< loss replay-thresh))
                        (.append replay-buf
                                 (python/tuple
                                   [(.to (.detach x) "cpu" ** :copy true)
                                    (.to (.detach y) "cpu" ** :copy true)
                                    (when trunk-ids
                                      (.to (.detach trunk-ids) "cpu" ** :copy true))]))
                        (when (> (count replay-buf) replay-cap)
                          (.pop replay-buf 0)))
                ;; P3 replay step: every replay-every main steps, sample
                ;; one buffered batch and run a frozen-Local train-step.
                ;; Net + dense + carry update; Local Bank stays put.
                ;; Captured replay loss + buffer size go to :metrics.
                _     (do
                        (when-let [metrics (:metrics m)]
                          (.__setitem__ metrics "replay_buf_n" (count replay-buf)))
                        (when (and (pos? replay-every)
                                   (zero? (mod (inc step) replay-every))
                                   (pos? (count replay-buf)))
                          (let [idx         (.item (torch/randint 0 (count replay-buf) (python/tuple [])))
                                [xr yr tr]  (.__getitem__ replay-buf idx)
                                _           (set-train-mode! m)
                                r-loss      (train-step m opt-dense opt-sparse opt-sparse-net
                                                        xr yr true tr)]
                            (when-let [metrics (:metrics m)]
                              (.__setitem__ metrics "replay_loss" (python/float r-loss))))))
                step' (inc step)]
            (when (zero? (mod step' 50))
              (let [cur-lr     (if (pos? warmup)
                                 (lr-at-step step total-steps
                                             (pick-lr) warmup (pick-lr-min))
                                 (pick-lr))
                    d-mult     (pick-lr-dense-mult step total-steps)
                    b-mult     (pick-lr-bank-mult  step total-steps)
                    n-mult     (pick-lr-net-mult   step total-steps)
                    has-net?   (some? opt-sparse-net)
                    wall-s     (- (time/time) t0)
                    n-tokens   (* B-cur T 50)        ; ~tokens since last print
                    prev-s     (.__getitem__ prev-print-s-ref 0)
                    delta-s    (max 0.001 (- wall-s prev-s))
                    tps        (/ n-tokens delta-s)
                    _          (.__setitem__ prev-print-s-ref 0 wall-s)
                    vram-gb    (try (/ (cuda/memory_allocated) 1.073741824e9)
                                    (catch python/Exception _ 0.0))
                    cost-usd   (* (/ wall-s 3600.0) 5.50)        ; H100 ~$5.50/h Modal
                    ;; Per-corpus loss summary (only when mix is set)
                    corp-summary (when corpus-tracker
                                   (corpus-loss-summary corpus-tracker))
                    ;; Build the lr substring
                    lr-str (cond
                             (and (= 1.0 d-mult) (= 1.0 b-mult) (not has-net?))
                             (format "lr=%.2e" cur-lr)
                             (not has-net?)
                             (format "lr_d=%.2e lr_b=%.2e"
                                     (* cur-lr d-mult) (* cur-lr b-mult))
                             :else
                             (format "lr_d=%.2e lr_b=%.2e lr_n=%.2e"
                                     (* cur-lr d-mult)
                                     (* cur-lr b-mult)
                                     (* cur-lr n-mult)))]
                ;; Main step line — fixed-width fields, easy to grep
                (println (format "step %6d | loss %.3f | tps %.1fk | vram %.1fgb | $%.2f | wall %.0fs | %s"
                                 step' loss
                                 (/ tps 1000.0)
                                 vram-gb
                                 cost-usd
                                 wall-s
                                 lr-str))
                ;; Per-corpus loss line (only when mix and >=1 corpus has data)
                (when (and corp-summary (pos? (count corp-summary)))
                  (let [parts (python/list)]
                    (doseq [t corp-summary]
                      (let [i      (.__getitem__ t 0)
                            mean-l (.__getitem__ t 2)
                            label  (when mix-labels (nth mix-labels i))]
                        (.append parts (format "%s=%.2f" (or label (str "c" i)) mean-l))))
                    (println (str "         by-corpus[ema50]: "
                                  (.join " " parts)))))
                ;; Router-metrics line — distill/replay aux losses. Only
                ;; printed when at least one is active (distill_coef > 0
                ;; or replay_every > 0). Tells you whether the
                ;; consolidation mechanisms are doing meaningful work
                ;; alongside the main CE.
                (when (or (pos? (pick-distill-coef))
                          (pos? replay-every)
                          (pos? (pick-delim-aux-coef)))
                  (let [metrics (:metrics m)
                        d-loss  (or (.get metrics "distill_loss")     0.0)
                        d-raw   (or (.get metrics "distill_loss_raw") 0.0)
                        r-loss  (or (.get metrics "replay_loss")      0.0)
                        buf-n   (or (.get metrics "replay_buf_n")     0)
                        x-loss  (or (.get metrics "delim_loss")       0.0)]
                    ;; distill_raw is pre-coef MSE — tells us whether Net is
                    ;; converging to the target (raw falls) vs the cosine
                    ;; schedule artifact making coef-scaled distill rise.
                    (println (format "         router-metrics: distill=%.4f (raw=%.4f)  replay=%.4f  replay_buf=%d/%d  delim=%.4f"
                                     d-loss d-raw r-loss buf-n replay-cap x-loss))))
                nil))
            ;; Cross-worker bank sync. Has to happen AFTER the optimizer
            ;; step (so dirty rows from this step are flushed) and outside
            ;; train-step's autograd graph. We sync before eval/ckpt so
            ;; eval-time reads see the freshest cross-worker state.
            (when (and do-sync? (zero? (mod step' sync-every)))
              (let [t-sync (time/time)
                    layers (python/list (map :memory (:blocks m)))
                    res    (mem/sync_banks layers volume)
                    dirty  (or (.get res "total_dirty_pages") 0)
                    nlay   (or (.get res "n_layers_synced") 0)
                    dt     (- (time/time) t-sync)]
                (println (format "  ── sync at step %d: %d dirty pages across %d layers in %.2fs ──"
                                 step' dirty nlay dt))
                (append-jsonl! log-path
                               (format "{\"step\":%d,\"event\":\"sync\",\"dirty_pages\":%d,\"n_layers\":%d,\"sync_s\":%.2f,\"wall_s\":%.1f}"
                                       step' dirty nlay dt (- (time/time) t0)))))
            (when (zero? (mod step' eval-every))
              (println (format "  ── eval at step %d ──" step'))
              (let [r (eval-bpc m val-data T 16 (pick-ablation-eval-cap 50000))]
                (append-jsonl! log-path
                               (format "{\"step\":%d,\"event\":\"eval\",\"loss\":%.4f,\"val_bpc\":%.4f,\"val_ppl\":%.4f,\"wall_s\":%.1f}"
                                       step' loss (:bpc r) (:ppl r) (- (time/time) t0)))
                ;; Intermediate ablation Δ measurement, if requested.
                ;; Reuses the just-computed control bpc; runs one extra
                ;; eval-bpc with V zeroed and then restores V in-place.
                (when (and (pos? ablate-every) (zero? (mod step' ablate-every)))
                  ;; Capture per-layer NetBank telemetry BEFORE the ablation
                  ;; block zeros Local/Net V — last_output_norm is set by the
                  ;; most recent forward (the control eval-bpc), so reads
                  ;; here reflect the live banks, not the zeroed ones.
                  (let [telem-mod (python/__import__ "mmllm.telemetry"
                                                     ** :fromlist
                                                     (python/list ["layer_telemetry" "to_event_json"]))
                        entries (python/list
                                  (map (fn [iv]
                                         (let [i (first iv) b (second iv)]
                                           (.layer_telemetry telem-mod i
                                                             (:netbank b)
                                                             (:memory b)
                                                             (:long-gate b))))
                                       (map-indexed vector (:blocks m))))]
                    (append-jsonl! log-path
                                   (.to_event_json telem-mod step' entries)))
                  (let [t-abl     (time/time)
                        eval-cap  (pick-ablation-eval-cap 50000)
                        ctrl      (:bpc r)
                        ;; Δ_local: zero Local V only
                        abl-l     (ablation-step! m val-data T 16 eval-cap)
                        d-l       (- abl-l ctrl)
                        ;; Δ_net: zero NetBank V only (nil if NetBank disabled)
                        abl-n     (ablation-step-net! m val-data T 16 eval-cap)
                        d-n       (when abl-n (- abl-n ctrl))
                        ;; Δ_both: zero BOTH (only run when NetBank present;
                        ;; otherwise it would equal Δ_local trivially)
                        abl-b     (when abl-n (ablation-step-both! m val-data T 16 eval-cap))
                        d-b       (when abl-b (- abl-b ctrl))
                        dt        (- (time/time) t-abl)
                        ;; P4 consolidation index — capture first Δ_local
                        ;; as baseline; report relative drop on subsequent
                        ;; events. Positive = Net is taking over Local
                        ;; (consolidation working). Negative = Local is
                        ;; getting MORE essential (routing-absorption).
                        baseline  (.__getitem__ delta-local-baseline-ref 0)
                        _         (when (nil? baseline)
                                    (.__setitem__ delta-local-baseline-ref 0 d-l))
                        baseline2 (.__getitem__ delta-local-baseline-ref 0)
                        cons-idx  (when (and baseline2 (> (python/abs baseline2) 1e-6))
                                    (/ (- baseline2 d-l) baseline2))]
                    (println (format "  ── ablation Δ at step %d: ctrl=%.4f"
                                     step' ctrl))
                    (println (format "       Δ_local: %.4f → %+.4f" abl-l d-l))
                    (when abl-n
                      (println (format "       Δ_net:   %.4f → %+.4f" abl-n d-n))
                      (println (format "       Δ_both:  %.4f → %+.4f  (synergy: %+.4f)"
                                       abl-b d-b (- d-b (+ d-l d-n)))))
                    (when cons-idx
                      (println (format "       consolidation_idx: %+.4f  (baseline Δ_local=%+.4f)"
                                       cons-idx baseline2)))
                    (println (format "       wall: %.1fs" dt))
                    (append-jsonl! log-path
                                   (format "{\"step\":%d,\"event\":\"ablation_intermediate\",\"control_bpc\":%.4f,\"ablated_bpc\":%.4f,\"delta_bpc\":%.4f,\"delta_local\":%.4f,\"delta_net\":%s,\"delta_both\":%s,\"consolidation_idx\":%s,\"baseline_delta_local\":%s,\"ablation_s\":%.2f,\"wall_s\":%.1f}"
                                           step'
                                           ctrl abl-l d-l   ;; legacy fields = Local-only (back-compat)
                                           d-l
                                           (if d-n (format "%.4f" d-n) "null")
                                           (if d-b (format "%.4f" d-b) "null")
                                           (if cons-idx (format "%.4f" cons-idx) "null")
                                           (if baseline2 (format "%.4f" baseline2) "null")
                                           dt (- (time/time) t0)))))))
            ;; PKM slot utilization log + optional dead-slot reinit.
            ;; Each PKM layer's hit counters cover the window since the
            ;; last reset; we log per-layer entropy and dead-row counts,
            ;; reinit dead rows if enabled, then reset counters.
            (when (and (pos? slot-every) (zero? (mod step' slot-every)))
              (doseq [[i blk] (map-indexed vector (:blocks m))]
                ;; Local Bank slot stats
                (let [mem (:memory blk)
                      st  (.slot_usage_stats mem)
                      d-a (.get st "dead_a")
                      d-b (.get st "dead_b")
                      ea  (or (.get st "entropy_a") 0.0)
                      eb  (or (.get st "entropy_b") 0.0)
                      em  (or (.get st "entropy_a_max") 0.0)
                      reinit-summary
                      (if slot-reinit?
                        (.reinit_dead_slots mem)
                        nil)
                      n-a (if reinit-summary (.get reinit-summary "n_ka_reinit") 0)
                      n-b (if reinit-summary (.get reinit-summary "n_kb_reinit") 0)]
                  (append-jsonl! log-path
                                 (format "{\"step\":%d,\"event\":\"slot_usage\",\"tier\":\"local\",\"layer\":%d,\"dead_a\":%d,\"dead_b\":%d,\"entropy_a\":%.3f,\"entropy_b\":%.3f,\"entropy_max\":%.3f,\"reinit_a\":%d,\"reinit_b\":%d,\"wall_s\":%.1f}"
                                         step' i d-a d-b ea eb em n-a n-b (- (time/time) t0)))
                  ;; Per-row Local V touch-count distribution (#1 spike
                  ;; visibility). Lazy-init buffer; only populated when
                  ;; MMLLM_BANK_COLD_BOOST is on (since the boost code is
                  ;; what creates _per_row_touches). Otherwise no-op.
                  (let [V-weight (.- (.- mem V) weight)
                        touches  (python/getattr V-weight "_per_row_touches" nil)]
                    (when touches
                      (let [tf       (.float touches)
                            mean-v   (.item (.mean tf))
                            std-v    (.item (.std tf))
                            mx       (.item (.amax touches))
                            n-rows   (.numel touches)
                            n-nz     (.item (.sum (.gt touches 0)))
                            pct-nz   (* 100.0 (/ (python/float n-nz) n-rows))
                            kth      (.kthvalue tf (python/int (* 0.95 n-rows)))
                            p95      (.item (.- kth values))]
                        (append-jsonl! log-path
                                       (format "{\"step\":%d,\"event\":\"row_touch_dist\",\"tier\":\"local\",\"layer\":%d,\"mean\":%.2f,\"std\":%.2f,\"max\":%d,\"p95\":%.2f,\"pct_nonzero\":%.2f,\"wall_s\":%.1f}"
                                               step' i mean-v std-v mx p95 pct-nz (- (time/time) t0))))))
                  (.reset_slot_usage mem))
                ;; NetBank slot stats (when enabled)
                (when-let [nb (:netbank blk)]
                  (let [st  (.slot_usage_stats nb)
                        d-a (.get st "dead_a")
                        d-b (.get st "dead_b")
                        ea  (or (.get st "entropy_a") 0.0)
                        eb  (or (.get st "entropy_b") 0.0)
                        em  (or (.get st "entropy_a_max") 0.0)
                        reinit-summary
                        (if slot-reinit?
                          (.reinit_dead_slots nb)
                          nil)
                        n-a (if reinit-summary (.get reinit-summary "n_ka_reinit") 0)
                        n-b (if reinit-summary (.get reinit-summary "n_kb_reinit") 0)]
                    (append-jsonl! log-path
                                   (format "{\"step\":%d,\"event\":\"slot_usage\",\"tier\":\"net\",\"layer\":%d,\"dead_a\":%d,\"dead_b\":%d,\"entropy_a\":%.3f,\"entropy_b\":%.3f,\"entropy_max\":%.3f,\"reinit_a\":%d,\"reinit_b\":%d,\"wall_s\":%.1f}"
                                           step' i d-a d-b ea eb em n-a n-b (- (time/time) t0)))
                    (.reset_slot_usage nb))))
              ;; Per-param norm log — gated by MMLLM_LOG_PARAM_NORMS.
              ;; Walks named tensor groups, writes L∞/L2 per group.
              ;; Identifies which param tensor (if any) is drifting
              ;; toward inf so we can localize the source of NaN.
              (when (pick-log-param-norms?)
                (let [t-now    (- (time/time) t0)
                      log-norm! (fn [tag t]
                                  (when t
                                    (let [linf (.item (.amax (.abs t)))
                                          l2   (.item (.norm t))]
                                      (append-jsonl! log-path
                                        (format "{\"step\":%d,\"event\":\"param_norms\",\"tag\":\"%s\",\"linf\":%.4e,\"l2\":%.4e,\"wall_s\":%.1f}"
                                                step' tag linf l2 t-now)))))]
                  (log-norm! "tok-emb" (.- (:tok-emb m) weight))
                  (log-norm! "norm-final" (.- (:norm-final m) weight))
                  (when-let [mh (:mtp-head m)]
                    (log-norm! "mtp-head" (.- mh weight)))
                  (when-let [ih (:importance-head m)]
                    (log-norm! "ih-proj-w" (.- (.- ih proj) weight))
                    (log-norm! "ih-proj-b" (.- (.- ih proj) bias)))
                  (doseq [[i blk] (map-indexed vector (:blocks m))]
                    (log-norm! (format "blk%d-q-proj" i) (.- (:q-proj blk) weight))
                    (log-norm! (format "blk%d-k-proj-l" i) (.- (:k-proj-l blk) weight))
                    (log-norm! (format "blk%d-v-proj-l" i) (.- (:v-proj-l blk) weight))
                    (log-norm! (format "blk%d-o-proj" i) (.- (:o-proj blk) weight))
                    (log-norm! (format "blk%d-gate-proj" i) (.- (:gate-proj blk) weight))
                    (log-norm! (format "blk%d-down-proj" i) (.- (:down-proj blk) weight))
                    (log-norm! (format "blk%d-mem-Ka" i) (.- (:memory blk) K_a))
                    (log-norm! (format "blk%d-mem-Kb" i) (.- (:memory blk) K_b))
                    (log-norm! (format "blk%d-mem-V" i) (.- (.- (:memory blk) V) weight))
                    (when-let [nb (:netbank blk)]
                      (log-norm! (format "blk%d-net-Ka" i) (.- nb K_a))
                      (log-norm! (format "blk%d-net-Kb" i) (.- nb K_b))
                      (log-norm! (format "blk%d-net-V" i) (.- (.- nb V) weight))
                      (log-norm! (format "blk%d-net-expander" i) (.- (.- nb expander) weight)))
                    (when-let [c (:carry blk)]
                      (log-norm! (format "blk%d-carry-gate" i) (.- (.- c gate) weight))))))
              ;; Single-line router-metrics JSONL event so dashboards
              ;; can plot distill_loss / replay_loss / replay_buf size
              ;; over time. Cheap — reads from in-memory dict.
              (let [metrics (:metrics m)
                    t-now   (- (time/time) t0)]
                (when metrics
                  (append-jsonl! log-path
                    (format "{\"step\":%d,\"event\":\"router_metrics\",\"distill_loss\":%.6e,\"replay_loss\":%.6e,\"replay_buf_n\":%d,\"replay_cap\":%d,\"delim_loss\":%.6e,\"wall_s\":%.1f}"
                            step'
                            (or (.get metrics "distill_loss") 0.0)
                            (or (.get metrics "replay_loss")  0.0)
                            (or (.get metrics "replay_buf_n") 0)
                            replay-cap
                            (or (.get metrics "delim_loss")   0.0)
                            t-now))))
              ;; Per-layer SwitchGate distribution log. Each block's
              ;; long-gate's most recent forward stored mean (sdpa, local,
              ;; net) weights. Trend over training shows tier consolidation
              ;; (e.g., as NetBank learns, net_frac should grow at the
              ;; expense of local_frac on stable corpora).
              (let [t-now (- (time/time) t0)]
                (doseq [[i blk] (map-indexed vector (:blocks m))]
                  (let [gd (.- (:long-gate blk) last_gate_dist)]
                    (when gd
                      (let [s (python/float (.__getitem__ gd 0))
                            l (python/float (.__getitem__ gd 1))
                            n (python/float (.__getitem__ gd 2))]
                        (append-jsonl! log-path
                          (format "{\"step\":%d,\"event\":\"gate_dist\",\"layer\":%d,\"sdpa\":%.4f,\"local\":%.4f,\"net\":%.4f,\"wall_s\":%.1f}"
                                  step' i s l n t-now))))))))
            (when (zero? (mod step' ckpt-every))
              (save-checkpoint! m opt-dense opt-sparse opt-sparse-net ckpt-dir step' volume)
              (println (format "  ── ckpt at step %d ──" step')))
            (recur step'))))
        (finally
          ;; Stop the energy tracker and emit a single training_energy
          ;; event with the run's totals. Wrapped in its own try/except
          ;; so an instrumentation failure can never break a finished
          ;; training run.
          (try
            (let [s (.stop tracker)]
              (println (format "  ── energy: %.4f kWh / %.1f gCO2eq / %.5f J/tok over %s tokens (backend=%s) ──"
                               (.get s "kwh") (.get s "gco2eq")
                               (.get s "j_per_tok") (.get s "n_tokens")
                               (.get s "backend")))
              (println (format "  ── memory: peak VRAM %.2f / %.2f GB; ~%.4f kWh attributable to VRAM-resident state (estimate) ──"
                               (.get s "peak_vram_gb") (.get s "total_vram_gb")
                               (.get s "vram_idle_kwh_estimate")))
              (when-let [w (.get s "warning")]
                (println (format "  ── energy WARN: %s ──" w)))
              (append-jsonl! log-path
                             (format "{\"event\":\"training_energy\",\"backend\":\"%s\",\"wall_s\":%.1f,\"kwh\":%.6f,\"gco2eq\":%.3f,\"n_tokens\":%d,\"j_per_tok\":%.6f,\"tok_per_s\":%.2f,\"peak_w\":%.1f,\"peak_vram_gb\":%.3f,\"total_vram_gb\":%.3f,\"vram_idle_kwh_estimate\":%.6f,\"pue\":%.3f,\"grid_g_per_kwh\":%.1f}"
                                     (.get s "backend") (.get s "wall_s")
                                     (.get s "kwh") (.get s "gco2eq")
                                     (.get s "n_tokens") (.get s "j_per_tok")
                                     (.get s "tok_per_s") (.get s "peak_w")
                                     (.get s "peak_vram_gb") (.get s "total_vram_gb")
                                     (.get s "vram_idle_kwh_estimate")
                                     (.get s "pue") (.get s "grid_g_per_kwh"))))
            (catch python/Exception e
              (println (format "  ── energy: instrumentation failed: %s ──" e)))))))))

;;; ─────────────────────── copy-from-far probe ───────────────────────
;;;
;;; Synthetic task: each sequence is laid out as
;;;   [key (k bytes)][val (v bytes)][distractor (T-2k-2v bytes)][key][val]
;;; and the model is trained on next-token loss across the whole thing.
;;; Probe metric: argmax accuracy on the LAST val-len positions —
;;; can the model recall val given key after the distractor?

(defn copy-batch
  "Generate a (B, T) batch of [key val distractor key val] sequences."
  [B T key-len val-len]
  (let [d-len (- T (* 2 key-len) (* 2 val-len))
        seqs  (python/list)]
    (assert (pos? d-len) "T must be > 2*(key-len + val-len)")
    (doseq [_ (range B)]
      (let [k    (torch/randint 32 127 (python/tuple [key-len]) ** :dtype torch/long)
            val  (torch/randint 32 127 (python/tuple [val-len]) ** :dtype torch/long)
            d    (torch/randint 32 127 (python/tuple [d-len])   ** :dtype torch/long)
            seq  (torch/cat (python/list [k val d k val]))]
        (.append seqs seq)))
    (torch/stack seqs)))

(defn- copy-train-step
  "Same shape as train-step but the loss is computed ONLY on the
   last val-len target positions (the recall val). Distractor and
   key positions are random — including them in the loss drowns
   the learnable signal in pure entropy."
  [m opt-dense opt-sparse x y val-len]
  (let [[logits _ _] (forward m x)
        L            (.size logits 1)
        logits-tail (.narrow logits 1 (- L val-len) val-len)
        y-tail      (.narrow y      1 (- (.size y 1) val-len) val-len)
        loss        (F/cross_entropy (.reshape logits-tail -1 vocab-size)
                                     (.reshape y-tail -1))]
    (.zero_grad opt-dense)
    (.zero_grad opt-sparse)
    (.backward loss)
    (.step opt-dense)
    (.step opt-sparse)
    (.item loss)))

(defn train-copy
  "Train on copy-from-far synthetic data. Returns trained model.
   Loss is masked to only the last val-len positions per sequence."
  [config steps key-len val-len]
  (let [m          (build-model config)
        opt-dense  (optim/AdamW    (python/list (parameters m))         ** :lr (pick-lr-dense))
        opt-sparse ((pick-sparse-optimizer) (python/list (sparse-parameters m)) ** :lr (pick-lr-bank))
        T          (:seq-len config)
        d-len      (- T (* 2 key-len) (* 2 val-len))]
    (println (format "train-copy: %d steps; T=%d, key=%d, val=%d, distractor=%d (loss masked to recall)"
                     steps T key-len val-len d-len))
    (doseq [step (range steps)]
      (let [seqs (copy-batch 4 T key-len val-len)
            x    (.narrow seqs 1 0 (- T 1))
            y    (.narrow seqs 1 1 (- T 1))
            l    (copy-train-step m opt-dense opt-sparse x y val-len)]
        (when (zero? (mod step 50))
          (println (format "  step %4d  loss %.3f" step l)))))
    m))

(defn probe-eval
  "Measure recall accuracy on n-test held-out copy sequences.
   Returns {:per-token <float> :per-seq <float>}."
  [m n-test seq-len key-len val-len]
  (set-eval-mode! m)
  (let [seqs        (copy-batch n-test seq-len key-len val-len)
        T           seq-len
        targets     (.narrow seqs 1 (- T val-len) val-len)            ; (n_test, val_len)
        inputs      (.narrow seqs 1 0 (- T 1))                         ; (n_test, T-1)
        [logits _ _] (forward m inputs)
        ;; logits[:, t, :] predicts inputs[t+1]; we want the last val_len predictions
        pred-logits (.narrow logits 1 (- (- T 1) val-len) val-len)     ; (n_test, val_len, V)
        pred-tokens (.argmax pred-logits ** :dim -1)
        matches     (.eq pred-tokens targets)
        per-tok     (.item (.mean (.float matches)))
        per-seq     (.item (.mean (.float (.all matches ** :dim -1))))]
    {:per-token per-tok :per-seq per-seq}))

;;; ─────────────────────── CLI ───────────────────────

(defn- pick-config [arg]
  (case arg
    "long" long-leaning-config
    default-config))

(defn cli-main []
  ;; Tune CPU thread counts before any torch op runs (set_num_interop_threads
  ;; is one-shot per process). Wrapped in try because it raises if any
  ;; parallel torch work has already happened — e.g., on basilisp re-bootstrap.
  (try
    (let [r (setup-threads!)]
      (println (format "  threads: %d intra-op / %d inter-op (set MMLLM_NUM_THREADS to override)"
                       (:n-threads r) (:n-interop r))))
    (catch python/Exception e
      (println (format "  threads: setup skipped (%s)" e))))
  (let [args (vec (rest sys/argv))
        cmd  (first args)
        cfg  (pick-config (second args))]
    (case cmd
      "train"      (do (train cfg 200) (println "done."))
      "sample"     (let [m   (train cfg 200)
                         out (sample m "she " 200)]
                     (println "──────") (println out))
      "compare"    (do
                     (println "═══════ short-leaning  (5 short / 7 long) ═══════")
                     (train default-config 200)
                     (println)
                     (println "═══════ long-leaning   (2 short / 10 long) ═══════")
                     (train long-leaning-config 200)
                     (println "done."))
      "train-mmap" (let [path     (or (second args) "/tmp/mmllm-bank")
                         mmap-cfg (assoc default-config :memory-mmap-path path)]
                     (train mmap-cfg 200)
                     (println "done."))
      "probe"      (let [key-len 4
                         val-len 4
                         steps   2000
                         T       (:seq-len cfg)
                         n-test  64
                         m       (train-copy cfg steps key-len val-len)
                         ;; same test data for baseline & ablation runs
                         _       (torch/manual_seed 42)
                         acc-w   (probe-eval m n-test T key-len val-len)
                         ;; ablate: zero every block's value bank V.weight
                         _       (doseq [b (:blocks m)] (.zero_bank (:memory b)))
                         _       (torch/manual_seed 42)
                         acc-o   (probe-eval m n-test T key-len val-len)]
                     (println)
                     (println "═══ recall accuracy ═══")
                     (println (format "  with bank:        per-token=%.3f  per-seq=%.3f"
                                      (:per-token acc-w) (:per-seq acc-w)))
                     (println (format "  bank zeroed (ablation): per-token=%.3f  per-seq=%.3f"
                                      (:per-token acc-o) (:per-seq acc-o)))
                     (println (format "  Δ per-seq:        %+.3f" (- (:per-seq acc-o) (:per-seq acc-w))))
                     (println (format "  chance baseline:  %.3f" (/ 1.0 95))))
      "build-corpus"  (let [out-path (or (second args) "/tmp/mmllm-corpus.bin")
                            src      (or (nth args 2 nil) "/home/user/mmllm")
                            stats    (corp/build-corpus out-path [src])]
                        (println (format "  built: %d files, %s"
                                         (get stats "files") (get stats "human")))
                        (println (format "  → %s" (get stats "path"))))
      "clone-clojure" (let [target (or (second args) "/tmp/clojure-corpus")
                            paths  (corp/clone-repos target nil)]
                        (println (format "  %d repos at %s" (count paths) target)))
      "train-corpus"  (let [path  (or (second args) "/tmp/mmllm-corpus.bin")
                            mpath (nth args 2 nil)
                            steps (python/int (or (nth args 3 nil) 500))
                            cfg2  (if mpath (assoc cfg :memory-mmap-path mpath) cfg)]
                        (train-corpus cfg2 steps path)
                        (println "done."))
      "fetch-text8"   (let [out   (or (second args) "/tmp/text8")
                            stats (corp/fetch-mahoney "text8" out)]
                        (println (format "  text8: %s (%d bytes, cached=%s)"
                                         (get stats "path") (get stats "bytes")
                                         (get stats "cached"))))
      "fetch-enwik8"  (let [out   (or (second args) "/tmp/enwik8")
                            stats (corp/fetch-mahoney "enwik8" out)]
                        (println (format "  enwik8: %s (%d bytes, cached=%s)"
                                         (get stats "path") (get stats "bytes")
                                         (get stats "cached"))))
      "split-text8"   (let [in    (or (second args) "/tmp/text8")
                            paths (corp/split-text8 in)]
                        (println (format "  train: %s (%d bytes)"
                                         (get paths "train") (get paths "bytes_train")))
                        (println (format "  val:   %s (%d bytes)"
                                         (get paths "val")   (get paths "bytes_val")))
                        (println (format "  test:  %s (%d bytes)"
                                         (get paths "test")  (get paths "bytes_test"))))
      "train-text8"   (let [base  (or (second args) "/tmp/text8")
                            mpath (nth args 2 nil)
                            steps (python/int (or (nth args 3 nil) 500))
                            cfg2  (if mpath (assoc cfg :memory-mmap-path mpath) cfg)]
                        (train-text8 cfg2 steps base)
                        (println "done."))
      "train-long"    (let [base       (or (second args) "/tmp/text8")
                            mpath      (nth args 2 nil)
                            total      (python/int (or (nth args 3 nil) 10000))
                            eval-every (python/int (or (nth args 4 nil) 1000))
                            ckpt-every (python/int (or (nth args 5 nil) 5000))
                            train-path (str base ".train.bin")
                            val-path   (str base ".val.bin")
                            ckpt-dir   (str base ".ckpts")
                            log-path   (str base ".log.jsonl")
                            cfg2       (if mpath (assoc cfg :memory-mmap-path mpath) cfg)]
                        (train-long cfg2 train-path val-path ckpt-dir log-path
                                    total eval-every ckpt-every)
                        (println "done."))
      "fim-eval"      (let [ckpt-dir  (or (second args) "/tmp/mmllm-cpu/fim-corpus.ckpts")
                            eval-path (or (nth args 2 nil) "/tmp/mmllm-cpu/fim-eval.jsonl")
                            ckpt-step (when (nth args 3 nil)
                                        (python/int (nth args 3 nil)))
                            fim-eval  (python/__import__ "mmllm.fim.eval" ** :fromlist (python/list ["run_fim_eval" "print_summary"]))
                            ;; Build a fresh CPU model with cpu-tiny config + load the ckpt
                            cfg2      (assoc default-config-cpu-tiny
                                             :memory-mmap-path "/tmp/mmllm-cpu/fim-eval-bank")]
                        (.__setitem__ (.- os environ) "MMLLM_DEVICE" "cpu")
                        (.__setitem__ (.- os environ) "MMLLM_BANK_ON_GPU" "false")
                        (let [m            (build-model cfg2)
                              opt-dense    (optim/AdamW (python/list (parameters m)) ** :lr 1e-3)
                              opt-sparse   (optim/SparseAdam (python/list (sparse-parameters m)) ** :lr 1e-3)
                              ckpt-dir-py  (python/str ckpt-dir)
                              ;; Resolve ckpt step (latest if not specified)
                              actual-step  (or ckpt-step
                                               (let [os-py    (python/__import__ "os")
                                                     re-py    (python/__import__ "re")
                                                     entries  (python/list (.listdir os-py ckpt-dir-py))
                                                     step-dirs (python/list (filter (fn [n] (.startswith n "step-")) entries))
                                                     steps    (python/list (map (fn [n] (python/int (.replace n "step-" ""))) step-dirs))]
                                                 (if (zero? (count steps))
                                                   (do (println "no ckpts found at " ckpt-dir-py) (sys/exit 1))
                                                   (apply max steps))))]
                          (println (format "  fim-eval: ckpt=%s/step-%d  eval=%s"
                                           ckpt-dir actual-step eval-path))
                          (load-checkpoint! m opt-dense opt-sparse ckpt-dir actual-step)
                          (set-eval-mode! m)
                          (let [result (.run_fim_eval fim-eval m forward eval-path ** :device "cpu")]
                            (.print_summary fim-eval result))))
      "fim-build-corpus" (let [language     (or (second args) "generic")
                               source-root  (or (nth args 2 nil) "/tmp/mmllm-cpu/sources")
                               output-pref  (or (nth args 3 nil) "/tmp/mmllm-cpu/fim-corpus")
                               fim-ratio    (python/float (or (nth args 4 nil) "0.5"))
                               psm-ratio    (python/float (or (nth args 5 nil) "0.5"))
                               rng-seed     (python/int   (or (nth args 6 nil) "0"))
                               fim-gen-py   (python/__import__ "mmllm.fim.generator"
                                                                ** :fromlist (python/list ["LANGUAGE_EXTENSIONS"
                                                                                            "build_fim_corpus"
                                                                                            "collect_source_files"]))
                               exts         (.get (.- fim-gen-py LANGUAGE_EXTENSIONS)
                                                  language (python/tuple))
                               paths        (.collect_source_files fim-gen-py source-root
                                                                   ** :extensions exts)]
                           (println (format "  fim-build-corpus  language=%s  source=%s  out=%s"
                                            language source-root output-pref))
                           (println (format "    found %d source files (extensions=%s)"
                                            (count paths) (str exts)))
                           (when (zero? (count paths))
                             (println "    no source files found; aborting") (sys/exit 1))
                           (let [stats (.build_fim_corpus fim-gen-py
                                          (python/list paths) output-pref
                                          ** :language language
                                          :fim_ratio fim-ratio
                                          :psm_ratio psm-ratio
                                          :rng_seed rng-seed)]
                             (println (format "  done. stats: %s" (python/dict stats)))))
      "train-fim"     (let [base       (or (second args) "/tmp/mmllm-cpu/fim-corpus")
                            mpath      (or (nth args 2 nil) "/tmp/mmllm-cpu/fim-bank")
                            total      (python/int (or (nth args 3 nil) 5000))
                            eval-every (python/int (or (nth args 4 nil) 500))
                            ckpt-every (python/int (or (nth args 5 nil) 1000))]
                        ;; train-fim wraps train-cpu but force-enables the
                        ;; FIM loss mask so the model trains only on middle
                        ;; bytes. All other knobs (focal, IH, carry, distill,
                        ;; replay, alpha_net, NetBank, ...) still respected.
                        (.__setitem__ (.- os environ) "MMLLM_FIM_LOSS_MASK_MIDDLE_ONLY" "true")
                        (println (format "  train-fim: FIM_LOSS_MASK_MIDDLE_ONLY=true forced"))
                        (let [train-path (str base ".train.bin")
                              val-path   (str base ".val.bin")
                              ckpt-dir   (str base ".ckpts")
                              log-path   (str base ".log.jsonl")
                              cfg2       (assoc default-config-cpu-tiny
                                                :memory-mmap-path mpath)]
                          (.__setitem__ (.- os environ) "MMLLM_DEVICE" "cpu")
                          (when (nil? (.get (.- os environ) "MMLLM_BATCH"))
                            (.__setitem__ (.- os environ) "MMLLM_BATCH" "4"))
                          (when (nil? (.get (.- os environ) "MMLLM_BANK_ON_GPU"))
                            (.__setitem__ (.- os environ) "MMLLM_BANK_ON_GPU" "false"))
                          (train-long cfg2 train-path val-path ckpt-dir log-path
                                      total eval-every ckpt-every)
                          (println "done.")))
      "bootstrap-chain" (let [target-dir (or (second args)
                                             (.get (.- os environ) "MMLLM_BOOTSTRAP_DIR"))]
                          ;; Genesis ckpt builder for a fresh chain at a non-default
                          ;; architecture (e.g. symmetric Local at 24 layers). Reads
                          ;; arch overrides from env vars at model-build time
                          ;; (MMLLM_LOCAL_BANK_LAYERS, MMLLM_NETBANK_SHARED, etc.),
                          ;; builds the model with random init, and writes:
                          ;;   <target-dir>/V_net.{0..N-1}.bin   — mmap'd Gaussian
                          ;;   <target-dir>/dense.pt             — torch list of params
                          ;;   <target-dir>/chain_meta.json      — locked arch knobs
                          ;; so subsequent birds that resume from this dir rebuild
                          ;; the model with the SAME arch (otherwise dense.pt's
                          ;; param-count won't match and load fails).
                          (when (nil? target-dir)
                            (println "ERROR: bootstrap-chain needs a target dir (arg or MMLLM_BOOTSTRAP_DIR)")
                            (python/exit 2))
                          (.__setitem__ (.- os environ) "MMLLM_DEVICE" "cpu")
                          (when (nil? (.get (.- os environ) "MMLLM_BANK_ON_GPU"))
                            (.__setitem__ (.- os environ) "MMLLM_BANK_ON_GPU" "false"))
                          (os/makedirs target-dir ** :exist_ok true)
                          ;; Pre-allocate NetBank V_net.{i}.bin files with random
                          ;; Gaussian init — pure-python helper in mmllm.netbank.
                          (let [netb (python/__import__ "mmllm.netbank"
                                                        ** :fromlist (python/list ["prepare_netbank_files"]))
                                n-layers (:n-layers default-config-cpu-mini)
                                sqrt-n   (python/int (or (.get (.- os environ) "MMLLM_NET_SQRT_N") "1024"))
                                c-net    (python/int (or (.get (.- os environ) "MMLLM_NET_C_NET") "8"))
                                _ (.prepare_netbank_files netb
                                                          (str target-dir "/V_net")
                                                          n-layers sqrt-n c-net)
                                ;; Point the build at the freshly-allocated mmaps.
                                _ (.__setitem__ (.- os environ) "MMLLM_NET_BANK_PATH"
                                                (str target-dir "/V_net"))
                                cfg     (assoc default-config-cpu-mini
                                               :memory-mmap-path (str target-dir "/local"))
                                m       (build-model cfg)
                                params  (python/list (for [p (parameters m)]
                                                       (.detach (.clone (.- p data)))))]
                            (torch/save params (str target-dir "/dense.pt"))
                            ;; Persist arch knobs alongside the ckpt so resumers can
                            ;; re-export the same env before build-model. json.dumps
                            ;; doesn't know how to serialize basilisp PersistentMap,
                            ;; so build a python dict directly.
                            (let [meta (python/dict)]
                              (.__setitem__ meta "chain_genesis" true)
                              (.__setitem__ meta "config_name" "cpu-mini")
                              (.__setitem__ meta "MMLLM_LOCAL_BANK_LAYERS"
                                            (or (.get (.- os environ) "MMLLM_LOCAL_BANK_LAYERS") ""))
                              (.__setitem__ meta "MMLLM_NETBANK_SHARED"
                                            (or (.get (.- os environ) "MMLLM_NETBANK_SHARED") "false"))
                              (.__setitem__ meta "MMLLM_NET_SQRT_N" (str sqrt-n))
                              (.__setitem__ meta "MMLLM_NET_C_NET"  (str c-net))
                              (.__setitem__ meta "MMLLM_SQRT_N"
                                            (or (.get (.- os environ) "MMLLM_SQRT_N") ""))
                              (.__setitem__ meta "n_layers" n-layers)
                              (let [json (python/__import__ "json")
                                    f    (python/open (str target-dir "/chain_meta.json") "w")]
                                (.write f (.dumps json meta ** :indent 2))
                                (.close f)))
                            (println (format "bootstrap-chain: wrote dense.pt + V_net.{0..%d}.bin + chain_meta.json to %s"
                                             (- n-layers 1) target-dir))))
      "train-fim-mini" (let [base       (or (second args) "/tmp/mmllm-cpu/fim-corpus")
                             mpath      (or (nth args 2 nil) "/tmp/mmllm-cpu/fim-bank")
                             total      (python/int (or (nth args 3 nil) 5000))
                             eval-every (python/int (or (nth args 4 nil) 500))
                             ckpt-every (python/int (or (nth args 5 nil) 1000))]
                         ;; Same FIM-mask-forcing wrapper as train-fim, but
                         ;; uses default-config-cpu-mini (d_model=32, d_ff=128,
                         ;; ~500k dense params — ~35× smaller trunk). Same
                         ;; 32-layer asymmetric Local/Net layout, same q_dim
                         ;; bank shapes scaled by q_dim=16. Designed for
                         ;; "does the bank tier get adopted when the trunk
                         ;; isn't capable enough to solve FIM alone?" spike.
                         (.__setitem__ (.- os environ) "MMLLM_FIM_LOSS_MASK_MIDDLE_ONLY" "true")
                         (println (format "  train-fim-mini: FIM_LOSS_MASK_MIDDLE_ONLY=true forced; cfg=cpu-mini"))
                         (let [train-path (str base ".train.bin")
                               val-path   (str base ".val.bin")
                               ckpt-dir   (str base ".ckpts")
                               log-path   (str base ".log.jsonl")
                               cfg2       (assoc default-config-cpu-mini
                                                 :memory-mmap-path mpath)]
                           (.__setitem__ (.- os environ) "MMLLM_DEVICE" "cpu")
                           (when (nil? (.get (.- os environ) "MMLLM_BATCH"))
                             (.__setitem__ (.- os environ) "MMLLM_BATCH" "4"))
                           (when (nil? (.get (.- os environ) "MMLLM_BANK_ON_GPU"))
                             (.__setitem__ (.- os environ) "MMLLM_BANK_ON_GPU" "false"))
                           (train-long cfg2 train-path val-path ckpt-dir log-path
                                       total eval-every ckpt-every)
                           (println "done.")))
      "train-cpu"     (let [base       (or (second args) "/tmp/mmllm-cpu/corpus.bin")
                            mpath      (or (nth args 2 nil) "/tmp/mmllm-cpu/bank")
                            total      (python/int (or (nth args 3 nil) 5000))
                            eval-every (python/int (or (nth args 4 nil) 1000))
                            ckpt-every (python/int (or (nth args 5 nil) 1000))
                            train-path (str base ".train.bin")
                            val-path   (str base ".val.bin")
                            ckpt-dir   (str base ".ckpts")
                            log-path   (str base ".log.jsonl")
                            cfg2       (assoc default-config-cpu-tiny
                                              :memory-mmap-path mpath)]
                        ;; Force CPU device + tiny batch in-process so
                        ;; the operator doesn't have to remember to set
                        ;; MMLLM_DEVICE / MMLLM_BATCH. Other knobs
                        ;; (focal, IH, carry, etc.) still respected via env.
                        (.__setitem__ (.- os environ) "MMLLM_DEVICE" "cpu")
                        (when (nil? (.get (.- os environ) "MMLLM_BATCH"))
                          (.__setitem__ (.- os environ) "MMLLM_BATCH" "4"))
                        ;; Force the bank V to mmap-backed CPUPinnedEmbedding
                        ;; on CPU runs. Otherwise the GPU-resident default
                        ;; logs "V will live on GPU" misleadingly and ignores
                        ;; the user's mmap_path. Operator can still override
                        ;; by setting MMLLM_BANK_ON_GPU explicitly.
                        (when (nil? (.get (.- os environ) "MMLLM_BANK_ON_GPU"))
                          (.__setitem__ (.- os environ) "MMLLM_BANK_ON_GPU" "false"))
                        (println (format "  train-cpu: cfg=cpu-tiny corpus=%s bank=%s total=%d"
                                         base mpath total))
                        (train-long cfg2 train-path val-path ckpt-dir log-path
                                    total eval-every ckpt-every)
                        (println "done."))
      "bench"         (let [base      (or (second args) "/data/pile-github.bin")
                            ckpt-step (when (nth args 2 nil) (python/int (nth args 2 nil)))
                            bank-path (or (nth args 3 nil) "/data/pile-bank-3tier")
                            n-warm    (python/int (or (nth args 4 nil) 50))
                            n-time    (python/int (or (nth args 5 nil) 500))
                            ;; bench must use the same config the training
                            ;; pipeline does (cpu-tiny). Default `cfg` is
                            ;; default-config (d_model=384) which mismatches
                            ;; ckpts saved by train-fim / train-cpu.
                            bench-cfg default-config-cpu-tiny]
                        (bench-inference bench-cfg base ckpt-step bank-path n-warm n-time)
                        (println "done."))
      "bench-spec"    (let [base      (or (second args) "/data/pile-github.bin")
                            ckpt-step (when (nth args 2 nil) (python/int (nth args 2 nil)))
                            bank-path (or (nth args 3 nil) "/data/pile-bank-3tier")
                            n-warm    (python/int (or (nth args 4 nil) 30))
                            n-time    (python/int (or (nth args 5 nil) 200))
                            K         (python/int (or (nth args 6 nil) 4))]
                        (bench-inference-spec cfg base ckpt-step bank-path n-warm n-time K)
                        (println "done."))
      "bench-batch"   (let [base      (or (second args) "/data/pile-github.bin")
                            ckpt-step (when (nth args 2 nil) (python/int (nth args 2 nil)))
                            bank-path (or (nth args 3 nil) "/data/pile-bank-3tier")
                            n-warm    (python/int (or (nth args 4 nil) 20))
                            n-time    (python/int (or (nth args 5 nil) 100))
                            B         (python/int (or (nth args 6 nil) 16))]
                        (bench-inference-batch cfg base ckpt-step bank-path n-warm n-time B)
                        (println "done."))
      "fetch-artifacts" (let [out-dir (or (second args) "./mmllm-artifacts")
                              base    (nth args 2 nil)]
                          (let [stats (art/fetch_artifacts out-dir base)]
                            (println (format "  fetched %d files, %d cached, %s total"
                                             (.get stats "n_fetched")
                                             (.get stats "n_cached")
                                             (.get stats "total_human"))))
                          (println "done."))
      "bank-quantize" (let [in-prefix  (or (second args) "/data/pile-bank-3tier")
                            out-prefix (or (nth args 2 nil) "/data/pile-bank-3tier-int8")
                            n-layers   (python/int (or (nth args 3 nil) (:n-layers cfg)))
                            sqrt-n     (pick-sqrt-n cfg)
                            head-dim   (quot (:d-model cfg) (:n-heads cfg))
                            q-dim      (* (:n-long-heads cfg) head-dim)]
                        (println (format "  bank-quantize: in=%s.<i>.bin → out=%s.<i>.int8.bin"
                                         in-prefix out-prefix))
                        (println (format "    n-layers=%d  sqrt-n=%d  q-dim=%d  (n-rows per layer = %d)"
                                         n-layers sqrt-n q-dim (* sqrt-n sqrt-n)))
                        (let [results (mem/quantize_bank_files in-prefix out-prefix n-layers q-dim)]
                          (doseq [r results]
                            (println (format "    %s → %s   %.2f GB → %.2f GB   (ratio %.2fx, max|x|=%g, %d clamped)"
                                             (.get r "in_path") (.get r "out_path")
                                             (/ (.get r "in_bytes") 1.073741824e9)
                                             (/ (.get r "out_bytes") 1.073741824e9)
                                             (.get r "compression_ratio")
                                             (.get r "max_abs_overall")
                                             (.get r "n_clamped")))))
                        (println "done."))
      "fetch-pile-github" (let [out      (or (second args) "/tmp/pile-github.bin")
                                cap      (when (nth args 2 nil)
                                           (python/int (nth args 2 nil)))
                                workers  (python/int (or (nth args 3 nil) 4))
                                stats    (if (> workers 1)
                                           (corp/fetch-pile-github-parallel out cap workers)
                                           (corp/fetch-pile-github out cap))]
                            (println (format "  pile-github: %s (%d bytes, %d entries kept)"
                                             (get stats "path")
                                             (get stats "bytes")
                                             (get stats "entries"))))
      "split-pile-github" (let [in       (or (second args) "/tmp/pile-github.bin")
                                val-cap  (python/int (or (nth args 2 nil) 100000000))
                                test-cap (python/int (or (nth args 3 nil) 100000000))
                                paths    (corp/split-pile-github in val-cap test-cap)]
                            (println (format "  train: %s (%d bytes)"
                                             (get paths "train") (get paths "bytes_train")))
                            (println (format "  val:   %s (%d bytes)"
                                             (get paths "val")   (get paths "bytes_val")))
                            (println (format "  test:  %s (%d bytes)"
                                             (get paths "test")  (get paths "bytes_test"))))
      "prepare-hf-dataset" (let [key       (or (second args) "")
                                 out       (or (nth args 2 nil) "")
                                 max-bytes (python/int (or (nth args 3 nil) 5000000000))
                                 val-bytes (python/int (or (nth args 4 nil) 50000000))
                                 test-bytes (python/int (or (nth args 5 nil) 50000000))]
                             (when (or (zero? (count key)) (zero? (count out)))
                               (println "  prepare-hf-dataset needs <dataset-key> <out-path>")
                               (sys/exit 1))
                             (let [stats (ds/prepare_hf_dataset
                                           key out
                                           ** :max_bytes max-bytes
                                              :val_bytes val-bytes
                                              :test_bytes test-bytes)]
                               (println (format "  done — %d records / %d bytes (skipped %d)"
                                                (.get stats "n_records")
                                                (.get stats "bytes")
                                                (.get stats "n_skipped")))))
      "inspect-dataset" (let [path (or (second args) "")
                              n    (python/int (or (nth args 2 nil) 4000))]
                          (when (zero? (count path))
                            (println "  inspect-dataset needs <bin-path>")
                            (sys/exit 1))
                          (println (ds/inspect_dataset path n)))
      "eval-agent" (let [base       (or (second args) "/tmp/agent")
                         ckpt       (when (nth args 2 nil)
                                      (python/int (nth args 2 nil)))
                         bank       (or (nth args 3 nil) "/tmp/bank")
                         eval-path  (or (nth args 4 nil) "/tmp/eval.test.bin")
                         eval-name  (or (nth args 5 nil) "agent")
                         n-samples  (python/int (or (nth args 6 nil) 50))
                         gen-len    (python/int (or (nth args 7 nil) 512))
                         log-path   (or (nth args 8 nil) (str base ".eval.jsonl"))
                         ;; Auto-detect cpu-tiny ckpts (train-fim / train-cpu).
                         ;; dense.pt[0] is tok_emb of shape (256, d-model).
                         ;; If d-model=192 use cpu-tiny; else default-config.
                         ;; Critical: loading dense.pt into a wrong-shape
                         ;; freshly-built model hits a `.copy_` shape mismatch.
                         eval-cfg   (if ckpt
                                      (let [path (str base ".ckpts/step-" ckpt "/dense.pt")
                                            saved (try (python/list (torch/load path ** :map_location "cpu" :weights_only false))
                                                       (catch python/Exception _ nil))
                                            tok-emb (when saved (.__getitem__ saved 0))
                                            dmodel  (when tok-emb (.__getitem__ (.- tok-emb shape) 1))]
                                        (cond
                                          (= dmodel 192) default-config-cpu-tiny
                                          :else cfg))
                                      cfg)]
                     (when (not (identical? eval-cfg cfg))
                       (println (format "  eval-agent: auto-selected cpu-tiny config (d-model=%d)"
                                        (:d-model eval-cfg))))
                     (eval-agent eval-cfg base ckpt bank eval-path
                                 eval-name n-samples gen-len log-path))
      "eval-bpc-on-path" (let [base       (or (second args) "/tmp/agent")
                               ckpt       (when (nth args 2 nil)
                                            (python/int (nth args 2 nil)))
                               bank       (or (nth args 3 nil) "/tmp/bank")
                               eval-path  (or (nth args 4 nil) "/tmp/eval.test.bin")
                               eval-name  (or (nth args 5 nil) "bpc")
                               log-path   (or (nth args 6 nil) (str base ".eval.jsonl"))]
                           ;; Same config-match invariant as eval-agent.
                           (eval-bpc-on-path cfg base ckpt bank
                                             eval-path eval-name log-path))
      "quick-ablate" (let [base       (or (second args) "/tmp/mmllm-cpu/fim-chain-stack")
                           ckpt       (when (nth args 2 nil)
                                        (python/int (nth args 2 nil)))
                           bank       (or (nth args 3 nil) "/tmp/mmllm-cpu/fim-bank-chain-stack")
                           eval-path  (or (nth args 4 nil) (str base ".val.bin"))
                           cfg2       (assoc default-config-cpu-mini
                                             :memory-mmap-path bank)]
                       (.__setitem__ (.- os environ) "MMLLM_DEVICE" "cpu")
                       (when (nil? (.get (.- os environ) "MMLLM_BATCH"))
                         (.__setitem__ (.- os environ) "MMLLM_BATCH" "4"))
                       (when (nil? (.get (.- os environ) "MMLLM_BANK_ON_GPU"))
                         (.__setitem__ (.- os environ) "MMLLM_BANK_ON_GPU" "false"))
                       (when (nil? (.get (.- os environ) "MMLLM_ABLATION_QUICK"))
                         (.__setitem__ (.- os environ) "MMLLM_ABLATION_QUICK" "true"))
                       (quick-ablate-on-path cfg2 base ckpt bank eval-path))
      "eval-battery-on-ckpt" (let [base        (or (second args) "/tmp/agent")
                                   ckpt        (when (nth args 2 nil)
                                                 (python/int (nth args 2 nil)))
                                   bank        (or (nth args 3 nil) "/tmp/bank")
                                   bpc-evals   (or (nth args 4 nil) "")
                                   agent-evals (or (nth args 5 nil) "")
                                   n-samples   (python/int (or (nth args 6 nil) 50))
                                   gen-len     (python/int (or (nth args 7 nil) 256))
                                   log-path    (or (nth args 8 nil) (str base ".eval.jsonl"))]
                               ;; One basilisp process per ckpt — model + bank
                               ;; load once, then iterate all eval targets.
                               ;; ~5-10× faster than the per-eval-subprocess
                               ;; pattern this replaces.
                               (eval-battery-on-ckpt cfg base ckpt bank
                                                     bpc-evals agent-evals
                                                     n-samples gen-len log-path))
      (do (println "usage: mmllm {train|sample|compare|train-mmap|probe")
          (println "                  |build-corpus|clone-clojure|train-corpus")
          (println "                  |fetch-text8|fetch-enwik8|split-text8|train-text8")
          (println "                  |train-cpu|train-long")
          (println "                  |fim-build-corpus|train-fim|fim-eval")
          (println "                  |bench|bench-batch|bench-spec")
          (println "                  |fetch-artifacts|bank-quantize")
          (println "                  |fetch-pile-github|split-pile-github")
          (println "                  |prepare-hf-dataset|inspect-dataset|eval-agent} [args...]")
          (println "  train [short|long]")
          (println "  sample [short|long]")
          (println "  compare")
          (println "  train-mmap [base-path]                   (creates <path>.0.bin … <path>.N.bin)")
          (println "  probe [short|long]                       (copy-from-far recall accuracy)")
          (println "  build-corpus [out-path] [source-dir]     (default: mmllm → /tmp/mmllm-corpus.bin)")
          (println "  clone-clojure [target-dir]               (shallow-clone Clojure-heavy upstream repos)")
          (println "  train-corpus [corpus-path] [mmap-path] [steps]")
          (println "                                           (mmap-path → <path>.<i>.bin per layer; lets bank exceed RAM)")
          (println "  fetch-text8  [out-path]                  (download Matt Mahoney's text8 → out-path)")
          (println "  fetch-enwik8 [out-path]                  (download Matt Mahoney's enwik8 → out-path)")
          (println "  split-text8  [base-path]                 (90M/5M/5M Mikolov → <base>.{train,val,test}.bin)")
          (println "  train-text8  [base-path] [mmap-path] [steps]")
          (println "                                           (train + eval BPC on val/test; standard byte-LM benchmark)")
          (println "  train-long   [base-path] [mmap-path] [total-steps] [eval-every] [ckpt-every]")
          (println "                                           (long-running: periodic eval-bpc, ckpt every N, resume from")
          (println "                                            <base>.ckpts/ on restart. Designed for Modal/long boxes.)")
          (println "  fim-build-corpus [language] [source-root] [output-prefix] [fim-ratio] [psm-ratio] [seed]")
          (println "                                           (build FIM train/val/test from raw source files;")
          (println "                                            language picks splitter: json|clojure|python|generic.)")
          (println "  train-fim [base] [bank-path] [total-steps] [eval-every] [ckpt-every]")
          (println "                                           (FIM training — forces MMLLM_FIM_LOSS_MASK_MIDDLE_ONLY=true;")
          (println "                                            same telemetry/ckpt pipeline as train-cpu.)")
          (println "  train-fim-mini [base] [bank-path] [total-steps] [eval-every] [ckpt-every]")
          (println "                                           (same as train-fim but uses default-config-cpu-mini —")
          (println "                                            d_model=32, d_ff=128, q_dim=16, ~500k dense params;")
          (println "                                            test bank-tier adoption with a sub-capable trunk.)")
          (println "  fim-eval  [ckpt-dir] [eval-jsonl] [step]")
          (println "                                           (FIM-bpc + FIM-exact on the eval JSONL produced by")
          (println "                                            scripts/build_fim_eval.py; per-language summary.)")
          (println "  bench        [base] [ckpt-step] [bank-path] [n-warm] [n-time]")
          (println "                                           (B=1 inference tok/sec on trained checkpoint)")
          (println "  bench-batch  [base] [ckpt-step] [bank-path] [n-warm] [n-time] [B]")
          (println "                                           (batched inference: B parallel sequences, aggregate tok/sec)")
          (println "  bench-spec   [base] [ckpt-step] [bank-path] [n-warm] [n-time] [K]")
          (println "                                           (speculative decoding: draft K tokens, verify in parallel)")
          (println "  fetch-artifacts [out-dir] [url]          (download release artifacts from GitHub)")
          (println "  bank-quantize [in-prefix] [out-prefix] [n-layers]")
          (println "                                           (fp32 bank → int8 + per-row fp16 scale, ~4× compression)")
          (println "  fetch-pile-github [out-path] [max-bytes] [workers]")
          (println "                                           (download Pile-Github corpus, parallel streaming)")
          (println "  split-pile-github [in-path] [val-bytes] [test-bytes]")
          (println "                                           (split into train/val/test)")
          (println "  prepare-hf-dataset <dataset-key> <out-path> [max-bytes] [val-bytes] [test-bytes]")
          (println "                                           (HF dataset → uint8 byte stream + train/val/test split.")
          (println "                                            Keys: commitpackft|xlam|magicoder|cosmopedia|fineweb-edu")
          (println "                                                  |the-stack-v2-{py,md,sh}.  See mmllm.datasets.)")
          (println "  inspect-dataset <bin-path> [n-bytes]     (decode first N bytes of a prepared .bin and print)")
          (println "  eval-agent <base> <ckpt-step> <bank-path> <eval-test.bin> <eval-name> [n-samples] [gen-len] [log-path]")
          (println "                                           (load ckpt, generate against held-out SFT prompts,")
          (println "                                            score JSON tool-call validity / name-match / args-match)")
          (println "  eval-bpc-on-path <base> <ckpt-step> <bank-path> <test.bin> <eval-name> [log-path]")
          (println "                                           (load ckpt, run BPC on arbitrary held-out byte tensor —")
          (println "                                            cheap, no generation. Pretraining-style metric.)")
          (sys/exit 1)))))
