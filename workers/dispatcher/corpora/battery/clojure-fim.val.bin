                  {:add-id "a7"
                   :op-type :add-array-edge
                   :op-path []
                   :value {:head-node-id "NodeC"
                           :tail-node-id array/array-end-node-id}}]
        path []]
    (doseq [crdt-ops (repeatedly 500 #(shuffle crdt-ops))]
      (let [{:keys [crdt]} (apply-ops/apply-ops
