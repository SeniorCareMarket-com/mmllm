  (is (= (minus [1 2 3] 1) (matrix [0 1 2])))
  (is (= (minus 1 [1 2 3]) (matrix [0 -1 -2])))
  (is (= (minus [1 2 3] (matrix [1 2 3]) (matrix [0 0 0]))))
  
  ;; element by element multiplication on matrices
  (is (= (mult A A A) (matrix [[1 8 27] 
