(defn get-publish-time [archive slug]
  (loop [remainder archive]
    (if (empty? remainder)
      nil
      (if (= ((first remainder) :slug) slug)
        ((first remainder) :publish-time)
        (recur (rest remainder))))))<|fim_mid|>(defn get-relative-path [month year slug]
  (str month "-" year "/" slug ".html"))<|fim_eom|>

