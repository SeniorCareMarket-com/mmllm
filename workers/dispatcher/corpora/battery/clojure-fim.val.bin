            kv (crdt/get-value (assoc arg :path [1]))
            _ (is (= "B" kv))]))))

(deftest test-change-value-of-array-item
  (let [schema (l/array-schema l/string-schema)
        sys-time-ms (u/str->long "1640205282858")
