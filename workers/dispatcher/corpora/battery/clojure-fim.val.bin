    <|fim_mid|>[:div {:class (if @modal "modal-dialog modal-visible" "modal-dialog")}
     (when @modal
       [:div
        [:a {:class "close" :href "#" :on-click #(dispatch [:set-modal nil])} "✖"] [@modal]])]<|fim_eom|>

