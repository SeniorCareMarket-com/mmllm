                   :value "A"}
                  {:add-id "a2"
                   :op-type :add-value
                   :op-path ["NodeB"]
                   :value "B"}
                  {:add-id "a3"
                   :op-type :add-value
                   :op-path ["NodeC"]
                   :value "C"}
                  {:add-id "a4"
                   :op-type :add-array-edge
                   :op-path []
