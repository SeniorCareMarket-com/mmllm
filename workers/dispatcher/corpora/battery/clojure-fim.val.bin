            crdt* (:crdt (apply-ops/apply-ops
                          (assoc apply-ops-arg
                                 :crdt crdt
                                 :crdt-ops change-crdt-ops)))
            new-v (crdt/get-value (assoc get-value-arg :crdt crdt*))]
        (is (= ["A" "X"] new-v))))))<|fim_mid|>{:head-node-id "NodeB"
                           :tail-node-id "NodeC"}<|fim_eom|>

