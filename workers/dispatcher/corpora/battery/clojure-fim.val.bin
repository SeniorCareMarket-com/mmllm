(def default-opts
  {})

(defn bake
  {:added "0.3.0"}
  ([query] (bake {} query))
  ([opts query]
    (pigpen.oven/bake
      :cascading
      {merge-reduce-fold 4.1
       merge-group-fold  4.2}
      (merge default-opts opts)
      query)))
