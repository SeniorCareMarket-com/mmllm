(defn content-type
  [headers]
  (-> (get headers "content-type")
      (str/split #";")
      (first)
      (str/trim)))

(defn encode
  [{:keys [headers] :as req}]
  (let <|fim_mid|>[content-type (content-type headers)]<|fim_eom|>

