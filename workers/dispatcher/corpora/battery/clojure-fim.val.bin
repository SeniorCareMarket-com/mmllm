(defonce test-env (atom {}))

(defn create-service []
      (let [port (test.utils/get-free-port)
            interceptors [(body-params/body-params)
                          pedestal/html-body]
            server-params {:env                      :prod
                           ::pedestal/routes         (into #{} service/grpc-routes)
                           ::pedestal/port           port
