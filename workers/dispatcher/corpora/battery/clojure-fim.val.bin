                  {:add-id "a100"
                   :op-path []
                   :op-type :add-container}
                  {:add-id "a1"
                   :op-type :add-value
                   :op-path ["NA"]
                   :value "A"}
                  {:add-id "a2"
                   :op-type :add-value
                   :op-path ["NB"]
                   :value "B"}
                  {:add-id "a4"
                   :op-type :add-array-edge
