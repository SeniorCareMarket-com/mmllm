                      (g/connect a :out-from-inline x :input-1)
                      (g/connect b :out-from-inline x :input-2)))
            a-deps  (dependencies a :out-from-inline)
            b-deps  (dependencies b :out-from-inline)]
        (is (= a-deps
               #{[a :out-from-inline]
                 [x :output-1]}))
        (is (= b-deps
               #{[b :out-from-inline]
                 [x :output-2]}))))))
