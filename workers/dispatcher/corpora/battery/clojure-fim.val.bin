            [:a {:href "https://twitter.com/kirshatrov"} "@kirshatrov"]]]]
         (sidebar-toggle)))

(defn get-post
  [year month day post]
  (let [post (posts/open-post (posts/get-post-file year month day post))]
    (single-post-page post)))

(defn list-posts
  [collection]
  (html5 {:lang "en"}
         (page-head "All posts")
         (page-sidebar)
         [:div {:class "wrap"}
          (page-masthead)
          [:div {:class "container content"}
           [:div {:class "posts"}
            (for [post collection]
              [:div {:class "post"}
               [:h1 { :class "post-title" }
                [:a { :href (:permalink post) } (:title post)]]
               [:span {:class "post-date"} (format-post-date (:date post))]])]]]
         (sidebar-toggle)))
<|fim_pre|>(ns clj-blog.views
  (:require [clj-blog.posts :as posts]
            [clj-time.core :as t]
