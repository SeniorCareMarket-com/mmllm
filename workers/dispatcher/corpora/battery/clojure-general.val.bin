(ns ^{:author "John Alan McDonald" :date "2016-11-07"
      :doc "Tests for zana.io.paths." }
    
    zana.test.io.paths
  
  (:require [clojure.java.io :as io]
            [clojure.test :as test]
            [zana.api :as z]))
;;------------------------------------------------------------------------------
(comment
  mvn -Dtest=zana.test.io.paths clojure:test
  (test/run-tests 'zana.test.io.paths)
  )
