(ns table.core-test
  (:require clojure.string)
  (:use clojure.test
        table.core))

(defn unindent [string]
  (clojure.string/replace (clojure.string/trim string) #"\n\s*" "\n"))

(deftest test-table-prints-to-out
  (is (=
       (str (unindent
             "
      +---+---+
      | 1 | 2 |
      +---+---+
      | 3 | 4 |
      +---+---+
      ") "\n")
       (with-out-str (table [["1" "2"] ["3" "4"]])))))

(deftest test-table-with-vecs-in-vec
  (is (=
       (unindent
        "
      +---+---+
      | 1 | 2 |
      +---+---+
      | 3 | 4 |
      +---+---+
      ")
       (table-str [["1" "2"] ["3" "4"]]))))

