r2.ATR = \"movie/year\" AND
r2.VAL <= ?
"
     1979]
    movies-db))

(defn test-pred-ch-5-1 []
  (run-test
    ["
SELECT DISTINCT r5.VAL AS actor
FROM datoms AS r1
INNER JOIN datoms AS r2 ON r1.ENT = r2.ENT
INNER JOIN datoms AS r3 ON r3.VAL < r2.VAL
