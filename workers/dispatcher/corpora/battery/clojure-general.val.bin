(defn test-edn-ch-0 []
  (run-test
    ["
SELECT r1.VAL
FROM datoms AS r1
WHERE
r1.ATR = \"movie/title\"
"]
    movies-db))

(defn test-basic-queries-ch-1-0 []
  (run-test
    ["
SELECT r1.ENT
FROM datoms AS r1
WHERE
r1.ATR = \"movie/year\" AND
r1.VAL = 1987
"]
    movies-db))

