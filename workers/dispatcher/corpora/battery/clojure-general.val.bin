(defn biggest-sb [n]
  (if (= n 0)
    (println (str "the biggest SB is: " (get-in v-data [1 :name])))
    (println (get-in v-data [2 :name]))))

(defn test-fn [n]
  (def a "the SB is: ")
  (let [x n]
    (if (= n 0)
