(defn optional-params
  "This function will default to \"Hello, world\" when an argument is not passed"
  ([] (optional-params "Kushalraj" "Pandey"))
  ([firstname lastname] (str "Hello, " firstname " " lastname)))

(defn argument-with-ampersand
  "Lets supply an ampersanded param"
  [personA personB & personX]
  (println personA "&" personB "went out with" (count personX) "chaperones."))

(defn indexable-words [text]
  (let [indexable-word? (fn [w] (> (count w) 1))]
    (filter indexable-word? (str/split text #"\W+"))))

