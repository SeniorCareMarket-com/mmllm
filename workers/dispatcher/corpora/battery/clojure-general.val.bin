               { :nome "Paulo"
                :certificados ["Java" "Ciência da Computação"] }
               { :nome "Daniela"
                :certificados ["Arquitetura" "Gastronomia"] }])
;awnser
(println "Total certs" (->> clientes (map :certificados) (map count) (reduce +)))




