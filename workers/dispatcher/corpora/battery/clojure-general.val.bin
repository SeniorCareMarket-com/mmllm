                   :post-tags "<"
                   :template "{{highlighted-line}}"
                   :stem? false
                   :query-parser "surround"}]
      (is (= ">adibas< and >nikon<"
             (with-in-str text-from-stdin
                          (str/trim
                            (with-out-str
                              (grep/grep [query] nil nil options))))))))

  (testing "quoting"
    (let [text-from-stdin "adidas foos"
          query "OR(\"adidas foo\"*, nike)"                 ; `adidas foo` should be one term
          options {:split true
                   :pre-tags ">"
