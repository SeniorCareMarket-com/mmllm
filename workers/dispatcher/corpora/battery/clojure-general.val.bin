(ns ^{:author "wahpenayo at gmail dot com"
      :date "2018-04-17"
      :doc "Engel data affine regression models." }
    
    taiga.test.regress.engel.affine
  
  (:require [clojure.java.io :as io]
            [clojure.test :as test]
