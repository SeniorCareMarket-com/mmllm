(ns logical-7in7.core
  (:refer-clojure :exclude [==])
  (:use [clojure.core.logic])
  (:use [clojure.core.logic.pldb]))

(defn example []
  (run* [q]
    (== q true)))

(defn -main
  "Running example."
  [& args]
  (println "Start example")
  (example))

(defn easy_1 []
  (run* [q] (membero q [1 2 3]) (membero q [3 4 5])))

(defn easy_2 []
  (run* [q] (appendo [1 2 3] q [1 2 3 4 5])))


(db-rel mano x)
(db-rel womano x)

