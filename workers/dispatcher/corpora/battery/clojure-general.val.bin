                          :notes         "Stone fruit aroma with citrus notes."
                          :caryophyllene 0.1
                          :alpha         0.15
                          :substitutes   "Galaxy, Citra, Amarillo"}))


(def both
  (merge el-dorado celeia perle-us northdown horizon columbus challenger citra tettnanger galaxy topaz))

<|end|>


