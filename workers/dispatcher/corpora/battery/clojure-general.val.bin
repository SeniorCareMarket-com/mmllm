                        [:game/judges (l/array-schema name-schema)]])
        reader-schema (l/record-schema
                       ::lt/game
                       [[:game/players (l/array-schema name-schema)]
                        [:game/judges (l/array-schema name-schema)]
                        [:game/audience (l/array-schema name-schema)]])
        encoded (l/serialize writer-schema data)
