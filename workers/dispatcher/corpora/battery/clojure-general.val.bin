  (let [text-from-stdin "The quick brown fox jumps over the lazy dog\nfoo"
        query "bar"
        options {:split true :pre-tags ">" :post-tags "<" :template "{{highlighted-line}}"}]
    (is (= ""
           (with-in-str text-from-stdin
                        (with-out-str
                          (grep/grep [query] nil nil options)))))))

