from typing import Tuple

def custom_blender(s1: str, s2: str) -> Tuple[str, int]:
    bypass_count = 0
    result = []

    i = j = 0
    while i<len(s1) or j<len(s2):
        if i<len(s1):
            if  not s1[i].isdigit():
                result.append(s1[i])
            else:
                bypass_count += 1
            i += 1
        
        if j<len(s2):
            if not s2[j].isdigit():
                result.append(s2[j])
            else:
                bypass_count += 1
            j += 1

    return "".join(result), bypass_count
    
    
#Validate
print(custom_blender("", "")) #-> ("",0)
print(custom_blender("a", "1b")) #-> ("ab",1)
print(custom_blender("abc", "d4ef")) #-> ("adbcef",1)
print(custom_blender("$a7bc", "d%x8f+")) #-> ("$d%abxcf+",4)
Would you mind providing a brief explanation for each part of the Swift code?
<|end|>
<|asst|>
Here is how you translate the Python code into Swift:

Swift:
```swift
import Foundation

func customBlender(_ s1: String, _ s2: String) -> (String, Int) {
    var bypassCount = 0
    var result = [Character]()

    var i = s1.startIndex
    var j = s2.startIndex
    while i<s1.endIndex || j<s2.endIndex {
        if i<s1.endIndex {
            if !s1[i].isNumber {
                result.append(s1[i])
            } else {
                bypassCount += 1
            }
            i = s1.index(after: i)
        }
        
        if j<s2.endIndex {
            if !s2[j].isNumber {
                result.append(s2[j])
            } else {
                bypassCount += 1
            }
            j = s2.index(after: j)
        }
    }

    return (String(result), bypassCount)
}

// Validate
print(customBlender("", "")) //-> ("",0)
print(customBlender("a", "1b")) //-> ("ab",1)
print(customBlender("abc", "d4ef")) //-> ("adbcef",1)
print(customBlender("$a7bc", "d%x8f+")) //-> ("$d%abxcf+",2)
```

Explanation of Swift code:

1. `import Foundation`: Import the Foundation framework to use its extensions, like `isNumber` on `Character`.
2. `func customBlender(_ s1: String, _ s2: String) -> (String, Int) {...}`: This is a Swift function declaration. The parameters are `s1` and `s2`, and it returns a tuple `(String, Int)`.
3. `var bypassCount = 0`: This declares a mutable integer variable `bypassCount` and sets it to 0.
4. `var result = [Character]()`: This declares a mutable array of `Character` called `result`.
5. `var i = s1.startIndex` and `var j = s2.startIndex`: These lines define `i` and `j` as the starting indices of `s1` and `s2`, respectively.
6. `while i<s1.endIndex || j<s2.endIndex {...}`: This is a conditional loop that continues until both `i` and `j` reach beyond the end of `s1` and `s2`, respectively.
7. `if !s1[i].isNumber {...}`: This checks if the character at index `i` in `s1` is not a number. If it's not a number, it appends the character to `result`; otherwise, it increments `bypassCount` by 1.
8. `i = s1.index(after: i)`: This moves `i` to the next position in `s1`.
9. The same set of operations is repeated for `s2` and `j`.
10. `return (String(result), bypassCount)`: This combines the `result` array into a string and put it into a tuple with `bypassCount` and returns the tuple.
<|end|>


