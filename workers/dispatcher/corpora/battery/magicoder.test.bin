```python
def find_char_positions(text, char):
    if isinstance(text,str) and isinstance(char,str) and len(char)==1:
        positions = []
        for i in range(len(text)):
            if text[i] == char:
                positions.append(i)
        return positions
    else:
        return "Error: Input a alphanumeric string and a single character"

print(find_char_positions('uvwxyz', 'x')) # Expected output: [4]
print(find_char_positions('uvwxyzuvwxyz', 'x')) # Expected output: [4, 10]
