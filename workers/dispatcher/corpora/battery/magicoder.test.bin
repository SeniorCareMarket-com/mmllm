Please increase the difficulty of the given programming test question by allowing only a limited number of distinct element changes.

Finish the following code:

def smallest_change(arr, limit):
    """
    Given an array arr of integers, find the minimum number of elements that
    need to be changed within limit distinct element changes to make the array palindromic. A palindromic array is an array that
    is read the same backwards and forwards. In one change, you can change one element to any other element.

    For example:
    smallest_change([1,2,3,5,4,7,9,6], 3) == 4
    smallest_change([1, 2, 3, 4, 3, 2, 2], 2) == 1
    smallest_change([1, 2, 3, 2, 1], 1) == 0
    """
<|end|>
<|asst|>
def smallest_change(arr, limit):
    def count_changes(i, j, memo):
        if i >= j:
            return 0
        if (i, j, limit) in memo:
            return memo[(i, j, limit)]
        
        if arr[i] == arr[j]:
            count = count_changes(i + 1, j - 1, memo)
        else:
            count = 1 + count_changes(i + 1, j - 1, memo)
        
        memo[(i, j, limit)] = count
        return count
    
    memo = {}
    changes = count_changes(0, len(arr) - 1, memo)
    
    if changes <= limit * 2:
        return changes // 2
    else:
        return -1

# Test cases
print(smallest_change([1, 2, 3, 5, 4, 7, 9, 6], 3)) # should return 4
print(smallest_change([1, 2, 3, 4, 3, 2, 2], 2)) # should return 1
print(smallest_change([1, 2, 3, 2, 1], 1)) # should return 0
print(smallest_change([1, 2, 3, 4, 5, 6, 7], 3)) # should return -1
print(smallest_change([1, 2, 3, 4, 5, 4, 3, 2, 1], 1)) # should return 0
<|end|>


