    /* Define a class for your divs */
    .myDivs {
      width: 200px;
      height: 200px;
      margin: 10px;
    }

    /* Use nth-child to style odd and even divs differently */
    .myDivs:nth-child(odd) {
      background-color: #004d00; /* Dark green */
    }

    .myDivs:nth-child(even) {
      background-color: #66ff66; /* Light green */
    }
  </style>
</head>
<body>

<script>
// Function to create and append divs dynamically
function createDivs(num) {
  for(let i = 0; i < num; i++) {
    // Create a new div
    let newDiv = document.createElement("div");

    // Assign the id and class
    newDiv.id = "div" + (i + 1);
    newDiv.className = "myDivs";

    // Append the div to the body
    document.body.appendChild(newDiv);
  }
}

// Create 10 divs
