Develop a multi-layered, secure, RESTful API using Node.js and Express.js, that not only disseminates real-time atmospheric temperature, relative humidity, pressure, and wind speed information pertaining to a specified geographical locale but also stores this data in a MongoDB database. The API should include user authentication and rate-limiting features. Additionally, the API should be capable of handling requests at a large scale, using concepts such as clustering or worker threads, without crashing. The application should also implement comprehensive error and exception handling mechanisms to deal with any potential errors or issues that could arise. Proper tests should be written for the API using Mocha and Chai, to ensure its correct functioning.
<|end|>
<|asst|>
This is quite a big task, but I'll give you the high-level overview of how you might structure your code and the key pieces of software you'll be using.
Please be aware that any API keys or URLs must be replaced with your own information.

1. **First, start with installing the required dependencies with npm:**
   
```sh
npm install express mongoose cors dotenv bcryptjs jsonwebtoken express-rate-limit cluster
```

2. **Initializing the Server and Middlewares**

```javascript
const express = require("express");
const cors = require("cors");
const rateLimit = require("express-rate-limit");
const router = express.Router();
const app = express();

app.use(express.json());
app.use(cors());

app.use(rateLimit({ //limit number of requests per interval
  windowMs: 15 * 60 * 1000, 
  max: 100 
}));

app.use("/", router); 
```

3. **Setting up MongoDB and User Model Schema with Mongoose** 

Assuming you have MongoDB set up in an environment variable `DB_URI`, 

```javascript
const mongoose = require("mongoose");
const bcrypt = require("bcryptjs");

mongoose.connect(process.env.DB_URI, {useNewUrlParser: true, useUnifiedTopology: true, useCreateIndex: true});

const userSchema = new mongoose.Schema({
    username: { type: String, required: true, unique: true },
    password: { type: String, required: true },
});

userSchema.pre('save', async function(blog, next) { //hash password before saving
    if(this.isNew || this.isModified('password')) {
        this.password = await bcrypt.hash(this.password, 10);
    }
    next();
});
 
const User = mongoose.model("User", userSchema);
```

4. **Including User Authentication**

```javascript
const jwt = require("jsonwebtoken");

router.post('/register', async (req, res) => {
    const { username, password } = req.body;
    const user = new User({ username, password });
    await user.save();
    const token = jwt.sign({ _id: user._id }, process.env.SECRET);
    res.status(200).json({ token });
});

router.post('/login', async (req, res) => {
    const { username, password } = req.body;
    const user = await User.findOne({ username });
    const validPassword = await bcrypt.compare(password, user.password);
    if(!validPassword) return res.status(400).send('Wrong username or password.');
    const token = jwt.sign({ _id: user._id }, process.env.SECRET);
    res.send({ token });
});

//secure route
router.get('/secure', verifyToken, (req, res) => {
    res.send('Access secured route');
});

function verifyToken(req, res, next) { //jwt verify middleware
    const token = req.header('auth-token');
    if(!token) return res.status(401).send('Access denied!');
    try{
        const verified = jwt.verify(token, process.env.SECRET);
        req.user = verified;
        next();
    }catch(err) {
        res.status(400).send('Invalid token!');
    }
}
```

5. **Setting up the API endpoints to handle the atmospheric data**

Replace `API_KEY` and `API_URL` by your actual credentials.

```javascript
const axios = require('axios');

router.get("/weather/:id", verifyToken, async (req, res) => {
  try {
    const weatherDataResponse = await axios.get(`${API_URL}/${req.params.id}?apiKey=${API_KEY}`);
    const weatherData = await weatherDataResponse.data;

    res.status(200).json(weatherData);
  } 
catch(err) {
    res.status(500).json({ error: err });
  }
});
```

6. **Implementing Clustering**

```javascript
const cluster = require("cluster");
const os = require("os");

if (cluster.isMaster) {
  const cpuCount = os.cpus().length;

  for(let i = 0; i < cpuCount; i++) {
    cluster.fork(); // create worker for each cpu
  }

  cluster.on("exit", worker => {
    console.log(`Worker ${worker.id} has exited`);
    cluster.fork(); // replace the exited worker
  });
} 
else {
  // usual server code goes here
  const port = 3000;
  app.listen(port, () => {
    console.log(`Server running on port ${port}`);
  });
}
```
7. **Setting up Tests with Mocha and Chai**

Create a new file named test.js or similar at your project root. This file will hold your tests for your application:

```javascript
const chai = require('chai');
const chaiHttp = require('chai-http');
const server = require('../index');
let should = chai.should();

chai.use(chaiHttp);

describe('/GET weather', () => {
    it('it should get weather data', (done) => {
      chai.request(server)
          .get('/weather/testid')
          .end((err, res) => {
                res.should.have.status(200);
                res.body.should.be.a('array');
            done();
          });
    });
});
```
Run your tests with: 

```sh
mocha test.js
```

Lastly, Start your server with ```node server.js```. Make sure MongoDB is running.

Again, this is a very high-level overview and there's plenty of work here involved in the details, ensuring everything is properly secure, and deciding how much of the work your server should do versus your client. 

But I hope this gives you a clearer idea of how you could start tackling this problem!
<|end|>


