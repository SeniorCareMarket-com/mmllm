import random  # Import the built-in 'random' library

def generate_sort_display_numbers():
    try:
        # Generate 5 unique numbers within a range of 1-100
        num_list = random.sample(range(1, 101), 5)

        # Sort numbers in ascending order and display
        print("Ascending order: ", sorted(num_list))

