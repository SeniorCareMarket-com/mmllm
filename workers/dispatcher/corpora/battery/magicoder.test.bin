def vowels_count(s):
    """A function 'vowels_count', accepting a string as input, returning the number of vowels.
    Vowels are 'a', 'e', 'i', 'o', 'u', and 'y' ONLY when found at the end of the word. 
    The function should account for special characters, numbers, spaces, and empty strings.

    Example:
    >>> vowels_count("abcde")
    2
    >>> vowels_count("ACEDy")
    3
    >>> vowels_count("éxamplë 42")
    3
    """
