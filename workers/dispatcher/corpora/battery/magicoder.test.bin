Develop a JavaScript function meticulously crafted to generate a probabilistic discrete numeric value, given an array of probabilities. Furthermore, the function must also handle edge cases such as non-conformity of probability array (sum not equal to 1), null or undefined values within the array, or empty array input. 

Additionally, the function should also provide error handling mechanism for situations where the array input doesn't contain numeric inputs or if the array size exceeds a certain threshold, let's say 10,000. It should also include unit tests to verify its functionality under different scenarios.
<|end|>
<|asst|>
Here's a JavaScript function that handles all the requirements you mentioned. It uses the alias method for random number generation, which handles discrete probabilities well:

```javascript
function generateNumber(probArray){
    if(!Array.isArray(probArray)){
        throw new Error("Input should be an array");
    }

    if(probArray.length > 10000){
        throw new Error("Array size limit exceeded");
    }

    if(probArray.length < 1){
        throw new Error("Input array is empty");
    }

    var sum = 0;
    for(var i=0; i<probArray.length; i++){
        if(typeof probArray[i] !== 'number' || isNaN(probArray[i])){
            throw new Error("Non-numeric value detected in array");      
        }
        else if(probArray[i] === null || probArray[i] === undefined){
            throw new Error("Null or undefined value detected in array");      
        }
        sum += probArray[i];
    }

    if(sum.toFixed(2) != 1.00){
        throw new Error("Sum of probabilities is not 1");
    }

    var aliasArray = [];
    var probArrayNormalized = probArray.map(function(val){return val * probArray.length;});
    var small = [];
    var large = [];
    for(var i=0; i<probArrayNormalized.length; i++){
        ((probArrayNormalized[i] < 1.00)?small:large).push(i);
    }

    while(small.length>0 && large.length>0){
        var l = small.pop(), g = large.pop();
        aliasArray[l] = {prob: probArrayNormalized[l], alias: g};
        probArrayNormalized[g] = (probArrayNormalized[g] + probArrayNormalized[l]) - 1;
        ((probArrayNormalized[g] < 1.00)?small:large).push(g);
    }

    while(large.length>0){
        var g = large.pop();
        aliasArray[g] = {prob: 1, alias: g};
    }

    var index = Math.floor(Math.random() * aliasArray.length);
    return Math.random() < aliasArray[index].prob ? index : aliasArray[index].alias;
}
```

Here are some basic unit tests you can run:

