import math
def is_prime(n):
    """對於質數返回真，對於非質數返回假。
    >>> is_prime(6)
    False
    >>> is_prime(101)
    True
    >>> is_prime(11)
    True
    >>> is_prime(13441)
    False
    >>> is_prime(61)
    True
    >>> is_prime(4)
    False
    >>> is_prime(1)
    False
    """

    # 1 is not a prime number
    if n == 1:
        return False

    # 2 and 3 are prime numbers
    if n < 4:
        return True
    
    # except 2 all other even numbers are not prime
    if n % 2 == 0: 
        return False

    # check for factors up to the square root of n
    for i in range(3, math.isqrt(n) + 1, 2): 
        if n % i == 0:
            return False
    return True
