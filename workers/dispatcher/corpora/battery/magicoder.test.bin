Show me the Rust rendition of this code:
from typing import List

def intersperse(numbers: List[int], delimeter: int) -> List[int]:
    # if the list is empty return immediately
    if not numbers:
        return []
        
    if delimeter > 0:
        # intersperse the values
        interspersed_numbers = [numbers[0]]  
        for num in numbers[1:]:
            interspersed_numbers.extend([delimeter, num])
    else:  # delimeter < 0
        abs_delimeter = abs(delimeter)  
        interspersed_numbers = [numbers[0]]
        for index, num in enumerate(numbers[1:]):
            # skip the indices that are multiples of the absolute value of the delimeter
            if (index + 1) % abs_delimeter != 0:
                interspersed_numbers.extend([delimeter, num])
            else:
                interspersed_numbers.append(num)
        
    return interspersed_numbers
Please include remarks in the Rust translation to help me follow along.
<|end|>
<|asst|>
Sure, here is the Rust version of your Python code. 

```rust
// A function that takes a Vec<i32> and an i32 and returns a Vec<i32>.
pub fn intersperse(numbers: Vec<i32>, delimiter: i32) -> Vec<i32> {
    // if the list is empty return immediately
    if numbers.len() == 0 {
        return vec![]; // an empty vector
    }

    // Create a mutable vector where we'll store our interspersed values.
    let mut interspersed_numbers = vec![numbers[0]];

    if delimiter > 0 {
        // intersperse the values
        for &num in &numbers[1..] {
            // the extend() method can be used to add multiple elements
            // to the vector: in this case, the delimiter and the current number.
            interspersed_numbers.extend(vec![delimiter, num]);
        }
    } else {
        // in Rust, to get the absolute value of a number,
        // we can use the abs() method of the i32 type directly.
        let abs_delimiter = delimiter.abs();
        
        for (index, &num) in numbers[1..].iter().enumerate() {
            // In Rust, if we want to check if one number is divisible by another,
            // we use the % operator, just like in Python
            if (index + 1) % abs_delimiter as usize != 0 {
                interspersed_numbers.extend(vec![delimiter, num]);
            } else {
                interspersed_numbers.push(num);
            }
        }
    }
    
    // Return our finished array.
    interspersed_numbers
}
```
You can call this function with a given vector and delimiter like this:

```rust
fn main() {
    let numbers = vec![1, 2, 3, 4, 5];
    let delimiter = 2;
    let interspersed = intersperse(numbers, delimiter);
    println!("{:?}", interspersed);
}
```
