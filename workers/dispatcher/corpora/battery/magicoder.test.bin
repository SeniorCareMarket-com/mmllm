```c
#include <stdio.h>
#include <stdbool.h> // for the usage of bool in C
#include <string.h>  // for the usage of strlen

// Function to check if a number is prime
bool isPrime(int num) {
    if (num <= 1) return false;    // 1 and less are not prime
    if (num == 2) return true;     // 2 is the only even prime number
    if (num % 2 == 0) return false; // Remove any other even number

    for (int i = 3; i * i <= num; i += 2) { // Only need to check odd numbers up to sqrt(n)
        if (num % i == 0)
            return false; 
    }

    return true; // Return true if no factors found
}

// Function to calculate the sum of ASCII values of characters in a string and check if the sum is a prime number
bool prime_ascii_sum(char* str) {
    int asciiSum = 0;

    for (size_t i = 0; i < strlen(str); i++) { // loop through each character in the string
        asciiSum += (int) str[i]; // add the ASCII value of the character to the sum
    }

    return isPrime(asciiSum); // check if the sum is a prime number
}

int main() {
    printf("%d\n", prime_ascii_sum("Hello")); // Use printf function to print the result. True is '1' and False is '0'.
    printf("%d\n", prime_ascii_sum("abcdcba"));
    printf("%d\n", prime_ascii_sum("programming"));
    printf("%d\n", prime_ascii_sum("orange"));

    return 0;
}
```

Make sure you compile the above code using `-std=c99` or later, because `bool` type is supported since C99. If you're using `gcc`, then the command to compile would be `gcc -std=c99 filename.c`.
