        <a-scene>
            <a-sky src="antarctica360.jpg" rotation="0 -130 0"></a-sky>
        </a-scene>
    </div>

    <h2 style="text-align: center">Photo Gallery</h2>
    <div class="slideshow-container">
        <div class="mySlides fade">
            <img src="antarctica1.jpg" style="width:100%">
        </div>

        <div class="mySlides fade">
            <img src="antarctica2.jpg" style="width:100%">
        </div>

        <div class="mySlides fade">
            <img src="antarctica3.jpg" style="width:100%">
        </div>
    </div>
<script>
    document.addEventListener("DOMContentLoaded", function(event) { 
        let sliderIndex = 0;
        showSlides();

        function showSlides()
        {
            let slides = document.getElementsByClassName("mySlides");
            for (let i = 0; i < slides.length; i++) {
                slides[i].style.display = "none";
            }

            sliderIndex++;
            if(sliderIndex > slides.length) {
                sliderIndex = 1;
            } 

            slides[sliderIndex - 1].style.display = "block";
            setTimeout(showSlides, 2000);
        }
    });
</script>
</body>
</html>
```

