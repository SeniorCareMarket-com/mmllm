```swift
import Foundation

// Define the function
func findDivisors(n: Int) -> [Int] {
    var divisors = [Int]()
    for i in 1...n {
        if n % i == 0 {
            divisors.append(i)
        }
    }
    return divisors
}

// Call the function
let number = 10
let divisors = findDivisors(n: number)
print("The divisors of \(number) are: \(divisors)")
