I'm looking to rewrite this in C++:
def count_nums(arr):
    count = 0
    for num in arr:
        digit_sum = sum(int(digit) for digit in str(abs(num)))
        if num < 0:
            digit_sum = -digit_sum
        if digit_sum > 0 and digit_sum % 4 == 0:
            count += 1
    return count

print(count_nums([]))  # Output: 0
print(count_nums([-1, 11, -11]))  # Output: 1
print(count_nums([1, 1, 2]))  # Output: 0
<|end|>
<|asst|>
Sure, here is a way to implement the Python function in C++:

```C++
#include <iostream>
#include <vector>
#include <cstdlib> // For abs()

int count_nums(std::vector<int> arr) {
    int count = 0;
    for(int num : arr){
        int digit_sum = 0;
        int abs_num = std::abs(num);
        while(abs_num > 0){
            digit_sum += abs_num % 10;
            abs_num = abs_num / 10;
        }
        if(num < 0)
            digit_sum = -digit_sum;
        if(digit_sum > 0 && digit_sum % 4 == 0)
            count++;
    }
    return count;
}

int main() {
    std::cout << count_nums({}) << std::endl;  // Output: 0
    std::cout << count_nums({-1, 11, -11}) << std::endl;  // Output: 1
    std::cout << count_nums({1, 1, 2}) << std::endl;  // Output: 0
    return 0;
}
```

Just as a reminder, since C++ doesn't have built-in functionality for converting between integer and string types as easily as Python, we used the division by 10 method to get each digit from the number (integer division in C++ automatically truncates decimal places). This way, we don't need to convert the number into a string.
<|end|>


