The above solution assumes that the two input strings are of the same length. If they are not, we need to manually handle that case:

from typing import Tuple

def custom_mix_strings(s1: str, s2: str) -> str:
    combined = ''.join(i + j for i, j in zip(s1, s2))
    if len(s1) > len(s2):
        combined += s1[len(s2):]
    elif len(s2) > len(s1):
        combined += s2[len(s1):]
    return combined[::-1]

# Let's run the function with the example provided

print(custom_mix_strings("abcd", "efg")) # Output: "gfebdcba"
print(custom_mix_strings("abc", "defgh")) # Output: "hgfebacd"
