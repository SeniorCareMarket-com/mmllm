Implement a bag of words model on the text data in https://raw.githubusercontent.com/dD2405/Twitter_Sentiment_Analysis/master/train.csv. However, do not use nltk or any other external libraries to remove stopwords and create a bag of words. Additionally, implement an inverse document frequency (IDF) to weigh the word frequencies. Your model should include functionality to transform new incoming text data to fit into the established bag of words model.
<|end|>
<|asst|>
Below is the pure Python implementation of Bag of Words model, without using external libraries like NLTK or SKlearn for text manipulation. This example also includes IDF implementation.

```python
import csv
import urllib.request
import re
from collections import Counter
from math import log

class BagOfWords:
    def __init__(self):
        self.word_counts = Counter()
        self.idf = {}
        self.documents = 0

    def tokenize(self, text):
        # Lowercasing, special character removal and split by whitespace
        return re.sub("[^\w]", " ", text.lower()).split()

    def fit(self, text_data):
        document_freq = Counter()
        for text in text_data:
            self.documents += 1
            words = self.tokenize(text)
            self.word_counts.update(words)

            # Document Frequencies calculation
            document_words = set(words)
            document_freq.update(document_words)

        # IDF calculation
        for word, doc_freq in document_freq.items():
            self.idf[word] = log(self.documents / (1 + doc_freq))

    def transform(self, text_data):
        vectors = []
        for text in text_data:
            words = self.tokenize(text)
            vector = {word: tf * self.idf.get(word, 0.0) for word, tf in Counter(words).items()}
            vectors.append(vector)

        # Return vectors
        return vectors


# Test the code
url = 'https://raw.githubusercontent.com/dD2405/Twitter_Sentiment_Analysis/master/train.csv'
response = urllib.request.urlopen(url)
lines = [l.decode('utf-8') for l in response.readlines()]
cr = csv.reader(lines)

# Skip header
next(cr)

data = []
for row in cr:
    data.append(row[2]) # Assuming 2nd column is the text data

bog = BagOfWords()
bog.fit(data)
transformed_data = bog.transform(["Example text to transform."])

print(transformed_data)
```
