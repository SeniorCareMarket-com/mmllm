```python
arr = [1, 2, 3]

def error_log(input):
    try:
        if type(input) != int:
            raise TypeError("Error: input is not integer.")
        elif input < 0 or input > len(arr) - 1:
            raise IndexError("Error: Index out of range.")
    except IndexError as e:
        print(e)
    except TypeError as e:
        print(e)

input = '5'
error_log(input)
```
