<|asst|>
Here is the equivalent C# code for your Python code:

```csharp
using System.Collections.Generic;
using System.Linq;

public class Car
{
    public double x, y;
    public double speed;
    public bool collided;

    public Car((double, double) pos, double speed) 
    {
        (x, y) = pos;
        this.speed = speed;
        collided = false;
    }

    public void Move()
    {
        if (!collided)
            x += speed;
    }
}

public class Race
{
    public List<Car> cars;
    public double afterCollisionSpeed;
    public List<(double, double)> collisions;

    public Race(List<(double, double)> leftCars, List<(double, double)> rightCars, double afterCollisionSpeed)
    {
        cars = leftCars.Select(x => new Car(x, 1.0)).ToList();
        cars.AddRange(rightCars.Select(x => new Car(x, -1.0)).ToList());
        this.afterCollisionSpeed = afterCollisionSpeed;
        collisions = new List<(double, double)>();
    }

    public void CheckCollisions()
    {
        for (int i = 0; i < cars.Count; i++)
        {
            for (int j = i + 1; j < cars.Count; j++)
            {
                if (cars[i].x == cars[j].x && cars[i].y == cars[j].y)
                {
                    cars[i].collided = cars[j].collided = true;
                    cars[i].speed = cars[j].speed = afterCollisionSpeed;
                    collisions.Add((cars[i].x, cars[i].y));
                }
            }
        }
    }

    public void Step()
    {
        CheckCollisions();
        foreach (var car in cars)
        {
            car.Move();
        }
    }
}
```
Please note that C# is statically typed, so some things - like tuples assignment to multiple variables at once and list comprehensions - must be done a bit differently.
<|end|>


