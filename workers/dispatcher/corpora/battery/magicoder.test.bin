```python
import re

def validate_string(s):
    vowel = set('aeiouAEIOU')
    consonant = set('bcdfghjklmnpqrstvwxyzBCDFGHJKLMNPQRSTVWXYZ')

    s = s.strip()

    if (len(set(s[i] for i in range(len(s)) if s[i] in vowel)) >= 5 and 
