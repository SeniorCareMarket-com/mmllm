Sure, here's a conversion for your JavaScript code to C++ code. 

```cpp
#include <vector>
#include <string>
#include <iostream>

// Function to count number of odd digits in a string
int countOddDigits(const std::string& str) {
    int count = 0;
    for(char ch: str) {
        if ((ch - '0') % 2 != 0) count++;
    }
    return count;
}

// Function to process a vector of strings
std::vector<std::string> oddCount(const std::vector<std::string>& vec) {
    std::vector<std::string> results;
    
    for(const std::string& str : vec) {
        int oddDigitsCount = countOddDigits(str);
        std::string result = "the number of odd elements " + std::to_string(oddDigitsCount) +
                             " in the string " + std::to_string(oddDigitsCount) +
                             " of the input.";
        results.push_back(result);
    }

    return results;
}

int main() {
    // Test case
    std::vector<std::string> list = {"123", "456", "789"};
    std::vector<std::string> result = oddCount(list);

    // Print result
    for (const std::string& str : result) {
      std::cout << str << std::endl;
    }

    return 0;
}
```
Noted that in C++, strings are arrays of characters and each character can easily be converted to its integer representation by subtracting '0'.

This code will work for strings composed of digit characters. If the string includes non-digit characters, you may want to adjust the `countOddDigits` function to skip those.
