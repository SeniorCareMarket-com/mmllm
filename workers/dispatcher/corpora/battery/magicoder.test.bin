labels_tensor = tf.constant(labels, dtype=tf.int32)
range_tensor = tf.range(10, dtype=tf.int32)
result = tf.cast(tf.not_equal(labels_tensor[:, None], range_tensor), tf.int32)
&lt;/code&gt;
END SOLUTION
