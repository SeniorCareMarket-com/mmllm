I'd like to see how this is done in Rust:
def minimum_changes_to_palindrome(arr, limit):
    from collections import Counter
    
    # count the frequency of each number in the array
    freq_counter = Counter(arr)
    
    # sort the keys of the counter and store them in a list
    sorted_keys = sorted(freq_counter.keys())
    
    # initialize the count of changes needed
    count = 0
    
    # Use two-pointer technique to scan the list from both ends
    i = 0
    j = len(sorted_keys) - 1
    
    while i <= j:
        # If the counts of the elements at both ends are greater than 'limit', 
        # we need to change both elements
        if freq_counter[sorted_keys[i]] > limit and freq_counter[sorted_keys[j]] > limit:
            count += 2
        # If the count of the element at the left end is greater than 'limit',
        # we need to change the left element
        elif freq_counter[sorted_keys[i]] > limit:
            count += 1    
        # If the count of the element at the right end is greater than 'limit',
        # we need to change the right element
        elif freq_counter[sorted_keys[j]] > limit:
            count += 1
        # move the pointers
        i += 1
        j -= 1
    
    return count
<|end|>
<|asst|>
Here is how you can translate this Python function into Rust:

```rust
use std::collections::HashMap;
use std::iter::FromIterator;

fn minimum_changes_to_palindrome(arr: &[isize], limit: isize) -> isize {
    // count the frequency of each number in the array
    let freq_counter = arr.iter().fold(HashMap::new(), |mut map, val| {
        *map.entry(val).or_insert(0) += 1;
        map
    });
    
    // sort the keys of the counter and store them in a vector
    let mut sorted_keys: Vec<&isize> = Vec::from_iter(freq_counter.keys());
    sorted_keys.sort();
    
    // initialize the count of changes needed
    let mut count = 0;
    
    // Use two-pointer technique to scan the list from both ends
    let mut i = 0;
    let mut j = sorted_keys.len() - 1;
    
    while i <= j {
        // If the counts of the elements at both ends are greater than 'limit', 
        // we need to change both elements
        if *freq_counter.get(sorted_keys[i]).unwrap_or(&0) > limit 
        && *freq_counter.get(sorted_keys[j]).unwrap_or(&0) > limit {
            count += 2;
        // If the count of the element at the left end is greater than 'limit',
        // we need to change the left element
        } else if *freq_counter.get(sorted_keys[i]).unwrap_or(&0) > limit {
            count += 1;
        // If the count of the element at the right end is greater than 'limit',
        // we need to change the right element
        } else if *freq_counter.get(sorted_keys[j]).unwrap_or(&0) > limit {
            count += 1;
        }
        // move the pointers
        i += 1;
        j -= 1;
    }
    
    count
}
```

Note that rust uses & to get an item in a HashMap and a function called unwrap_or to safely get a value from the HashMap (it will return the default value of 0 if the element doesn't exist in the HashMap). Also, rather than directly doing arithmetic on i and j, we use += 1 and -= 1 because rust doesn't support the ++ and -- operators.
<|end|>


