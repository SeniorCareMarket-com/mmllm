<|asst|>
Here is the Swift translation of your JavaScript code:

```swift
import Foundation

func execute(n: Int) -> ([Int], Int) {
    
    // Create a function to check if a number is prime
    func isPrime(num: Int) -> Bool {
        for i in 2...Int(sqrt(Double(num))) {
            if num % i == 0 { return false }
        }
        return num > 1
    }
    
    // Create an empty array for primes and a variable for total sum
    var primes: [Int] = []
    var sum = 0

    // Loop from 2 until n (exclusive)
    for i in 2..<n {
        // Check if the number is prime
        if isPrime(num: i) {
            // If prime, append to primes array and add to sum
            primes.append(i)
            sum += i
        }
    }
    
    // Return primes list and total sum
    return (primes, sum)
}

// Test the function
print(execute(n: 5))   // ([2,3], 5)
print(execute(n: 11))  // ([2,3,5,7], 17)
print(execute(n: 0))   // ([], 0)
print(execute(n: 20))  // ([2,3,5,7,11,13,17,19], 77)
print(execute(n: 1))   // ([], 0)
print(execute(n: 18))  // ([2,3,5,7,11,13,17], 58)
```

Please be aware that array notation in Swift is somewhat different from JavaScript, and tuples are used in Swift to return multiple values from a function.
