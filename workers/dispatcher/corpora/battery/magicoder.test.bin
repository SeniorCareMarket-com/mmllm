import Foundation

func hasDivisibleNeighbors(numbers: [Int], divisor: Int) -> Bool {
    
    guard !numbers.isEmpty else {
        fatalError("Invalid input. First input must be an array and second input must be a number.")
    }
    
    for i in 0..<numbers.count - 1 {
        if numbers[i] % divisor == 0 && numbers[i+1] % divisor == 0 {
            return true
        }
    }
    
    return false
}

