#include<stdio.h>
#include<vector>
#include<string>
#include<cctype>
using namespace std;

string Strongest_Extension(string class_name, vector<string> extensions) {
    // Initialize current max strength to the minimum possible of int.
    int max_strength = INT_MIN;
    string strongest_extension;

    // Loop through all the monikers
    for (auto ext : extensions) {
        int strength = 0;
        // Find the strength of the current moniker
        for (auto ch : ext) {
            if(isupper(ch)) {
                // If character is uppercase increment the strength
                strength++;
            } else if(islower(ch)) {
                // If character is lowercase decrement the strength
                strength--;
            }
        }

        // Check if current strength is greater than max_strength,
        // If true then update max_strength and strongest_extension.
        if(strength > max_strength) {
            max_strength = strength;
            strongest_extension = ext;
        }
    }

    // Return class_name.strongest_extension
    return class_name + "." + strongest_extension;
}
<|end|>
<|asst|>
Sure, here's the aforementioned C++ code translated into Swift:

```swift
import Foundation

func strongestExtension(class_name: String, extensions: [String]) -> String {
    // Initialize current max strength to the minimum possible of Int.
    var max_strength: Int = .min
    var strongest_extension = ""

    // Loop through all the extensions
    for ext in extensions {
        var strength = 0
        // Find the strength of the current extension
        for ch in ext.unicodeScalars {
            if(CharacterSet.uppercaseLetters.contains(ch)) {
                // If character is uppercase increment the strength
                strength += 1
            } else if(CharacterSet.lowercaseLetters.contains(ch)) {
                // If character is lowercase decrement the strength
                strength -= 1
            }
        }

        // Check if current strength is greater than max_strength,
        // If true then update max_strength and strongest_extension.
        if(strength > max_strength) {
            max_strength = strength
            strongest_extension = ext
        }
    }

    // Return class_name.strongest_extension
    return "\(class_name).\(strongest_extension)"
}
```
In Swift, the equivalent for isupper and islower are the characterSet.uppercaseLetters and characterSet.lowercaseLetters respectively. The .min property of Swift's Int type is equivalent to INT_MIN in C++. String concatenation is done using the \() syntax instead of the + operator in C++.
<|end|>


