```java
import java.util.Random;

public class Main {
    public static void main(String[] args) {
        Random random = new Random();
        String alphabet = "abcdefghijklmnopqrstuvwxyz";
        String lowerCaseOutput = "";
        String upperCaseOutput = "";

        for (int i = 0; i < 5; i++) {
            lowerCaseOutput += alphabet.charAt(random.nextInt(alphabet.length()));
        }
        
        for (int i = 0; i < 5; i++) {
            upperCaseOutput += String.valueOf(alphabet.charAt(random.nextInt(alphabet.length()))).toUpperCase();
        }

        String result = lowerCaseOutput + upperCaseOutput;
        System.out.println(result);
    }
}
```

