Python Code:

```python
def sort_strings(arr1, arr2):
    import re      # for regular expressions
    merged_array = arr1 + arr2
    clean_array = []  # For strings that pass the pattern test
    pattern = re.compile('^[a-zA-Z]+$') # Regular expression pattern for checking alphanumeric characters only
    for string in merged_array:
        if pattern.match(string):
            clean_array.append(string)
    unique_array = list(set(clean_array))   # Convert to set and back to list to remove duplicates
    unique_array.sort(reverse=True)         # Sort the list in reverse order
    return unique_array

arr1 = ["kiwi", "melon", "orange", "34apple$", ""]
arr2 = ["mango", "apple", "orange", "@banana", "123"]
print(sort_strings(arr1, arr2))
