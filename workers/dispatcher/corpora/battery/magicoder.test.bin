what's the c version of this code?
def median_and_mode(l: list):
    # Check if the list is empty
    if not l:
        return None, None

    # Define a dictionary for counting the occurrences of each number
    dic = {}
    for num in l:
        if num in dic:
            dic[num] += 1
        else:
            dic[num] = 1

    # From the dictionary, get the list of keys (numbers) and values (counts)
    keys = list(dic.keys())
    values = list(dic.values())

    # Compute the median
    total_n = len(l)
    cumulative_n = 0
    median = None
    for i in range(len(keys)):
        cumulative_n += values[i]
        if cumulative_n >= total_n / 2:
            # When the list length is even, the median is the average of the two middle numbers.
            # When it is odd, the median is the middle number.
            if total_n % 2 == 0 and cumulative_n == total_n / 2:
                median = (keys[i] + keys[i + 1]) / 2
            else:
                median = keys[i]
            break

    # Compute the mode
    max_count = max(values)
    mode_index = values.index(max_count)
    mode = keys[mode_index] if max_count > 1 else None

    return median, mode
<|end|>
<|asst|>
C doesn't have built-in equivalents to Python's lists and dictionary but we can use arrays and structures to achieve the same functionality. Here is a C code with similar functionality. This C code only works with integer arrays and it may be different from Python's implementation with a dictionary.

```c
#include<stdio.h>
#include<stdlib.h>

#define MAX 100

struct number_count
{
    int value; // number
    int count; // how many times appears
};

void median_and_mode(int* list, int n, float* median, int* mode) {
    struct number_count counts[MAX];
    for(int i=0;i<MAX;i++)
    {
        counts[i].value = 0;
        counts[i].count = 0;
    }

    if(n>0)
    {
        int i,j;
        for(i=0;i<n;i++)
        {
            int number = list[i];
            for(j=0;j<MAX;j++)
            {
                if(counts[j].value == number || counts[j].count == 0)
                {
                    counts[j].value = number;
                    counts[j].count++;
                    break;
                }
            }
        }

        int total_n = n, cum_n = 0;
        for(i=0;i<total_n;i++)
        {
            cum_n += counts[i].count;
            if(cum_n >= total_n / 2)
            {
                if(total_n % 2 == 0 && cum_n == total_n / 2)
                    *median = ((float)counts[i].value + (float)counts[i+1].value) / 2.0;
                else
                    *median = (float)counts[i].value;
                break;
            }
        }

        int max_count = 0, mode_index = -1;
        for(i=0;i<MAX;i++)
        {
            if(counts[i].count > max_count)
            {
                max_count = counts[i].count;
                mode_index = i;
            }
        }
        if(max_count > 1)
            *mode = counts[mode_index].value;
        else
            *mode = INT_MIN; // NA
    }
    else
    {
        *median = 0.0;
        *mode = INT_MIN; // NA
    }
}

int main(){
    int array[] = {1, 2, 2, 3, 3, 3, 4, 4, 4, 4};
    float median = 0.0;
    int mode = 0;
    median_and_mode(array,10,&median,&mode);
    printf("Median: %f\n",median);
    printf("Mode: %d\n",mode);
    return 0;
}
```

In this code, MAX is set to 100. It has to be at least larger than the number of unique entries in the input array. The median_and_mode function populates the parallel arrays counts[] with the count for each unique value (similar to Python dictionary keys and values).
Please note that performance can be improved by keeping keys sorted or using a hashtable or binary search tree, but it would make the code more complex. The code will fail if the number of unique numbers in the list exceeds MAX.
<|end|>


