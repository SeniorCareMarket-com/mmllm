def print_fibonacci_numbers(n):
    # The first two numbers in the Fibonacci sequence are 0 and 1
    a = 0
    b = 1

    # If n is less than or equal to 0, return without printing
    if n <= 0:
        return

    # If n is 1 or 2, print the first two numbers
    elif n == 1:
        print(a)
        return
    elif n == 2:
        print(a, b)
        return
    
