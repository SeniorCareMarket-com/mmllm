i would like to see this in go form:
def not_reverse_binary(a: str) -> str:
    result = ""
    for i in range(len(a) - 1, -1, -1):  # Iterating through "a" in reverse order
        result += str(int(not int(a[i])))  # Performing bitwise NOT and adding to result
    return result
<|end|>
<|asst|>
Here is the equivalent code in Go:

```go
package main

import (
	"fmt"
	"strconv"
)

func notReverseBinary(a string) string {
	result := ""
	for i := len(a) - 1; i >= 0; i-- {  // Iterating through "a" in reverse order
		val, _ := strconv.Atoi(string(a[i]))  // converting string to int
		notVal := 1 - val  // performing bitwise NOT operation
		result += strconv.Itoa(notVal)  // adding it to result
	}
	return result
}

func main() {
	fmt.Println(notReverseBinary("0110"))
}

```
In this Go code, we're using strconv's Atoi and Itoa functions to convert a string to an int and an int to a string respectively.
<|end|>


