from typing import Union, Optional

def refine_integer(input_value: Union[float, str, None], round_down: bool = True, precision: Optional[int] = None) -> Optional[Union[int, float]]:
    try:
        number = float(input_value)
        if precision is not None:
            factor = 10 ** precision
            if round_down:
                return (int(number * factor) if number > 0 else -int(-number * factor))/ factor
            else:
                return (int(number * factor + 0.5) if number > 0 else -int(-number * factor + 0.5)) / factor
        else:
            return int(number) if round_down else int(number + 0.5 * (1 if number >= 0 else -1))
    except (TypeError, ValueError):
        return None
<|end|>
<|asst|>
To port the Python code boolean parameter for rounding and option for precision to Rust:

```rust
use std::str::FromStr;

fn refine_integer<T: FromStr + ToString>(input_value: Option<T>, round_down: bool, precision: Option<i32>)
                                         -> Option<f32> where <T as std::str::FromStr>::Err : std::fmt::Debug {
     match input_value {
         None => None,
         Some(val) => {
             match val.to_string().parse::<f32>() {
                 Err(_) => None,
                 Ok(number) => {
                     match precision {
                         Some(precision) => {
                             let factor = 10_f32.powi(precision);
                             if round_down {
                                 if number > 0.0 {
                                     return Some((number * factor).floor() / factor);
                                 } else {
                                     return Some((-((-number) * factor).floor()) / factor);
                                 }
                             } else {
                                 if number > 0.0 {
                                     return Some((number * factor + 0.5).floor() / factor);
                                 } else {
                                      return Some((-((-number) * factor + 0.5).floor()) / factor);
                                 }
                             }
                         }, 
                         None => {
                             if round_down {
                                 return Some(number.floor());
                             } else {
                                 if number >= 0.0 {
                                     return Some((number + 0.5).floor());
                                 } else {
                                     return Some((number - 0.5).floor());
                                 }
                             }
                         }
                     }
                 }
             }
         }
     }
 
}
```
Remember to place this code within a function or a main block in order for it to run. You can call the function with values like this:

```rust
fn main() {
    println!("{:?}", refine_integer(Some("123.456"), false, Some(2)));
    println!("{:?}", refine_integer(Some(123.456), true, None));
}
```

This will print:

```shell
Some(123.46)
Some(123.0)
```

Please adjust data types according to your needs. I have used `f32` for simplicity.
<|end|>


