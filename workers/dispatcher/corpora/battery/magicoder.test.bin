import PropTypes from 'prop-types';
import { createPeerConnection, createLocalStream } from './utils';

class Video extends Component {
    static propTypes = {
        username: PropTypes.string.isRequired,
        roomName: PropTypes.string.isRequired,
        video: PropTypes.bool.isRequired,
        audio: PropTypes.bool.isRequired,
        handleVideoToggle: PropTypes.func.isRequired,
        handleAudioToggle: PropTypes.func.isRequired
    };

    constructor(props) {
        super(props);
        this.localVideoRef = React.createRef();
        this.remoteVideoRef = React.createRef();
        this.peerConnection = createPeerConnection();
    }

    componentDidMount() {
        this.setupLocalVideo();
        this.setupPeerConnection();
    }

    setupLocalVideo = () => {
        createLocalStream(this.props.video, this.props.audio).then((stream) => {
            this.localVideoRef.current.srcObject = stream;
            this.peerConnection.addStream(stream);
        });
    }

    setupPeerConnection = () => {
        this.peerConnection.onaddstream = (event) => {
            this.remoteVideoRef.current.srcObject = event.stream;
        };
    }

    handleVideoToggle = () => {
        this.props.handleVideoToggle();
        this.setupLocalVideo();
    }

    handleAudioToggle = () => {
        this.props.handleAudioToggle();
        this.setupLocalVideo();
    }

    render() {
        return (
            <div>
                <h2>Video</h2>
                <video ref={this.localVideoRef} autoPlay muted></video>
                <video ref={this.remoteVideoRef} autoPlay></video>
                <button onClick={this.handleVideoToggle}>
                    {this.props.video ? 'Turn off' : 'Turn on'} video
                </button>
                <button onClick={this.handleAudioToggle}>
                    {this.props.audio ? 'Mute' : 'Unmute'} audio
                </button>
            </div>
        );
    }
}

export default Video;
