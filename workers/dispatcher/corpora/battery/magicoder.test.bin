This is a broad task. Due to the constraints of limited response length, I'll provide a general road-map and some code snippets.

Running FastAPI and SQLAlchemy integration:
Let’s install necessary modules with pip:
```bash
pip install fastapi[all] uvicorn sqlalchemy passlib[bcrypt] python-jwt python-multipart
```

account.py which manage JWT Related Operations:
```python
from datetime import datetime, timedelta
from jose import jwt
from passlib.context import CryptContext


pwd_context = CryptContext(schemes=["bcrypt"], deprecated="auto")

SECRET_KEY = "YOUR-SECRET-KEY"
ALGORITHM = "HS256"
ACCESS_TOKEN_EXPIRE_MINUTES = 30

def verify_password(plain_password, hashed_password):
    return pwd_context.verify(plain_password, hashed_password)


def get_password_hash(password):
    return pwd_context.hash(password)


def create_access_token(data: dict, expires_delta: timedelta = None):
    to_encode = data.copy()
    if expires_delta:
        expire = datetime.utcnow() + expires_delta
    else:
        expire = datetime.utcnow() + timedelta(minutes=15)
    to_encode.update({"exp": expire})
    encoded_jwt = jwt.encode(to_encode, SECRET_KEY, algorithm=ALGORITHM)
    return encoded_jwt
```

user.py includes ORM functionalities:
```python
from sqlalchemy import Boolean, Column, Integer, String
from sqlalchemy.orm import Session
from .database import Base, SessionLocal

session = SessionLocal()

class User(Base):
    __tablename__ = "users"

    id = Column(Integer, primary_key=True, index=True)
    username = Column(String, unique=True, index=True)
    hashed_password = Column(String)
    is_active = Column(Boolean, default=True)


def get_user(username: str):
    return session.query(User).filter(User.username == username).first()

def create_user(username: str, hashed_password: str):
    db_user = User(username=username, hashed_password=hashed_password)
    session.add(db_user)
    session.commit()
    session.refresh(db_user)
    return db_user
```

main.py which includes FastAPI App:
```python
from fastapi import FastAPI, Depends, HTTPException, status
from sqlalchemy.orm import Session
from . import account, user

app = FastAPI()

def authenticate_user(username: str, password: str):
    the_user = user.get_user(username)
    if not the_user:
        return False
    if not account.verify_password(password, the_user.hashed_password):
        return False
    return the_user

@app.post("/token", response_model=schemas.Token)
def login_for_access_token(form_data: OAuth2PasswordRequestForm = Depends()):
    user = authenticate_user(form_data.username, form_data.password)
    if not user:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Incorrect username or password",
            headers={"WWW-Authenticate": "Bearer"},
        )
    access_token_expires = timedelta(minutes=account.ACCESS_TOKEN_EXPIRE_MINUTES)
    access_token = account.create_access_token(
        data={"sub": user.username}, expires_delta=access_token_expires
    )
    return {"access_token": access_token, "token_type": "bearer"}
```

