Here is the corrected Python code:

```python
from collections import defaultdict

def frogPosition(n, edges, t, target):
    node = defaultdict(list)
    for u, v in edges:
        node[u].append(v)
        node[v].append(u)
        
    prob = [[0]*(t+1) for _ in range(n+1)]
    prob[1][0] = 1

    visited = [0]*(n+1)
    
    def dfs(x, t):
        visited[x] = 1
        child = sum(visited[i]==0 for i in node[x])
        for i in range(t, -1, -1):
            for y in node[x]:
                if visited[y] == 0:
                    for j in range(i, -1, -1):
                        prob[y][j+1] += prob[x][i] / child
                    prob[x][i+1] = 0 if child else prob[x][i]
                    
        for y in node[x]:
            if visited[y] == 0:
                dfs(y, t)

    dfs(1, t)
    return prob[target][t] if prob[target][t] != 0 else -1

```

