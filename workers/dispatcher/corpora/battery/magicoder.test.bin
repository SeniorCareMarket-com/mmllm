Construct a function to fill in the provided code:

def uncommon_elements(sequence):
    '''
    Given a non-empty list of positive integers, return all distinct integers with a frequency exceeding half the integer's value.
    The frequency of an integer denotes its occurrence count in the list.
    If no values meet this criterion, return an empty list.
    Examples:
        uncommon_elements([4, 1, 2, 2, 3, 1]) == [2, 3]
        uncommon_elements([1, 2, 2, 3, 3, 3, 4, 4, 4]) == [2, 3, 4]
        uncommon_elements([5, 5, 4, 4, 4]) == [4]
    '''
<|end|>
<|asst|>
def uncommon_elements(sequence):
    '''
    Given a non-empty list of positive integers, return all distinct integers with a frequency exceeding half the integer's value.
    The frequency of an integer denotes its occurrence count in the list.
    If no values meet this criterion, return an empty list.
    Examples:
        uncommon_elements([4, 1, 2, 2, 3, 1]) == [2, 3]
        uncommon_elements([1, 2, 2, 3, 3, 3, 4, 4, 4]) == [2, 3, 4]
        uncommon_elements([5, 5, 4, 4, 4]) == [4]
    '''
    frequency = {}
    result = []

    for element in sequence:
        if element in frequency:
            frequency[element] += 1
        else:
            frequency[element] = 1

    for key, value in frequency.items():
        if value > (key / 2):
            result.append(key)

    return result

print(uncommon_elements([4, 1, 2, 2, 3, 1]))
print(uncommon_elements([1, 2, 2, 3, 3, 3, 4, 4, 4]))
print(uncommon_elements([5, 5, 4, 4, 4]))
<|end|>


