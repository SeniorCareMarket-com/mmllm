Port this code to C# for me, please:
from typing import List, Tuple

class Car:
    def __init__(self, pos: Tuple[float, float], speed: float):
        self.x, self.y = pos
        self.speed = speed
        self.collided = False

    def move(self):
        if not self.collided:
            self.x += self.speed

class Race:
    def __init__(self, left_cars: List[Tuple[float, float]], right_cars: List[Tuple[float, float]], after_collision_speed: float):
        self.cars = [Car(pos, 1.0) for pos in left_cars] + [Car(pos, -1.0) for pos in right_cars]
        self.after_collision_speed = after_collision_speed
        self.collisions = []

    def check_collisions(self):
        for i in range(len(self.cars)):
            for j in range(i+1, len(self.cars)):
                if self.cars[i].x == self.cars[j].x and self.cars[i].y == self.cars[j].y:
                    self.cars[i].collided = self.cars[j].collided = True
                    self.cars[i].speed = self.cars[j].speed = self.after_collision_speed
                    self.collisions.append((self.cars[i].x, self.cars[i].y))

    def step(self):
        self.check_collisions()
        for car in self.cars:
            car.move()
