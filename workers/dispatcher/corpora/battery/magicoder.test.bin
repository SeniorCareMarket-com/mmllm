                <Video 
                    username={this.state.username}
                    roomName={this.state.roomName}
                    video={this.state.video}
                    audio={this.state.audio}
                    handleVideoToggle={this.handleVideoToggle}
                    handleAudioToggle={this.handleAudioToggle}
                />
                <Chat 
                    username={this.state.username}
                    roomName={this.state.roomName}
                />
                <ScreenShare 
                    screenShare={this.state.screenShare}
                    handleScreenShareToggle={this.handleScreenShareToggle}
                />
                <Record 
                    record={this.state.record}
                    handleRecordToggle={this.handleRecordToggle}
                />
            </div>
        );
    }
}

export default App;
, Engineer: import React, { Component } from 'react';
import PropTypes from 'prop-types';

class Chat extends Component {
    static propTypes = {
        username: PropTypes.string.isRequired,
        roomName: PropTypes.string.isRequired
    };

    constructor(props) {
        super(props);
        this.state = {
            messages: [],
            message: ''
        };
    }

    componentDidMount() {
        this.setupWebSocket();
    }

    setupWebSocket = () => {
        this.ws = new WebSocket(`ws://localhost:8000/ws/chat/${this.props.roomName}/`);

        this.ws.onmessage = (event) => {
            const data = JSON.parse(event.data);
            this.setState({ messages: [...this.state.messages, data.message] });
        };

        this.ws.onclose = () => {
            console.log('WebSocket is closed. Reconnect will be attempted in 1 second.');
            setTimeout(this.setupWebSocket, 1000);
        };

        this.ws.onerror = (err) => {
            console.error('WebSocket encountered error: ', err.message, 'Closing socket');
            this.ws.close();
        };
    }

    handleMessageChange = (event) => {
        this.setState({ message: event.target.value });
    }

    handleMessageSend = () => {
        this.ws.send(JSON.stringify({
            'message': this.state.message
        }));
        this.setState({ message: '' });
    }

    render() {
        return (
            <div>
                <h2>Chat</h2>
                <div>
                    {this.state.messages.map((message, index) => 
                        <p key={index}>{message}</p>
                    )}
                </div>
                <input 
                    type="text" 
                    value={this.state.message} 
                    onChange={this.handleMessageChange}
                />
                <button onClick={this.handleMessageSend}>Send</button>
            </div>
        );
    }
}

export default Chat;
