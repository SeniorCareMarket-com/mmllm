<|asst|>
The C language isn't designed to work with HTTP requests out of the box, and it doesn't support JSON natively, unlike Python. However, you can use libraries such as libcurl and cJSON to achieve similar functionality. Here is an attempt to rewrite your Python code in C using these libraries:

1. Install the libraries:

For CentOS/RHEL:

```bash
yum install curl-devel
yum install gcc
```

For Ubuntu/Debian:

```bash
apt-get install libcurl4-openssl-dev
apt-get install build-essential
```

2. C code:

```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <curl/curl.h>
#include <cjson/cJSON.h>

struct string {
  char *ptr;
  size_t len;
};

void init_string(struct string *s) {
  s->len = 0;
  s->ptr = malloc(s->len+1);
  if (s->ptr == NULL) {
    fprintf(stderr, "malloc() failed\n");
    exit(EXIT_FAILURE);
  }
  s->ptr[0] = '\0';
}

size_t writefunc(void *ptr, size_t size, size_t nmemb, struct string *s) {
  size_t new_len = s->len + size*nmemb;
  s->ptr = realloc(s->ptr, new_len+1);
  if (s->ptr == NULL) {
    fprintf(stderr, "realloc() failed\n");
    exit(EXIT_FAILURE);
  }
  memcpy(s->ptr+s->len, ptr, size*nmemb);
  s->ptr[new_len] = '\0';
  s->len = new_len;

  return size*nmemb;
}

int main(void) {
  CURL *curl;
  CURLcode res;

  curl_global_init(CURL_GLOBAL_DEFAULT);
  curl = curl_easy_init();

  struct curl_slist *headers = NULL;
  headers = curl_slist_append(headers, "Content-Type: application/json");
  headers = curl_slist_append(headers, "Authorization: EndpointKey {0}"); // replace {0} with subscription key
    
  struct string s;
  init_string(&s);
  
  if(curl) {
    curl_easy_setopt(curl, CURLOPT_URL, "<your-host>/qnamaker/v4.0/knowledgebases/{0}/generateAnswer"); // replace {0} with kb id
    curl_easy_setopt(curl, CURLOPT_POSTFIELDS, cJSON_Print(cJSON_CreateString("What's the weather like?")));
    curl_easy_setopt(curl, CURLOPT_HTTPHEADER, headers);
    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, writefunc);
    curl_easy_setopt(curl, CURLOPT_WRITEDATA, &s);
    

    res = curl_easy_perform(curl);
    if(res != CURLE_OK)
      fprintf(stderr, "curl_easy_perform() failed: %s\n", curl_easy_strerror(res));

    curl_easy_cleanup(curl);
  }

  printf("%s\n", s.ptr);

  free(s.ptr);

  curl_global_cleanup();

  return 0;
}
```

The response from the HTTP request will be printed out in the console in the form of raw JSON data. Keep in mind that creating HTTP client programs is more difficult in C than in higher-level languages like Python. Understandably, using C for such tasks is not common. Also note that error checking for malloc() and realloc() is minimal to keep the example code less complicated.
<|end|>


