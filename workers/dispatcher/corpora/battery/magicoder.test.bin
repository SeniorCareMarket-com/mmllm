<dropdown 
  :items="filteredCityList" 
  ref="city" 
  itemText="persianName"
  :placeholder="{{$t('SearchCityAndHotel')}}" 
  @onSelect="onSelectCity"
>
</dropdown>


Even I tried this-

<dropdown 
  :items="filteredCityList" 
  ref="city" 
  itemText="persianName"
