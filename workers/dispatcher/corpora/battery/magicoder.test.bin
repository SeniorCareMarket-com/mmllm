how would you write this in swift?
def sorted_based_on_parity_and_magnitude(arr):
    def bit_count(n):
        return bin(n).count('1')

    arr.sort(key=lambda x: (bit_count(x)%2, bit_count(x), -x))

    return arr
<|end|>
<|asst|>
This is how you can write it in Swift:

```swift
func bitCount(_ n: Int) -> Int {
    return String(n , radix: 2).filter({ $0 == "1" }).count
}

func sortedBasedOnParityAndMagnitude(_ arr: [Int]) -> [Int] {
    return arr.sorted {
        let leftBC = bitCount($0)
        let rightBC = bitCount($1)
        
        if leftBC % 2 != rightBC % 2 {
            return leftBC % 2 < rightBC % 2
        } else if leftBC != rightBC {
            return leftBC < rightBC
        } else {
            return $0 > $1
        }
    }
}
```

This snippet correctly replicates the given Python function. It sorts the array with parity (even or odd count of 1's in binary representation) being the primary factor, number of 1's in binary representation being the secondary factor, and magnitudes being the tertiary factor.

In Swift, the `sorted` function does not sort arrays in place, but rather it creates a new sorted array. The `bitCount` function converts an integer to its binary form, then counts the number of '1' bits.
<|end|>


