from typing import List, Tuple

def rolling_max_min(numbers: List[int]) -> List[Tuple[int, int]]:
    """
    From a given list of integers, generate a list of rolling maximum and minimum elements found until the given moment
    in the sequence, as a tuple (maximum, minimum).
    >>> rolling_max_min([1, 2, 3, 2, 3, 4, 2])
    [(1, 1), (2, 1), (3, 1), (3, 2), (3, 2), (4, 2), (4, 2)]
    """
<|end|>
<|asst|>
result = []
    current_min = float('inf')
    current_max = float('-inf')

    for number in numbers:
        current_min = min(current_min, number)
        current_max = max(current_max, number)
        result.append((current_max, current_min))

    return result

if __name__ == "__main__":
    test_case = [1, 2, 3, 2, 3, 4, 2]
    print(rolling_max_min(test_case))
<|end|>


