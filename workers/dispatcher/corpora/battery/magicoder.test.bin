<|asst|>
Here is a implementation of an Employee class using vector and templates in C++.

```cpp
#include<bits/stdc++.h>
using namespace std;

class Employee 
{
public:
    int id;
    string email;
    string department;
    string reporting_manager;

    Employee(int id, string email, string dep, string rm): id(id), email(email), department(dep), reporting_manager(rm) {}
};

class EmployeeDatabase
{
public:
    vector<Employee> database;

    void addEmployee(int id, string email, string dep, string rm) 
    {
        Employee newEmployee(id, email, dep, rm);
        database.push_back(newEmployee);
    }

    void sortById() 
    {
        sort(database.begin(), database.end(), [](Employee a, Employee b) 
        {
            return a.id < b.id;
        });
    }

    void sortByDepartment() 
    {
        sort(database.begin(), database.end(), [](Employee a, Employee b) 
        {
            return a.department < b.department;
        });
    }

    void searchByManager(string rm) 
    {
        for(auto& emp : database) {
            if(emp.reporting_manager == rm) {
                cout<<"ID: "<<emp.id<<" Email: "<<emp.email<<" Department: "<<emp.department<<endl;
            }
        }
    }
};

int main()
{
    EmployeeDatabase db;
    db.addEmployee(101, "Jake@gmail.com", "Finance", "David");
    db.addEmployee(102, "Laura@gmail.com", "HR", "Sara");
    db.addEmployee(103, "Smith@gmail.com", "IT", "David");
    db.sortById();
    //Uncomment to print sorted by ID
    //for(const auto &i : db.database) 
    //    std::cout << i.id << ' ' << i.email << ' ' << i.department <<' '<< i.reporting_manager <<'\n';
    db.sortByDepartment();
    //Uncomment to print sorted by Department
    //for(const auto &i : db.database) 
    //    std::cout << i.id << ' ' << i.email << ' ' << i.department <<' '<< i.reporting_manager <<'\n';
    db.searchByManager("David");
    return 0;
}
```
