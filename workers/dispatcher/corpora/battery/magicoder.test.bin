from typing import Union

def math_operator(a: Union[int, float], b: Union[int, float], operator: str, handle_exception: bool = False) -> Union[int, float, str]:
    try:
        if operator == '+': return a + b
        elif operator == '-': 
            if a < b and handle_exception: return "Error: Cannot subtract a larger number from a smaller one."
            return a - b
        elif operator == '*': return a * b
        elif operator == '/': 
            if b == 0 and handle_exception: return "Error: Division by Zero."
            return a / b
        else: return "Invalid operator."
    except Exception as e:
        if handle_exception: return str(e)
        raise e
