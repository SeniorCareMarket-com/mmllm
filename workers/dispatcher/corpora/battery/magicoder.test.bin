```csharp
using System;

class Program
{
    static void Main()
    {
        double fahrenheit, celsius;

        // taking temperature in fahrenheit as input
        Console.Write("Enter Temperature in Fahrenheit: ");
        fahrenheit = Convert.ToDouble(Console.ReadLine());

