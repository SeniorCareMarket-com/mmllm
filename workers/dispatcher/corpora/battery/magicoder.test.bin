## Code: ScreenShare.js
```javascript
import React, { Component } from 'react';
import PropTypes from 'prop-types';

class ScreenShare extends Component {
    static propTypes = {
        screenShare: PropTypes.bool.isRequired,
        handleScreenShareToggle: PropTypes.func.isRequired
    };

    constructor(props) {
        super(props);
        this.videoRef = React.createRef();
    }

    componentDidUpdate(prevProps) {
        if (this.props.screenShare !== prevProps.screenShare) {
            this.handleScreenShare();
        }
    }

    handleScreenShare = () => {
        if (this.props.screenShare) {
            this.startScreenShare();
        } else {
            this.stopScreenShare();
        }
    }

    startScreenShare = () => {
        if (navigator.getDisplayMedia) {
            navigator.getDisplayMedia({video: true}).then(this.handleSuccess, this.handleError);
        } else if (navigator.mediaDevices.getDisplayMedia) {
            navigator.mediaDevices.getDisplayMedia({video: true}).then(this.handleSuccess, this.handleError);
        } else {
            this.getScreenId((error, sourceId, screenConstraints) => {
                navigator.mediaDevices.getUserMedia(screenConstraints).then(this.handleSuccess).catch(this.handleError);
            });
        }
    }

    stopScreenShare = () => {
        let tracks = this.videoRef.current.srcObject.getTracks();
        tracks.forEach(track => track.stop());
        this.videoRef.current.srcObject = null;
    }

    handleSuccess = (stream) => {
        this.videoRef.current.srcObject = stream;
    }

    handleError = (error) => {
        console.log('Error: ' + error);
    }

    render() {
        return (
            <div>
                <h2>Screen Share</h2>
                <video ref={this.videoRef} autoPlay></video>
                <button onClick={this.props.handleScreenShareToggle}>
                    {this.props.screenShare ? 'Stop' : 'Start'} screen share
                </button>
            </div>
        );
    }
}

export default ScreenShare;
```
