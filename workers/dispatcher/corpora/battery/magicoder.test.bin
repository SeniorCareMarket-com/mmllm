```ruby
def multiply_numbers(num1, num2, num3)
  [num1, num2, num3].each do |num|
    raise ArgumentError, 'All arguments must be numbers' unless num.is_a? Numeric
  end
  
  return num1 * num2 * num3
end

begin
  puts "Enter first number:"
  num1 = gets.chomp.to_f  # use to_f to allow floating-point numbers
  puts "Enter second number:"
  num2 = gets.chomp.to_f
  puts "Enter third number:"
  num3 = gets.chomp.to_f
  
  result = multiply_numbers(num1, num2, num3)

  puts "The multiplied result of your numbers is #{result}"
rescue ArgumentError => e
  puts e.message
end
