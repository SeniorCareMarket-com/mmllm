Program a C++ class to store a student's name and age.
<|end|>
<|asst|>
Here is a simple C++ class definition to help you store a student's name and age.

```cpp
#include <string>

class Student {
private:
    std::string name;
    int age;

public:
    // Constructor
    Student(std::string studentName, int studentAge) {
        name = studentName;
        age = studentAge;
    }

    // Getter and Setter for Name
    std::string getName() {
        return name;
    }

    void setName(std::string newName) {
        name = newName;
    }

    // Getter and Setter for Age
    int getAge() {
        return age;
    }

    void setAge(int newAge) {
        if(newAge >= 0) {
            age = newAge;
        }
        else {
            // Handling Negative Ages
            std::cout << "Can't assign negative age. Current age remains as is." << std::endl;
        }
    }
};
```

You can use this class to create a new student, get and set the name and age.
For Example:
```cpp
int main() {
    // Create a Student
    Student student1("John Doe", 20);

    // Get the Student Details
    cout << "Student Name: " << student1.getName() << ", Age: " << student1.getAge() << endl;
    // Outputs: "Student Name: John Doe, Age: 20"

    // Set the Student Details
    student1.setName("Jane Doe");
    student1.setAge(22);

    cout << "Student Name: " << student1.getName() << ", Age: " << student1.getAge() << endl;
    // Outputs: "Student Name: Jane Doe, Age: 22"

    return 0;
}
```
<|end|>


