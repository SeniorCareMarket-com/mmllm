Create a JavaScript code that takes an integer as input and returns its prime factors.
n = 12
<|end|>
<|asst|>
Here is a JavaScript code that takes an integer as input and returns its prime factors:

```javascript
function primeFactors(n) {
  let factors = [];
  let divisor = 2;

  while (n > 1) {
    while (n % divisor === 0) {
      factors.push(divisor);
      n = n / divisor;
    }
    divisor++;
  }
  return factors;
}

let n = 12;
let result = primeFactors(n);
console.log(`Prime factors of ${n}:`, result);
```

When you run this code, it will return the prime factors of 12: [2, 2, 3].
<|end|>


