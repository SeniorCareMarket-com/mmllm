i need the lua equivalent for this:
def is_palindrome(string: str, l: int, r: int) -> bool:
    """ 
    Test if the given string between indexes l and r is a palindrome, 
    while ignoring case, punctuation and word boundaries during the check.
    """ 
    # Base case: empty string and single characters are palindromes
    if l >= r:
        return True
    
    # Ignore non-alphanumeric characters and recursion on remaining substring
    if not string[l].isalnum():
        return is_palindrome(string, l+1, r)
    elif not string[r].isalnum():
        return is_palindrome(string, l, r-1)
    
    # Compare lowercased characters at the ends of the substring
    if string[l].lower() != string[r].lower():
        return False
    else:
        return is_palindrome(string, l+1, r-1)

def longest_palindromic_postfix(string: str) -> str:
    """ 
    Find the longest palindrome present at the end of the supplied string, 
    while ignoring case and non-alphanumeric characters.
    """
    for i in range(len(string)):
        if is_palindrome(string, i, len(string)-1):
            return string[i:]
      
def make_palindrome(string: str) -> str:
    """ 
    Create the shortest palindrome starting with a given string, while ignoring case and non-alphanumeric characters.
    The algorithm works as follows:
    - Identify the longest palindrome suffix of the given string.
    - Append the reversed prefix (that comes before the palindromic suffix) to the end of the original string.
    """
    if len(string)>200:
        return 'Input string too long'
    
    palindrome_suffix = longest_palindromic_postfix(string)
    prefix = string[:len(string) - len(palindrome_suffix)]
    
    if len(prefix + string + prefix[::-1])>250:
        return 'Palindrome length exceeds 250 characters'
    
    return prefix + string + prefix[::-1]
<|end|>
<|asst|>
Here's the Lua equivalent for your python code:

```lua
function is_palindrome(str, l, r) 
    if l >= r then
        return true
    end

    curr_l_char = str:sub(l + 1, l + 1)
    curr_r_char = str:sub(r + 1, r + 1)

    if not curr_l_char:find("%w") then
        return is_palindrome(str, l + 1, r)
    elseif not curr_r_char:find("%w") then
        return is_palindrome(str, l, r - 1)
    end

    if curr_l_char:lower() ~= curr_r_char:lower() then
        return false
    else
        return is_palindrome(str, l + 1, r - 1)
    end
end

function longest_palindromic_postfix(str)
    len = str:len()
    for i = 0, len - 1 do
        if is_palindrome(str, i, len - 1) then
            return str:sub(i + 1)
        end
    end
end

function make_palindrome(str)
    len = str:len()
    if len > 200 then
        return 'Input string too long'
    end
    
    palindrome_suffix = longest_palindromic_postfix(str)
    palindrome_len = palindrome_suffix:len()
    prefix = str:sub(1, len - palindrome_len)
    final_palindrome = prefix .. str .. string.reverse(prefix)
    
    if final_palindrome:len() > 250 then
        return 'Palindrome length exceeds 250 characters'
    end
    
    return final_palindrome
end
```

A couple of things to note:
- 1-based index in Lua. This is why there are "+1" adjustments when accessing string characters.
- Lua uses ".." for string concatenation instead of "+".
- The `find` method is used to check if a character is alphanumeric.
- The method `string.reverse` is used to reverse a string in Lua.
<|end|>


