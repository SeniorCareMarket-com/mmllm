[{"name": "finance.calculateROE", "results": {"results": [{"year": "2018", "roe": -21.84}, {"year": "2019", "roe": -12.96}, {"year": "2020", "roe": 3.25}, {"year": "2021", "roe": 17.75}, {"year": "2022", "roe": 30.51}]}}]
