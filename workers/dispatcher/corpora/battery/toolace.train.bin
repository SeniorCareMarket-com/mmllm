[GeneticDriftSimulator(initial_population={"population_id": "NA_Wolves", "allele_frequencies": {"alleleA": 0.3, "alleleB": 0.7}}, simulation_parameters={"number_of_generations": 10, "generation_time": 5, "population_size": 150})]
