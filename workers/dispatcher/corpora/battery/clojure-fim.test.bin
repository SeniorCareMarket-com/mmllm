    [sg/heading headings ::opentype]
    [:p
     "Bindings and helpers to "
     [:a {:href "https://github.com/opentypejs/opentype.js"}
      "OpenType.js"]
     ", which helps in creating, measuring, transforming, and displaying OpenType fonts."]]
