(def counter-example
  (let [
    (count (ref/new 0))
  ]

  (render-in-body (fn []
    (el "h2" no-props (fn [] (text "Counter")))
    (el "div" no-props (fn [] (text (int->string count))))
    (el "div" no-props (fn []
