    "})(document, window, 'yandex_metrika_callbacks2');"
    "</script>"
    "<noscript><div><img src='https://mc.yandex.ru/watch/" id "'"
    " style='position:absolute; left:-9999px;' alt='' /></div></noscript>\n"))
;


(defn mailru-top [id]
