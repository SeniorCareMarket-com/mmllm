  (ks/texify (sat o05) "ks") 
  )

(def o06 '(xor P Q))
(ba/ba o06)
(sat? o06)
(sat o06)
(comment
  (ks/texify (sat o06) "ks")  
  )

(def o07 '(ite P Q R))
(ba/ba o07)
(sat? o07)
(comment
  (ks/texify (sat o07) "ks") 
  )

(def o08 '(always P))
(ba/ba o08)
(sat? o08)
(sat o08)
(comment
  (ks/texify (sat o08) "ks")
  (ks/texify (sat '(always (and P Q))) "ks")
