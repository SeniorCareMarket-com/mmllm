(ns editor.yamlparser
  (:refer-clojure :exclude [load])
  (:require [clojure.walk :refer [walk]])
  (:import [java.io Reader]
           [java.util List Map]
           [org.snakeyaml.engine.v1.api Load LoadSettingsBuilder]))

(defn- translate
  <|fim_mid|>[x key-transform-fn]<|fim_eom|>

