(defrecord WorkFlowObj []
  WorkFlow
  (exec [me job] (wsexec me job)))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
(defn workflow<>

  "Creare workflow from a list of symbols."
  {:arglists '(<|fim_mid|>[symbols]<|fim_eom|>

