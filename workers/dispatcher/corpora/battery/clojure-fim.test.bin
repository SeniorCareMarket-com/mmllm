(def o11 '(until P Q))
(ba/ba o11)
(sat? o11)
(comment
  (ks/texify (sat o11) "ks")
  (ks/texify (sat '(and P (until P Q))) "ks")
  (ks/texify (sat '(and (until P Q) (atnext P))) "ks")
