       (with-precision 6 :rounding Floor       (+ 3.5555555M 1)) 4.55555M        ;;; FLOOR
       (with-precision 6 :rounding HalfUp      (+ 3.5555555M 1)) 4.55556M        ;;; HALF_UP
       (with-precision 6 :rounding HalfDown    (+ 3.5555555M 1)) 4.55556M        ;;; HALF_DOWN
