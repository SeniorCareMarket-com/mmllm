++
#include<iostream>
#include<vector>
#include<algorithm>
using namespace std;

vector<int> sort_third(vector<int> l){
    // Vector to store elements at multiples of 3 positions 
    vector<int> multiplesOfThree;
    
    for (int i=0; i<l.size(); i++){
        // Operand is 0-based, but we want 1-based (i+1)
        if ((i+1) % 3 == 0) 
            multiplesOfThree.push_back(l[i]);
    }
    // Sort the multiples of 3 elements
    sort(multiplesOfThree.begin(), multiplesOfThree.end());

    // Put sorted multiples of 3 back into original positions
    for (int i=0, j=0; i<l.size(); i++) {
        if((i+1) % 3 == 0) l[i] = multiplesOfThree[j++];
    }
    
    return l;
}

