I have code written in X, can you translate it to Javascript?
import math
import itertools

def is_prime(n):
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    sqrtn = math.isqrt(n)
    for divisor in range(3, sqrtn + 1, 2):
        if n % divisor == 0:
            return False
    return True

def contains_duplicates(s):
    return len(set(s)) != len(s)

def advanced_prime_sum(n, m):
    def get_primes(n):
        min = 10**(n-1)
        max = 10**n
        return [x for x in range(min, max) if is_prime(x)]

    def is_valid(n):
        return (not contains_duplicates(str(n)) and
                is_prime(sum(int(i) for i in str(n))) and
                n % 5 != 0 and
                n**3 < m)

    primes = get_primes(n)
    valid_primes = filter(is_valid, primes)
    return sum(valid_primes)

# Test case:
print(advanced_prime_sum(3, 2000000000))
<|end|>
<|asst|>
Here is the equivalent JavaScript code of the given Python code:

```javascript
function isPrime(n) {
    if (n <= 1) {
        return false;
    }
    if (n === 2) {
        return true;
    }
    if (n % 2 === 0) {
        return false;
    }
    let sqrtn = Math.floor(Math.sqrt(n));
    for (let divisor = 3; divisor <= sqrtn + 1; divisor += 2) {
        if (n % divisor === 0) {
            return false;
        }
    }
    return true;
}

function containsDuplicates(s) {
    return new Set([...s]).size !== s.length;
}

function advancedPrimeSum(n, m) {
    function getPrimes(n) {
        let min = Math.pow(10, n-1);
        let max = Math.pow(10, n);
        
        let primes = [];
        
        for (let x = min; x < max; x++) {
            if (isPrime(x)) {
                primes.push(x);
            }
        }
        return primes;
    }

    function isValid(n) {
        let nString = n.toString();

        let sum = 0;
        
        for (let i = 0; i < nString.length; i++) {
            sum += parseInt(nString[i]);
        }

        let condition = (
            !containsDuplicates(nString) &&
            isPrime(sum) &&
            n % 5 !== 0 && 
            Math.pow(n, 3) < m
        );

        return condition;
    }

    let primes = getPrimes(n);
    let validPrimes = primes.filter(n => isValid(n));

    let sum = validPrimes.reduce((a, b) => a + b, 0);
    return sum;
}

// Test case:
console.log(advancedPrimeSum(3, 2000000000));
```
This JavaScript code does the same as the provided Python code. It checks for prime numbers, validates whether a number contains duplicates, and does a couple of other validations before returning sum of valid prime numbers.
