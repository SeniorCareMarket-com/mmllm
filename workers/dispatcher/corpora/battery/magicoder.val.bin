What would this look like in Swift?
#include<iostream>
#include<vector>
#include<string>
using namespace std;

vector<string> substitute_check_uniqueness(string s, string t) {
    for (char c : t) {
        replace(s.begin(), s.end(), c, '*');
    }
    
    int counts[256] = {0};
    for (char c : s) {
        counts[c]++;
        if (counts[c] > 1 && c != '*') {
            return {s, "Non-unique"};
        }
    }
    return {s, "Unique"};
}

int main() {
    string s = "hello", t = "he";
    vector<string> result = substitute_check_uniqueness(s, t);
    cout << result[0] << " " << result[1] << "\n";
    
    s = "world"; t = "o";
    result = substitute_check_uniqueness(s, t);
    cout << result[0] << " " << result[1] << "\n";
    
    s = "substitution"; t = "s";
    result = substitute_check_uniqueness(s, t);
    cout << result[0] << " " << result[1] << "\n";
    
    return 0;
}
<|end|>
<|asst|>
In Swift, this program would look something like below. One of the significant differences is Swift does not have a direct equivalent of C++ 'replace' function to replace characters. Instead, we use the 'replacingOccurrences' method. Also, Swift does not have a specific 256 character ASCII way to count characters like C++. Instead, we make use of dictionaries to count the characters.

```swift
import Foundation

func substituteCheckUniqueness(s: String, t: String) -> [String] {
    var str = s
    for c in t {
        str = str.replacingOccurrences(of: String(c), with: "*")
    }
    
    var counts: [Character: Int] = [:]
    for character in str {
        counts[character, default: 0] += 1
        if let count = counts[character], count > 1 && character != "*" {
            return [str, "Non-unique"]
        }
    }
    return [str, "Unique"]
}

var s = "hello"
var t = "he"
var result = substituteCheckUniqueness(s: s, t: t)
print("\(result[0]) \(result[1])")

s = "world"
t = "o"
result = substituteCheckUniqueness(s: s, t: t)
print("\(result[0]) \(result[1])")

s = "substitution"
t = "s"
result = substituteCheckUniqueness(s: s, t: t)
print("\(result[0]) \(result[1])")
```
In this Swift code:

- `s` and `t` are the strings passed into the `substituteCheckUniqueness` function.
- Each character in `t` is replaced with an '*' in `s`.
- `counts` is a dictionary that stores the amount of each character in `s`.
- Each character in `s` is checked for counts. If a character count is over 1 and it's not an '*', it returns `s` and "Non-unique".
- If no characters are over 1 (except for '*'), it returns `s` and "Unique".
- The main part of the code calls the `substituteCheckUniqueness` function multiple times with different `s` and `t` inputs, printing the results.
<|end|>


