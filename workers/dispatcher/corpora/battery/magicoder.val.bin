    >>> pattern_match_order(['abcde', 'bcdea', 'cdeaz', 'arrayz'], (['b', 'c', 'd'], 'a', 'z'))
    ['arrayz']
    >>> pattern_match_order(['abc', 'azy'], (['b', 'c'], 'a', 'z'))
    ['abc']
