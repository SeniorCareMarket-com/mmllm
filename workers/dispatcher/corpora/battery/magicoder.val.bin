positive_data = data[data['sentiment']==4]
negative_data = data[data['sentiment']==0]

# Generate positive word cloud
positive_wordcloud = WordCloud(stopwords=stopwords).generate(' '.join(positive_data['text']))
plt.imshow(positive_wordcloud, interpolation='bilinear')
plt.axis("off")
plt.show()

# Generate negative word cloud
negative_wordcloud = WordCloud(stopwords=stopwords).generate(' '.join(negative_data['text']))
plt.imshow(negative_wordcloud, interpolation='bilinear')
plt.axis("off")
plt.show()
```

