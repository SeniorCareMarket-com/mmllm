<|asst|>
Sure! Here is the Swift equivalent:

```swift
// Function to get Greatest Common Divisor
func gcd(_ a: Int, _ b: Int) -> Int {
    // If b is 0, returns a, else the gcd function calls itself recursively.
    // Generally, if b is 0, then the common divisor must be the other number.
    return b == 0 ? a : gcd(b, a % b)
}

func returnDecimalAsFraction(_ number: Double) -> String {
    // Integer part of the number
    let integerPart = Int(number)
    // Fractional part of the number.
    let decimalPart = number - Double(integerPart)

    // Default fraction in case decimal part is 0
    var fraction = "0/1"

    //Checks if the decimal part isn't zero
    if decimalPart != 0 {
        // Works out the denominator
        let denominator = Int(pow(10.0, Double(decimalPart.description.split(separator: ".").last?.count ?? 0)))
        // Works out the numerator
        let numerator = Int(decimalPart * Double(denominator))

        // Get the greatest common divisor of numerator and denominator
        let divider = gcd(numerator, denominator)

        // Divides the numerator and the denominator by the gcd
        // This will simplify the fraction.
        let reducedNumerator = numerator / divider
        let reducedDenominator = denominator / divider

        // Combine the simplified numerator and denominator into a fraction
        fraction = "\(reducedNumerator)/\(reducedDenominator)"
    }
    // Returns the fraction
    return fraction
}

print(returnDecimalAsFraction(3.5)) // Output '1/2'
```
This Swift code replicates the functionality from the JavaScript code you provided. It creates a string representation of a fractional part of a number.
