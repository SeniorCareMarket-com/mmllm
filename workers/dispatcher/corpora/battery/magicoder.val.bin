            # SQL Query
            sql = 'SELECT * FROM your_table WHERE ID > 5 ORDER BY ID DESC'
            cursor.execute(sql)
            
            # Fetch the records
            result = cursor.fetchall()
            for row in result:
                print(f"ID: {row[0]}, Name: {row[1]}, Address: {row[2]}")

    except pymysql.Error as e:
