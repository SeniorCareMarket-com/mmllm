Write a script that sorts an array of strings in alphabetical order, but with prioritization based on a separate array of priority names. The priority names should come first in the sorted list, retaining their original order, followed by the rest of the names in alphabetical order. Implement this in a way that does not directly sort the original array. 

For example, given the following input:
```
var names = ["John", "Zoe", "Alice", "Charlie", "Ben"];
var priorityNames = ["Zoe", "John"];
```
The output should be:
```
["Zoe", "John", "Alice", "Ben", "Charlie"];
```

Also, write tests for your code to ensure your solution works correctly in different scenarios.
<|end|>
<|asst|>
Here is a JavaScript solution that satisfies the given criteria:

```javascript
function sortNamesWithPriority(originalNames, priorityNames) {
  
  // To make sure priority names retain their original order, we will iterate through priorityNames backward
  const prioritizedNames = [...priorityNames].reverse().filter(name => originalNames.includes(name));
  const sortedNames = originalNames.filter(name => !priorityNames.includes(name)).sort();

  return [...prioritizedNames.reverse(), ...sortedNames];
}

const names = ["John", "Zoe", "Alice", "Charlie", "Ben"];
const priorityNames = ["Zoe", "John"];
console.log(sortNamesWithPriority(names, priorityNames)); // Expected output: ["Zoe", "John", "Alice", "Ben", "Charlie"]
```

And here are some tests:

```javascript
function testFunction() {
  const names1 = ["John", "Zoe", "Alice", "Charlie", "Ben"];
  const priorityNames1 = ["Zoe", "John"];
  const result1 = sortNamesWithPriority(names1, priorityNames1);
  console.log(JSON.stringify(result1) === '["Zoe","John","Alice","Ben","Charlie"]');
  
  const names2 = ["Adam", "Fred", "Dean", "Alice", "Eve"];
  const priorityNames2 = ["Dean", "Eve"];
  const result2 = sortNamesWithPriority(names2, priorityNames2);
  console.log(JSON.stringify(result2) === '["Dean","Eve","Adam","Alice","Fred"]');
  
  const names3 = ["John", "Zoe", "Alice", "Charlie", "Ben"];
  const priorityNames3 = ["Zoe", "Charlie", "John"];
  const result3 = sortNamesWithPriority(names3, priorityNames3);
  console.log(JSON.stringify(result3) === '["Zoe","Charlie","John","Alice","Ben"]');
  
  const names4 = ["John", "Zoe", "Alice", "Charlie", "Ben"];
  const priorityNames4 = ["Harry", "Ron"];
  const result4 = sortNamesWithPriority(names4, priorityNames4);
  console.log(JSON.stringify(result4) === '["Alice","Ben","Charlie","John","Zoe"]');

  const names5 = [];
  const priorityNames5 = ["Harry", "Ron"];
  const result5 = sortNamesWithPriority(names5, priorityNames5);
  console.log(JSON.stringify(result5) === '[]');

  const names6 = ["John", "Zoe", "Alice", "Charlie", "Ben"];
  const priorityNames6 = [];
  const result6 = sortNamesWithPriority(names6, priorityNames6);
  console.log(JSON.stringify(result6) === '["Alice","Ben","Charlie","John","Zoe"]');
}
testFunction();
```
These tests cover different edge cases, such as when the priority array has elements not present in the original array, when one of the arrays is empty, and when the order of the priority array is different from the original array.
