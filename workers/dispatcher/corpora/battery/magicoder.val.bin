help me turn this code into c++ syntax:
import psycopg2
import psycopg2.pool
from psycopg2 import OperationalError, errorcodes, errors

def create_conn_pool(minconn, maxconn, host, dbname, user, password, port):
    try:
        conn_pool = psycopg2.pool.SimpleConnectionPool(minconn,
                                                       maxconn,
                                                       host=host,
                                                       database=dbname,
                                                       user=user,
                                                       password=password,
                                                       port=port)
        if conn_pool:
            print("Connection pool created successfully")

        return conn_pool
    except OperationalError as e:
        print(f"The error '{e}' occurred")

def conn_pool_min_max(conn_pool):
    print(f"Connections in use: {conn_pool.ntasks}")
    print(f"Connections available: {len(conn_pool._pool)}")

def execute_query(conn_pool, query):
    # Get connection from connection pool
    conn = conn_pool.getconn()
    if conn is not None:
        conn.autocommit = True
        cursor = conn.cursor()
        try:
            cursor.execute(query)
            print("Query executed successfully")
        except errors as e:
            print(f"The error '{e}' occurred")

        finally:
            # Close the cursor and return the connection back to the connection pool
            cursor.close()
            conn_pool.putconn(conn)
    else:
        print('Not able to get a connection')

if __name__ == '__main__':
    conn_pool = create_conn_pool(1, 10, 'hostname', 'dbname', 'username', 'password', 'port')
    conn_pool_min_max(conn_pool)
    execute_query(conn_pool, 'SELECT * FROM table_name')
    conn_pool_min_max(conn_pool)
    conn_pool.closeall()
