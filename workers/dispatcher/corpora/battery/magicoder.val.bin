Sure, below is your Python code translated into Java.

```Java
import com.amazonaws.ClientConfiguration;
import com.amazonaws.auth.profile.ProfileCredentialsProvider;
import com.amazonaws.regions.Region;
import com.amazonaws.regions.Regions;
import com.amazonaws.services.dynamodbv2.AmazonDynamoDB;
import com.amazonaws.services.dynamodbv2.AmazonDynamoDBClientBuilder;
import com.amazonaws.services.dynamodbv2.model.*;
import com.amazonaws.services.sqs.AmazonSQS;
import com.amazonaws.services.sqs.AmazonSQSClientBuilder;
import com.fasterxml.jackson.databind.ObjectMapper;

import java.util.ArrayList;
import java.util.List;
import java.util.Map;

// Main class
public class MainClass {

    // Clients for DynamoDB and SQS
    private static AmazonDynamoDB dynamodb;
    private static AmazonSQS sqs;

    // URLs for the SQS queue
    private static final String QUEUE_URL = "https://sqs.us-east-2.amazonaws.com/123456789012/my-queue";

    // Main method
    public static void main(String[] args) throws Exception {
        // Setup the DynamoDB and SQS clients
        dynamodb = AmazonDynamoDBClientBuilder.standard().build();
        sqs = AmazonSQSClientBuilder.standard().build();

        // Create DynamoDB table
        createTable();

        // Load data from file
        ObjectMapper mapper = new ObjectMapper();
        List<Map<String,String>> data = mapper.readValue(MainClass.class.getResourceAsStream("data.json"), ArrayList.class);

        // Put each item from the data into the DynamoDB table
        for(Map<String,String> item : data) {
            putItem("MyTable", item);
        }
    }

    // Method to create DynamoDB table
    private static void createTable() {
        List<AttributeDefinition> attributeDefinitions = new ArrayList<>();
        // Setting id as primary key and attribute type as Number
        attributeDefinitions.add(new AttributeDefinition().withAttributeName("id").withAttributeType(ScalarAttributeType.N));

        List<KeySchemaElement> ks = new ArrayList<>();
        ks.add(new KeySchemaElement().withAttributeName("id").withKeyType(KeyType.HASH));

        ProvisionedThroughput provisionedthroughput = new ProvisionedThroughput().withReadCapacityUnits(5L).withWriteCapacityUnits(5L);

        CreateTableRequest request = new CreateTableRequest()
                .withTableName("MyTable")
                .withAttributeDefinitions(attributeDefinitions)
                .withKeySchema(ks)
                .withProvisionedThroughput(provisionedthroughput);

        // Creating the table
        dynamodb.createTable(request);
    }

    // Method to put item into the DynamoDB table
    private static void putItem(String tableName, Map<String,String> itemData) {
        try {
            // Put item into table
            dynamodb.putItem(new PutItemRequest().withTableName(tableName).withItem(itemData));
        } catch (Exception e) {
            // Handle error and push failed item to SQS queue for further handling
            sqs.sendMessage(new SendMessageRequest().withQueueUrl(QUEUE_URL).withMessageBody(itemData.toString()));
        }
    }
}
```

