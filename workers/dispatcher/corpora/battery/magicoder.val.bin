Here is the equivalent C++ code for your Python function. Please note that in C++, we are using `unordered_map` to represent the Python `dict`, `vector<string>` to represent Python `list`, and `pair<string, int>` to represent Python `tuple`:

```cpp
#include <iostream>
#include <unordered_map>
#include <vector>
#include <string>

using namespace std;

unordered_map<string, int> fruit_distribution(int s, int n, vector<string> fruits, vector<string> new_fruits_list) {
    unordered_map<string, int> fruit_dict;
    
    // Counting frequency of each fruit in the original fruits list
    for (auto fruit : fruits) {
        if (fruit_dict.find(fruit) == fruit_dict.end())
            fruit_dict[fruit] = 1;
        else
            fruit_dict[fruit] += 1;
    }

    // Counting frequency of each fruit in the new_fruits_list and adding it to the original fruit_dict
    for (auto new_fruit : new_fruits_list) {
        if (fruit_dict.find(new_fruit) == fruit_dict.end())
            fruit_dict[new_fruit] = 1;
        else
            fruit_dict[new_fruit] += 1;
    }

    return fruit_dict;
}

int main() {
    // Checking the function
    vector<string> original_fruits = {"apple", "banana", "mango", "orange", "apple", "mango"};
    vector<string> new_fruits = {"grape", "banana", "apple", "kiwi"};
    unordered_map<string, int> fruit_dict = fruit_distribution(6, 4, original_fruits, new_fruits);
    
    for (auto f : fruit_dict) {
        cout << f.first << ": " << f.second << "\n";
    }

    return 0;
}
```

Please note that in C++, you need to compile your program first, then run it. And also there is no `print` function in C++, we use `cout` instead, from the iostream library. The `<<` operator is used with `cout` to send data to the standard output (usually your monitor).
