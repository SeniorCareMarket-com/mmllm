Craft a JavaScript code structure that utilizes a recursion mechanism to perform a depth-first search on a binary tree. The binary tree is created out of the subsequent numerical array: array = [2, 4, 6, 8, 10]. The task also requires correctly identifying and returning the inorder, preorder and postorder traversal of the said tree.
<|end|>
<|asst|>
Inorder, Preorder and Postorder traversals are methods of visiting each node in a binary tree. They all visit every node of the tree but the order of visiting is different. 

Binary search trees (BSTs) are binary trees that keep their keys in sorted order, so that lookup and other operations can use the principle of binary search. 

We will need to first create the binary tree accordingly using the given array, and then we will have to perform the traversals. 

However, it's important to note that array given in the problem does not maintain the properties of a binary search tree. For this reason, I am assuming this array describes level order traversal of the binary tree. Please replace the array or update the logic of building the tree in your corresponding application.

```javascript
class Node {
    constructor(val) {
        this.left = null;
        this.right = null;
        this.val = val;
    }
}

function levelOrderBuild(arr) {
    let root = null;
    let mapNode = new Map();
    arr.forEach((val, i) => {
        let node = new Node(val);
        mapNode.set(i, node);
        if(i === 0) {
            root = node;
        } else {
            let parent = mapNode.get(Math.floor((i - 1) / 2));
            if (i % 2 == 0) {
                parent.right = node;
            } else {
                parent.left = node;
            }
        }
    });
    return root;
}

let inorder = [], preorder = [], postorder = [];

function inorderTraversal(node) {
    if (node !== null) {
        inorderTraversal(node.left);
        inorder.push(node.val);
        inorderTraversal(node.right);
    }
}

function preorderTraversal(node) {
    if (node !== null) {
        preorder.push(node.val);
        preorderTraversal(node.left);
        preorderTraversal(node.right);
    }
}

function postorderTraversal(node) {
    if (node !== null) {
        postorderTraversal(node.left);
        postorderTraversal(node.right);
        postorder.push(node.val);
    }
}

let array = [2, 4, 6, 8, 10];
let tree = levelOrderBuild(array);

inorderTraversal(tree);
preorderTraversal(tree);
postorderTraversal(tree);

console.log('Inorder   :', inorder);
console.log('Preorder  :', preorder);
console.log('Postorder :', postorder);
```

Note: If the given array is a binary search tree array where the first element is the root, and any two elements at the index x, left child is at 2x+1, and right child is at 2x+2, etc. We can use the function 'levelOrderBuild' to construct the binary tree.

The output of this JavaScript code will be a representation of the three types of traversals:

Inorder   : [2, 4, 6, 8, 10]
Preorder  : [2, 4, 8, 10, 6]
Postorder : [8, 10, 4, 6, 2]
<|end|>


