def uncommon_elements(sequence):
    #Function to check if a number is prime
    def is_prime(n):
        if n <= 1 or (n % 2 == 0 and n > 2): 
            return False
        return all(n % i for i in range(3, int(n**0.5) + 1, 2))
 
    #Create a dictionary where key will be the number
    frequency_count = {} 
    for num in sequence: 
        if num in frequency_count: 
            frequency_count[num] += 1
        else: 
            frequency_count[num] = 1
  
    result = []
    for key, value in frequency_count.items():
        if is_prime(value) and value > key // 2:
            result.append(key)

    return result
