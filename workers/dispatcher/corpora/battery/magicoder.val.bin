```go
package main

import (
	"strings"
	"fmt"
)

func main() {
	testStr := "This is first line.\nThis is second line.\nThis is third line."
	word := "second"

	lines := strings.Split(testStr, "\n")
	for _, line := range lines {
		if strings.Contains(line, word) {
			fmt.Println(line)
			break
		}
	}
}
