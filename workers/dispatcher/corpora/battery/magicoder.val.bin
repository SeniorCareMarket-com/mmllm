```python
def robust_median(lst):
    length = 0
    first_elem = None
    for elem in lst:
        if isinstance(elem, tuple):
            for number in elem:
                if number is not None and type(number) in [int, float]:
                    length += 1
                    if first_elem is None:
                        first_elem = number
        else:
            if elem is not None and type(elem) in [int, float]:
                length += 1
                if first_elem is None:
                    first_elem = elem

    if length == 0:
        return None 
    if length == 1:
        return first_elem

    middle = length // 2
    for elem in lst:
        if isinstance(elem, tuple):
            for number in elem:
                if number is not None and type(number) in [int, float]:
                    count = sum(1 for i in lst for val in (i if isinstance(i, tuple) else [i]) 
                                 if val is not None and type(val) in [int, float] and val <= number)
                    if length % 2 == 0:
                        if count == middle or count == middle + 1:
                            if first_elem is None:
                                first_elem = number
                            first_elem = max(number, first_elem) if count == middle else min(number, first_elem)
                    elif count == middle + 1:
                        return number
        else:
            if elem is not None and type(elem) in [int, float]:
                count = sum(1 for i in lst for val in (i if isinstance(i, tuple) else [i])
                             if val is not None and type(val) in [int, float] and val <= elem)
                if length % 2 == 0:
                    if count == middle or count == middle + 1:
                        if first_elem is None:
                            first_elem = elem
                        first_elem = max(elem, first_elem) if count == middle else min(elem, first_elem)
                elif count == middle + 1:
                    return elem
    return first_elem
```

This code defines a function robust_median() that accepts a list containing integers, floats, or tuples. The function calculates the 'robust median' of the list. It's robust because it handles not only integers and floats but also tuples containing them, and ignores None and non-numeric values.
