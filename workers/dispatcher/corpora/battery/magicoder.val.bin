function is_prime(n)
    if n < 2 then
        return false
    end
    for i=2, math.sqrt(n) do
        if n % i == 0 then
            return false
        end
    end
    return true
end

function prime_product_quad(b)
    local factors = {}
    local n = 2
    while n <= b do
        if b % n == 0 then
            if is_prime(n) then
                table.insert(factors,n)
            end
            b = b/n
        else
            n = n + 1
        end
    end
    if #factors == 4 and is_prime(factors[1]) and is_prime(factors[2]) and is_prime(factors[3]) and is_prime(factors[4]) and b == factors[1]*factors[2]*factors[3]*factors[4] then
        return factors
    else
        return "Not a product of 4 distinct prime numbers."
    end
end
```

