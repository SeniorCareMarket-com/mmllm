<|asst|>
def subtreeWithMaxAvg(root):
    max_avg_node = [None, 0]  # node_with maximum average_value, [node, average_value]

    def depth_sum_count_average(node):
        if not node:
            return -1.0, 0 , 0   # depth, sum, count
        l_d, l_s, l_c = depth_sum_count_average(node.left)
        r_d, r_s, r_c = depth_sum_count_average(node.right)
        if l_d < r_d:    # the left subtree is deeper
            d, s, c = l_d + 1, l_s + node.val, l_c
        elif l_d > r_d:  # the right subtree is deeper
            d, s, c = r_d + 1, r_s + node.val, r_c
        else:            # both subtrees have the same depth
            d, s, c = l_d + 1, l_s + r_s + node.val, l_c + r_c + 1

        avg = s / c
        if avg > max_avg_node[1]:  # update the node with the maximum average value
            max_avg_node[0], max_avg_node[1] = node, avg

        return d, s, c

    depth_sum_count_average(root)

    return max_avg_node[0]
<|end|>


