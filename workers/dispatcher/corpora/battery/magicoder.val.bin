show me how this would look in javascript:
def next_smallest(lst):
    if len(lst) < 2:  # If the list has less than 2 elements, return None
        return None
    
    first_min = second_min = float('inf')
    
    for num in lst:
        if num < first_min:  # If num is smaller than both first_min and second_min
            second_min = first_min
            first_min = num
        elif num < second_min and num != first_min:  # If num is only smaller than second_min
            second_min = num
            
    if second_min == float('inf'):  # If second_min was never updated, return None
        return None
    
    return second_min

# Test cases
print(next_smallest([1, 2, 3, 4, 5]))  # Output: 2
print(next_smallest([5, 1, 4, 3, 2]))  # Output: 2
print(next_smallest([]))  # Output: None
print(next_smallest([1, 1]))  # Output: None
would be helpful to have comments explaining the javascript code.
<|end|>
<|asst|>
Here's how the given code would look in JavaScript. 

```javascript
function nextSmallest(arr) {
    // If the array has less than 2 elements, return null
    if (arr.length < 2) {
        return null;
    }

    let firstMin = Infinity;
    let secondMin = Infinity;

    for (let i = 0; i < arr.length; i++) {
        // If current element is smaller than both firstMin and secondMin
        if (arr[i] < firstMin) {
            secondMin = firstMin;  // Update secondMin to value of firstMin
            firstMin = arr[i];  // Update firstMin to current element
        } 
        // If current element is only smaller than secondMin and not equal to firstMin
        else if (arr[i] < secondMin && arr[i] !== firstMin) {  
            secondMin = arr[i];  // Update secondMin to current element
        }
    }

    // If secondMin was never updated, return null
    if (secondMin == Infinity) {
        return null;
    }

    // Return the smallest number in the list which is not the minimum
    return secondMin;
}

// Test cases
console.log(nextSmallest([1, 2, 3, 4, 5]));  // Output: 2
console.log(nextSmallest([5, 1, 4, 3, 2]));  // Output: 2
console.log(nextSmallest([]));  // Output: null
console.log(nextSmallest([1, 1]));  // Output: null
```

In JavaScript, `Infinity` is used to represent infinity, and `null` instead of `None`. Also, to compare values not to be the same, we use `!==` instead of Python's `!=`. This JavaScript code has the same functionality as your Python code.
