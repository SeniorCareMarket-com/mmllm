from typing import Optional, Union

def refine_integer(input_value: Union[float, str, None], round_down: bool = True) -> Optional[int]:
    if input_value is None:
        return None
    try:
        # Check if the input is a string that can be converted to a float
        number = float(input_value)
    except ValueError:
        # Throw an error if the input value is a non-numeric string
        raise ValueError('Invalid input: non-numeric string')
        
    # Use the round_down parameter (True for rounding down, False for rounding up) 
    # to specify rounding.
    if round_down:
        # If True, round the number down.
        return int(number // 1) 
    else:
        # If False, round the number up.
        return int(number // 1) + 1 if number % 1 != 0 else int(number)
could you insert annotations in the c code to clarify its operation?
