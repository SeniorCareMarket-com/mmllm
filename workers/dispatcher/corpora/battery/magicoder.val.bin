Create a function to complete the code below:

def uncommon_elements(sequence):
    '''
    You are given a non-empty list of positive integers. Return all unique integers that meet the following two conditions:
    1. Have a frequency greater than half the value of the integer itself.
    2. Their frequency in the list is a prime number.
    
    The frequency of an integer is the number of times it appears in the list.
    If no such value exists, return an empty list.
    Examples:
        uncommon_elements([4, 1, 2, 2, 3, 1]) == [2, 3]
        uncommon_elements([1, 2, 2, 3, 3, 3, 4, 4, 4]) == [3, 4]
        uncommon_elements([5, 5, 4, 4, 4]) == [4]
    '''
<|end|>
<|asst|>
def uncommon_elements(sequence):
    def is_prime(num):
        if num < 2:
            return False
        for i in range(2, int(num ** 0.5) + 1):
            if num % i == 0:
                return False
        return True

    def has_required_frequency(num, sequence):
        freq = sequence.count(num)
        return freq > (num // 2) and is_prime(freq)

    unique_elements = set(sequence)
    result = [num for num in unique_elements if has_required_frequency(num, sequence)]
    return result

print(uncommon_elements([4, 1, 2, 2, 3, 1])) # should return [2, 3]
print(uncommon_elements([1, 2, 2, 3, 3, 3, 4, 4, 4])) # should return [3, 4]
print(uncommon_elements([5, 5, 4, 4, 4])) # should return [4]
print(uncommon_elements([2, 2, 2, 5, 5])) # should return [2]
print(uncommon_elements([2, 2, 2, 5, 5, 5])) # should return []
<|end|>


