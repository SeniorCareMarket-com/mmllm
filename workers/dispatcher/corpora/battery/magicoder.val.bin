Sure, here is your code made Swift-compliant:

```swift
import Foundation

func findClosestElements(numbers: [Double]) -> [Double] {
    var numbers = numbers
    numbers.sort()
    var minDiff = Double.greatestFiniteMagnitude
    var result = [Double]()
    
    for i in 0..<(numbers.count - 1) {
        let diff = numbers[i+1] - numbers[i]
        if diff < minDiff {
            minDiff = diff
            result = [numbers[i], numbers[i+1]]
        }
    }
    
    return result
}
```

Note that this code assumes that the array `numbers` has at least two elements. If there is a chance it can have zero or one element, you might want to handle that case as well.
