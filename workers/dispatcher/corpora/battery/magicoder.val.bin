fig = px.scatter(df_b,
                x="EAD", 
                y="RAR",
                size="Margen_bruto",
                hover_name="Cliente",
                hover_data={'EAD': ':.0f', 'RAR': ':.0%', 'Margen_bruto': ':.0f'},
                size_max=30,
                trendline='lowess',
                trendline_color_override='black',
                trendline_scope='overall',
                title="BÉLGICA dic 2019 - 46 clientes")


