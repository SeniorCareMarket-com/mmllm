The corrected Python code should look something like this:

```python
from transformers import Trainer, TrainingArguments, AutoTokenizer, AutoModelForSequenceClassification
import pandas as pd
import numpy as np
from sklearn.preprocessing import MultiLabelBinarizer
from torch import nn, cuda
from torch.utils.data import Dataset

class TextDataset(Dataset):

def __init__(self, texts, labels, tokenizer, max_length):
    self.texts = texts
    self.labels = labels
    self.tokenizer = tokenizer
    self.max_length = max_length

def __len__(self):
    return len(self.texts)

def __getitem__(self, index):
    text = self.texts[index]
    inputs = self.tokenizer.encode_plus(text, add_special_tokens=True, max_length=self.max_length, padding='max_length', return_tensors='pt')

    return {
        'input_ids': inputs['input_ids'].squeeze(),
        'attention_mask': inputs['attention_mask'].squeeze(),
        'labels': self.labels[index]
}

def compute_metrics(eval_pred):
    predictions, labels = eval_pred
    predictions = np.argmax(predictions, axis=1)
    labels[labels<=0.5] = 0
    labels[labels>0.5] = 1
    return {'accuracy': (predictions == labels).mean()}

data = pd.read_csv('data.csv')
texts = data['text'].tolist()
labels = data['labels'].apply(lambda x: [int(i) for i in x.split(', ')]).tolist()

mlb = MultiLabelBinarizer()
labels = mlb.fit_transform(labels)
num_labels = len(mlb.classes_)

model_name = 'distilbert-base-uncased'
tokenizer = AutoTokenizer.from_pretrained(model_name)
model = AutoModelForSequenceClassification.from_pretrained(model_name, num_labels=num_labels)

if cuda.is_available():
    model = model.cuda()

dataset = TextDataset(texts, labels, tokenizer, max_length=128)

training_args = TrainingArguments(
    output_dir='./results',
    num_train_epochs=3,
    per_device_train_batch_size=4,
    per_device_eval_batch_size=4,
    learning_rate=2e-5,
    logging_dir='./logs',
)

trainer = Trainer(
    model=model,
    args=training_args,
    compute_metrics=compute_metrics,
    train_dataset=dataset,
)

trainer.train()
```

This corrected Python code imports the needed classes from the Transformers, pandas, numpy, sklearn, and torch libraries, correctly defines the custom TextDataset class for handling the text and labels, defines a function for computing metrics during training, loads a specific language model and tokenizer using the Transformers library, checks for the presence of a CUDA-enabled GPU for faster training, and initializes and starts a model training session using the Transformers library's Trainer class.
