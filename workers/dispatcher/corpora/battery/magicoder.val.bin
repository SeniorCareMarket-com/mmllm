write this code in swift, please:
def below_zero(operations: List[Tuple[str, int]], case_insensitive: bool = False) -> bool:
    balance = 0
    for op, value in operations:
        if case_insensitive:
            op = op.lower()
            
        if op == 'deposit':
            balance += value
        elif op == 'withdrawal':
            balance -= value

        if balance < 0:
            return True

    return False
<|end|>
<|asst|>
In Swift, your function could translate like this:

```swift
func belowZero(operations: [(String, Int)], caseInsensitive: Bool = false) -> Bool {
    var balance = 0
    for (op, value) in operations {
        var operation = op
        if caseInsensitive {
            operation = op.lowercased()
        }
        
        switch operation {
        case "deposit":
            balance += value
        case "withdrawal":
            balance -= value
        default: 
            continue
        }

        if balance < 0 {
            return true
        }
    }
    
    return false
}
```

Note: Swift does not have an exact equivalent of Python's tuples, but here I've used a combination of Swift arrays and tuples for the operations parameter. This also allows us to apply destructuring in the loop, similar to Python.
<|end|>


