    for new_fruit in new_fruits_list:
        if new_fruit not in fruit_dict:
            fruit_dict[new_fruit] = 1
        else:
            fruit_dict[new_fruit] += 1

    return fruit_dict

# Checking the function
original_fruits = ['apple', 'banana', 'mango', 'orange', 'apple', 'mango']
new_fruits = ['grape', 'banana', 'apple', 'kiwi']
