How does this code look in C++?
package main

import (
	"fmt"
	"strings"
)

func RecursiveCount(str string, substring string) int {
    l1 := len(str)
    l2 := len(substring)
 
    if l1 == 0 || l2 == 0 {
        return 0
    }
 
    count := 0
    if strings.HasPrefix(str, substring) {
        count = 1
    }
 
    return count + RecursiveCount(str[1:], substring)
}

func main() { 
    fmt.Println(RecursiveCount("", "a"))        // Output: 0.
    fmt.Println(RecursiveCount("aaa", "a"))     // Output: 3.
    fmt.Println(RecursiveCount("aaaa", "aa"))   // Output: 3.
}
<|end|>
<|asst|>
The equivalent C++ code uses the `std::string::substr(start_pos, num_of_chars)` function where `start_pos` is the position where the sub-string begins, and `num_of_chars` is the length of the sub-string. The `std::string::find(substring)` function returns '0' when it finds the sub-string at the start of the string else it returns `std::string::npos` (a large number signifying not found).

```cpp
#include <iostream>
#include <string>

int RecursiveCount(std::string str, std::string substring) {
    int l1 = str.size();
    int l2 = substring.size();

    if (l1 == 0 || l2 == 0) {
        return 0;
    }

    int count = 0;
    if (str.find(substring) == 0) {
        count = 1;
    }

    return count + RecursiveCount(str.substr(1), substring);
}

int main() {
    std::cout << RecursiveCount("", "a") << std::endl;       // Output: 0.
    std::cout << RecursiveCount("aaa", "a") << std::endl;    // Output: 3.
    std::cout << RecursiveCount("aaaa", "aa") << std::endl;  // Output: 3.
}
```
