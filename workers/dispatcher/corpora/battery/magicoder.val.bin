            return False
    return True

print(subset_check({1, 4, 3, 34, 653, 2, 5}, {5, 7, 1, 5, 9, 653, 121}))  # Output should be False
print(subset_check({3, 2}, {5, 3, 2, 8}))  # Output should be True
i'd appreciate some explanation for the java version of the code.
