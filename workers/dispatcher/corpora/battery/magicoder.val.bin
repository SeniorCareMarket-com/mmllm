, Engineer: from typing import List
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.metrics.pairwise import cosine_similarity
from user import User
from article import Article
from database import DatabaseManager

class Recommendation:
    def __init__(self, user: User, db_manager: DatabaseManager):
        self.user = user
        self.db_manager = db_manager
        self.articles = self._fetch_articles()

    def _fetch_articles(self) -> List[Article]:
        articles_data = self.db_manager.get_articles()
        return [Article(**article) for article in articles_data]

    def get_recommendations(self) -> List[Article]:
        tfidf = TfidfVectorizer(stop_words='english')
        tfidf_matrix = tfidf.fit_transform([article.summary for article in self.articles])
        user_profile = tfidf.transform([' '.join(self.user.interests + list(self.user.reading_habits.keys()))])
        cosine_sim = cosine_similarity(user_profile, tfidf_matrix)
        sim_scores = list(enumerate(cosine_sim[0]))
        sim_scores = sorted(sim_scores, key=lambda x: x[1], reverse=True)
        recommended_articles = [self.articles[i[0]] for i in sim_scores]
        return recommended_articles
, Engineer: from flask import Flask, render_template, request, redirect, url_for
from flask_bcrypt import Bcrypt
from flask_login import LoginManager, login_user, logout_user, login_required, current_user
from user import User
from article import Article
from recommendation import Recommendation
from database import DatabaseManager

app = Flask(__name__)
bcrypt = Bcrypt(app)
login_manager = LoginManager(app)
db_manager = DatabaseManager()

@login_manager.user_loader
def load_user(user_id):
    return db_manager.get_user(user_id)

@app.route('/')
@login_required
def index():
    recommendation = Recommendation(current_user, db_manager)
    articles = recommendation.get_recommendations()
    return render_template('index.html', articles=articles)

@app.route('/login', methods=['GET', 'POST'])
def login():
    if request.method == 'POST':
        username = request.form['username']
        password = request.form['password']
        user = db_manager.get_user(username)
        if user and bcrypt.check_password_hash(user.password, password):
            login_user(user)
            return redirect(url_for('index'))
    return render_template('login.html')

@app.route('/logout')
@login_required
def logout():
    logout_user()
    return redirect(url_for('login'))

@app.route('/register', methods=['GET', 'POST'])
def register():
    if request.method == 'POST':
        username = request.form['username']
        password = bcrypt.generate_password_hash(request.form['password']).decode('utf-8')
        user = User(username=username, password=password, db_manager=db_manager)
        db_manager.insert_user(user)
        return redirect(url_for('login'))
    return render_template('register.html')

@app.route('/feedback', methods=['GET', 'POST'])
@login_required
def feedback():
    if request.method == 'POST':
        feedback = request.form['feedback']
        current_user.update_reading_habits(feedback)
    return render_template('feedback.html')

if __name__ == '__main__':
    db_manager.create_tables()
    app.run(debug=True)
