// Erroneous reference code
public static int[] getIndexAndLengthProduct(String[] inputArray, int limit) {
    int[] result = new int[inputArray.length];

    for (int i = 0; i < inputArray.length && i < limit; i++) {
        int length = inputArray[i].length();
