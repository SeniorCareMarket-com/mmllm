def convert_number(number, conversion_type):
    dict_int_roman = {
        1: 'i', 4: 'iv', 5: 'v', 9: 'ix', 10: 'x', 40: 'xl', 50: 'l', 90: 'xc',
        100: 'c', 400: 'cd', 500: 'd', 900: 'cm', 1000: 'm'}

    dict_roman_int = {v: k for k, v in dict_int_roman.items()}

    def int_to_roman(num):
        res = ''
        for i in sorted(dict_int_roman.keys(), reverse=True):
            while num >= i:
                res += dict_int_roman[i]
                num -= i
        return res

    def roman_to_int(s):
        i = res = 0
        while i < len(s):
            if i + 1 < len(s) and dict_roman_int[s[i:i+2]] > dict_roman_int[s[i]]:
                res += dict_roman_int[s[i:i+2]]
                i += 2
            else:
                res += dict_roman_int[s[i]]
                i += 1
        return res

    if conversion_type == 'int_to_roman':
        return int_to_roman(int(number))
    elif conversion_type == 'roman_to_int':
        return roman_to_int(str(number))
    elif conversion_type == 'int_to_hex':
        return hex(int(number))[2:]
    elif conversion_type == 'hex_to_int':
        return int(str(number), 16)
    else:
        raise ValueError("Invalid conversion type")

# Test
print(convert_number(25, 'int_to_hex'))  # '19'
print(convert_number('19', 'hex_to_int'))  # 25
print(convert_number('cdxxvi', 'roman_to_int'))  # 426
print(convert_number(426, 'int_to_roman'))  # 'cdxxvi'
Help me translate it to Rust
<|end|>
<|asst|>
Here is the Python code translated to Rust:

Please notice that in Rust a function can't return two different types based on a condition (like it happens in the Python code, where the function returns a string for some conversions and an int for others) so instead we return a String in every case. 

```rust
pub fn convert_number(number: &str, conversion_type: &str) -> Result<String, &'static str> {
    use std::collections::HashMap;

    let mut dict_int_roman: HashMap<&str, i32> = HashMap::new();
    dict_int_roman.insert("i", 1);
    dict_int_roman.insert("iv", 4);
    dict_int_roman.insert("v", 5);
    dict_int_roman.insert("ix", 9);
    dict_int_roman.insert("x", 10);
    dict_int_roman.insert("xl", 40);
    dict_int_roman.insert("l", 50);
    dict_int_roman.insert("xc", 90);
    dict_int_roman.insert("c", 100);
    dict_int_roman.insert("cd", 400);
    dict_int_roman.insert("d", 500);
    dict_int_roman.insert("cm", 900);
    dict_int_roman.insert("m", 1000);

    let mut dict_roman_int = HashMap::new();
    for (key, val) in dict_int_roman.iter() {
        dict_roman_int.insert(val, key);
    }

    let mut result = String::new();
    match conversion_type {
        "int_to_roman" => {
            let mut num = number.parse().unwrap();
            for i in dict_roman_int.keys().rev() {
                while num >= *i {
                    result.push_str(dict_roman_int[i]);
                    num -= i;
                }
            }
        },
        "roman_to_int" => {
            let s = number.chars().collect::<Vec<char>>();
            let mut i = 0;
            while i < s.len() {
                if i + 1 < s.len() && dict_int_roman[&s[i..i+2].to_string()] > dict_int_roman[&s[i].to_string()] {
                    result = format!("{}", dict_int_roman[&s[i..i+2].to_string()]);
                    i += 2;
                } else {
                    result = format!("{}", dict_int_roman[&s[i].to_string()]);
                    i += 1;
                }
            }
        },
        "int_to_hex" => {
            result = format!("{:x}", number.parse::<i32>().unwrap());
        },
        "hex_to_int" => {
            result = format!("{}", i32::from_str_radix(number, 16).unwrap());
        },
        _ => {
            return Err("Invalid conversion type")
        }
    }
    Ok(result)
}

```

Please note that for simplicity and readability, error management in this Rust code is not thorough - in real production code you'd want to appropriately manage potential errors at all points where `unwrap()` is used.
<|end|>


