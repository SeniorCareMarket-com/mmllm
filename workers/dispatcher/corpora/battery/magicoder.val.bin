Sure! Here is the translated C# code:

```csharp
using System;
using System.Collections.Generic;
using System.Linq;

public static class Program
{
    private static readonly List<int> PrimesLessThanTen = new List<int> {2, 3, 5, 7};

    public static void Main()
    {
        var testList = new List<double> {-0.56, 1.54, 3.5, 2.56, -1.8, 3.9};
        Console.WriteLine(MultiplyAbsValuesV3(testList));
    }

    private static int ApplyRules(double value)
    {
        var closestInteger = (int)Math.Floor(value) >= 0 ? (int)Math.Floor(value): (int)Math.Ceiling(value);
        
        var isPrimeDivisible = PrimesLessThanTen.Any(prime => closestInteger % prime == 0);
        
        if (closestInteger == 0 && value < 0) return -1;  // special case for -0
    
        // exclude items divisible by primes and convert negatives to positives if their decimal part >= 0.5
        if (isPrimeDivisible || (closestInteger < 0 && value - closestInteger >= 0.5)) return 1;

        return Math.Abs(closestInteger);
    }
    
    private static int MultiplyAbsValuesV3(List<double> lst)
    {
        return lst.Select(ApplyRules).Aggregate((a, b) => a * b);
    }
}
