Sure, I have debugged and reformatted the code. Here you go:

```python
from typing import List
from collections import deque

class Node:
    def __init__(self, val: int = 0, offsprings: 'List[Node]' = None):
        self.val = val
        self.offspring = offsprings if offsprings is not None else []
        self.parent = None  # Parent not needed for this problem

def build_tree(data):
    n = len(data)
    if n == 0: 
        return None
    nodes = [Node(data[i]) for i in range(n) if data[i] is not None]
    node_map, children = {}, []
    for i in range(n):
        if data[i] is None:
            nodes[node_map[data[i-1]]].offspring.extend(children)
            children.clear()
        else: 
            children.append(nodes[i])
            node_map[data[i]] = i
    return nodes[0]

def clone_tree(root):
    if root is None:
        return None
    clone_root = Node(root.val)
    clone_map = {root.val: clone_root}
    q = deque([(root, clone_root)])
    while q:
        node, clone_node = q.popleft()
        for child in node.offspring:
            if child.val not in clone_map:
                clone_child = Node(child.val)
                clone_map[child.val] = clone_child
                q.append((child, clone_child))
            clone_node.offspring.append(clone_child)
    return clone_root

def locate_node(root, target):
    if root is None:
        return None
    q = deque([root])
    while q:
        node = q.popleft()
        if node.val == target:
            return node
        for child in node.offspring:
            q.append(child)
    return None
```

Please note that there are some assumptions made while debugging:
- The `Node` class contains an attribute `offsprings` which is a list that contains the child nodes (in case of tree). And the `parent` attribute I've kept as you mentioned in the comment that it's not needed for this problem.
- `build_tree` function is supposed to take a list where an element at index `i` represents a node with a value and its children.
<|end|>


