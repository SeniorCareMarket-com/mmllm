Could you translate this snippet to Go?
def advanced_monotonic(l: list, strict: bool = False):
    # Initialize the previous_value variable to None
    previous_value = None
    # Initialize monotonically increasing and decreasing indicators
    increasing = True
    decreasing = True

    for item in l:
        try:
            # Firstly, try to convert the item to float for comparison. If this fails, the item is not numerical and
            # should be skipped.
            float_item = float(item)
            if previous_value is not None:
                if float_item > previous_value:
                    decreasing = False
                elif float_item < previous_value:
                    increasing = False
                elif strict:
                    # strict mode is enabled and this element is the same as the last
                    increasing = decreasing = False
            previous_value = float_item
        except (TypeError, ValueError):
            # Skip non-numerical items
            continue
    return increasing or decreasing
<|end|>
<|asst|>
Here is your Python code translated to Go:

```Go
package main

import (
	"fmt"
	"strconv"
)

func AdvancedMonotonic(l []string, strict bool) bool {
	var previousValue float64
	increasing := true
	decreasing := true
	isSet := false

	for _, item := range l {
		floatItem, err := strconv.ParseFloat(item, 64)
		if err != nil {
			continue
		}

		if isSet {
			if floatItem > previousValue {
				decreasing = false
			} else if floatItem < previousValue {
				increasing = false
			} else if strict {
				increasing = false
				decreasing = false
			}
		}

		previousValue = floatItem
		isSet = true
	}

	return increasing || decreasing
}

func main() {
	result := AdvancedMonotonic([]string{"1", "2", "3"}, false)
	fmt.Println(result)

	result = AdvancedMonotonic([]string{"3", "2", "1"}, false)
	fmt.Println(result)

	result = AdvancedMonotonic([]string{"1", "2.2", "3"}, false)
	fmt.Println(result)

	result = AdvancedMonotonic([]string{"1", "2", "2"}, true)
	fmt.Println(result)
}
``` 

This Go code does exactly the same thing as your Python code. It checks whether a slice of strings have strictly increasing, strictly decreasing or non-strictly monotonic values. Note that in Go we don't have default values for function parameters so we need to pass in all parameters when calling the function.
<|end|>


