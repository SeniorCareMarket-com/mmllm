<|end|>
<|asst|>
def triangle_area(a, h):
    try:
        a = float(a)
        h = float(h)
    except ValueError:
        return "Invalid input! Please enter numeric values."
    
    if a <= 0 or h <= 0:
        return "Invalid input! Please enter positive values."
    
    area = 0.5 * a * h
    return area
