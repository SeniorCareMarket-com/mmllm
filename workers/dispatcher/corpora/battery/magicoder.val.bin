    position: absolute;
    width: 100%;
    text-align: center;
    color: black;
  }
</style>
</head>
<body>
  <div id="progress-bar-container">
    <div id="progress-bar"></div>
    <div id="progress-label">0%</div>
  </div>

  <button onclick="increaseProgress(10);">Increase progress by 10%</button>

  <script>
  const progressBar = document.getElementById('progress-bar');
  const progressLabel = document.getElementById('progress-label');

  function increaseProgress(amount) {
    const currentWidth = parseFloat(progressBar.style.width) || 0;
    const newWidth = currentWidth + amount;

    progressBar.style.transition = 'width 0.5s';
    progressBar.style.width = `${Math.min(newWidth, 100)}%`;
    progressLabel.innerText = `${Math.min(newWidth, 100).toFixed(0)}%`;
  }
  </script>
</body>
</html>
