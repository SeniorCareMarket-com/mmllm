def transform(element):
    """ Aggregate user's habits by considering different timezone """
    # You could use libraries like pandas or pytz to handle time zones
    # Add your custom logic based on the business requirements
    pass

def load(element):
    """ Prepare records for BigQuery """
    record = {
        'user_id': element['user_id'], 
        'song_id': element['song_id'],
        ...
    }
    return record

# Define your Beam pipeline options
options = PipelineOptions()

with beam.Pipeline(options=options) as p:
    rows = (
        p
        # Extract
        | 'Read from Kafka' >> ReadFromKafka(consumer_config={'bootstrap.servers': 'localhost:9092'},
                                                 topics=['topic'], 
                                                 value_coder=TableRowJsonCoder())
        | 'Extract events' >> beam.Map(extract)
        
        # Transform
        | 'User habits' >> beam.Map(transform)
        
        # Load
        | 'Prepare BigQuery record' >> beam.Map(load)
        
        | 'Write to BigQuery' >> WriteToBigQuery(
                'your_project:your_dataset.your_table',
                schema='...',
                create_disposition=BigQueryDisposition.CREATE_IF_NEEDED,
                write_disposition=BigQueryDisposition.WRITE_APPEND)
    )
```

Please note that Apache Beam's Python SDK does not have in-built transformation for considering different timezones, so you would need to manually handle this in the Transform function. Additionally, this is a generic solution, you would have to modify the extract, transform, and load functions according to your Kafka message schema and business requirements.
