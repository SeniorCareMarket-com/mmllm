Craft a robust JavaScript algorithm that not only identifies the type of web browser utilized by the user, but also its version number, the operating system on which the browser is being run, and whether or not the user is in private browsing mode. Furthermore, your solution should account for at least five of the most common modern browsers.
<|end|>
<|asst|>
Here's a basic JavaScript code snippet that identifies the browser type, version and operating system:

```javascript
function getBrowserDetails() {
    var ua= navigator.userAgent, tem, 
    M= ua.match(/(opera|chrome|safari|firefox|msie|trident(?=\/))\/?\s*(\d+)/i) || [];
    if(/trident/i.test(M[1])){
        tem=  /\brv[ :]+(\d+)/g.exec(ua) || [];
        return {name:'IE',version:(tem[1] || '')};
    }
    if(M[1]=== 'Chrome'){
        tem= ua.match(/\bOPR|Edge\/(\d+)/)
        if(tem!= null) return {name:'Opera', version:tem[1]};
    }
    M= M[2]? [M[1], M[2]]: [navigator.appName, navigator.appVersion, '-?'];
    if((tem= ua.match(/version\/(\d+)/i))!= null) M.splice(1, 1, tem[1]);
    return {
      name: M[0],
      version: M[1]
    };
 }

function getOS() {
  var userAgent = window.navigator.userAgent,
      platform = window.navigator.platform,
      macosPlatforms = ['Macintosh', 'MacIntel', 'MacPPC', 'Mac68K'],
      windowsPlatforms = ['Win32', 'Win64', 'Windows', 'WinCE'],
      iosPlatforms = ['iPhone', 'iPad', 'iPod'],
      os = null;

  if (macosPlatforms.indexOf(platform) !== -1) {
    os = 'Mac OS';
  } else if (iosPlatforms.indexOf(platform) !== -1) {
    os = 'iOS';
  } else if (windowsPlatforms.indexOf(platform) !== -1) {
    os = 'Windows';
  } else if (/Android/.test(userAgent)) {
    os = 'Android';
  } else if (!os && /Linux/.test(platform)) {
    os = 'Linux';
  }
  return os;
}

console.log(getBrowserDetails());
console.log(getOS());
```

Please note, detecting the private browsing mode is much more difficult and in most modern browsers impossible due to user privacy concerns, as detecting whether or not a user is in private browsing mode can be considered a violation of user privacy.

Moreover, browser detection is strongly discouraged by most web development professionals, as it can break websites when they’re viewed in unknown or new browsers of which the script is not aware. It is recommended to use feature detection instead of browser detection. Feature detection is a technique in which the script checks whether or not the features that it needs to operate are supported by the user’s web browser rather than checking the browser's name and version. Modernizr is a very well known JavaScript library for feature detection. It is always good to use proper fallback methods.
<|end|>


