import random
def generate_nums(n):
    if n < 1 or n > 100:
        raise ValueError("'n' must be between 1 and 100.")
        
    num_list = []
    while len(num_list) < n:
        num = random.randint(0, 100)
        if num not in num_list:
            num_list.append(num)
    return num_list

print(generate_nums(5))
```

