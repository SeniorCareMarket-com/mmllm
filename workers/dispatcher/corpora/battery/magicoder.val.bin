Translate this code to Swift
def shared_elements(list1: list, list2: list) -> list:
    # Start with an empty list to store the found shared elements.
    shared = []
    # Iterate through the first input list.
    for element in list1:
        # If the element is present in the second input list and is not already stored, add it to the shared list.
        if element in list2 and element not in shared:
            shared.append(element)

    # Now sort the list using bubble sort.
    for i in range(len(shared)):
        for j in range(len(shared) - i - 1):
            if shared[j] > shared[j + 1]:
                shared[j], shared[j + 1] = shared[j + 1], shared[j]

    return shared
Could you insert annotations in the Swift code to clarify its operation?
<|end|>
<|asst|>
Sure, here is the Python code translated into Swift with added comments:

```swift
// Define a function that takes in two arrays and returns an array of the shared elements
func sharedElements(list1: [Int], list2: [Int]) -> [Int] {
    // Create an empty array to store the shared elements
    var shared: [Int] = []
    
    // Iterate through the first input list
    for element in list1 {
        // If the element is present in the second list and is not already in the shared array, add it to the shared array
        if list2.contains(element) && !shared.contains(element) {
            shared.append(element)
        }
    }
    
    // Sort the shared array using bubble sort
    for i in 0..<shared.count {
        for j in 0..<shared.count - i - 1 { 
            // If the current element is larger than the next element, swap them
            if shared[j] > shared[j + 1] {
                let temp = shared[j]
                shared[j] = shared[j + 1]
                shared[j + 1] = temp
            }
        }
    }
    
    // Return the array of shared elements, now sorted 
    return shared
}
```
Please note that Swift arrays have built-in sort methods (`sorted()`, `sort()`) which could potentially simplify this code if performance or behavior is not reason of concern.
<|end|>


