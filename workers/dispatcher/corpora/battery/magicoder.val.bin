public class ItemHandler {
    PriorityQueue<Item> priorityQueueForType;
    CurrencyExchangeService currencyExchangeService;
    // maintain a priority queue for every type of item
    Map<String, PriorityQueue<Item>> itemMap = new ConcurrentHashMap<>();

    public void addItem(Item item) {
        // convert currency to a standard one, let's say USD for the purpose of comparison
        item.price = currencyExchangeService.convertCurrency(item.price, item.currency, "USD");

        if (!itemMap.containsKey(item.type)) {
            PriorityQueue<Item> pq = new PriorityQueue<>(new Comparator<Item>() { 
                public int compare(Item i1, Item i2) {
                    return i1.price.compareTo(i2.price);
                }
            });
            itemMap.put(item.type, pq);
        }

        itemMap.get(item.type).add(item);
    }

    public List<Item> getLowestPricedItems(String type, int n) {
        List<Item> result = new ArrayList<>();

        if (itemMap.containsKey(type)) {
            PriorityQueue<Item> pq = itemMap.get(type);
            Iterator iterator = pq.iterator();

            while(iterator.hasNext() && n-- > 0){
                result.add(iterator.next());
            }
        }

        return result;
    }
}
```

