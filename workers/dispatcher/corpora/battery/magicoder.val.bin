```python
import math

def surface_area_irregular_tetrahedron(a, b, c, d, e, f):
    # calculate the square of the sides
    a2 = a * a
    b2 = b * b
    c2 = c * c
    d2 = d * d
    e2 = e * e
    f2 = f * f

    # calculate the semi-perimeter of each face
    x = (b2 + d2 - e2) / 2
    y = (c2 + e2 - f2) / 2
    z = (a2 + f2 - d2) / 2
    h = (a2 + e2 - b2) / 2

    # calculate the cross-sectional area of each face
    v = math.sqrt(4 * b2 * d2 - e2 * e2)
    u = math.sqrt(4 * c2 * e2 - f2 * f2)
    w = math.sqrt(4 * a2 * f2 - d2 * d2)
    t = math.sqrt(4 * a2 * e2 - b2 * b2)

    # calculate the total surface area
    area = 0.25 * math.sqrt((u + v + w + t - 2 * math.sqrt(u*v + v*w + u*t + v*t + w*t))**2 - 
                            (144 * (a2 + b2 + c2 + d2) * ((a2*b2) + (a2*c2) + (b2*c2) + 
                            (b2*d2) + (c2*d2) + (d2*a2) - (a2*b2*c2) - (b2*c2*d2) - 
                            (c2*d2*a2) - (d2*a2*b2)) / 16))

    return area
```
This function calculates the surface area of an irregular tetrahedron given the lengths of its sides a, b, c, d, e, and f.
