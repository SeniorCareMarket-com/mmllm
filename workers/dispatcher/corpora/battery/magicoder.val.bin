import java.util.*;

public class Solution {
    public static List<Integer> makeAPile(int n) {
        List<Integer> pile = new ArrayList<>();
        for (int i = 0; i < n; i++) {
            if (n % 2 == 0) pile.add(n + 2 * i);
            else pile.add(n + 2 * i);
        }
        return pile;
    }
    public static void main(String[] args) {
        System.out.println(makeAPile(3));  // prints [3, 5, 7]
    }
}
It would be helpful if you could annotate the Swift code.
