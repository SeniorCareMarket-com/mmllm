import java.util.ArrayList;

public class Main {
    public static void main(String[] args) {
        Object num = new ArrayList<>();
        ((ArrayList<Integer>) num).add(1);
        ((ArrayList<Integer>) num).add(2);
        ((ArrayList<Integer>) num).add(3);

        ArrayList<Integer> arr = new ArrayList<>();
        arr.add(1);
        arr.add(2);
        arr.add(1);
        arr.add(3);
        arr.add(2);
        arr.add(1);

        find_positions(arr, num);
    }

    public static void find_positions(ArrayList<Integer> arr, Object num){
        if(num instanceof ArrayList){
            ArrayList<ArrayList<Integer>> result = new ArrayList<>();
            for(int n : (ArrayList<Integer>) num){
                ArrayList<Integer> temp = new ArrayList<>();
                for(int i = 0; i < arr.size(); i++){
                    if(arr.get(i) == n){
                        temp.add(i);
                    }
                }
                result.add(temp);
            }
            System.out.println(result);
        }
        else{
            ArrayList<Integer> result = new ArrayList<>();
            for(int i = 0; i < arr.size(); i++){
                if(arr.get(i) == (int) num){
                    result.add(i);
                }
            }
            System.out.println(result);
        }
    }
}
```

