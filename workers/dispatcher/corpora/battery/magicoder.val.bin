Here is a cleaned up version of your OCR scanned Python code:

```python
from collections import defaultdict
import itertools

def flatten(obj, origin):
    if isinstance(obj, set) or isinstance(obj, list) or isinstance(obj, tuple):
        for x in obj:
            yield from flatten(x, origin)
    elif isinstance(obj, dict):
        for k, v in obj.items():
            yield from flatten(k, origin)
            yield from flatten(v, origin)
    elif callable(obj):  # If the object is a callable (e.g. function)
        if obj.__name__ == "<lambda>":  # Check if the callable is a lambda (anonymous function)
            yield {"anonymous function", obj}, origin
        else:  # if it isn't anonymous function
            yield obj.__name__, origin
    elif hasattr(obj, '__dict__'):  # Custom object case
        yield (obj.__class__.__name__ , vars(obj)), origin
    else:
        yield obj, origin


def count_elements(t1, t2):
    heads = dict(tuple1=t1, tuple2=t2)
    data = defaultdict(lambda: [0, 0])
    for head, tup in heads.items():
        for typ in flatten(tup, head):
            data[typ[0]][0 if head == 'tuple1' else 1] += 1
    # Process the result to the final format
    for key, (n1, n2) in data.items(): 
        if n1 > 0 and n2 > 0:
            data[key] = [(n1, n2), 'both']
        else: 
            origin = 'tuple1' if n1 > 0 else 'tuple2'
            data[key] = (max(n1, n2), origin)
    return data

# Call the function
print(count_elements((1, 2, {('key1', 'key2'): 3}, 4), ((5, 5), 6, {'key': 7}, 8)))
```
