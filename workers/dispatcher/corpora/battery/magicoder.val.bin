```python
import hashlib
import string
import random
import re

class Person:
    def __init__(self, name, age, gender, occupation):
        self.id = self.generate_id(name, age, gender, occupation)
        self.name = self.check_name(name)
        self.age = self.check_age(age)
        self.gender = self.check_gender(gender)
        self.occupation = self.check_occupation(occupation)

    @staticmethod
    def generate_id(name, age, gender, occupation):
        unique_str = name + str(age) + gender + occupation + ''.join(random.choices(string.ascii_letters + string.digits, k=5))
        hashed_id = hashlib.sha256(unique_str.encode()).hexdigest()
        return hashed_id

    @staticmethod
    def check_name(name):
        if re.match("^[A-Za-z]*$", name):
            return name
        else:
            raise ValueError('Invalid value for name')

    @staticmethod
    def check_age(age):
        if isinstance(age, int) and 0 <= age <= 120:
            return age
        else:
            raise ValueError('Invalid value for age')

    @staticmethod
    def check_gender(gender):
        if gender.lower() in ('male', 'female'):
            return gender
        else:
            raise ValueError('Invalid value for gender')

    @staticmethod
    def check_occupation(occupation):
        if len(occupation) <= 50:
            return occupation
        else:
            raise ValueError('Invalid value for occupation')

# Test with valid data:
person1 = Person('John', 20, 'Male', 'Developer')
print(person1.id)

# Test with invalid data:
try:
    person2 = Person('John123', 20, 'Male', 'Developer')
except ValueError as e:
    print(e)

try:
    person3 = Person('John', 200, 'Male', 'Developer')
except ValueError as e:
    print(e)

try:
    person4 = Person('John', 20, 'other', 'Developer')
except ValueError as e:
    print(e)

try:
    person5 = Person('John', 20, 'Male', 'This is a really long occupation name that is definitely more than fifty characters')
except ValueError as e:
    print(e)
```
In this code, Person is a class representing an individual. An instance of the Person class takes name, age, gender and occupation as arguments, generates a unique and secure ID, and validates each field. If a field is invalid, it raises a ValueError with a corresponding message.

The generate_id method creates a unique hash for each person by combining their name, age, gender and occupation with a random string, then using SHA256 to hash it.

Each check_X method validates its corresponding field: check_name ensures that name consists only of English letters; check_age checks that age is an integer between 0 and 120; check_gender only allows the values 'male' or 'female'; and check_occupation ensures that occupation is no longer than 50 characters.
