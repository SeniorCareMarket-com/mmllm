package main

import (
	"fmt"
	"sort"
	)

// Median function
func Median(l []int) float64 {
	sort.Ints(l)
	n := len(l)
	
	// handling the case when the length is even
	if n%2 == 0 {
		return (float64(l[n/2-1]) + float64(l[n/2])) / 2.0
	}
	
	// handling the case when the length is odd
	return float64(l[n/2])
}

func main() {
	test1 := []int{3, 1, 2, 4, 5}
	test2 := []int{-10, 4, 6, 1000, 10, 20}
	fmt.Println(Median(test1)) //should print 3
	fmt.Println(Median(test2)) //should print 15
}
<|end|>
