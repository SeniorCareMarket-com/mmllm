Can you adapt this code to C++?
import re

def peculiar_count(lst):
    results = []
    for string in lst:
        # Count the number of odd digits and reverse the numerical sequences.
        odd_cnt = 0
        pieces = re.findall(r'\D+|\d+', string)
        for i, piece in enumerate(pieces):
            if piece.isdigit():
                odd_cnt += sum(1 for digit in piece if int(digit) % 2 != 0)
                pieces[i] = piece[::-1]
        updated = ''.join(pieces)

        # Capitalize vowels, replace 'i's, and invert date strings.
        updated = updated.replace('a', 'A').replace('e', 'E').replace('o', 'O').replace('u', 'U')
        updated = updated.replace('i', str(odd_cnt))
        if '-' in updated and len(updated) == 10:
            updated = '-'.join(reversed(updated.split('-'))).replace('0', 'Z')

        results.append(updated)
    return results
<|end|>
<|asst|>
Sure, here is a version of your code in C++ that uses similar logic and regular expressions.

```cpp
#include <iostream>
#include <vector>
#include <string>
#include <regex>
#include <algorithm>
#include <cctype>

std::vector<std::string> peculiar_count(std::vector<std::string> &vec) {
    std::vector<std::string> results;

    for (const auto &str : vec) {
        // Count the number of odd digits and reverse the numerical sequences.
        size_t odd_count = 0;
        std::regex re("[^0-9]+|[0-9]+");
        std::sregex_token_iterator it(str.begin(), str.end(), re), end;
        std::vector<std::string> pieces(it, end);
        for (auto &piece : pieces) {
            if (std::isdigit(piece[0])) {
                odd_count += std::count_if(piece.begin(), piece.end(), [](char c) { return (c - '0') % 2 != 0; });
                std::reverse(piece.begin(), piece.end());
            }
        }

        // Combine pieces back into a string.
        std::string updated;
        for (const auto& piece : pieces) updated += piece;

        // Capitalize vowels, replace 'i's, and invert date strings.
        for (auto &ch : updated) {
            if (strchr("aeou", tolower(ch))) ch = toupper(ch);
            else if (tolower(ch) == 'i') ch = '0' + odd_count;
        }
        if (std::count(updated.begin(), updated.end(), '-') == 2 && updated.size() == 10) {
            auto mid = std::find(updated.begin(), updated.end(), '-');
            auto end = std::find(mid + 1, updated.end(), '-');
            std::reverse(updated.begin(), mid);
            std::reverse(mid + 1, end);
            std::reverse(end + 1, updated.end());
            std::replace(updated.begin(), updated.end(), '0', 'Z');
        }
        results.push_back(updated);
    }
    return results;
}

int main() {
    std::vector<std::string> test = { "123-456-7890", "hello", "AEIOU", "aeiou", "10-20-30" };
    auto res = peculiar_count(test);
    for (const auto &str : res)
        std::cout << str << std::endl;
    return 0;
}
```

Please note that C++'s handling of strings and characters is different than Python's so the syntax looks a bit different. Instead of `replace`, we use `std::replace`, for example. Also, `isdigit`, `strchr`, `tolower`, and `toupper` functions are used to check if the character is a digit, search a character in a string, convert string to lowercase, and convert string to uppercase respectively.
<|end|>


