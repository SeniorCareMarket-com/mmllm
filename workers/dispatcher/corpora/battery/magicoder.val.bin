<|asst|>
```cpp
#include <math.h>
#include <unordered_map>
#include <vector>

// Function to check if a number is prime
bool is_prime(int n) {
    if(n <= 1 || (n % 2 == 0 && n > 2))
        return false;
    for(int i = 3; i <= sqrt(n); i += 2)
        if(n % i == 0)
            return false;
    return true;
}

std::vector<int> uncommon_elements(const std::vector<int>& sequence) {
    // Create an unordered_map (similar to dictionary) where key will be the number
    std::unordered_map<int, int> frequency_count;
    for(int num : sequence) 
        frequency_count[num]++;
    
    std::vector<int> result;
    for(auto &item : frequency_count)
        if(is_prime(item.second) && item.second > item.first / 2)
            result.push_back(item.first);

    return result;
}
```
<|end|>


